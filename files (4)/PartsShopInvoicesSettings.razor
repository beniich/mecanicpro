   PAGES : Pièces, E-Commerce, Factures, Paramètres
   ============================================================ *@

@* ─────────────────────────────────────────────────────────── *@
@* Pages/Parts/PartsCatalog.razor                              *@
@* ─────────────────────────────────────────────────────────── *@
@page "/parts"
@attribute [Authorize(Policy = "RequireMechanic")]
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Pièces détachées — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">⚙ Catalogue Pièces</h1>
            <p class="page-subtitle">@_total pièce(s) · @_lowStockCount en rupture</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-ghost" @onclick="ShowLowStock">⚠ Ruptures (@_lowStockCount)</button>
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/parts/new")'>＋ Ajouter</button>
        </div>
    </div>

    @* Category tabs *@
    <div class="category-tabs">
        <button class="cat-tab @(_category == "" ? "active" : "")" @onclick='() => SetCategory("")'>
            Toutes
        </button>
        @foreach (var cat in _categories)
        {
            <button class="cat-tab @(_category == cat ? "active" : "")"
                    @onclick="() => SetCategory(cat)">
                @cat
            </button>
        }
    </div>

    <div class="filter-bar">
        <div class="search-wrap">
            <input class="search-field" placeholder="Référence, nom, marque…"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
            <span class="search-ico">⌕</span>
        </div>
        <select class="filter-select" @bind="_brandFilter">
            <option value="">Toutes marques</option>
            @foreach (var b in _brands)
            { <option value="@b">@b</option> }
        </select>
        <button class="btn btn-ghost" @onclick="() => _showLowStockOnly = !_showLowStockOnly">
            @(_showLowStockOnly ? "✓ " : "")Ruptures seul.
        </button>
    </div>

    @if (_loading) { <PartsSkeleton /> }
    else
    {
        <div class="parts-grid">
            @foreach (var p in _parts)
            {
                <div class="part-card @(p.IsLowStock ? "low-stock" : "")">
                    <div class="part-img">
                        @if (p.ImageUrl != null)
                        { <img src="@p.ImageUrl" alt="@p.Name" /> }
                        else
                        { <span class="part-img-placeholder">⚙</span> }
                    </div>
                    <div class="part-body">
                        <div class="part-ref mono">@p.Reference</div>
                        <div class="part-name">@p.Name</div>
                        @if (p.Brand != null)
                        { <div class="part-brand">@p.Brand</div> }
                        <div class="part-compat text-muted">@p.CompatibleVehicles</div>
                    </div>
                    <div class="part-footer">
                        <div class="part-price">@p.UnitPrice.ToString("N2") €</div>
                        <div class="part-stock @(p.IsLowStock ? "text-danger" : "text-muted")">
                            📦 @p.StockQuantity
                            @if (p.IsLowStock) { <span>⚠</span> }
                        </div>
                    </div>
                    <div class="part-actions">
                        <button class="btn btn-sm btn-ghost full-width"
                                @onclick="() => AddToQuote(p)">＋ Devis</button>
                        <button class="icon-btn-sm"
                                @onclick="() => ShowStockModal(p)" title="Ajuster stock">📦</button>
                        <button class="icon-btn-sm"
                                @onclick='() => Nav.NavigateTo($"/parts/{p.Id}/edit")' title="Modifier">✏</button>
                    </div>
                </div>
            }
        </div>
        <Pagination CurrentPage="_page" TotalPages="_totalPages" OnPageChanged="ChangePage" />
    }
</div>

@* Stock Adjustment Modal *@
@if (_stockTarget != null)
{
    <Modal Title=@($"Stock — {_stockTarget.Name}") OnClose="() => _stockTarget = null">
        <div class="stock-modal">
            <div class="stock-current">
                Stock actuel : <strong>@_stockTarget.StockQuantity</strong>
            </div>
            <div class="stock-controls">
                <button class="btn btn-ghost" @onclick="() => _stockDelta--">−</button>
                <input type="number" class="form-input center" style="width:80px"
                       @bind="_stockDelta" />
                <button class="btn btn-ghost" @onclick="() => _stockDelta++">＋</button>
            </div>
            <div class="stock-preview">
                Nouveau stock : <strong>@(_stockTarget.StockQuantity + _stockDelta)</strong>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" @onclick="() => _stockTarget = null">Annuler</button>
            <button class="btn btn-primary" @onclick="ConfirmStockAdjust">Confirmer</button>
        </div>
    </Modal>
}

@code {
    [SupplyParameterFromQuery] public string? Filter { get; set; }

    private List<PartDto> _parts = new();
    private List<string> _categories = new() { "Moteur", "Freinage", "Suspension", "Électrique", "Transmission", "Climatisation" };
    private List<string> _brands = new() { "Bosch", "NGK", "Brembo", "Valeo", "Mann", "K&N", "Monroe", "Varta" };
    private bool _loading = true;
    private string _search = "", _category = "", _brandFilter = "";
    private bool _showLowStockOnly;
    private int _page = 1, _totalPages = 1, _total, _lowStockCount;
    private PartDto? _stockTarget;
    private int _stockDelta;

    protected override async Task OnInitializedAsync()
    {
        if (Filter == "lowstock") _showLowStockOnly = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var url = $"/api/v1/parts?page={_page}&pageSize=24" +
                  $"&search={Uri.EscapeDataString(_search)}&category={_category}" +
                  $"&brand={_brandFilter}&lowStockOnly={_showLowStockOnly}";
        var result = await Api.GetAsync<PartPagedResult>(url);
        _parts = result?.Items.ToList() ?? new();
        _total = result?.Total ?? 0;
        _totalPages = result?.TotalPages ?? 1;
        _lowStockCount = result?.LowStockCount ?? 0;
        _loading = false;
    }

    private async Task SetCategory(string cat) { _category = cat; _page = 1; await LoadAsync(); }
    private async Task OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadAsync(); } }
    private async Task ChangePage(int p) { _page = p; await LoadAsync(); }
    private async Task ShowLowStock() { _showLowStockOnly = true; _page = 1; await LoadAsync(); }

    private void ShowStockModal(PartDto p) { _stockTarget = p; _stockDelta = 0; }
    private void AddToQuote(PartDto p) => Toast.Show($"{p.Name} ajouté au devis", ToastType.Success);

    private async Task ConfirmStockAdjust()
    {
        if (_stockTarget == null) return;
        await Api.PostAsync<object>($"/api/v1/parts/{_stockTarget.Id}/stock",
            new { delta = _stockDelta, reason = "Ajustement manuel" });
        Toast.Success("Stock mis à jour");
        _stockTarget = null;
        await LoadAsync();
    }
}


@* ─────────────────────────────────────────────────────────── *@
@* Pages/Shop/EcommercePage.razor                              *@
@* ─────────────────────────────────────────────────────────── *@
@page "/shop"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav
@inject ToastService Toast
@inject CartService Cart

<PageTitle>Boutique — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">🛒 E-Commerce</h1>
            <p class="page-subtitle">Achats et ventes de pièces</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-ghost" @onclick='() => Nav.NavigateTo("/shop/orders")'>
                📦 Mes commandes
            </button>
            @if (Cart.ItemCount > 0)
            {
                <button class="btn btn-primary" @onclick="ShowCart">
                    🛒 Panier (@Cart.ItemCount)
                </button>
            }
        </div>
    </div>

    @* Stats row *@
    <div class="shop-stats-row">
        <div class="shop-stat-card">
            <div class="shop-stat-val">@_monthRevenue.ToString("N0") €</div>
            <div class="shop-stat-label">📈 Ventes ce mois</div>
            <div class="shop-stat-trend trend-up">↑ +22%</div>
        </div>
        <div class="shop-stat-card">
            <div class="shop-stat-val">@_monthOrders</div>
            <div class="shop-stat-label">📦 Commandes</div>
        </div>
        <div class="shop-stat-card">
            <div class="shop-stat-val">@_monthPurchases.ToString("N0") €</div>
            <div class="shop-stat-label">🏭 Achats fournisseurs</div>
        </div>
        <div class="shop-stat-card" style="border-color:rgba(34,197,94,.2)">
            <div class="shop-stat-val" style="color:var(--green)">@_margin.ToString("N0") %</div>
            <div class="shop-stat-label">💰 Marge brute</div>
        </div>
    </div>

    @* Catalog tabs *@
    <div class="shop-tabs">
        <button class="shop-tab @(_shopView == "catalog" ? "active" : "")"
                @onclick='() => _shopView = "catalog"'>🏪 Catalogue</button>
        <button class="shop-tab @(_shopView == "orders" ? "active" : "")"
                @onclick='() => _shopView = "orders"'>📦 Commandes</button>
        <button class="shop-tab @(_shopView == "suppliers" ? "active" : "")"
                @onclick='() => _shopView = "suppliers"'>🏭 Fournisseurs</button>
        <button class="shop-tab @(_shopView == "analytics" ? "active" : "")"
                @onclick='() => _shopView = "analytics"'>📊 Analytics</button>
    </div>

    @if (_shopView == "catalog")
    {
        <div class="filter-bar">
            <div class="search-wrap">
                <input class="search-field" placeholder="Rechercher une pièce…"
                       @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
                <span class="search-ico">⌕</span>
            </div>
            <select class="filter-select" @bind="_sortBy">
                <option value="name">Trier par nom</option>
                <option value="price_asc">Prix croissant</option>
                <option value="price_desc">Prix décroissant</option>
                <option value="popular">Popularité</option>
            </select>
        </div>

        <div class="shop-grid">
            @foreach (var p in _shopParts)
            {
                <div class="shop-card">
                    <div class="shop-img">
                        @if (p.ImageUrl != null) { <img src="@p.ImageUrl" alt="@p.Name" /> }
                        else { <span class="shop-img-placeholder">⚙</span> }
                        @if (p.IsLowStock)
                        { <span class="stock-badge low">Stock limité</span> }
                        else if (!p.IsAvailable)
                        { <span class="stock-badge out">Rupture</span> }
                    </div>
                    <div class="shop-body">
                        <div class="shop-brand">@(p.Brand ?? p.Category)</div>
                        <div class="shop-name">@p.Name</div>
                        <div class="shop-ref mono">@p.Reference</div>
                        <div class="shop-price-row">
                            <span class="shop-price">@p.UnitPrice.ToString("N2") €</span>
                            <span class="shop-stock text-muted">@p.StockQuantity en stock</span>
                        </div>
                        <div class="shop-actions">
                            <div class="qty-control">
                                <button @onclick="() => DecreaseQty(p.Id)">−</button>
                                <span>@GetQty(p.Id)</span>
                                <button @onclick="() => IncreaseQty(p.Id)">＋</button>
                            </div>
                            <button class="btn btn-primary btn-sm"
                                    @onclick="() => AddToCart(p)"
                                    disabled="@(!p.IsAvailable)">
                                🛒 Ajouter
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
        <Pagination CurrentPage="_page" TotalPages="_totalPages" OnPageChanged="ChangePage" />
    }
    else if (_shopView == "orders")
    {
        <OrdersTable Orders="_orders" OnViewOrder="id => Nav.NavigateTo($&quot;/shop/orders/{id}&quot;)" />
    }
    else if (_shopView == "analytics")
    {
        <ShopAnalytics GarageId="@_garageId" />
    }
</div>

@* Cart Drawer *@
@if (_showCartDrawer)
{
    <div class="drawer-overlay" @onclick="CloseCart">
        <div class="drawer" @onclick:stopPropagation="true">
            <div class="drawer-header">
                <h3>🛒 Panier (@Cart.ItemCount articles)</h3>
                <button @onclick="CloseCart">✕</button>
            </div>
            <div class="drawer-body">
                @foreach (var item in Cart.Items)
                {
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <div class="cart-item-name">@item.Name</div>
                            <div class="cart-item-ref mono">@item.Reference</div>
                        </div>
                        <div class="cart-item-qty">
                            <button @onclick="() => Cart.Decrease(item.PartId)">−</button>
                            <span>@item.Quantity</span>
                            <button @onclick="() => Cart.Increase(item.PartId)">＋</button>
                        </div>
                        <div class="cart-item-price">@((item.UnitPrice * item.Quantity).ToString("N2")) €</div>
                        <button class="cart-item-remove" @onclick="() => Cart.Remove(item.PartId)">✕</button>
                    </div>
                }
            </div>
            <div class="drawer-footer">
                <div class="cart-total">
                    <span>Total HT</span>
                    <span class="mono">@Cart.TotalHT.ToString("N2") €</span>
                </div>
                <div class="cart-total">
                    <span>TVA 20%</span>
                    <span class="mono">@Cart.TVA.ToString("N2") €</span>
                </div>
                <div class="cart-total cart-grand-total">
                    <span>Total TTC</span>
                    <span class="mono accent">@Cart.TotalTTC.ToString("N2") €</span>
                </div>
                <button class="btn btn-primary full-width" @onclick="ProceedCheckout">
                    💳 Payer — @Cart.TotalTTC.ToString("N2") €
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ShopPartDto> _shopParts = new();
    private List<OrderDto> _orders = new();
    private bool _loading = true;
    private string _search = "", _sortBy = "name", _shopView = "catalog";
    private int _page = 1, _totalPages = 1;
    private decimal _monthRevenue, _monthPurchases, _margin;
    private int _monthOrders;
    private Dictionary<Guid, int> _quantities = new();
    private bool _showCartDrawer;
    private Guid _garageId;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var url = $"/api/v1/parts?page={_page}&search={_search}&sortBy={_sortBy}&shop=true";
        var result = await Api.GetAsync<ShopPartPagedResult>(url);
        _shopParts = result?.Items.ToList() ?? new();
        _totalPages = result?.TotalPages ?? 1;
        var stats = await Api.GetAsync<ShopStatsDto>("/api/v1/shop/stats");
        if (stats != null)
        {
            _monthRevenue = stats.MonthRevenue;
            _monthOrders = stats.MonthOrders;
            _monthPurchases = stats.MonthPurchases;
            _margin = stats.MarginPercent;
        }
        _loading = false;
    }

    private void AddToCart(ShopPartDto p)
    {
        Cart.Add(new CartItem(p.Id, p.Name, p.Reference, p.UnitPrice, GetQty(p.Id)));
        Toast.Success($"{p.Name} ajouté au panier");
    }

    private int GetQty(Guid id) => _quantities.TryGetValue(id, out var q) ? Math.Max(q, 1) : 1;
    private void IncreaseQty(Guid id) => _quantities[id] = GetQty(id) + 1;
    private void DecreaseQty(Guid id) => _quantities[id] = Math.Max(1, GetQty(id) - 1);
    private void ShowCart() => _showCartDrawer = true;
    private void CloseCart() => _showCartDrawer = false;
    private async Task OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadAsync(); } }
    private async Task ChangePage(int p) { _page = p; await LoadAsync(); }

    private async Task ProceedCheckout()
    {
        var items = Cart.Items.Select(i => new { partId = i.PartId, qty = i.Quantity }).ToList();
        var result = await Api.PostAsync<CheckoutIntentDto>("/api/v1/checkout/intent", new { items });
        if (result?.ClientSecret != null)
            Nav.NavigateTo($"/checkout/payment?secret={result.ClientSecret}&orderId={result.OrderId}");
    }
}


@* ─────────────────────────────────────────────────────────── *@
@* Pages/Invoices/InvoiceList.razor                            *@
@* ─────────────────────────────────────────────────────────── *@
@page "/invoices"
@attribute [Authorize(Policy = "RequireGarageOwner")]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Factures — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <h1 class="page-title">🧾 Factures</h1>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/invoices/new")'>
            ＋ Créer facture
        </button>
    </div>

    <div class="invoice-kpi-row">
        <div class="inv-kpi"><div class="inv-kpi-val">@_totalMonth.ToString("N0") €</div><div class="inv-kpi-label">Ce mois</div></div>
        <div class="inv-kpi"><div class="inv-kpi-val" style="color:var(--green)">@_paidCount</div><div class="inv-kpi-label">Payées</div></div>
        <div class="inv-kpi"><div class="inv-kpi-val" style="color:var(--amber)">@_pendingCount</div><div class="inv-kpi-label">En attente</div></div>
        <div class="inv-kpi"><div class="inv-kpi-val" style="color:var(--red)">@_overdueCount</div><div class="inv-kpi-label">En retard</div></div>
    </div>

    <div class="filter-bar">
        <div class="search-wrap">
            <input class="search-field" placeholder="Numéro, client…"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
            <span class="search-ico">⌕</span>
        </div>
        <select class="filter-select" @bind="_statusFilter">
            <option value="">Tous statuts</option>
            <option value="draft">Brouillon</option>
            <option value="issued">Émise</option>
            <option value="paid">Payée</option>
            <option value="overdue">En retard</option>
        </select>
        <input type="month" class="filter-select" @bind="_monthFilter" />
        <button class="btn btn-ghost" @onclick="LoadAsync">Filtrer</button>
        <button class="btn btn-ghost" @onclick="ExportAsync">⬇ Export CSV</button>
    </div>

    @if (_loading) { <TableSkeleton Rows="10" /> }
    else
    {
        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Numéro</th><th>Client</th><th>Date</th><th>Échéance</th>
                        <th>HT</th><th>TVA</th><th>TTC</th><th>Statut</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in _invoices)
                    {
                        <tr class="table-row @(inv.IsOverdue ? "row-critical" : "")">
                            <td><span class="mono accent">@inv.Number</span></td>
                            <td>@inv.CustomerName</td>
                            <td class="mono">@inv.IssuedAt.ToString("dd/MM/yyyy")</td>
                            <td class="mono @(inv.IsOverdue ? "text-danger" : "")">
                                @inv.DueDate?.ToString("dd/MM/yyyy")
                            </td>
                            <td class="mono">@inv.TotalHT.ToString("N2") €</td>
                            <td class="mono text-muted">@inv.TaxAmount.ToString("N2") €</td>
                            <td class="mono"><strong>@inv.TotalTTC.ToString("N2") €</strong></td>
                            <td><StatusBadge Status="@inv.Status" /></td>
                            <td>
                                <div class="action-btns">
                                    <a href="/api/v1/invoices/@inv.Id/pdf" target="_blank" class="icon-btn-sm" title="PDF">📄</a>
                                    <button class="icon-btn-sm" @onclick="() => SendInvoice(inv.Id)" title="Envoyer">📧</button>
                                    @if (inv.Status == "issued")
                                    {
                                        <button class="icon-btn-sm" @onclick="() => MarkPaid(inv.Id)" title="Marquer payée">✓</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Pagination CurrentPage="_page" TotalPages="_totalPages" OnPageChanged="ChangePage" />
        </div>
    }
</div>

@code {
    private List<InvoiceListDto> _invoices = new();
    private bool _loading = true;
    private string _search = "", _statusFilter = "";
    private DateTime? _monthFilter;
    private int _page = 1, _totalPages = 1;
    private decimal _totalMonth;
    private int _paidCount, _pendingCount, _overdueCount;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var url = $"/api/v1/invoices?page={_page}&search={_search}&status={_statusFilter}";
        var result = await Api.GetAsync<InvoicePagedResult>(url);
        _invoices = result?.Items.ToList() ?? new();
        _totalPages = result?.TotalPages ?? 1;
        _totalMonth = result?.TotalMonth ?? 0;
        _paidCount = result?.PaidCount ?? 0;
        _pendingCount = result?.PendingCount ?? 0;
        _overdueCount = result?.OverdueCount ?? 0;
        _loading = false;
    }

    private async Task SendInvoice(Guid id)
    {
        await Api.PostAsync<object>($"/api/v1/invoices/{id}/send", null);
        Toast.Success("Facture envoyée par email");
    }

    private async Task MarkPaid(Guid id)
    {
        await Api.PostAsync<object>($"/api/v1/invoices/{id}/mark-paid", null);
        Toast.Success("Facture marquée comme payée");
        await LoadAsync();
    }

    private async Task ExportAsync() { /* CSV export */ }
    private async Task OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadAsync(); }
    private async Task ChangePage(int p) { _page = p; await LoadAsync(); }

    public record InvoiceListDto(
        Guid Id, string Number, string CustomerName,
        decimal TotalHT, decimal TaxAmount, decimal TotalTTC,
        string Status, DateTime IssuedAt, DateTime? DueDate, bool IsOverdue);

    public record InvoicePagedResult(
        IEnumerable<InvoiceListDto> Items, int Total, int TotalPages,
        decimal TotalMonth, int PaidCount, int PendingCount, int OverdueCount);
}


@* ─────────────────────────────────────────────────────────── *@
@* Pages/Settings/SettingsPage.razor                           *@
@* ─────────────────────────────────────────────────────────── *@
@page "/settings"
@attribute [Authorize]
@inject ApiClient Api
@inject ToastService Toast
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Paramètres — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <h1 class="page-title">⚙ Paramètres</h1>
    </div>

    <div class="settings-layout">
        <div class="settings-nav">
            @foreach (var s in _sections)
            {
                <button class="settings-nav-item @(_section == s.Id ? "active" : "")"
                        @onclick="() => _section = s.Id">
                    <span>@s.Icon</span>
                    <span>@s.Label</span>
                </button>
            }
        </div>

        <div class="settings-content">

            @if (_section == "profile")
            {
                <div class="settings-section">
                    <h2 class="settings-title">👤 Profil</h2>
                    <div class="form-group">
                        <label class="form-label">Prénom</label>
                        <input class="form-input" @bind="_profile.FirstName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nom</label>
                        <input class="form-input" @bind="_profile.LastName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-input" type="email" @bind="_profile.Email" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Téléphone</label>
                        <input class="form-input" @bind="_profile.Phone" />
                    </div>
                    <button class="btn btn-primary" @onclick="SaveProfile">💾 Sauvegarder</button>
                </div>
            }

            else if (_section == "security")
            {
                <div class="settings-section">
                    <h2 class="settings-title">🔐 Sécurité</h2>

                    <div class="settings-card">
                        <div class="settings-card-header">
                            <div>
                                <div class="settings-card-title">Changer le mot de passe</div>
                                <div class="settings-card-desc">Utilisez un mot de passe fort d'au moins 10 caractères</div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Mot de passe actuel</label>
                            <input class="form-input" type="password" @bind="_oldPwd" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Nouveau mot de passe</label>
                            <input class="form-input" type="password" @bind="_newPwd" />
                            <PasswordStrength Password="@_newPwd" />
                        </div>
                        <button class="btn btn-ghost" @onclick="ChangePassword">🔑 Changer</button>
                    </div>

                    <div class="settings-card">
                        <div class="settings-card-header">
                            <div>
                                <div class="settings-card-title">Authentification à 2 facteurs</div>
                                <div class="settings-card-desc">Protégez votre compte avec Google Authenticator</div>
                            </div>
                            <div class="toggle-switch @(_totpEnabled ? "on" : "")"
                                 @onclick="Toggle2FA"></div>
                        </div>
                        @if (_show2faSetup)
                        {
                            <TotpSetupWizard OnCompleted="On2FASetupCompleted" />
                        }
                    </div>

                    <div class="settings-card">
                        <div class="settings-card-title">Sessions actives</div>
                        <div class="sessions-list">
                            @foreach (var s in _sessions)
                            {
                                <div class="session-item">
                                    <div class="session-info">
                                        <div>@s.Device</div>
                                        <div class="text-muted">@s.IpAddress · @s.LastActivity.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                    @if (s.IsCurrent)
                                    { <span class="badge success">Actuelle</span> }
                                    else
                                    {
                                        <button class="btn btn-sm btn-danger-ghost"
                                                @onclick="() => RevokeSession(s.Id)">Révoquer</button>
                                    }
                                </div>
                            }
                        </div>
                        <button class="btn btn-danger-ghost" @onclick="RevokeAllSessions">
                            ⚠ Révoquer toutes les sessions
                        </button>
                    </div>
                </div>
            }

            else if (_section == "garage")
            {
                <div class="settings-section">
                    <h2 class="settings-title">🏪 Mon Garage</h2>
                    <div class="form-group">
                        <label class="form-label">Nom du garage</label>
                        <input class="form-input" @bind="_garage.Name" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Adresse</label>
                        <input class="form-input" @bind="_garage.Address" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Téléphone</label>
                        <input class="form-input" @bind="_garage.Phone" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">SIRET</label>
                        <input class="form-input" @bind="_garage.Siret" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Logo</label>
                        <ImageUploader VehicleId="Guid.Empty" OnUploaded="OnLogoUploaded" />
                    </div>
                    <button class="btn btn-primary" @onclick="SaveGarage">💾 Sauvegarder</button>
                </div>
            }

            else if (_section == "notifications")
            {
                <div class="settings-section">
                    <h2 class="settings-title">🔔 Notifications</h2>
                    @foreach (var pref in _notifPrefs)
                    {
                        <div class="notif-pref-item">
                            <div>
                                <div class="notif-pref-label">@pref.Label</div>
                                <div class="notif-pref-desc text-muted">@pref.Description</div>
                            </div>
                            <div class="notif-channels">
                                <label><input type="checkbox" @bind="pref.Email" /> Email</label>
                                <label><input type="checkbox" @bind="pref.Sms" /> SMS</label>
                                <label><input type="checkbox" @bind="pref.Push" /> Push</label>
                            </div>
                        </div>
                    }
                    <button class="btn btn-primary" @onclick="SaveNotifPrefs">💾 Sauvegarder</button>
                </div>
            }

            else if (_section == "api")
            {
                <div class="settings-section">
                    <h2 class="settings-title">🔌 API & Intégrations</h2>
                    <div class="settings-card">
                        <div class="settings-card-title">Clé API</div>
                        <div class="api-key-row">
                            <input class="form-input mono" type="@(_showApiKey ? "text" : "password")"
                                   value="@_apiKey" readonly />
                            <button class="btn btn-ghost" @onclick="() => _showApiKey = !_showApiKey">
                                @(_showApiKey ? "🙈" : "👁")
                            </button>
                            <button class="btn btn-ghost" @onclick="RegenerateApiKey">🔄 Régénérer</button>
                        </div>
                    </div>
                    <div class="settings-card">
                        <div class="settings-card-title">Webhooks</div>
                        <div class="form-group">
                            <label class="form-label">URL webhook</label>
                            <input class="form-input" @bind="_webhookUrl" placeholder="https://…" />
                        </div>
                        <button class="btn btn-ghost" @onclick="TestWebhook">🧪 Tester</button>
                        <button class="btn btn-primary" @onclick="SaveWebhook">💾 Sauvegarder</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _section = "profile";

    private readonly List<SettingsSection> _sections = new()
    {
        new("profile", "👤", "Profil"),
        new("security", "🔐", "Sécurité"),
        new("garage", "🏪", "Mon Garage"),
        new("notifications", "🔔", "Notifications"),
        new("api", "🔌", "API & Webhooks"),
    };

    private ProfileModel _profile = new();
    private GarageModel _garage = new();
    private List<NotifPref> _notifPrefs = new();
    private List<SessionDto> _sessions = new();
    private string _oldPwd = "", _newPwd = "";
    private bool _totpEnabled, _show2faSetup;
    private string _apiKey = "", _webhookUrl = "";
    private bool _showApiKey;

    protected override async Task OnInitializedAsync()
    {
        var user = await Auth.GetCurrentUserAsync();
        if (user != null)
        {
            _profile.FirstName = user.FirstName;
            _profile.LastName = user.LastName;
            _profile.Email = user.Email;
        }
        _notifPrefs = new List<NotifPref>
        {
            new("Rappel révision", "Alertes avant une révision planifiée"),
            new("Panne critique", "Notification immédiate pour pannes critiques"),
            new("Paiement reçu", "Confirmation de paiement client"),
            new("Stock rupture", "Alerte pièces en rupture de stock"),
            new("Nouveau message", "Chat client non lu"),
        };
        _apiKey = "mp_live_••••••••••••••••••••••••••••";
    }

    private async Task SaveProfile()
    {
        await Api.PutAsync<object>("/api/v1/auth/profile", _profile);
        Toast.Success("Profil mis à jour");
    }

    private async Task ChangePassword()
    {
        var result = await Api.PostAsync<object>("/api/v1/auth/change-password",
            new { oldPassword = _oldPwd, newPassword = _newPwd });
        Toast.Success("Mot de passe modifié");
        _oldPwd = ""; _newPwd = "";
    }

    private void Toggle2FA()
    {
        if (!_totpEnabled) _show2faSetup = true;
        else { /* show disable confirm */ }
    }

    private void On2FASetupCompleted() { _totpEnabled = true; _show2faSetup = false; Toast.Success("2FA activé !"); }
    private async Task SaveGarage() { await Api.PutAsync<object>("/api/v1/garage", _garage); Toast.Success("Garage mis à jour"); }
    private async Task SaveNotifPrefs() { await Api.PostAsync<object>("/api/v1/notifications/preferences", _notifPrefs); Toast.Success("Préférences sauvegardées"); }
    private void OnLogoUploaded() => Toast.Success("Logo mis à jour");
    private async Task RevokeSession(string id) { await Api.DeleteAsync($"/api/v1/auth/sessions/{id}"); Toast.Show("Session révoquée"); }
    private async Task RevokeAllSessions() { await Api.PostAsync<object>("/api/v1/auth/sessions/revoke-all", null); Nav.NavigateTo("/login"); }
    private async Task RegenerateApiKey() { var r = await Api.PostAsync<ApiKeyDto>("/api/v1/settings/api-key/regenerate", null); if (r != null) { _apiKey = r.Key; _showApiKey = true; } }
    private async Task TestWebhook() { await Api.PostAsync<object>("/api/v1/settings/webhook/test", new { url = _webhookUrl }); Toast.Show("Webhook testé — voir les logs"); }
    private async Task SaveWebhook() { await Api.PostAsync<object>("/api/v1/settings/webhook", new { url = _webhookUrl }); Toast.Success("Webhook sauvegardé"); }

    private record SettingsSection(string Id, string Icon, string Label);
    private class ProfileModel { public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; public string Email { get; set; } = ""; public string? Phone { get; set; } }
    private class GarageModel { public string Name { get; set; } = ""; public string? Address { get; set; } public string? Phone { get; set; } public string? Siret { get; set; } }
    private class NotifPref { public string Label { get; set; } = ""; public string Description { get; set; } = ""; public bool Email { get; set; } = true; public bool Sms { get; set; } = true; public bool Push { get; set; } = true; public NotifPref(string l, string d) { Label = l; Description = d; } }
    private record SessionDto(string Id, string Device, string IpAddress, DateTime LastActivity, bool IsCurrent);
    private record ApiKeyDto(string Key);
}
