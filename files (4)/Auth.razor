@* ============================================================
   AUTH PAGES : Login, Register, Verify2FA, ForgotPassword
   ============================================================ *@

@* Pages/Auth/Login.razor *@
@page "/login"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Connexion — MecaPro</PageTitle>

<div class="auth-card fade-in">
    <div class="auth-logo">
        <span class="auth-logo-icon">⬡</span>
        <span class="auth-logo-text">MecaPro</span>
    </div>
    <h1 class="auth-title">Connexion</h1>
    <p class="auth-subtitle">Accédez à votre espace mécanicien</p>

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="auth-error">⚠ @_errorMsg</div>
    }

    @if (!_need2Fa)
    {
        <EditForm Model="_loginForm" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label class="form-label">Email</label>
                <InputText @bind-Value="_loginForm.Email" type="email"
                           class="form-input" placeholder="vous@garage.com"
                           autocomplete="email" />
                <ValidationMessage For="() => _loginForm.Email" class="form-error" />
            </div>

            <div class="form-group">
                <label class="form-label">Mot de passe</label>
                <div class="input-with-toggle">
                    <InputText @bind-Value="_loginForm.Password"
                               type="@(_showPwd ? "text" : "password")"
                               class="form-input" placeholder="••••••••••"
                               autocomplete="current-password" />
                    <button type="button" class="pwd-toggle"
                            @onclick="() => _showPwd = !_showPwd">
                        @(_showPwd ? "🙈" : "👁")
                    </button>
                </div>
                <ValidationMessage For="() => _loginForm.Password" class="form-error" />
            </div>

            <div class="form-options">
                <label class="checkbox-label">
                    <input type="checkbox" @bind="_rememberMe" />
                    <span>Se souvenir de moi</span>
                </label>
                <a href="/forgot-password" class="forgot-link">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="btn btn-primary full-width" disabled="@_loading">
                @if (_loading)
                {
                    <span class="btn-spinner"></span>
                    <span>Connexion…</span>
                }
                else
                {
                    <span>Se connecter</span>
                }
            </button>
        </EditForm>

        <div class="auth-divider">
            <span>ou</span>
        </div>

        <div class="oauth-buttons">
            <button class="btn btn-ghost full-width" @onclick="LoginWithGoogle">
                <img src="/images/google.svg" alt="Google" width="18" />
                Continuer avec Google
            </button>
            <button class="btn btn-ghost full-width" @onclick="LoginWithMicrosoft">
                <img src="/images/microsoft.svg" alt="Microsoft" width="18" />
                Continuer avec Microsoft
            </button>
        </div>

        <p class="auth-footer">
            Pas encore de compte ? <a href="/register" class="auth-link">Créer un compte</a>
        </p>
    }
    else
    {
        @* 2FA Step *@
        <div class="twofa-section">
            <div class="twofa-icon">📱</div>
            <h2 class="twofa-title">Vérification à 2 facteurs</h2>
            <p class="twofa-desc">Entrez le code de votre application d'authentification (Google Authenticator)</p>

            <div class="otp-inputs">
                @for (int i = 0; i < 6; i++)
                {
                    var idx = i;
                    <input type="text" maxlength="1"
                           class="otp-input @(_otpError ? "error" : "")"
                           @bind="_otpDigits[idx]"
                           @onkeyup="(e) => HandleOtpKey(e, idx)"
                           @ref="_otpRefs[idx]"
                           inputmode="numeric" pattern="[0-9]*" />
                }
            </div>

            @if (_otpError)
            {
                <div class="auth-error">Code invalide. Réessayez.</div>
            }

            <button class="btn btn-primary full-width" @onclick="HandleVerify2FA"
                    disabled="@(_loading || _otpDigits.Any(d => string.IsNullOrEmpty(d)))">
                Vérifier
            </button>

            <button class="btn btn-ghost full-width" @onclick="BackToLogin">
                ← Retour à la connexion
            </button>
        </div>
    }
</div>

@code {
    private LoginModel _loginForm = new();
    private bool _loading;
    private bool _showPwd;
    private bool _rememberMe;
    private string _errorMsg = "";
    private bool _need2Fa;
    private string _tempToken = "";

    // 2FA OTP
    private string[] _otpDigits = new string[6];
    private ElementReference[] _otpRefs = new ElementReference[6];
    private bool _otpError;

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMsg = "";
        try
        {
            var result = await Auth.LoginAsync(_loginForm.Email, _loginForm.Password);
            if (result.Success)
            {
                Nav.NavigateTo("/");
            }
            else if (result.Need2Fa)
            {
                _need2Fa = true;
                _tempToken = result.TempToken!;
            }
            else
            {
                _errorMsg = result.ErrorMessage ?? "Erreur de connexion.";
            }
        }
        finally { _loading = false; }
    }

    private async Task HandleVerify2FA()
    {
        _loading = true;
        _otpError = false;
        var code = string.Join("", _otpDigits);
        var result = await Auth.Verify2FAAsync(_tempToken, code);
        if (result.Success)
            Nav.NavigateTo("/");
        else
        {
            _otpError = true;
            Array.Clear(_otpDigits, 0, 6);
        }
        _loading = false;
    }

    private async Task HandleOtpKey(KeyboardEventArgs e, int idx)
    {
        if (!string.IsNullOrEmpty(_otpDigits[idx]) && idx < 5)
        {
            // Auto-focus next
        }
        if (string.Join("", _otpDigits).Length == 6)
            await HandleVerify2FA();
    }

    private void BackToLogin()
    {
        _need2Fa = false;
        _tempToken = "";
        Array.Clear(_otpDigits, 0, 6);
    }

    private void LoginWithGoogle()
        => Nav.NavigateTo("/api/v1/auth/external/google", forceLoad: true);

    private void LoginWithMicrosoft()
        => Nav.NavigateTo("/api/v1/auth/external/microsoft", forceLoad: true);

    private class LoginModel
    {
        [Required(ErrorMessage = "Email requis")]
        [EmailAddress(ErrorMessage = "Email invalide")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Mot de passe requis")]
        [MinLength(6, ErrorMessage = "Minimum 6 caractères")]
        public string Password { get; set; } = "";
    }
}


@* Pages/Auth/Register.razor *@
@page "/register"
@layout AuthLayout
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Créer un compte — MecaPro</PageTitle>

<div class="auth-card fade-in">
    <div class="auth-logo">
        <span class="auth-logo-icon">⬡</span>
        <span class="auth-logo-text">MecaPro</span>
    </div>
    <h1 class="auth-title">Créer votre compte</h1>
    <p class="auth-subtitle">14 jours d'essai gratuit — sans carte bancaire</p>

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="auth-error">⚠ @_errorMsg</div>
    }

    <EditForm Model="_form" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Prénom</label>
                <InputText @bind-Value="_form.FirstName" class="form-input" placeholder="Jean" />
                <ValidationMessage For="() => _form.FirstName" class="form-error" />
            </div>
            <div class="form-group">
                <label class="form-label">Nom</label>
                <InputText @bind-Value="_form.LastName" class="form-input" placeholder="Dupont" />
                <ValidationMessage For="() => _form.LastName" class="form-error" />
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Email professionnel</label>
            <InputText @bind-Value="_form.Email" type="email" class="form-input" placeholder="jean@mongarage.fr" />
            <ValidationMessage For="() => _form.Email" class="form-error" />
        </div>

        <div class="form-group">
            <label class="form-label">Mot de passe</label>
            <InputText @bind-Value="_form.Password" type="password" class="form-input" placeholder="Min. 10 caractères" />
            <ValidationMessage For="() => _form.Password" class="form-error" />
            <PasswordStrength Password="@_form.Password" />
        </div>

        <div class="form-group">
            <label class="form-label">Confirmer le mot de passe</label>
            <InputText @bind-Value="_form.ConfirmPassword" type="password" class="form-input" placeholder="Répéter le mot de passe" />
            <ValidationMessage For="() => _form.ConfirmPassword" class="form-error" />
        </div>

        <div class="form-group">
            <label class="checkbox-label">
                <InputCheckbox @bind-Value="_form.AcceptTerms" />
                <span>J'accepte les <a href="/terms" class="auth-link">CGU</a> et la <a href="/privacy" class="auth-link">politique de confidentialité</a></span>
            </label>
        </div>

        <button type="submit" class="btn btn-primary full-width" disabled="@(_loading || !_form.AcceptTerms)">
            @if (_loading)
            {
                <span class="btn-spinner"></span>
                <span>Création du compte…</span>
            }
            else
            {
                <span>Créer mon compte gratuitement</span>
            }
        </button>
    </EditForm>

    <p class="auth-footer">
        Déjà un compte ? <a href="/login" class="auth-link">Se connecter</a>
    </p>
</div>

@code {
    private RegisterModel _form = new();
    private bool _loading;
    private string _errorMsg = "";

    private async Task HandleRegister()
    {
        _loading = true;
        _errorMsg = "";
        try
        {
            var result = await Auth.RegisterAsync(new RegisterRequest(
                _form.FirstName, _form.LastName, _form.Email,
                _form.Password, _form.ConfirmPassword));

            if (result.Success)
                Nav.NavigateTo("/dashboard?welcome=true");
            else
                _errorMsg = result.ErrorMessage ?? "Erreur lors de la création du compte.";
        }
        finally { _loading = false; }
    }

    private class RegisterModel
    {
        [Required] public string FirstName { get; set; } = "";
        [Required] public string LastName { get; set; } = "";
        [Required, EmailAddress] public string Email { get; set; } = "";
        [Required, MinLength(10)] public string Password { get; set; } = "";
        [Required, Compare(nameof(Password), ErrorMessage = "Les mots de passe ne correspondent pas")]
        public string ConfirmPassword { get; set; } = "";
        public bool AcceptTerms { get; set; }
    }
}


@* Layout/AuthLayout.razor *@
@inherits LayoutComponentBase

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MecaPro</title>
    <link rel="stylesheet" href="css/mecapro.css" />
</head>
<body class="auth-body">
    <div class="auth-bg">
        <div class="auth-bg-grid"></div>
        <div class="auth-bg-glow"></div>
    </div>
    <div class="auth-container">
        @Body
    </div>
</body>
</html>

@* Components/PasswordStrength.razor *@
@if (!string.IsNullOrEmpty(Password))
{
    <div class="pwd-strength">
        <div class="pwd-bar">
            @for (int i = 0; i < 4; i++)
            {
                <div class="pwd-segment @(GetStrengthClass(i))"></div>
            }
        </div>
        <span class="pwd-label @GetLabelClass()">@GetLabel()</span>
    </div>
}

@code {
    [Parameter] public string Password { get; set; } = "";

    private int GetStrength()
    {
        int s = 0;
        if (Password.Length >= 10) s++;
        if (Password.Any(char.IsUpper)) s++;
        if (Password.Any(char.IsDigit)) s++;
        if (Password.Any(c => !char.IsLetterOrDigit(c))) s++;
        return s;
    }

    private string GetStrengthClass(int seg)
    {
        var s = GetStrength();
        if (seg >= s) return "";
        return s switch { 1 => "weak", 2 => "fair", 3 => "good", 4 => "strong", _ => "" };
    }

    private string GetLabel() => GetStrength() switch
    {
        1 => "Faible", 2 => "Moyen", 3 => "Bon", 4 => "Fort", _ => ""
    };

    private string GetLabelClass() => GetStrength() switch
    {
        1 => "text-danger", 2 => "text-warn", 3 => "text-green", 4 => "text-green", _ => ""
    };
}

