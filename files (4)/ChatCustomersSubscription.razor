@* ─────────────────────────────────────────────────────────── *@
@* Pages/Chat.razor                                            *@
@* ─────────────────────────────────────────────────────────── *@

@page "/chat"
@attribute [Authorize]
@inject ApiClient Api
@inject ChatService ChatSvc
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Chat — MecaPro</PageTitle>

<div class="chat-page fade-in">
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <h2>Messages</h2>
            <span class="badge danger">@_unreadTotal</span>
        </div>
        <div class="chat-search">
            <input type="text" placeholder="Chercher…" @bind="_convSearch" class="search-field" />
        </div>
        <div class="conversations-list">
            @foreach (var conv in FilteredConversations)
            {
                <div class="conv-item @(conv.UserId == _activeUserId ? "active" : "") @(conv.UnreadCount > 0 ? "unread" : "")"
                     @onclick="() => SelectConversation(conv)">
                    <div class="conv-avatar">@conv.Initials</div>
                    <div class="conv-info">
                        <div class="conv-name">@conv.Name</div>
                        <div class="conv-preview">@conv.LastMessage</div>
                        <div class="conv-meta">
                            <span class="conv-plate">@conv.VehiclePlate</span>
                            <span class="conv-time">@FormatTime(conv.LastMessageAt)</span>
                        </div>
                    </div>
                    @if (conv.UnreadCount > 0)
                    {
                        <span class="conv-unread">@conv.UnreadCount</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="chat-main">
        @if (_activeConv == null)
        {
            <div class="chat-empty">
                <div class="chat-empty-icon">💬</div>
                <div class="chat-empty-title">Sélectionnez une conversation</div>
            </div>
        }
        else
        {
            <div class="chat-header">
                <div class="chat-header-info">
                    <div class="conv-avatar lg">@_activeConv.Initials</div>
                    <div>
                        <div class="chat-header-name">@_activeConv.Name</div>
                        <div class="chat-header-sub">@_activeConv.VehiclePlate</div>
                    </div>
                </div>
                <div class="chat-header-actions">
                    <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/vehicles/{_activeConv.VehicleId}")'>
                        🚗
                    </button>
                    <button class="icon-btn" @onclick='() => Nav.NavigateTo($"/customers/{_activeConv.CustomerId}")'>
                        👤
                    </button>
                </div>
            </div>

            <div class="chat-messages" @ref="_messagesContainer">
                @foreach (var msg in _messages)
                {
                    <div class="msg-wrap @(msg.IsOwn ? "own" : "other")">
                        @if (!msg.IsOwn)
                        {
                            <div class="msg-avatar">@_activeConv.Initials</div>
                        }
                        <div class="msg-bubble @(msg.IsOwn ? "bubble-own" : "bubble-other")">
                            @if (msg.VehicleId.HasValue)
                            {
                                <div class="msg-vehicle-ref">
                                    🚗 @msg.VehiclePlate
                                </div>
                            }
                            <div class="msg-text">@msg.Content</div>
                            <div class="msg-time">
                                @msg.SentAt.ToString("HH:mm")
                                @if (msg.IsOwn)
                                {
                                    <span class="msg-read-status">@(msg.IsRead ? "✓✓" : "✓")</span>
                                }
                            </div>
                        </div>
                    </div>
                }
                @if (_isTyping)
                {
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                }
            </div>

            <div class="chat-input-area">
                @* Quick templates *@
                <div class="quick-replies">
                    <button class="quick-reply" @onclick='() => SetMessage("Votre véhicule est prêt ! 🎉")'>
                        Véhicule prêt
                    </button>
                    <button class="quick-reply" @onclick='() => SetMessage("Je vous envoie le devis sous peu.")'>
                        Devis en cours
                    </button>
                    <button class="quick-reply" @onclick='() => SetMessage("La pièce est commandée, délai ~3 jours.")'>
                        Pièce commandée
                    </button>
                </div>
                <div class="chat-input-row">
                    <button class="attach-btn" title="Attacher image">📎</button>
                    <textarea class="chat-textarea" placeholder="Votre message…"
                              @bind="_message" @bind:event="oninput"
                              @onkeydown="HandleChatKeyDown" rows="1"></textarea>
                    <button class="send-btn @(string.IsNullOrWhiteSpace(_message) ? "" : "active")"
                            @onclick="SendMessage">
                        ➤
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? UserId { get; set; }

    private List<ConversationDto> _conversations = new();
    private List<ChatMessageDto> _messages = new();
    private ConversationDto? _activeConv;
    private string _activeUserId = "";
    private string _message = "";
    private string _convSearch = "";
    private bool _isTyping;
    private int _unreadTotal;
    private ElementReference _messagesContainer;

    private IEnumerable<ConversationDto> FilteredConversations =>
        string.IsNullOrWhiteSpace(_convSearch)
            ? _conversations
            : _conversations.Where(c => c.Name.Contains(_convSearch, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _conversations = await Api.GetAsync<List<ConversationDto>>("/api/v1/chat/conversations") ?? new();
        _unreadTotal = _conversations.Sum(c => c.UnreadCount);

        await ChatSvc.ConnectAsync();
        ChatSvc.OnMessageReceived += OnMessageReceived;
        ChatSvc.OnTypingReceived += OnTypingReceived;

        if (!string.IsNullOrEmpty(UserId))
        {
            var conv = _conversations.FirstOrDefault(c => c.UserId == UserId);
            if (conv != null) await SelectConversation(conv);
        }
    }

    private async Task SelectConversation(ConversationDto conv)
    {
        _activeConv = conv;
        _activeUserId = conv.UserId;
        _messages = await Api.GetAsync<List<ChatMessageDto>>($"/api/v1/chat/history/{conv.UserId}") ?? new();
        conv.UnreadCount = 0;
        _unreadTotal = _conversations.Sum(c => c.UnreadCount);
        await ChatSvc.MarkAsReadAsync(conv.UserId);
        await ScrollToBottomAsync();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_message) || _activeConv == null) return;
        var content = _message.Trim();
        _message = "";

        var msg = new ChatMessageDto
        {
            Id = Guid.NewGuid(),
            Content = content,
            IsOwn = true,
            SentAt = DateTime.Now,
            IsRead = false
        };
        _messages.Add(msg);
        await ChatSvc.SendAsync(_activeUserId, content, _activeConv.VehicleId?.ToString());
        await ScrollToBottomAsync();
    }

    private async Task HandleChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void SetMessage(string template) => _message = template;

    private void OnMessageReceived(ChatMessageDto msg)
    {
        if (msg.SenderId == _activeUserId)
        {
            _messages.Add(msg);
            InvokeAsync(ScrollToBottomAsync);
        }
        else
        {
            var conv = _conversations.FirstOrDefault(c => c.UserId == msg.SenderId);
            if (conv != null) { conv.UnreadCount++; conv.LastMessage = msg.Content; }
            _unreadTotal++;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnTypingReceived(string userId)
    {
        if (userId == _activeUserId)
        {
            _isTyping = true;
            InvokeAsync(StateHasChanged);
            Task.Delay(3000).ContinueWith(_ => { _isTyping = false; InvokeAsync(StateHasChanged); });
        }
    }

    private async Task ScrollToBottomAsync()
    {
        // JS interop to scroll
        await Task.CompletedTask;
    }

    private string FormatTime(DateTime dt)
    {
        if (dt.Date == DateTime.Today) return dt.ToString("HH:mm");
        if (dt.Date == DateTime.Today.AddDays(-1)) return "Hier";
        return dt.ToString("dd/MM");
    }

    public async ValueTask DisposeAsync()
    {
        ChatSvc.OnMessageReceived -= OnMessageReceived;
        ChatSvc.OnTypingReceived -= OnTypingReceived;
        await ChatSvc.DisconnectAsync();
    }
}


@* ─────────────────────────────────────────────────────────── *@
@* Pages/Customers/CustomerList.razor                          *@
@* ─────────────────────────────────────────────────────────── *@

@page "/customers"
@attribute [Authorize(Policy = "RequireMechanic")]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Clients — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <h1 class="page-title">👥 Clients CRM</h1>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/customers/new")'>
            ＋ Nouveau client
        </button>
    </div>

    <div class="crm-stats-row">
        <div class="crm-stat-card">
            <div class="crm-stat-val">@_totalClients</div>
            <div class="crm-stat-label">Total clients</div>
        </div>
        <div class="crm-stat-card">
            <div class="crm-stat-val" style="color:var(--amber)">@_goldClients</div>
            <div class="crm-stat-label">🥇 Gold+</div>
        </div>
        <div class="crm-stat-card">
            <div class="crm-stat-val" style="color:var(--green)">@_avgLtv.ToString("N0") €</div>
            <div class="crm-stat-label">CA moyen / client</div>
        </div>
        <div class="crm-stat-card">
            <div class="crm-stat-val" style="color:var(--blue)">@_newThisMonth</div>
            <div class="crm-stat-label">Nouveaux ce mois</div>
        </div>
    </div>

    <div class="filter-bar">
        <input type="text" class="search-field" placeholder="Nom, email, téléphone…"
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearch" />
        <select class="filter-select" @bind="_segmentFilter">
            <option value="">Tous segments</option>
            <option value="Standard">Standard</option>
            <option value="Silver">Silver</option>
            <option value="Gold">Gold</option>
            <option value="Platinum">Platinum</option>
        </select>
        <button class="btn btn-ghost" @onclick="ExportGdpr">📥 Export RGPD</button>
    </div>

    @if (_loading)
    {
        <TableSkeleton Rows="10" />
    }
    else
    {
        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Segment</th>
                        <th>Points fidélité</th>
                        <th>Véhicules</th>
                        <th>CA total</th>
                        <th>Depuis</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _customers)
                    {
                        <tr class="table-row" @onclick="() => Nav.NavigateTo($&quot;/customers/{c.Id}&quot;)">
                            <td>
                                <div class="customer-cell">
                                    <div class="mini-avatar @c.Segment.ToLower()">
                                        @c.FirstName[0]@c.LastName[0]
                                    </div>
                                    <div>
                                        <strong>@c.FirstName @c.LastName</strong>
                                    </div>
                                </div>
                            </td>
                            <td><a href="mailto:@c.Email" class="email-link" @onclick:stopPropagation="true">@c.Email</a></td>
                            <td class="mono">@(c.Phone ?? "—")</td>
                            <td><SegmentBadge Segment="@c.Segment" /></td>
                            <td>
                                <div class="loyalty-cell">
                                    <div class="loyalty-bar">
                                        <div class="loyalty-fill" style="width:@GetLoyaltyPercent(c.LoyaltyPoints)%"></div>
                                    </div>
                                    <span class="mono">@c.LoyaltyPoints</span>
                                </div>
                            </td>
                            <td class="center">@c.VehicleCount</td>
                            <td class="mono accent">@c.TotalSpent.ToString("N0") €</td>
                            <td class="mono text-muted">@c.CreatedAt.ToString("MM/yyyy")</td>
                            <td @onclick:stopPropagation="true">
                                <div class="action-btns">
                                    <button class="icon-btn-sm" @onclick='() => Nav.NavigateTo($"/customers/{c.Id}")'>👁</button>
                                    <button class="icon-btn-sm" @onclick='() => Nav.NavigateTo($"/chat?userId={c.Id}")'>💬</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Pagination CurrentPage="_page" TotalPages="_totalPages" OnPageChanged="ChangePage" />
        </div>
    }
</div>

@code {
    private List<CustomerDto> _customers = new();
    private bool _loading = true;
    private string _search = "";
    private string _segmentFilter = "";
    private int _page = 1;
    private int _totalPages;
    private int _totalClients;
    private int _goldClients;
    private decimal _avgLtv;
    private int _newThisMonth;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var url = $"/api/v1/customers?page={_page}&pageSize=20&search={_search}&segment={_segmentFilter}";
        var result = await Api.GetAsync<PagedResult<CustomerDto>>(url);
        _customers = result?.Items.ToList() ?? new();
        _totalPages = result?.TotalPages ?? 1;
        var stats = await Api.GetAsync<CrmStatsDto>("/api/v1/customers/stats");
        if (stats != null)
        {
            _totalClients = stats.Total;
            _goldClients = stats.GoldPlus;
            _avgLtv = stats.AvgLifetimeValue;
            _newThisMonth = stats.NewThisMonth;
        }
        _loading = false;
    }

    private async Task OnSearch(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadAsync(); }
    private async Task ChangePage(int p) { _page = p; await LoadAsync(); }
    private double GetLoyaltyPercent(int pts) => Math.Min(100, pts / 50.0);

    private async Task ExportGdpr()
    {
        // trigger download of GDPR JSON
    }
}


@* ─────────────────────────────────────────────────────────── *@
@* Pages/Subscription/SubscriptionPage.razor                   *@
@* ─────────────────────────────────────────────────────────── *@

@page "/subscription"
@attribute [Authorize(Policy = "RequireGarageOwner")]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Abonnement — MecaPro</PageTitle>

<div class="page fade-in">
    <div class="page-header">
        <h1 class="page-title">💳 Abonnement</h1>
    </div>

    @if (_currentSub != null)
    {
        <div class="sub-current-card @_currentSub.PlanTier">
            <div class="sub-current-header">
                <div>
                    <div class="sub-plan-name">Plan @_currentSub.PlanName</div>
                    <StatusBadge Status="@_currentSub.Status" />
                </div>
                <div class="sub-price">
                    @_currentSub.PriceMonthly € <span>/mois</span>
                </div>
            </div>
            <div class="sub-details">
                <div class="sub-detail">📅 Depuis le @_currentSub.StartDate.ToString("dd/MM/yyyy")</div>
                <div class="sub-detail">🔄 Prochain renouvellement : @_currentSub.NextRenewal?.ToString("dd/MM/yyyy")</div>
                <div class="sub-detail">👥 Mécaniciens : @_currentSub.MechanicsUsed / @_currentSub.MaxMechanics</div>
            </div>
            <div class="sub-actions">
                <button class="btn btn-ghost" @onclick="OpenStripePortal">💳 Gérer carte bancaire</button>
                <button class="btn btn-danger-ghost" @onclick="ShowCancelConfirm">Annuler l'abonnement</button>
            </div>
        </div>
    }

    <h2 class="section-title">Changer de plan</h2>

    <div class="plans-grid">
        @foreach (var plan in _plans)
        {
            <div class="plan-card @(plan.IsCurrentPlan ? "current" : "") @(plan.IsFeatured ? "featured" : "")">
                @if (plan.IsFeatured)
                {
                    <div class="plan-badge">POPULAIRE</div>
                }
                @if (plan.IsCurrentPlan)
                {
                    <div class="plan-badge current-badge">ACTUEL</div>
                }
                <div class="plan-name">@plan.Name</div>
                <div class="plan-price">
                    @if (plan.PriceMonthly == 0)
                    {
                        <span>Sur devis</span>
                    }
                    else
                    {
                        <span class="plan-amount">@plan.PriceMonthly €</span>
                        <span class="plan-period">/mois</span>
                    }
                </div>
                <div class="plan-features">
                    <PlanFeature Label="@GetMechanicsLabel(plan.MaxMechanics)" Available="true" />
                    <PlanFeature Label="Véhicules illimités" Available="@(plan.MaxVehicles == 0)" />
                    <PlanFeature Label="QR Codes véhicules" Available="true" />
                    <PlanFeature Label="Chat client" Available="true" />
                    <PlanFeature Label="E-Commerce" Available="@plan.HasEcommerce" />
                    <PlanFeature Label="Accès API" Available="@plan.HasApiAccess" />
                    <PlanFeature Label="White-label" Available="@plan.IsWhiteLabel" />
                    <PlanFeature Label="SLA 99.9% + Support dédié" Available="@plan.IsWhiteLabel" />
                </div>
                @if (!plan.IsCurrentPlan)
                {
                    <button class="btn @(plan.IsFeatured ? "btn-primary" : "btn-ghost") full-width"
                            @onclick="() => StartCheckout(plan.Id)">
                        @(plan.PriceMonthly == 0 ? "Nous contacter" : "Choisir ce plan")
                    </button>
                }
                else
                {
                    <button class="btn btn-disabled full-width" disabled>Plan actuel</button>
                }
            </div>
        }
    </div>

    <div class="invoices-section">
        <h2 class="section-title">🧾 Historique factures</h2>
        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr><th>Numéro</th><th>Date</th><th>Montant</th><th>Statut</th><th>PDF</th></tr>
                </thead>
                <tbody>
                    @foreach (var inv in _invoices)
                    {
                        <tr>
                            <td class="mono">@inv.Number</td>
                            <td>@inv.IssuedAt.ToString("dd/MM/yyyy")</td>
                            <td class="mono">@inv.TotalTTC.ToString("N2") €</td>
                            <td><StatusBadge Status="@inv.Status" /></td>
                            <td>
                                <a href="/api/v1/invoices/@inv.Id/pdf" target="_blank" class="btn btn-ghost btn-xs">
                                    📄 PDF
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private SubscriptionDto? _currentSub;
    private List<PlanDto> _plans = new();
    private List<InvoiceDto> _invoices = new();

    protected override async Task OnInitializedAsync()
    {
        _currentSub = await Api.GetAsync<SubscriptionDto>("/api/v1/subscriptions/current");
        _plans = await Api.GetAsync<List<PlanDto>>("/api/v1/plans") ?? new();
        _invoices = await Api.GetAsync<List<InvoiceDto>>("/api/v1/subscriptions/invoices") ?? new();
    }

    private async Task StartCheckout(Guid planId)
    {
        var result = await Api.PostAsync<CheckoutSessionDto>("/api/v1/subscriptions/checkout",
            new { planId });
        if (result?.Url != null)
            Nav.NavigateTo(result.Url, forceLoad: true); // Redirect to Stripe
    }

    private async Task OpenStripePortal()
    {
        var result = await Api.GetAsync<PortalSessionDto>("/api/v1/payments/portal");
        if (result?.Url != null)
            Nav.NavigateTo(result.Url, forceLoad: true);
    }

    private void ShowCancelConfirm() { /* show confirm dialog */ }

    private string GetMechanicsLabel(int max)
        => max == int.MaxValue ? "Mécaniciens illimités" : $"{max} mécanicien(s)";
}


@* ─────────────────────────────────────────────────────────── *@
@* COMPOSANTS PARTAGÉS                                         *@
@* ─────────────────────────────────────────────────────────── *@

@* Components/KpiCard.razor *@
@* <KpiCard Icon="🚗" Value="47" Label="Véhicules" Trend="+3" TrendUp="true" Color="amber" /> *@

<div class="kpi-card color-@Color" @onclick="OnClick">
    <div class="kpi-icon-wrap">
        <span class="kpi-icon">@Icon</span>
    </div>
    <div class="kpi-body">
        <div class="kpi-value">@Value</div>
        <div class="kpi-label">@Label</div>
    </div>
    @if (!string.IsNullOrEmpty(Trend))
    {
        <div class="kpi-trend @(TrendUp ? "trend-up" : "trend-down")">
            @(TrendUp ? "↑" : "↓") @Trend
        </div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Trend { get; set; } = "";
    [Parameter] public bool TrendUp { get; set; }
    [Parameter] public string Color { get; set; } = "amber";
    [Parameter] public EventCallback OnClick { get; set; }
}


@* Components/StatusBadge.razor *@
<span class="status-badge status-@Status.ToLower().Replace(" ", "-") @(Small ? "sm" : "")">
    @GetLabel()
</span>

@code {
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public bool Small { get; set; }

    private string GetLabel() => Status switch
    {
        "InProgress" or "En cours" => "En cours",
        "Scheduled"  or "Planifié" => "Planifié",
        "Completed"  or "Terminé"  => "Terminé",
        "Urgent"                   => "🔴 Urgent",
        "Cancelled"                => "Annulé",
        "Active"     or "active"   => "Actif",
        "Trialing"                 => "Essai",
        "PastDue"                  => "Impayé",
        "Resolved"                 => "Résolu",
        "Open"                     => "Ouvert",
        "paid"       or "Paid"     => "Payé",
        "draft"                    => "Brouillon",
        "issued"                   => "Émise",
        _                          => Status
    };
}


@* Components/Modal.razor *@
<div class="modal-overlay" @onclick="HandleOverlayClick">
    <div class="modal-container" @onclick:stopPropagation="true">
        <div class="modal-header">
            <h3 class="modal-title">@Title</h3>
            <button class="modal-close" @onclick="OnClose">✕</button>
        </div>
        <div class="modal-body">
            @ChildContent
        </div>
        @if (Footer != null)
        {
            <div class="modal-footer">@Footer</div>
        }
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool CloseOnOverlay { get; set; } = true;

    private async Task HandleOverlayClick()
    {
        if (CloseOnOverlay) await OnClose.InvokeAsync();
    }
}


@* Components/QrCodeViewer.razor *@
@inject ApiClient Api
@inject IJSRuntime JS

<div class="qr-viewer">
    @if (_loading)
    {
        <div class="qr-skeleton"></div>
    }
    else if (_qr != null)
    {
        <div class="qr-code-wrap">
            <img src="@_qr.ImageBase64" alt="QR Code @LicensePlate" class="qr-image" />
        </div>
        <div class="qr-plate">@LicensePlate</div>
        <div class="qr-make">@Make @Model</div>
        <div class="qr-url mono">@_qr.Url</div>
        <div class="qr-actions">
            <button class="btn btn-primary" @onclick="DownloadQr">⬇ Télécharger</button>
            <button class="btn btn-ghost" @onclick="PrintQr">🖨 Imprimer</button>
            <button class="btn btn-ghost" @onclick="RegenerateQr">🔄 Régénérer</button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid VehicleId { get; set; }
    [Parameter] public string LicensePlate { get; set; } = "";
    [Parameter] public string Make { get; set; } = "";
    [Parameter] public string Model { get; set; } = "";

    private QrCodeDto? _qr;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _qr = await Api.GetAsync<QrCodeDto>($"/api/v1/vehicles/{VehicleId}/qr");
        _loading = false;
    }

    private async Task DownloadQr()
        => await JS.InvokeVoidAsync("mecapro.downloadBase64", _qr!.ImageBase64, $"QR_{LicensePlate}.png");

    private async Task PrintQr()
        => await JS.InvokeVoidAsync("mecapro.printElement", "qr-image");

    private async Task RegenerateQr()
    {
        _loading = true;
        _qr = await Api.PostAsync<QrCodeDto>($"/api/v1/vehicles/{VehicleId}/qr/regenerate", null);
        _loading = false;
    }
}


@* Components/ImageUploader.razor *@
@inject ApiClient Api
@inject ToastService Toast
@inject IJSRuntime JS

<div class="uploader">
    <div class="drop-zone @(_isDragging ? "dragging" : "")"
         @ondragenter="() => _isDragging = true"
         @ondragleave="() => _isDragging = false"
         @ondragover:preventDefault="true"
         @ondrop="HandleDrop">
        <div class="drop-icon">📸</div>
        <div class="drop-text">Glissez vos photos ici</div>
        <div class="drop-sub">PNG, JPG, HEIC — Max 10 MB chacune</div>
        <InputFile OnChange="HandleFileSelected" multiple class="file-input" accept="image/*" />
        <button class="btn btn-ghost">Parcourir…</button>
    </div>

    @if (_previews.Any())
    {
        <div class="preview-grid">
            @foreach (var prev in _previews)
            {
                <div class="preview-item @(prev.Uploading ? "uploading" : prev.Done ? "done" : "")">
                    <img src="@prev.DataUrl" alt="@prev.FileName" class="preview-img" />
                    <div class="preview-name">@prev.FileName</div>
                    @if (prev.Uploading)
                    {
                        <div class="preview-progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width:@prev.Progress%"></div>
                            </div>
                        </div>
                    }
                    @if (prev.Done)
                    {
                        <div class="preview-done">✓</div>
                    }
                    @if (prev.Error != null)
                    {
                        <div class="preview-error">@prev.Error</div>
                    }
                </div>
            }
        </div>

        <div class="uploader-actions">
            <button class="btn btn-primary" @onclick="UploadAll"
                    disabled="@(_previews.Any(p => p.Uploading))">
                ⬆ Importer @_previews.Count photo(s)
            </button>
            <button class="btn btn-ghost" @onclick="ClearAll">✕ Annuler</button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid VehicleId { get; set; }
    [Parameter] public EventCallback OnUploaded { get; set; }

    private List<ImagePreview> _previews = new();
    private bool _isDragging;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            var preview = new ImagePreview { FileName = file.Name };
            _previews.Add(preview);
            var buffer = new byte[file.Size];
            await file.OpenReadStream(10_000_000).ReadAsync(buffer);
            preview.DataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            preview.FileData = buffer;
            preview.ContentType = file.ContentType;
        }
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        _isDragging = false;
        // Handle dropped files via JS interop
    }

    private async Task UploadAll()
    {
        foreach (var preview in _previews.Where(p => !p.Done && p.Error == null))
        {
            preview.Uploading = true;
            preview.Progress = 0;
            StateHasChanged();
            try
            {
                await Api.UploadImageAsync(
                    $"/api/v1/vehicles/{VehicleId}/images",
                    preview.FileData!, preview.FileName, preview.ContentType!);
                preview.Done = true;
                preview.Progress = 100;
            }
            catch (Exception ex)
            {
                preview.Error = "Erreur upload";
            }
            finally
            {
                preview.Uploading = false;
            }
            StateHasChanged();
        }
        Toast.Show("Photos importées", ToastType.Success);
        await OnUploaded.InvokeAsync();
    }

    private void ClearAll() => _previews.Clear();

    private class ImagePreview
    {
        public string FileName { get; set; } = "";
        public string? DataUrl { get; set; }
        public byte[]? FileData { get; set; }
        public string? ContentType { get; set; }
        public bool Uploading { get; set; }
        public bool Done { get; set; }
        public int Progress { get; set; }
        public string? Error { get; set; }
    }
}


@* Components/Toast/ToastContainer.razor *@
@inject ToastService ToastSvc
@implements IDisposable

<div class="toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="toast toast-@toast.Type.ToString().ToLower() @(toast.IsLeaving ? "leaving" : "")">
            <span class="toast-icon">@GetIcon(toast.Type)</span>
            <span class="toast-msg">@toast.Message</span>
            <button class="toast-close" @onclick="() => Remove(toast)">✕</button>
        </div>
    }
</div>

@code {
    private List<ToastItem> _toasts = new();

    protected override void OnInitialized()
    {
        ToastSvc.OnShow += Show;
    }

    private void Show(string message, ToastType type)
    {
        var toast = new ToastItem { Message = message, Type = type };
        _toasts.Add(toast);
        InvokeAsync(StateHasChanged);
        Task.Delay(4000).ContinueWith(_ => Remove(toast));
    }

    private void Remove(ToastItem toast)
    {
        toast.IsLeaving = true;
        InvokeAsync(StateHasChanged);
        Task.Delay(300).ContinueWith(_ =>
        {
            _toasts.Remove(toast);
            InvokeAsync(StateHasChanged);
        });
    }

    private string GetIcon(ToastType t) => t switch
    {
        ToastType.Success => "✅",
        ToastType.Error   => "🔴",
        ToastType.Warning => "⚠",
        _                 => "ℹ"
    };

    public void Dispose() => ToastSvc.OnShow -= Show;

    private class ToastItem
    {
        public string Message { get; set; } = "";
        public ToastType Type { get; set; }
        public bool IsLeaving { get; set; }
    }
}


@* Components/Pagination.razor *@
<div class="pagination">
    <button class="page-btn" disabled="@(CurrentPage <= 1)"
            @onclick="() => OnPageChanged.InvokeAsync(CurrentPage - 1)">
        ←
    </button>
    @for (int i = Math.Max(1, CurrentPage - 2); i <= Math.Min(TotalPages, CurrentPage + 2); i++)
    {
        var page = i;
        <button class="page-btn @(page == CurrentPage ? "active" : "")"
                @onclick="() => OnPageChanged.InvokeAsync(page)">
            @page
        </button>
    }
    <button class="page-btn" disabled="@(CurrentPage >= TotalPages)"
            @onclick="() => OnPageChanged.InvokeAsync(CurrentPage + 1)">
        →
    </button>
    <span class="page-info">Page @CurrentPage / @TotalPages</span>
</div>

@code {
    [Parameter] public int CurrentPage { get; set; }
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
}


@* Components/RevisionTimeline.razor *@
<div class="revision-timeline">
    @foreach (var rev in Revisions.OrderByDescending(r => r.ScheduledDate))
    {
        <div class="tl-item @(rev.Status == "Completed" ? "done" : rev.ScheduledDate > DateTime.Now ? "upcoming" : "")">
            <div class="tl-dot"></div>
            <div class="tl-content">
                <div class="tl-date mono">@rev.ScheduledDate.ToString("dd/MM/yyyy")</div>
                <div class="tl-title">@rev.Type</div>
                <div class="tl-meta">
                    @if (rev.ActualCost.HasValue)
                    {
                        <span class="mono">@rev.ActualCost.Value.ToString("N0") € TTC</span>
                    }
                    else
                    {
                        <span class="text-muted">Est. @rev.EstimatedCost.ToString("N0") €</span>
                    }
                    <span>⏱ @(rev.ActualMinutes ?? rev.EstimatedMinutes) min</span>
                </div>
                <StatusBadge Status="@rev.Status" Small="true" />
            </div>
        </div>
    }
    @if (!Revisions.Any())
    {
        <div class="empty-state-sm">Aucune révision enregistrée</div>
    }
</div>

@code {
    [Parameter] public IEnumerable<RevisionDto> Revisions { get; set; } = new List<RevisionDto>();
}


