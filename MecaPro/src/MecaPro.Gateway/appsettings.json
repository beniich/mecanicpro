{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "notifications-cluster",
        "Match": { "Path": "/api/v1/notifications/{**catch-all}" }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/v1/inventory/{**catch-all}" }
      },
      "api-route": {
        "ClusterId": "monolith-cluster",
        "Match": { "Path": "{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": { "Destinations": { "auth": { "Address": "https://localhost:5100" } } },
      "notifications-cluster": { "Destinations": { "notifications": { "Address": "https://localhost:5200" } } },
      "inventory-cluster": { "Destinations": { "inventory": { "Address": "https://localhost:5300" } } },
      "monolith-cluster": { "Destinations": { "monolith": { "Address": "https://localhost:5001" } } }
    }
  }
}
