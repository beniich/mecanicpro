@page "/planning/revisions-plannings"
@layout EmptyLayout
@attribute [Authorize]
@code {
    private PagedResult<RevisionDto>? pagedResult;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadRevisions();
    }

    private async Task LoadRevisions()
    {
        loading = true;
        // Fetch first page of revisions
        pagedResult = await Api.GetAsync<PagedResult<RevisionDto>>("/api/v1/revisions?page=1&pageSize=20");
        loading = false;
    }
}

<PageTitle>MECAPRO — Révisions Planifiées</PageTitle>

<div class="bg-surface text-on-surface font-body selection:bg-primary-container min-h-screen pb-24">
    <!-- TopAppBar -->
    <header class="bg-[#111318] flex justify-between items-center px-6 py-4 w-full border-b border-[#524534]/15 z-40 sticky top-0">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#f5a623] text-2xl">precision_manufacturing</span>
            <h1 class="text-2xl font-black tracking-[0.2em] text-[#f5a623] font-headline uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-[#e2e2e8]/60">notifications</span>
            <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant/30 flex items-center justify-center">
                <span class="material-symbols-outlined text-sm">person</span>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8">
        <!-- Hero Section / KPI -->
        <div class="mb-10 grid grid-cols-1 md:grid-cols-3 gap-6 uppercase font-headline">
            <div class="md:col-span-2 bg-surface-container-low p-8 rounded-xl border-l-2 border-secondary-container flex flex-col justify-between">
                <div>
                    <h2 class="text-5xl tracking-wider text-on-surface mb-2 italic">Révisions Planifiées</h2>
                    <p class="text-on-surface-variant font-body normal-case">Suivi technique et maintenance préventive de la flotte.</p>
                </div>
                <div class="mt-8 flex gap-12">
                    <div>
                        <p class="font-technical text-primary text-4xl font-bold tracking-tighter">@(pagedResult?.Total ?? 0)</p>
                        <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-label">Total interventions</p>
                    </div>
                </div>
            </div>
        </div>

        @if (loading)
        {
            <div class="flex justify-center py-20">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (pagedResult?.Items == null || !pagedResult.Items.Any())
        {
            <div class="text-center py-20 bg-surface-container-low rounded-3xl border border-dashed border-outline-variant/30">
                <span class="material-symbols-outlined text-6xl text-on-surface-variant/20 mb-4">event_busy</span>
                <p class="text-on-surface-variant uppercase font-black tracking-widest italic">Aucune intervention planifiée</p>
            </div>
        }
        else
        {
            <!-- Revision Cards List -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <div class="lg:col-span-8 space-y-4">
                    @foreach (var rev in pagedResult.Items)
                    {
                        <div @onclick='() => Nav.NavigateTo($"/clients/detail-intervention/{rev.Id}")' 
                             class="bg-surface-container-high rounded-xl overflow-hidden flex flex-col md:flex-row border-l-4 border-primary group hover:bg-surface-container-highest transition-all cursor-pointer">
                            <div class="p-6 flex-grow">
                                <div class="flex justify-between items-start mb-4 uppercase">
                                    <div>
                                        <div class="flex items-center gap-2 mb-2">
                                            <span class="bg-primary/10 text-primary px-2 py-0.5 rounded text-[10px] font-bold font-technical">@rev.Type</span>
                                            <span class="text-[10px] font-bold font-technical text-on-surface-variant">@rev.ScheduledDate.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                        <h4 class="text-xl font-bold font-body normal-case">Intervention #@rev.Id.ToString().Substring(0,8)</h4>
                                        <p class="font-technical text-sm text-on-surface-variant tracking-wider">STATUT: @rev.Status</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-2xl font-black font-technical text-primary">@rev.EstimatedCost€</p>
                                        <p class="text-[10px] text-on-surface-variant font-label italic">ESTIMATION</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </main>
</div>

@inject ApiClient Api
@inject NavigationManager Nav
