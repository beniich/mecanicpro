@page "/atelier/planning-equipes"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Planning Équipes</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-hidden flex flex-col">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#02e1f2]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#02e1f2] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 flex items-center gap-4">
               <button @onclick="PrevWeek" class="text-white/40 hover:text-white transition-all"><span class="material-symbols-outlined text-sm">chevron_left</span></button>
               <span class="text-[10px] font-black uppercase tracking-widest text-[#02e1f2]">SEMAINE 12 — MARS 2026</span>
               <button @onclick="NextWeek" class="text-white/40 hover:text-white transition-all"><span class="material-symbols-outlined text-sm">chevron_right</span></button>
            </div>
            <button class="bg-[#02e1f2] text-black px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-cyan-300 transition-all flex items-center gap-2 shadow-[0_0_15px_rgba(2,225,242,0.3)]">
                <span class="material-symbols-outlined text-sm">calendar_month</span> PUBLIER
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 mx-auto w-full flex-grow flex flex-col">

        <!-- Header Info -->
        <div class="flex justify-between items-end gap-6 mb-8 py-6 border-b border-white/5">
            <div>
                <span class="text-[#02e1f2] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">STAFF_CAPACITY_GRID</span>
                <h2 class="text-6xl font-black tracking-tighter italic uppercase leading-none drop-shadow-[0_0_15px_rgba(2,225,242,0.1)]">Planning Équipes</h2>
            </div>
            <div class="flex gap-4">
                <div class="flex items-center gap-2"><div class="w-3 h-3 bg-red-400 rounded-sm"></div><span class="text-[9px] font-black tracking-widest uppercase text-white/30">LOURDE</span></div>
                <div class="flex items-center gap-2"><div class="w-3 h-3 bg-[#00FF66] rounded-sm"></div><span class="text-[9px] font-black tracking-widest uppercase text-white/30">RAPIDE</span></div>
                <div class="flex items-center gap-2"><div class="w-3 h-3 bg-yellow-400 rounded-sm"></div><span class="text-[9px] font-black tracking-widest uppercase text-white/30">DIAG</span></div>
            </div>
        </div>

        <!-- Schedule Grid -->
        <div class="flex-grow bg-surface-container rounded-[40px] border border-white/5 overflow-hidden shadow-2xl flex flex-col">
            <!-- Grid Header (Days) -->
            <div class="grid grid-cols-[240px_repeat(5,1fr)] border-b border-white/10 bg-black/40">
                <div class="p-6 border-r border-white/5">
                     <p class="text-[10px] font-black uppercase tracking-[0.3em] text-white/20 italic">COLLABORATEURS</p>
                </div>
                @foreach (var day in days)
                {
                    <div class="p-6 font-black uppercase text-center border-r border-white/5 last:border-0">
                        <p class="text-[10px] tracking-widest text-[#02e1f2]">@day.Ddd</p>
                        <p class="text-2xl italic tracking-tighter">@day.Dd <span class="text-xs opacity-30 text-white">/ 03</span></p>
                    </div>
                }
            </div>

            <!-- Grid Body (Participants) -->
            <div class="flex-grow overflow-y-auto custom-scroll">
                @foreach(var emp in equipe)
                {
                    <div class="grid grid-cols-[240px_repeat(5,1fr)] border-b border-white/5 min-h-[140px] group">
                        <!-- Employee Info -->
                        <div class="p-6 border-r border-white/5 flex items-center gap-4 bg-white/[0.01] group-hover:bg-white/[0.03] transition-colors">
                            <img src="@emp.Avatar" class="w-12 h-12 rounded-xl object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all border border-white/10"/>
                            <div>
                                <p class="font-black italic uppercase text-white text-sm">@emp.Nom</p>
                                <p class="text-[8px] font-black text-white/40 uppercase tracking-widest mt-1">@emp.Spe</p>
                            </div>
                        </div>

                        <!-- Slots (Days) -->
                        @for (int i = 0; i < 5; i++)
                        {
                            var hasTask = emp.Planning[i] != null;
                            <div class="p-3 border-r border-white/5 last:border-0 relative">
                                @if(hasTask)
                                {
                                    <div class="h-full rounded-2xl p-4 @(emp.Planning[i].ColorClass) bg-opacity-10 border @(emp.Planning[i].BorderClass) flex flex-col justify-between hover:scale-[1.02] transition-transform cursor-pointer shadow-lg">
                                        <div>
                                            <p class="text-[8px] font-black uppercase tracking-widest @(emp.Planning[i].TextColorClass) mb-1">PO-#@emp.Planning[i].Ref</p>
                                            <p class="font-black uppercase text-[10px] leading-tight text-white/90">@emp.Planning[i].Task</p>
                                        </div>
                                        <div class="flex justify-between items-end">
                                            <span class="text-[9px] font-technical font-black @(emp.Planning[i].TextColorClass)">@emp.Planning[i].Time</span>
                                            <span class="material-symbols-outlined text-sm @(emp.Planning[i].TextColorClass) opacity-40">@emp.Planning[i].Icon</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="h-full border-2 border-dashed border-white/[0.02] rounded-2xl flex items-center justify-center opacity-0 group-hover:opacity-100 hover:border-white/10 transition-all">
                                        <button class="text-white/10 hover:text-[#02e1f2]"><span class="material-symbols-outlined">add_circle</span></button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </main>
</div>

@code {
    private List<DayHeader> days = new() {
        new("LUN", "23"), new("MAR", "24"), new("MER", "25"), new("JEU", "26"), new("VEN", "27")
    };

    private void PrevWeek() { }
    private void NextWeek() { }

    private List<StaffMember> equipe = new()
    {
        new("MARC DUBOIS", "Technicien Senior", "https://randomuser.me/api/portraits/men/32.jpg", "Expert Mécanique", new TaskItem?[] {
            new("642", "Distrib Porsche GT3", "08H - 17H", "bg-red-400", "border-red-400", "text-red-400", "history"),
            null,
            new("921", "Moteur Audi RS6", "09H - 18H", "bg-red-400", "border-red-400", "text-red-400", "engineering"),
            new("921", "Moteur Audi RS6 (Suite)", "08H - 12H", "bg-red-400", "border-red-400", "text-red-400", "engineering"),
            null
        }),
        new("SARAH MEYER", "Diagnostiqueuse", "https://randomuser.me/api/portraits/women/44.jpg", "Diag & Elec", new TaskItem?[] {
            new("814", "Analyse OBD Tesla", "10H - 12H", "bg-yellow-400", "border-yellow-400", "text-yellow-400", "psychology"),
            new("842", "Mapping ECU BMW", "08H - 18H", "bg-yellow-400", "border-yellow-400", "text-yellow-400", "memory"),
            null,
            null,
            new("910", "Paramétrage Optiques", "08H - 12H", "bg-yellow-400", "border-yellow-400", "text-yellow-400", "visibility")
        }),
        new("KARIM BENALI", "Technicien Rapide", "https://randomuser.me/api/portraits/men/22.jpg", "Pneumatiques", new TaskItem?[] {
            new("102", "Pneus Michelin RS4", "08H - 10H", "bg-green-400", "border-green-400", "text-green-400", "tire_repair"),
            new("105", "Vidange Express Clio", "10H - 11H", "bg-green-400", "border-green-400", "text-green-400", "oil_barrel"),
            new("110", "Freins Av. Captur", "14H - 16H", "bg-green-400", "border-green-400", "text-green-400", "handyman"),
            null,
            new("115", "Check-up Hiver XC60", "08H - 11H", "bg-green-400", "border-green-400", "text-green-400", "ac_unit")
        }),
    };

    record DayHeader(string Ddd, string Dd);
    record TaskItem(string Ref, string Task, string Time, string ColorClass, string BorderClass, string TextColorClass, string Icon);
    record StaffMember(string Nom, string Role, string Avatar, string Spe, TaskItem?[] Planning);
}
