    record CategoryMetrics(string T1, string V1, string S1, string SC1, string T2, string V2, string S2, string SC2, string T3, string V3, string S3, string SC3);
    record ModuleCategory(string Title, string Subtitle, string Icon, string IconColor, string BgIconBox, string AccentColor, CategoryMetrics Metrics, List<ModuleItem> Items);

