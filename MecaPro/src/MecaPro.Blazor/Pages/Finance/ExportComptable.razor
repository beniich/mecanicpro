@page "/export-comptable"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Export Comptable</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24">

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/billing")'>
            <span class="material-symbols-outlined text-[#02e1f2]">chevron_left</span>
            <span class="material-symbols-outlined text-[#02e1f2]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#02e1f2] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-white/5 border border-white/10 px-4 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest text-[#02e1f2] flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">storage</span> FEC / XSLX
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-5xl mx-auto space-y-10">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#02e1f2] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">ACCOUNTING_DATA_BRIDGE</span>
                <h2 class="text-6xl md:text-7xl font-black tracking-tighter italic uppercase leading-none drop-shadow-[0_0_15px_rgba(2,225,242,0.2)]">Export Comptable</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-widest font-black">Transfert des écritures de facturation vers le format comptable réglementaire.</p>
            </div>
            <div class="flex gap-4 mb-2">
                <button class="bg-white/5 border border-white/10 px-6 py-3 text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all rounded-xl flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">history</span> HISTORIQUE EXPORTS
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- Interface Export -->
            <div class="bg-surface-container rounded-[40px] border border-white/5 p-8 relative shadow-2xl overflow-hidden flex flex-col justify-between">
                
                <h3 class="font-black text-2xl italic uppercase tracking-tight text-white mb-8">Nouveau Traitement</h3>

                <div class="space-y-6">
                    <!-- Date Range -->
                    <div>
                        <label class="text-[10px] font-black tracking-[0.2em] text-[#02e1f2] uppercase mb-3 block">Période Fiscale (Mois)</label>
                        <div class="flex gap-4">
                            <select @bind="selectedMonth" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-sm font-black uppercase text-white outline-none focus:border-[#02e1f2]/50 transition-colors appearance-none text-center tracking-widest">
                                <option value="01">JANVIER 2026</option>
                                <option value="02">FÉVRIER 2026</option>
                                <option value="03" selected>MARS 2026</option>
                            </select>
                        </div>
                    </div>

                    <!-- Type Export -->
                    <div>
                        <label class="text-[10px] font-black tracking-[0.2em] text-[#02e1f2] uppercase mb-3 block">Format de Fichier Souhaité</label>
                        <div class="grid grid-cols-2 gap-3">
                            <button @onclick='() => format = "CSV"' class="px-4 py-4 rounded-xl border transition-all @(format == "CSV" ? "bg-[#02e1f2]/10 border-[#02e1f2] text-[#02e1f2]" : "bg-white/5 border-white/10 text-white/50 hover:border-white/30")">
                                <span class="font-black italic uppercase tracking-widest text-lg">CSV</span>
                                <p class="text-[8px] tracking-widest uppercase font-bold mt-1 opacity-70">EXCEL STANDART</p>
                            </button>
                            <button @onclick='() => format = "FEC"' class="px-4 py-4 rounded-xl border transition-all @(format == "FEC" ? "bg-[#02e1f2]/10 border-[#02e1f2] text-[#02e1f2]" : "bg-white/5 border-white/10 text-white/50 hover:border-white/30")">
                                <span class="font-black italic uppercase tracking-widest text-lg">FEC (TXT)</span>
                                <p class="text-[8px] tracking-widest uppercase font-bold mt-1 opacity-70">NORME FISCALE</p>
                            </button>
                        </div>
                    </div>

                    <!-- Software Target -->
                    <div>
                        <label class="text-[10px] font-black tracking-[0.2em] text-[#02e1f2] uppercase mb-3 block">Logiciel Cible (Mapping Tiers)</label>
                        <select class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-4 text-sm font-black uppercase text-white outline-none focus:border-[#02e1f2]/50 transition-colors appearance-none tracking-widest text-center">
                            <option>SAGE COMPTA 100</option>
                            <option>EBP COMPTABILITÉ</option>
                            <option>PENNYLANE API</option>
                            <option>CEGID QUADRATUS</option>
                            <option>GÉNÉRIQUE</option>
                        </select>
                    </div>
                </div>

                <div class="pt-8 mt-6 border-t border-white/5">
                    <button @onclick="LancerExport" disabled="@isExporting" class="w-full bg-[#02e1f2] text-black px-6 py-5 rounded-xl text-sm font-black uppercase tracking-widest hover:bg-cyan-300 transition-all flex items-center justify-center gap-3 shadow-[0_0_25px_rgba(2,225,242,0.3)] disabled:opacity-50">
                        @if (isExporting)
                        {
                            <div class="w-5 h-5 border-2 border-black border-t-transparent rounded-full animate-spin"></div>
                            <span>AGRÉGATION EN COURS...</span>
                        }
                        else if (exportDone)
                        {
                            <span class="material-symbols-outlined text-lg">check_circle</span> <span>NOUVEL EXPORT</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-lg">terminal</span> <span>GÉNÉRER LE TRAITEMENT DE LOT</span>
                        }
                    </button>
                </div>
            </div>

            <!-- Previsualisation / Terminal Log -->
            <div class="bg-black/80 rounded-[40px] border border-white/10 p-8 shadow-2xl flex flex-col relative overflow-hidden h-[600px]">
                
                <div class="flex items-center justify-between mb-4 border-b border-white/5 pb-4">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-white/30 text-sm">terminal</span>
                        <h3 class="font-technical text-sm text-white/50 tracking-[0.2em] font-black uppercase">LOG DE COMPILATION @format</h3>
                    </div>
                </div>

                <div class="flex-grow overflow-y-auto custom-scroll font-technical text-[10px] tracking-widest uppercase leading-loose text-[#00FF66]">
                    @if (logs.Any())
                    {
                        @foreach (var log in logs)
                        {
                            <p class="mb-1"><span class="text-white/30 truncate">[@DateTime.Now.ToString("HH:mm:ss.fff")]</span> @log</p>
                        }
                    }
                    else
                    {
                        <div class="h-full flex items-center justify-center opacity-30">
                            <span class="font-black italic text-lg tracking-widest text-center">SYSTÈME EN ATTENTE DE REQUÊTE...</span>
                        </div>
                    }
                </div>

                @if (exportDone)
                {
                    <div class="absolute bottom-6 left-6 right-6">
                        <button class="w-full bg-[#00FF66]/10 border border-[#00FF66]/50 text-[#00FF66] px-6 py-4 rounded-xl text-xs font-black uppercase tracking-[0.3em] hover:bg-[#00FF66]/20 transition-all flex items-center justify-center gap-2 shadow-[0_0_20px_rgba(0,255,102,0.2)] animate-pulse-border">
                            <span class="material-symbols-outlined text-sm">download</span> TÉLÉCHARGER EXPORT_@format
                        </button>
                    </div>
                }
            </div>

        </div>

    </main>
</div>

<style>
    .custom-scroll::-webkit-scrollbar { width: 4px; }
    .custom-scroll::-webkit-scrollbar-track { background: transparent; }
    .custom-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
    @@keyframes pulse-b { 0%,100% { box-shadow: 0 0 0 0 rgba(0,255,102,0.1); } 50% { box-shadow: 0 0 0 6px rgba(0,255,102,0); } }
    .animate-pulse-border { animation: pulse-b 2s ease-in-out infinite; }
</style>

@code {
    private string selectedMonth = "03";
    private string format = "CSV";
    private bool isExporting = false;
    private bool exportDone = false;
    private List<string> logs = new();

    private async Task LancerExport()
    {
        if (exportDone)
        {
            exportDone = false;
            logs.Clear();
            return;
        }

        isExporting = true;
        exportDone = false;
        logs.Clear();
        
        await AddLog("> INITIALISATION DU MODULE D'EXPORT COMPTABLE v3.1");
        await AddLog($"> CONNEXION A LA BASE DE DONNEES MECAPRO DB... [OK]");
        await AddLog($"> EXTRACTION DES ECRITURES POUR LE MOIS {selectedMonth}... (142 FACTURES TROUVEES)");
        await AddLog("> CARTOGRAPHIE DES COMPTES TIERS... [OK]");
        await AddLog("> CALCUL DE LA TVA COLLECTEE (COMPTE 445710)... (8,421.50 EUR)");
        await AddLog("> CALCUL DU CA HT (COMPTE 706000)... (42,107.50 EUR)");
        await AddLog($"> FORMATAGE AU STANDARD {format}... [OK]");
        await AddLog("> GENERATION DU FICHIER SECURISE EXPORT_COMPTA_03_2026." + format.ToLower());
        await AddLog("> CONTROLE D'INTEGRITE (CHECKSUM MD5)... [OK]");
        await AddLog("> PRET POUR LE TELECHARGEMENT.");

        isExporting = false;
        exportDone = true;
    }

    private async Task AddLog(string log)
    {
        logs.Add(log);
        StateHasChanged();
        await Task.Delay(300); // Simul délai de process
    }
}
