@page "/finance/factures-archive"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Archives Factures</PageTitle>

<div class="bg-background text-on-background font-body min-h-screen pb-24 md:pb-8">
    <!-- TopAppBar -->
    <header class="w-full top-0 sticky z-50 bg-[#111318] flex justify-between items-center px-6 py-4 shadow-[0_4px_20px_rgba(0,0,0,0.5)]">
        <div class="flex items-center gap-3 cursor-pointer" onclick="window.location.href='/'">
            <span class="material-symbols-outlined text-[#f5a623]" data-icon="settings_input_component">settings_input_component</span>
            <h1 class="font-headline text-[#f5a623] tracking-[0.05em] uppercase text-2xl">MecaPro</h1>
        </div>
        <div class="flex items-center gap-4">
            <button class="p-2 text-[#e2e2e8] hover:bg-[#282a2e] transition-colors rounded-lg">
                <span class="material-symbols-outlined" data-icon="notifications">notifications</span>
            </button>
            <div class="hidden md:flex gap-6">
                 <a class="text-[#e2e2e8]/60 font-headline tracking-wider hover:text-[#f5a623] transition-colors" href="/finance">FINANCE</a>
                 <a class="text-[#f5a623] font-headline tracking-wider" href="/finance/factures-archive">ARCHIVES</a>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 pt-8 space-y-8">
        <!-- Header Section -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-1 flex flex-col justify-center">
                <h2 class="font-headline text-4xl tracking-wider text-on-surface uppercase mb-1">Archives Factures</h2>
                <p class="text-on-surface-variant text-sm">Consultation et gestion des documents financiers archivés.</p>
            </div>
            <div class="bg-surface-container-high rounded-xl p-5 border-l-2 border-primary-container relative overflow-hidden">
                <div class="flex justify-between items-start mb-2">
                    <span class="text-xs font-mono text-on-surface-variant uppercase tracking-widest">Total Annuel 2024</span>
                    <span class="material-symbols-outlined text-primary text-sm" data-icon="trending_up">trending_up</span>
                </div>
                <div class="font-headline text-3xl text-primary tracking-tight">142,580.00 €</div>
                <div class="text-[10px] text-on-surface-variant font-mono mt-1 uppercase">482 FACTURES GÉNÉRÉES</div>
            </div>
            <div class="bg-surface-container-low rounded-xl p-5 border-l-2 border-outline-variant">
                <div class="flex justify-between items-start mb-2">
                    <span class="text-xs font-mono text-on-surface-variant uppercase tracking-widest">Total Annuel 2023</span>
                </div>
                <div class="font-headline text-3xl text-on-surface tracking-tight">128,450.00 €</div>
                <div class="text-[10px] text-on-surface-variant font-mono mt-1 uppercase">456 FACTURES ARCHIVÉES</div>
            </div>
        </section>

        <!-- Advanced Search Bar -->
        <section class="bg-surface-container rounded-xl p-1 shadow-sm border border-outline-variant/10">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-1">
                <div class="relative group">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg" data-icon="search">search</span>
                    <input class="w-full bg-surface-container-highest border-none rounded-lg pl-12 py-4 text-sm focus:ring-1 focus:ring-primary text-on-surface placeholder:text-outline" placeholder="Client ou N° Facture" type="text"/>
                </div>
                <div class="relative group">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg" data-icon="calendar_today">calendar_today</span>
                    <input class="w-full bg-surface-container-highest border-none rounded-lg pl-12 py-4 text-sm focus:ring-1 focus:ring-primary text-on-surface placeholder:text-outline" placeholder="Période (MM/AAAA)" type="text"/>
                </div>
                <div class="relative group">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg" data-icon="directions_car">directions_car</span>
                    <input class="w-full bg-surface-container-highest border-none rounded-lg pl-12 py-4 text-sm font-mono focus:ring-1 focus:ring-primary text-on-surface placeholder:text-outline" placeholder="Immatriculation" type="text"/>
                </div>
                <button class="bg-primary-container text-on-primary-container font-bold rounded-lg py-4 flex items-center justify-center gap-2 hover:opacity-90 active:scale-95 transition-all uppercase font-headline tracking-widest text-lg">
                    <span class="material-symbols-outlined" data-icon="filter_list">filter_list</span>
                    FILTRER LES ARCHIVES
                </button>
            </div>
        </section>

        <!-- Invoices List -->
        <section class="space-y-4">
            <div class="flex items-center justify-between px-2">
                <h3 class="text-xs font-mono text-outline uppercase tracking-[0.2em]">RÉSULTATS : MARS 2024</h3>
                <span class="text-[10px] text-outline uppercase">TRI : CHRONOLOGIQUE DÉCROISSANT</span>
            </div>
            <div class="space-y-2">
                <!-- Invoice Row Example -->
                <div class="group bg-surface-container-low hover:bg-surface-container-high transition-all rounded-lg p-4 flex flex-wrap md:flex-nowrap items-center gap-4 border border-outline-variant/10">
                    <div class="w-12 h-12 rounded bg-surface-container-highest flex items-center justify-center text-primary-container">
                        <span class="material-symbols-outlined" data-icon="description">description</span>
                    </div>
                    <div class="flex-1 min-w-[200px]">
                        <div class="flex items-center gap-2">
                            <span class="font-mono text-sm font-bold text-on-surface">FAC-2024-03-882</span>
                            <span class="px-2 py-0.5 rounded bg-primary/10 text-primary text-[10px] font-bold">RÉGLÉE</span>
                        </div>
                        <div class="text-on-surface-variant text-sm mt-0.5">Sébastien Lefebvre • Renault Megane IV</div>
                    </div>
                    <div class="hidden md:block font-mono text-on-surface-variant text-sm px-4">12/03/2024</div>
                    <div class="font-mono font-bold text-on-surface text-right px-4">842.50 €</div>
                    <div class="flex items-center gap-2 ml-auto">
                        <button class="p-2 text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined" data-icon="visibility">visibility</span>
                        </button>
                        <button class="p-2 bg-surface-container-highest text-on-surface rounded-lg hover:bg-primary-container hover:text-on-primary-container transition-all">
                            <span class="material-symbols-outlined" data-icon="download">download</span>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- BottomNavBar -->
    <nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-6 pt-3 bg-[#111318]/80 backdrop-blur-xl z-50 rounded-t-xl border-t border-[#524534]/15 shadow-[0_-4px_24px_rgba(245,166,35,0.05)] md:hidden">
        <a class="flex flex-col items-center justify-center text-[#949494] hover:text-[#ffc880]" href="/">
            <span class="material-symbols-outlined" data-icon="home">home</span>
            <span class="font-technical text-[10px] font-medium uppercase mt-1">Home</span>
        </a>
        <a class="flex flex-col items-center justify-center text-[#f5a623] bg-[#f5a623]/10 rounded-xl px-3 py-1" href="/finance/factures-archive">
            <span class="material-symbols-outlined" data-icon="description">description</span>
            <span class="font-technical text-[10px] font-medium uppercase mt-1">Archive</span>
        </a>
    </nav>
</div>
