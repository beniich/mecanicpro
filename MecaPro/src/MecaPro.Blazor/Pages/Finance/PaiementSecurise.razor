@page "/paiement-securise"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Terminal de Paiement Sécurisé</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 flex flex-col justify-center relative overflow-hidden">
    
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0 flex items-center justify-center opacity-30 pointer-events-none">
        <div class="w-[800px] h-[800px] bg-gradient-radial from-[#02e1f2]/10 to-transparent rounded-full blur-3xl"></div>
    </div>

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/billing")'>
            <span class="material-symbols-outlined text-[#02e1f2]">chevron_left</span>
            <span class="material-symbols-outlined text-white/50">precision_manufacturing</span>
            <h1 class="text-sm font-black tracking-[0.2em] text-white/50 uppercase">RETOURNER AUX FACTURES</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-[#02e1f2]/10 border border-[#02e1f2]/30 px-4 py-1.5 rounded-xl text-[10px] font-black uppercase text-[#02e1f2] tracking-widest flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">lock</span> CONNEXION SÉCURISÉE PCI-DSS
            </span>
        </div>
    </header>

    <main class="z-10 px-6 max-w-5xl mx-auto w-full pt-16 mt-8">

        @if (paymentComplete)
        {
            <!-- Success Screen -->
            <div class="bg-surface-container rounded-[40px] border border-green-400/30 p-16 flex flex-col items-center justify-center text-center shadow-[0_0_50px_rgba(74,222,128,0.1)]">
                <div class="w-32 h-32 bg-green-400/10 rounded-full flex items-center justify-center mb-8 relative">
                    <div class="absolute inset-0 border-[4px] border-green-400 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite] opacity-50"></div>
                    <span class="material-symbols-outlined text-[64px] text-green-400 animate-[bounce_1s_ease-in-out_infinite]">check_circle</span>
                </div>
                
                <h2 class="text-6xl font-black italic tracking-tighter uppercase mb-4 text-white">PAIEMENT CONFIRMÉ</h2>
                <p class="text-[10px] font-black tracking-[0.4em] text-green-400 uppercase mb-8">TX_REF: #STRIPE-CHG-92934A</p>
                
                <div class="bg-black/30 w-full max-w-md p-6 rounded-3xl border border-white/5 mb-8">
                    <div class="flex justify-between items-center pb-4 border-b border-white/5 mb-4 font-technical italic font-black">
                        <span class="text-white/50">MONTANT PAYÉ</span>
                        <span class="text-green-400 text-3xl">49.00 €</span>
                    </div>
                    <div class="flex justify-between items-center pb-2">
                        <span class="text-[10px] font-black uppercase tracking-widest text-white/50">CARTE</span>
                        <span class="text-sm font-black uppercase tracking-widest text-white flex items-center justify-center gap-2"><span class="w-8 h-5 flex items-center justify-center bg-white/10 rounded border border-white/20 text-[6px]">VISA</span> **** 8842</span>
                    </div>
                </div>

                <div class="flex gap-4">
                    <button class="bg-white/5 border border-white/10 px-6 py-3.5 text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all rounded-xl" @onclick='() => Nav.NavigateTo("/billing")'>
                        RETOUR FACTURES
                    </button>
                    <button class="bg-green-400 text-black px-6 py-3.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-green-300 transition-all flex items-center justify-center gap-2 shadow-[0_0_20px_rgba(74,222,128,0.2)]">
                        <span class="material-symbols-outlined text-sm">receipt</span> TÉLÉCHARGER REÇU
                    </button>
                </div>
            </div>
        }
        else
        {
            <!-- Payment Form -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                
                <!-- Left: Invoice Details -->
                <div class="flex flex-col justify-center">
                    <span class="text-[#02e1f2] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">SECURE_CHECKOUT</span>
                    <h2 class="text-5xl md:text-6xl font-black tracking-tighter italic uppercase leading-none mb-10 text-white">Règlement<br/>Facture</h2>
                    
                    <div class="space-y-6 bg-surface-container border border-white/5 rounded-[32px] p-8 shadow-xl">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="font-black text-xs uppercase tracking-widest text-white/50">Destinataire</p>
                                <p class="font-black italic text-2xl text-white uppercase mt-1">GARAGE MECAPRO</p>
                            </div>
                            <span class="material-symbols-outlined text-4xl text-white/10">store</span>
                        </div>
                        <div class="border-t border-white/5 pt-6 flex justify-between items-end">
                            <div>
                                <p class="font-black text-xs uppercase tracking-widest text-white/50">Facture N°</p>
                                <p class="font-technical italic font-black text-xl text-[#02e1f2] mt-1">#INV-2024-0012</p>
                                <p class="text-[10px] font-black tracking-widest text-white/30 uppercase mt-2 border border-white/10 rounded px-2 py-0.5 inline-block">ABONNEMENT PRO</p>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-xs uppercase tracking-widest text-white/50">Total à Payer</p>
                                <p class="font-technical italic font-black text-5xl text-white mt-1 leading-none tracking-tighter">49<span class="text-2xl text-white/50">.00€</span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Stripe Interface Mock -->
                <div class="bg-surface-container rounded-[40px] border border-white/5 p-8 relative shadow-2xl overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-[#02e1f2]/5 rounded-bl-[100px] pointer-events-none"></div>

                    <h3 class="font-black text-xl italic uppercase tracking-tight text-white mb-6">Informations Bancaires</h3>
                    
                    <form @onsubmit="SimulatePayment" class="space-y-6 relative z-10" @onsubmit:preventDefault="true">
                        <!-- Cardholder -->
                        <div>
                            <label class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase mb-2 block">Nom du Titulaire</label>
                            <input type="text" value="JEAN DUPONT" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm font-black uppercase text-white outline-none focus:border-[#02e1f2]/50 transition-colors" />
                        </div>
                        
                        <!-- Card Number -->
                        <div>
                            <label class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase mb-2 block">Numéro de carte</label>
                            <div class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 flex items-center gap-3 focus-within:border-[#02e1f2]/50 transition-colors">
                                <span class="material-symbols-outlined text-white/30 text-lg">credit_card</span>
                                <input type="text" value="**** **** **** 8842" class="w-full bg-transparent border-none text-sm font-technical font-black uppercase text-white outline-none" />
                                <div class="flex gap-1 shrink-0">
                                    <div class="w-8 h-5 bg-[#1A1F71] rounded flex items-center justify-center text-[5px] font-bold text-white italic">VISA</div>
                                    <div class="w-8 h-5 bg-[#FF5F00] flex items-center justify-center text-[5px] font-bold text-white italic relative overflow-hidden rounded">MC</div>
                                </div>
                            </div>
                        </div>

                        <!-- CVC / EXP -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase mb-2 block">Date d'expiration</label>
                                <input type="text" value="09 / 26" class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-sm font-technical font-black text-white text-center outline-none focus:border-[#02e1f2]/50 transition-colors" />
                            </div>
                            <div>
                                <label class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase mb-2 block">CVC</label>
                                <div class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 flex items-center justify-between focus-within:border-[#02e1f2]/50 transition-colors">
                                    <input type="password" value="123" class="w-full bg-transparent border-none text-sm font-technical font-black text-white text-center outline-none tracking-widest" maxlength="3" />
                                    <span class="material-symbols-outlined text-white/30 text-sm">help</span>
                                </div>
                            </div>
                        </div>

                        <!-- 3D Secure Hint -->
                        <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl p-4 flex gap-3 items-start my-6">
                            <span class="material-symbols-outlined text-blue-400 mt-0.5 text-lg">verified_user</span>
                            <div class="pt-0.5">
                                <p class="text-[10px] uppercase font-black tracking-widest text-blue-400 leading-none">3D SECURE ACTIF</p>
                                <p class="text-[10px] text-white/50 font-medium mt-1">Validation requise par votre banque.</p>
                            </div>
                        </div>

                        <button type="submit" disabled="@isProcessing" class="w-full mt-8 bg-[#02e1f2] text-black px-6 py-4 rounded-xl text-sm font-black uppercase tracking-widest hover:bg-cyan-300 transition-all flex items-center justify-center gap-3 shadow-[0_0_25px_rgba(2,225,242,0.3)] disabled:opacity-50">
                            @if (isProcessing)
                            {
                                <div class="w-5 h-5 border-2 border-black border-t-transparent rounded-full animate-spin"></div>
                                <span>CONTACT BANQUE...</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-lg">lock</span> <span>PAYER 49.00 €</span>
                            }
                        </button>
                    </form>
                    
                    <div class="flex justify-center items-center gap-2 mt-8 opacity-30 pointer-events-none">
                        <span class="material-symbols-outlined text-sm">lock</span>
                        <p class="text-[8px] font-black uppercase tracking-[0.2em]">POWERED_BY_STRIPE</p>
                    </div>
                </div>
            </div>
        }
    </main>
</div>

@code {
    private bool isProcessing = false;
    private bool paymentComplete = false;

    private async Task SimulatePayment()
    {
        isProcessing = true;
        await Task.Delay(2500); 
        isProcessing = false;
        paymentComplete = true;
    }
}
