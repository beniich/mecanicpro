@page "/finance/comparatif-devis-1"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Comparatif Devis Trio</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#f96b0c]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#f96b0c] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-white/5 border border-white/10 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase text-white/40 tracking-widest">
               ID_COMPARATIVE_042-XP
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#f96b0c] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">QUOTE_OPTIMIZATION_MATRIX</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Comparatif Devis</h2>
                <div class="flex gap-4 mt-6">
                    <span class="px-4 py-1.5 bg-white/5 border border-white/5 rounded-full text-[10px] uppercase font-black tracking-widest text-[#f96b0c] flex items-center gap-2">INTERVENTION: KIT EMBRAYAGE RS4</span>
                    <span class="px-4 py-1.5 bg-white/5 border border-white/10 rounded-full text-[10px] uppercase font-black tracking-widest text-white/40">3 OPTIONS DÉTECTÉES</span>
                </div>
            </div>
            
            <button class="bg-white/5 border border-white/10 px-8 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">mail</span> ENVOYER AU CLIENT
            </button>
        </div>

        <!-- Comparison Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @foreach (var quote in options)
            {
                <div class="bg-surface-container rounded-[40px] border @(quote.IsRecommended ? "border-[#00FF66] shadow-[0_0_50px_rgba(0,255,102,0.15)] ring-4 ring-[#00FF66]/5" : "border-white/5") p-10 flex flex-col relative overflow-hidden group hover:scale-[1.02] transition-all duration-500">
                    
                    @if (quote.IsRecommended)
                    {
                        <div class="absolute top-0 right-0 bg-[#00FF66] text-black font-black text-[8px] uppercase px-4 py-2 rounded-bl-3xl tracking-widest shadow-lg">MEILLEUR RAPPORT</div>
                    }

                    <div class="mb-10 flex flex-col items-center text-center">
                        <span class="material-symbols-outlined text-5xl mb-4 @(quote.Color)">@quote.Icon</span>
                        <h3 class="font-black italic text-3xl uppercase tracking-tighter text-white mb-2">@quote.Title</h3>
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-white/30">@quote.PartSource</p>
                    </div>

                    <div class="flex-grow space-y-6 mb-10">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5 flex flex-col items-center">
                                <p class="text-[7px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">PIÈCES HT</p>
                                <p class="text-xl font-black italic text-white font-technical">@quote.PartsPrice€</p>
                            </div>
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5 flex flex-col items-center">
                                <p class="text-[7px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">MAIN D'ŒUVRE</p>
                                <p class="text-xl font-black italic text-white font-technical">@quote.LaborPrice€</p>
                            </div>
                        </div>

                        <ul class="space-y-3">
                            @foreach (var feature in quote.Features)
                            {
                                <li class="flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-white/60">
                                    <span class="material-symbols-outlined text-[#00FF66] text-sm">check_circle</span> @feature
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="mt-auto border-t border-white/10 pt-8 flex flex-col items-center">
                        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 mb-2">TOTAL_TTC_ESTIMÉ</p>
                        <div class="flex items-baseline gap-1 mb-10">
                            <span class="text-6xl font-black italic text-white font-technical leading-none tracking-tighter">@quote.Total.ToString("0.00")</span>
                            <span class="text-2xl font-black text-white/50 italic font-technical">€</span>
                        </div>
                        <button class="w-full @(quote.IsRecommended ? "bg-[#00FF66] text-black" : "bg-white/5 text-white/40 border border-white/10 hover:text-white hover:bg-white/10") py-5 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all">SÉLECTIONNER OPTION</button>
                    </div>
                </div>
            }
        </div>

        <!-- Economy Summary -->
        <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex flex-col md:flex-row items-center justify-between gap-8 h-40">
             <div class="flex items-center gap-8">
                 <div class="w-20 h-20 rounded-3xl bg-[#00FF66]/10 flex items-center justify-center">
                     <span class="material-symbols-outlined text-[#00FF66] text-4xl">savings</span>
                 </div>
                 <div>
                     <p class="text-[10px] font-black uppercase tracking-widest text-white/30">ÉCONOMIE MAX PROJETÉE</p>
                     <p class="text-5xl font-black italic text-white">452,10 <span class="text-2xl text-white/30">€</span></p>
                 </div>
             </div>
             <p class="text-[10px] font-black uppercase italic text-right max-w-sm leading-loose tracking-widest opacity-40">L'IA de MecaPro compare automatiquement les catalogues fournisseurs (OEM vs Aftermarket) pour maximiser votre marge tout en réduisant le reste à charge client.</p>
        </div>

    </main>
</div>

@code {
    private List<QuoteOption> options = new()
    {
        new("SÉCURITÉ MAX", "PIÈCES CONSTRUCTEUR (OEM)", 1240, 420, "text-sky-400", "verified", new[] { "Pièces origine Audi", "Garantie 2 ans", "Fiabilité certifiée" }, false),
        new("PERFORMANCE B2B", "VALEO / LUK (PREMIUM)", 890, 420, "text-[#00FF66]", "shutter_speed", new[] { "Équivalence OEM", "Garantie 1 an", "Best Seller" }, true),
        new("ÉCONOMIE", "AFTERMARKET / RECONDITIONNÉ", 650, 420, "text-yellow-400", "recycling", new[] { "Pièces standard", "Garantie 6 mois", "Budget optimisé" }, false)
    };

    record QuoteOption(string Title, string PartSource, double PartsPrice, double LaborPrice, string Color, string Icon, string[] Features, bool IsRecommended)
    {
        public double Total => PartsPrice + LaborPrice;
    }
}
