@page "/finance/factures-abonnements"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Factures Abonnements</PageTitle>

<div class="bg-[#111318] text-[#e2e2e8] font-body selection:bg-primary/30 min-h-screen pb-24">
    <!-- TopAppBar -->
    <header class="bg-[#111318] border-b border-[#524534]/15 flex justify-between items-center px-6 py-4 w-full sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[#f5a623]">precision_manufacturing</span>
            <h1 class="text-2xl font-black tracking-[0.2em] text-[#f5a623] font-headline uppercase">MECAPRO</h1>
        </div>
        <div class="hidden md:flex items-center gap-8 text-xs font-medium uppercase tracking-wider">
            <a class="text-[#e2e2e8]/60 hover:text-[#f5a623]/80 transition-colors" href="#">Planning</a>
            <a class="text-[#f5a623]" href="#">Factures</a>
            <button class="bg-[#282a2e] p-2 rounded-full hover:bg-[#333539] transition-colors">
                <span class="material-symbols-outlined text-primary">notifications</span>
            </button>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pt-8 space-y-12">
        <!-- Subscription Header -->
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-8 bg-[#1a1c20] p-8 rounded-xl relative overflow-hidden group">
                <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-primary to-secondary-container"></div>
                <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                    <div>
                        <span class="text-on-surface-variant text-xs font-bold uppercase tracking-widest block mb-2">Abonnement Actuel</span>
                        <h2 class="font-headline text-6xl text-primary tracking-wider uppercase">PLAN PRO</h2>
                        <div class="mt-4 flex items-center gap-4">
                            <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold border border-primary/20">ACTIF</span>
                            <span class="text-on-surface/60 text-sm font-technical">ID: MP-992-SUBS</span>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-on-surface-variant text-xs uppercase tracking-widest">Prochaine facturation</p>
                        <p class="font-headline text-4xl text-on-surface uppercase">12 AVR 2024</p>
                        <p class="text-secondary text-sm font-bold mt-1">49.00€ / mois</p>
                    </div>
                </div>
            </div>
            <div class="lg:col-span-4 bg-[#282a2e] p-6 rounded-xl border border-outline-variant/10 flex flex-col justify-between">
                <div>
                    <h3 class="font-headline text-2xl tracking-wide uppercase">Passer à l'offre Enterprise</h3>
                    <p class="text-on-surface-variant text-sm mt-2 leading-relaxed">Multi-garages, API personnalisée et rapports avancés.</p>
                </div>
                <button class="mt-6 w-full bg-primary text-on-primary font-bold py-3 rounded-lg hover:scale-[0.98] transition-transform">
                    DÉCOUVRIR L'OFFRE
                </button>
            </div>
        </section>

        <!-- Billing History -->
        <section class="space-y-6">
            <h3 class="font-headline text-3xl tracking-wider flex items-center gap-3 uppercase">
                <span class="material-symbols-outlined text-primary">receipt_long</span>
                Historique des Factures
            </h3>
            <div class="bg-[#0c0e12] rounded-xl overflow-hidden border border-outline-variant/10">
                <table class="w-full text-left">
                    <thead class="bg-[#282a2e]/50 text-on-surface-variant font-bold text-[10px] uppercase tracking-widest">
                        <tr>
                            <th class="px-6 py-4">ID Facture</th>
                            <th class="px-6 py-4">Date</th>
                            <th class="px-6 py-4">Désignation</th>
                            <th class="px-6 py-4 text-right">Montant</th>
                            <th class="px-6 py-4">Statut</th>
                            <th class="px-6 py-4 text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/5">
                        <tr class="hover:bg-[#1a1c20] transition-colors">
                            <td class="px-6 py-5 font-technical text-sm font-medium">#INV-2024-003</td>
                            <td class="px-6 py-5 text-sm">12 Mars 2024</td>
                            <td class="px-6 py-5 text-sm">Abonnement MecaPro - Plan Pro (Mensuel)</td>
                            <td class="px-6 py-5 text-sm font-bold text-right font-technical">49.00 €</td>
                            <td class="px-6 py-5"><span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-[10px] font-bold border border-primary/20">PAYÉ</span></td>
                            <td class="px-6 py-5 text-center">
                                <button class="p-2 hover:bg-[#333539] rounded-lg transition-colors text-on-surface-variant">
                                    <span class="material-symbols-outlined text-xl">download</span>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>
