@page "/analytique-stats"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Analytique & Performances</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Hexagon Overlay Decor -->
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2249%22 viewBox=%220 0 28 49%22%3E%3Cg fill-rule=%22evenodd%22%3E%3Cg id=%22hexagons%22 fill=%22%2302e1f2%22 fill-opacity=%220.4%22 fill-rule=%22nonzero%22%3E%3Cpath d=%22M13.99 9.25l13 7.5v15l-13 7.5L1 31.75v-15l12.99-7.5zM3 17.9v12.7l10.99 6.34 11-6.35V17.9l-11-6.34L3 17.9zM0 15l12.98-7.5V0h-2v6.35L0 12.69v2.3zm0 18.5L12.98 41v8h-2v-6.85L0 35.81v-2.3zM15 0v7.5L27.99 15H28v-2.31h-.01L17 6.35V0h-2zm0 49v-8l12.99-7.5H28v2.31h-.01L17 42.15V49h-2z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#02e1f2]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#02e1f2] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-black/40 border border-[#02e1f2]/30 rounded-xl px-4 py-2 flex items-center gap-3">
               <span class="material-symbols-outlined text-[10px] text-[#02e1f2] animate-pulse">monitoring</span>
               <span class="text-[10px] font-black uppercase tracking-widest text-white/50">LIVE_METRICS_SYNC_ACTIVE</span>
            </div>
            <button class="bg-[#02e1f2] text-black px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-cyan-300 transition-all flex items-center gap-2 shadow-[0_4px_15px_rgba(2,225,242,0.2)]">
                <span class="material-symbols-outlined text-sm">download</span> EXPORT PDF
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#02e1f2] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">CENTRAL_DATA_INTELLIGENCE</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Analytique Stats</h2>
                <div class="flex gap-4 mt-6">
                    <button class="bg-[#02e1f2] text-black px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest">MOIS COURANT</button>
                    <button class="bg-white/5 border border-white/10 text-white/40 px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:text-white hover:bg-white/10 transition-all">ANNÉE 2026</button>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-surface-container-low p-5 border border-white/5 rounded-3xl min-w-[200px]">
                    <p class="text-[8px] font-black uppercase tracking-widest text-[#00FF66] mb-1 flex items-center gap-1">⬤ CA MARS <span class="material-symbols-outlined text-[10px]">trending_up</span></p>
                    <p class="text-3xl font-black italic text-white font-technical">42,107<span class="text-lg opacity-50">€</span></p>
                    <p class="text-[8px] font-bold text-[#00FF66] uppercase tracking-widest mt-1">+12.4% VS FÉV</p>
                </div>
                <div class="bg-surface-container-low p-5 border border-white/5 rounded-3xl min-w-[200px]">
                    <p class="text-[8px] font-black uppercase tracking-widest text-primary mb-1 flex items-center gap-1">⬤ TICKET MOYEN <span class="material-symbols-outlined text-[10px]">speed</span></p>
                    <p class="text-3xl font-black italic text-white font-technical">294<span class="text-lg opacity-50">€</span></p>
                    <p class="text-[8px] font-bold text-white/30 uppercase tracking-widest mt-1">OBJECTIF: 320€</p>
                </div>
            </div>
        </div>

        <!-- Big Chart Placeholder Area (Mocked with Custom SVG/Tailwind) -->
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Revenue Evolution -->
            <div class="lg:col-span-8 bg-surface-container rounded-[40px] border border-white/5 p-10 shadow-2xl relative overflow-hidden h-[500px] flex flex-col">
                <div class="flex justify-between items-center mb-8 relative z-10">
                    <h3 class="font-black text-2xl italic uppercase tracking-tight text-white">Évolution du Chiffre d'Affaires</h3>
                    <div class="flex gap-3">
                        <div class="flex items-center gap-2 px-3 py-1 bg-white/5 rounded-lg border border-white/10"><span class="w-1.5 h-1.5 rounded-full bg-[#02e1f2]"></span> <span class="text-[9px] font-bold uppercase tracking-widest text-white/40">CA RÉEL</span></div>
                        <div class="flex items-center gap-2 px-3 py-1 bg-white/5 rounded-lg border border-white/10"><span class="w-1.5 h-1.5 rounded-full bg-white/20"></span> <span class="text-[9px] font-bold uppercase tracking-widest text-white/40">MARGE (32%)</span></div>
                    </div>
                </div>

                <div class="flex-grow flex items-end justify-between gap-4 py-8 relative">
                    <!-- Y-Axis Labels -->
                    <div class="absolute left-0 bottom-0 top-0 w-px bg-white/5 flex flex-col justify-between text-[8px] font-black text-white/10 pr-2">
                        <span>40K</span><span>30K</span><span>20K</span><span>10K</span><span>0</span>
                    </div>
                    
                    <!-- Bars -->
                    @foreach(var data in revenueData)
                    {
                        <div class="flex-grow flex flex-col items-center justify-end group cursor-pointer relative pt-8">
                            <!-- Tooltip on hover -->
                            <div class="absolute bottom-full mb-4 px-3 py-2 bg-white text-black rounded-lg text-[10px] font-black uppercase opacity-0 group-hover:opacity-100 transition-all z-20 whitespace-nowrap">@data.Value€</div>
                            
                            <div class="w-full max-w-[40px] bg-gradient-to-t from-[#02e1f2]/20 to-[#02e1f2] rounded-t-lg transition-all @(data.IsCurrent ? "shadow-[0_0_30px_rgba(2,225,242,0.4)]" : "opacity-40 hover:opacity-100")" 
                                 style="height: @(data.Value / 45000.0 * 100)%;"></div>
                            <p class="mt-4 text-[9px] font-black uppercase tracking-widest @(data.IsCurrent ? "text-[#02e1f2]" : "text-white/20")">@data.Label</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Distribution Chart (Pie Mock) -->
            <div class="lg:col-span-4 bg-surface-container rounded-[40px] border border-white/5 p-10 shadow-2xl flex flex-col items-center justify-center relative">
                <h3 class="font-black text-xl italic uppercase tracking-tight text-white mb-10 w-full">Répartition Prestations</h3>
                
                <div class="relative w-64 h-64 flex items-center justify-center">
                    <!-- Donut SVG -->
                    <svg class="w-full h-full transform -rotate-90">
                        <circle cx="128" cy="128" r="100" stroke="rgba(255,255,255,0.05)" stroke-width="24" fill="transparent" />
                        <circle cx="128" cy="128" r="100" stroke="#02e1f2" stroke-width="24" fill="transparent" stroke-dasharray="628" stroke-dashoffset="150" />
                        <circle cx="128" cy="128" r="100" stroke="#f96b0c" stroke-width="24" fill="transparent" stroke-dasharray="628" stroke-dashoffset="450" />
                        <circle cx="128" cy="128" r="100" stroke="#FF00FF" stroke-width="24" fill="transparent" stroke-dasharray="628" stroke-dashoffset="550" />
                    </svg>
                    <div class="absolute flex flex-col items-center">
                        <p class="text-4xl font-black italic text-white leading-none">842</p>
                        <p class="text-[9px] font-black uppercase tracking-widest text-white/30 mt-1">INTERVENTIONS</p>
                    </div>
                </div>

                <div class="w-full mt-10 space-y-4">
                    <div class="flex justify-between items-center text-[10px] font-black uppercase">
                        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-[#02e1f2]"></span> <span>MÉCANIQUE LOURDE</span></div>
                        <span class="text-white">42%</span>
                    </div>
                    <div class="flex justify-between items-center text-[10px] font-black uppercase">
                        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-[#f96b0c]"></span> <span>ENTRETIEN RAPIDE</span></div>
                        <span class="text-white">35%</span>
                    </div>
                    <div class="flex justify-between items-center text-[10px] font-black uppercase">
                        <div class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-[#FF00FF]"></span> <span>DIAGNOSTIC & ÉLEC</span></div>
                        <span class="text-white">23%</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- KPI 2nd Row -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex items-center justify-between shadow-xl">
                <div>
                   <p class="text-[8px] font-black uppercase tracking-[0.4em] text-white/30 mb-2">TAU_DE_RETOUR</p>
                   <p class="text-4xl font-black italic text-white font-technical">2.4%</p>
                </div>
                <div class="w-16 h-16 rounded-2xl bg-[#00FF66]/10 border border-[#00FF66]/30 flex items-center justify-center text-[#00FF66]">
                    <span class="material-symbols-outlined text-4xl">keyboard_return</span>
                </div>
            </div>
            <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex items-center justify-between shadow-xl">
                <div>
                   <p class="text-[8px] font-black uppercase tracking-[0.4em] text-white/30 mb-2">EFFICIENCE_MO</p>
                   <p class="text-4xl font-black italic text-[#02e1f2] font-technical">104%</p>
                </div>
                <div class="w-16 h-16 rounded-2xl bg-[#02e1f2]/10 border border-[#02e1f2]/30 flex items-center justify-center text-[#02e1f2]">
                    <span class="material-symbols-outlined text-4xl">bolt</span>
                </div>
            </div>
            <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex items-center justify-between shadow-xl">
                <div>
                   <p class="text-[8px] font-black uppercase tracking-[0.4em] text-white/30 mb-2">SATISFACTION_NPS</p>
                   <p class="text-4xl font-black italic text-[#FF00FF] font-technical">9.2</p>
                </div>
                <div class="w-16 h-16 rounded-2xl bg-[#FF00FF]/10 border border-[#FF00FF]/30 flex items-center justify-center text-[#FF00FF]">
                    <span class="material-symbols-outlined text-4xl">stars</span>
                </div>
            </div>
        </section>

    </main>
</div>

@code {
    private List<ChartData> revenueData = new()
    {
        new("OCT", 18500),
        new("NOV", 24200),
        new("DEC", 38900),
        new("JAN", 31400),
        new("FEV", 37500),
        new("MAR", 42107, true)
    };

    record ChartData(string Label, int Value, bool IsCurrent = false);
}
