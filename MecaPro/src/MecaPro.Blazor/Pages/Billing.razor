@page "/billing"
@attribute [Authorize]
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-6">Gestion de l'Abonnement</MudText>

<MudGrid>
    <!-- Plans Accessibles -->
    <MudItem xs="12">
        <MudText Typo="Typo.h6" Class="mb-4">Choisissez votre formule</MudText>
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudCard Elevation="@(currentPlan == "Starter" ? 4 : 1)" Class="@(currentPlan == "Starter" ? "border-primary" : "")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Starter</MudText>
                            <MudText Typo="Typo.caption">Pour les auto-entrepreneurs</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (currentPlan == "Starter") { <MudChip Color="Color.Primary" Size="Size.Small">Actuel</MudChip> }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.h3" Align="Align.Center" Class="my-4">29€<span style="font-size: 1rem">/mois</span></MudText>
                        <MudList Dense="true">
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Jusqu'à 100 véhicules</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Diagnostics OBD Illimités</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Facturation PDF</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Close" IconColor="Color.Error">SignalR Chat Client</MudListItem>
                        </MudList>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Disabled="@(currentPlan == "Starter")">Sélectionner</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudCard Elevation="@(currentPlan == "Pro" ? 4 : 1)" Class="@(currentPlan == "Pro" ? "border-warning" : "")" Style="position:relative">
                    <div style="position:absolute; top:-10px; right:10px; background:#EAB308; color:white; padding:2px 10px; border-radius:10px; font-size:0.8rem">RECOMMANDÉ</div>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Professionnel</MudText>
                            <MudText Typo="Typo.caption">Pour les garages établis</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @if (currentPlan == "Pro") { <MudChip Color="Color.Warning" Size="Size.Small">Actuel</MudChip> }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.h3" Align="Align.Center" Class="my-4" Color="Color.Warning">79€<span style="font-size: 1rem">/mois</span></MudText>
                        <MudList Dense="true">
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Véhicules illimités</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Chat SignalR Client/Gérant</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Gestion Stocks avancée</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Relances automatiques</MudListItem>
                        </MudList>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" 
                                   OnClick="@(() => Subscribe("price_pro_123"))" Disabled="@(currentPlan == "Pro")">
                            Passer à Pro
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Business</MudText>
                            <MudText Typo="Typo.caption">Multi-garages & franchises</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.h3" Align="Align.Center" Class="my-4">199€<span style="font-size: 1rem">/mois</span></MudText>
                        <MudList Dense="true">
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Accès Multi-Garage</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">API Publique & Webhooks</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Marque Blanche</MudListItem>
                            <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">Support 24/7 Dédié</MudListItem>
                        </MudList>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true">Contacter Sales</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudItem>

    <!-- Historique des Factures -->
    <MudItem xs="12" Class="mt-8">
        <MudText Typo="Typo.h6" Class="mb-4">Mes Factures</MudText>
        <MudTable Items="@invoices" Elevation="1">
            <HeaderContent>
                <MudTh>N° Facture</MudTh>
                <MudTh>Date</MudTh>
                <MudTh>Montant</MudTh>
                <MudTh>Statut</MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Number</MudTd>
                <MudTd>@context.Date.ToShortDateString()</MudTd>
                <MudTd>@context.Total.ToString("C")</MudTd>
                <MudTd><MudChip Size="Size.Small" Color="Color.Success">Payée</MudChip></MudTd>
                <MudTd><MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Info" OnClick="@(() => DownloadInvoice(context))" /></MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

<style>
    .border-primary { border: 2px solid #1E3A8A; }
    .border-warning { border: 2px solid #EAB308; }
</style>

@code {
    private string currentPlan = "Starter";
    private List<InvoiceVm> invoices = new();

    protected override void OnInitialized()
    {
        invoices = new List<InvoiceVm>
        {
            new("INV-2024-0012", DateTime.Now.AddMonths(-1), 29.00m),
            new("INV-2024-0008", DateTime.Now.AddMonths(-2), 29.00m)
        };
    }

    private async Task Subscribe(string priceId)
    {
        // Integration with StripeService.CreateSubscriptionCheckoutAsync (Phase 6)
        Snackbar.Add("Redirection vers Stripe Checkout...", Severity.Info);
        await Task.Delay(1000);
        // En prod: Navigation.NavigateTo(checkoutUrl, forceLoad: true);
    }

    private void DownloadInvoice(InvoiceVm inv)
    {
        Snackbar.Add($"Téléchargement de {inv.Number} (PDF SkiaSharp)...", Severity.Success);
    }

    public record InvoiceVm(string Number, DateTime Date, decimal Total);
}
