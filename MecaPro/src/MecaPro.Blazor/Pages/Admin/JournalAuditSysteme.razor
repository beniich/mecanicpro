@page "/admin/journal-audit-systeme"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Logs de Sécurité</PageTitle>

<div class="bg-[#111318] text-[#e2e2e8] font-body selection:bg-primary/30 min-h-screen pb-24">
    <!-- TopAppBar -->
    <header class="flex justify-between items-center px-6 py-4 w-full bg-[#111318] border-b border-[#524534]/15 sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[#f5a623]" style="font-variation-settings: 'FILL' 1;">precision_manufacturing</span>
            <h1 class="text-2xl font-black tracking-[0.2em] text-[#f5a623] font-headline uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-6 text-xs uppercase font-bold font-body">
            <nav class="hidden md:flex gap-8 items-center text-[#e2e2e8]/60">
                <a class="hover:text-[#f5a623] transition-colors" href="#">Sécurité</a>
                <a class="hover:text-[#f5a623] transition-colors" href="#">Audit</a>
            </nav>
            <div class="w-10 h-10 rounded-full bg-[#282a2e] border border-white/10 overflow-hidden">
                <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCaeWNP-eHylhlgKPkpQYd9iWKxsVtxJ4H9qli6t10dQ3Jm8fdly6iJ8DMxz_ro6TB2gChLGwLGLCmKinUonndre1K_4zp_FK1QIjWWQqD4QX1T42Yl3tce19KpqRuvrrcTx0fb54SKKdI7K0G4NTxBnuqWUn8EY8LjV3j3fXq1_jr_o_g3L93a1eAAJ7zOJgGcKmpN0stdwPDstqW6-xEpfievGxJnHc1lDQwts1NhN5NWKEJE1cluJwrmO05L7KhtYziQEt2YG3Ws" alt="Operator"/>
            </div>
        </div>
    </header>

    <main class="pt-8 px-8 max-w-7xl mx-auto">
        <!-- Header -->
        <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4 font-headline uppercase">
            <div>
                <p class="font-technical text-primary text-sm tracking-widest mb-1 lowercase font-normal">Système de Diagnostic Central</p>
                <h2 class="text-5xl font-bold tracking-wider text-on-surface">Logs de Sécurité</h2>
            </div>
            <div class="flex gap-2 text-[10px] tracking-widest font-bold">
                <button class="bg-[#282a2e] px-4 py-2 rounded-lg border border-white/5 transition-colors">FILTRER</button>
                <button class="bg-primary-container text-on-primary-container px-4 py-2 rounded-lg shadow-[0_0_12px_rgba(245,166,35,0.2)]">EXPORTER</button>
            </div>
        </div>

        <!-- KPI Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8 font-headline uppercase font-bold">
            <div class="bg-[#282a2e] p-5 rounded-xl border-l-2 border-[#f26411] relative overflow-hidden">
                <p class="text-on-surface-variant text-[10px] tracking-widest mb-2 font-normal">État Global</p>
                <p class="text-4xl text-primary">OPÉRATIONNEL</p>
                <span class="material-symbols-outlined absolute right-[-10px] bottom-[-10px] text-7xl opacity-5">check_circle</span>
            </div>
            <div class="bg-[#282a2e] p-5 rounded-xl border-l-2 border-error relative overflow-hidden">
                <p class="text-on-surface-variant text-[10px] tracking-widest mb-2 font-normal text-error">Erreurs (24h)</p>
                <p class="text-4xl text-error">12</p>
                <span class="material-symbols-outlined absolute right-[-10px] bottom-[-10px] text-7xl opacity-10 text-error">warning</span>
            </div>
        </div>

        <!-- Console -->
        <div class="bg-[#0c0e12] rounded-xl overflow-hidden border border-white/5 flex flex-col h-[600px] shadow-2xl font-technical">
            <div class="bg-[#282a2e] px-6 py-3 flex items-center justify-between border-b border-white/5">
                <div class="flex items-center gap-4">
                    <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-error/40"></div>
                        <div class="w-3 h-3 rounded-full bg-primary/40"></div>
                        <div class="w-3 h-3 rounded-full bg-secondary/40"></div>
                    </div>
                    <span class="text-[10px] text-on-surface-variant">CONSOLE_OUTPUT_STREAM: v2.4.0</span>
                </div>
                <span class="inline-flex items-center gap-2 text-[10px] font-bold text-primary animate-pulse uppercase">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary"></span> LIVE
                </span>
            </div>

            <!-- Scrollable Log List -->
            <div class="flex-1 overflow-y-auto p-4 space-y-2 text-xs">
                <div class="flex gap-4 p-2 border-b border-white/5 hover:bg-white/5 transition-colors">
                    <span class="text-on-surface-variant opacity-60">14:22:01.034</span>
                    <span class="text-error font-bold">ERROR</span>
                    <span class="text-on-surface uppercase">Auth failure / IP: 192.168.1.104</span>
                </div>
                <div class="flex gap-4 p-2 border-b border-white/5 hover:bg-white/5 transition-colors">
                    <span class="text-on-surface-variant opacity-60">14:21:45.912</span>
                    <span class="text-primary font-bold">WARN</span>
                    <span class="text-on-surface uppercase">DB Query delay: 850ms</span>
                </div>
            </div>
        </div>
    </main>
</div>
