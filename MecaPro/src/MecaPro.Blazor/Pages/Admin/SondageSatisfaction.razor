@page "/marketing/sondage-satisfaction"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Configuration des Sondages</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Hexagon Overlay Decor -->
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2249%22 viewBox=%220 0 28 49%22%3E%3Cg fill-rule=%22evenodd%22%3E%3Cg id=%22hexagons%22 fill=%22%23FF00FF%22 fill-opacity=%220.4%22 fill-rule=%22nonzero%22%3E%3Cpath d=%22M13.99 9.25l13 7.5v15l-13 7.5L1 31.75v-15l12.99-7.5zM3 17.9v12.7l10.99 6.34 11-6.35V17.9l-11-6.34L3 17.9zM0 15l12.98-7.5V0h-2v6.35L0 12.69v2.3zm0 18.5L12.98 41v8h-2v-6.85L0 35.81v-2.3zM15 0v7.5L27.99 15H28v-2.31h-.01L17 6.35V0h-2zm0 49v-8l12.99-7.5H28v2.31h-.01L17 42.15V49h-2z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#FF00FF]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#FF00FF] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <button class="bg-[#FF00FF] text-white px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-magenta-600 transition-all flex items-center gap-2 shadow-lg shadow-magenta-500/30">
                <span class="material-symbols-outlined text-sm">rocket_launch</span> DÉPLOYER CAMPAGNE
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-6xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#FF00FF] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">SURVEY_AUTOMATION_HUB</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Sondages CRM</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Configuration et déploiement des flux NPS automatisés.</p>
            </div>
            
            <div class="bg-white/5 border border-white/5 rounded-3xl p-6 flex items-center gap-6">
                 <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-[#FF00FF] mb-1">AUTOMATES ACTIFS</p>
                    <p class="text-4xl font-black italic text-white font-technical">03</p>
                 </div>
                 <div class="w-px h-10 bg-white/10"></div>
                 <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-1">EMAILS / SMS EN ATTENTE</p>
                    <p class="text-4xl font-black italic text-white font-technical">112</p>
                 </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Form Left -->
            <div class="bg-surface-container rounded-[40px] border border-white/5 p-10 shadow-2xl space-y-8">
                <h3 class="font-black text-2xl italic uppercase tracking-tight text-white flex items-center gap-3">
                    <span class="material-symbols-outlined text-[#FF00FF]">settings_input_component</span> Paramètres du Flux
                </h3>

                <div class="space-y-6">
                    <div>
                        <label class="text-[9px] font-black tracking-widest uppercase text-white/30 mb-3 block">ÉVÉNEMENT DÉCLENCHEUR</label>
                        <select class="w-full bg-black/40 border border-white/10 rounded-2xl p-4 text-xs font-black uppercase text-white tracking-widest outline-none focus:border-[#FF00FF] transition-all">
                            <option>REVISION_COMPLETED</option>
                            <option>VEHICLE_DELIVERED</option>
                            <option>DEVIS_MODIFIED</option>
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="text-[9px] font-black tracking-widest uppercase text-white/30 mb-3 block">DÉLAI D'EXPÉDITION</label>
                            <div class="flex items-center bg-black/40 border border-white/10 rounded-2xl px-4 py-4">
                                <input type="number" value="48" class="bg-transparent border-none outline-none font-technical text-sm text-white w-full uppercase font-black" />
                                <span class="text-[8px] font-black text-white/30 uppercase">HEURES</span>
                            </div>
                        </div>
                        <div>
                            <label class="text-[9px] font-black tracking-widest uppercase text-white/30 mb-3 block">CANAL PRIORITAIRE</label>
                            <div class="flex gap-2">
                                <button class="flex-grow bg-[#FF00FF]/10 border border-[#FF00FF] text-[#FF00FF] py-4 rounded-xl text-[9px] font-black uppercase tracking-widest">EMAIL</button>
                                <button class="flex-grow bg-white/5 border border-white/10 text-white/40 py-4 rounded-xl text-[9px] font-black uppercase tracking-widest hover:text-white hover:bg-white/10 transition-all">SMS</button>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="text-[9px] font-black tracking-widest uppercase text-white/30 mb-3 block">RÉCOMPENSE OPT-IN (POINTS)</label>
                        <div class="bg-black/40 border border-white/10 rounded-2xl flex items-center justify-between p-4">
                           <span class="text-xs font-black uppercase tracking-widest text-[#FF00FF]">LOYALTY_BOOST</span>
                           <input type="number" value="100" class="bg-transparent border-none outline-none font-technical text-xl text-white w-20 text-right font-black" />
                        </div>
                    </div>
                </div>
                
                <button class="w-full bg-white/5 border border-white/5 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-sm">visibility</span> APERÇU DU QUESTIONNAIRE
                </button>
            </div>

            <!-- Preview Card Right -->
            <div class="bg-[#111318] rounded-[40px] border border-white/5 p-10 flex flex-col items-center justify-center gap-8 shadow-2xl relative overflow-hidden h-[550px]">
                <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #FF00FF 0%, transparent 80%);"></div>
                
                <div class="w-24 h-24 rounded-full bg-[#FF00FF]/10 flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-5xl text-[#FF00FF]">bolt</span>
                </div>
                
                <h3 class="font-black italic text-3xl uppercase tracking-tighter text-white">Simulation Template</h3>
                <p class="text-xs uppercase font-technical text-white/40 max-w-sm mx-auto leading-loose text-center font-bold tracking-widest">
                   Email envoyé sous 48h à l'issue de l'intervention. Lien dynamique sécurisé (v4-jwt) avec attribution de points fidelité immédiats.
                </p>

                <div class="w-full max-w-sm space-y-4 pt-10 border-t border-white/5">
                    <div class="flex justify-between items-center text-[8px] font-black uppercase tracking-widest text-white/20">
                        <span>SUJET: @NOM_GARAGE - VOTRE AVIS</span>
                        <span>v4.2</span>
                    </div>
                </div>

                <div class="flex gap-2">
                   @for(int i=0; i<3; i++) {
                       <div class="w-3 h-3 rounded bg-white/10"></div>
                   }
                </div>
                <div class="text-[8px] font-black text-[#FF00FF] uppercase tracking-[0.3em] font-technical">AUTO_GENERATED_BY_MECAPRO_AI</div>
            </div>
        </div>

    </main>
</div>

@code {
    
}
