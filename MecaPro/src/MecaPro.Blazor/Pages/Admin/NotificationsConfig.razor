@page "/marketing/notifications-config"


<div class="min-h-screen bg-[#0a0b0d] text-white p-8 font-['Outfit']">
    <!-- Header -->
    <div class="flex justify-between items-center mb-10">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-orange-500/20 flex items-center justify-center border border-orange-500/30">
                    <span class="material-symbols-outlined text-orange-400">notifications_active</span>
                </div>
                <h1 class="text-4xl font-black italic tracking-tighter uppercase">Notification <span class="text-orange-500">Matrix</span></h1>
            </div>
            <p class="text-gray-400 text-sm font-light tracking-wide uppercase">DÉCLENCHEURS & AUTOMATISATION DES FLUX SORTANTS</p>
        </div>
        <div class="flex gap-4">
            <div class="bg-white/5 border border-white/10 px-6 py-3 rounded-2xl flex items-center gap-4 hover:border-orange-500/30 transition-all cursor-pointer group">
                <div class="text-right">
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">DÉBIT SMS ESTIMÉ</p>
                    <p class="text-xl font-black text-orange-400">1.2k <span class="text-xs text-white/50">/m</span></p>
                </div>
                <span class="material-symbols-outlined text-orange-500 group-hover:rotate-12 transition-transform">bolt</span>
            </div>
            <button class="bg-orange-600 hover:bg-orange-500 px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-[0_0_30px_rgba(249,107,12,0.3)] flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">save</span> SAUVEGARDER CONFIG
            </button>
        </div>
    </div>

    <!-- Notification Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
        <!-- Left Col: Core Events -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[2.5rem] overflow-hidden">
                <div class="p-8 border-b border-white/5 bg-white/[0.02]">
                    <h3 class="text-xl font-bold italic tracking-tight">Configuration des Déclencheurs</h3>
                </div>
                
                <div class="p-0">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] bg-black/20">
                                <th class="px-8 py-4">Événement Métier</th>
                                <th class="px-4 py-4 text-center w-24">Email</th>
                                <th class="px-4 py-4 text-center w-24">SMS</th>
                                <th class="px-4 py-4 text-center w-24">Push</th>
                                <th class="px-8 py-4 text-right">Template</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/[0.05]">
                            @foreach (var config in notificationConfigs)
                            {
                                <tr class="hover:bg-white/[0.02] transition-colors group">
                                    <td class="px-8 py-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-1.5 h-1.5 rounded-full bg-orange-500 shadow-[0_0_8px_rgba(249,107,12,0.6)]"></div>
                                            <div>
                                                <p class="font-bold text-gray-200">@config.EventName</p>
                                                <p class="text-[10px] text-gray-500 font-medium">@config.Description</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-6 text-center">
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" @bind="config.EmailEnabled" class="sr-only peer">
                                            <div class="w-10 h-5 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-orange-600"></div>
                                        </label>
                                    </td>
                                    <td class="px-4 py-6 text-center">
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" @bind="config.SmsEnabled" class="sr-only peer">
                                            <div class="w-10 h-5 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-blue-600"></div>
                                        </label>
                                    </td>
                                    <td class="px-4 py-6 text-center">
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" @bind="config.PushEnabled" class="sr-only peer">
                                            <div class="w-10 h-5 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-green-600"></div>
                                        </label>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <button class="bg-white/5 hover:bg-white/10 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all">Éditer Template</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Col: Active Alerts & Preview -->
        <div class="space-y-8">
            <!-- SMS Preview -->
            <div class="bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-sm font-black uppercase tracking-widest text-orange-500">Live SMS Preview</h3>
                    <div class="flex gap-1">
                        <div class="w-1.5 h-1.5 rounded-full bg-red-500"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-yellow-500"></div>
                        <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                    </div>
                </div>
                
                <div class="relative max-w-[280px] mx-auto bg-[#1a1c24] rounded-[3rem] border-8 border-black/40 shadow-2xl overflow-hidden aspect-[9/18]">
                    <div class="absolute top-0 w-full h-8 bg-black/20 flex justify-center items-end pb-1 gap-1">
                        <div class="w-12 h-4 bg-black/40 rounded-full"></div>
                    </div>
                    
                    <div class="p-6 pt-12 space-y-4">
                        <div class="bg-white/5 p-4 rounded-2xl border border-white/10">
                            <p class="text-[10px] text-orange-400 font-bold mb-1">PROJET DASH — MECAPRO</p>
                            <p class="text-xs leading-relaxed text-gray-300">
                                Bonjour M. Martin, votre véhicule [LIC_PLATE] est prêt ! 🚗 Retrouvez-nous jusqu'à 18h.
                            </p>
                        </div>
                        
                        <div class="bg-white/5 p-4 rounded-2xl border border-white/10 animate-pulse">
                            <p class="text-[10px] text-blue-400 font-bold mb-1">ALERTE STOCK</p>
                            <p class="text-xs leading-relaxed text-gray-400 italic">
                                Saisie du template en cours...
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="bg-orange-600/10 border border-orange-500/20 rounded-[2rem] p-8">
                <h4 class="text-xs font-black uppercase tracking-[0.2em] text-orange-500 mb-6 italic">Performance Flux</h4>
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <p class="text-[10px] text-gray-500 font-bold uppercase mb-1">Délivrabilité</p>
                        <p class="text-2xl font-black italic">99.8%</p>
                    </div>
                    <div>
                        <p class="text-[10px] text-gray-500 font-bold uppercase mb-1">Taux Ouverture</p>
                        <p class="text-2xl font-black italic">84.2%</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<NotificationConfig> notificationConfigs = new()
    {
        new NotificationConfig { EventName = "Fin de Révision", Description = "Envoyé dès que le statut passe à Terminé", EmailEnabled = true, SmsEnabled = true, PushEnabled = false },
        new NotificationConfig { EventName = "Rappel RDV (J-1)", Description = "Rappel automatique 24h avant l'heure prévue", EmailEnabled = true, SmsEnabled = true, PushEnabled = true },
        new NotificationConfig { EventName = "Stock Critique", Description = "Alerte quand une pièce descend sous le seuil mini", EmailEnabled = true, SmsEnabled = false, PushEnabled = true },
        new NotificationConfig { EventName = "Nouveau Devis", Description = "Envoi du lien de paiement/validation au client", EmailEnabled = true, SmsEnabled = true, PushEnabled = false },
        new NotificationConfig { EventName = "Anomalie IoT", Description = "Alerte immédiate en cas de défaut matériel atelier", EmailEnabled = false, SmsEnabled = true, PushEnabled = true },
        new NotificationConfig { EventName = "Bienvenue Client", Description = "Post-onboarding premier rendez-vous", EmailEnabled = true, SmsEnabled = false, PushEnabled = false }
    };

    public class NotificationConfig
    {
        public string EventName { get; set; } = "";
        public string Description { get; set; } = "";
        public bool EmailEnabled { get; set; }
        public bool SmsEnabled { get; set; }
        public bool PushEnabled { get; set; }
    }
}
