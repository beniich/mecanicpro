@page "/diagnostic/vin-pro"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Décodeur VIN Pro</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-hidden relative">

    <!-- Hexagon Background -->
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2228%22 height=%2249%22 viewBox=%220 0 28 49%22%3E%3Cg fill-rule=%22evenodd%22%3E%3Cg id=%22hexagons%22 fill=%22%2300ff66%22 fill-opacity=%220.4%22 fill-rule=%22nonzero%22%3E%3Cpath d=%22M13.99 9.25l13 7.5v15l-13 7.5L1 31.75v-15l12.99-7.5zM3 17.9v12.7l10.99 6.34 11-6.35V17.9l-11-6.34L3 17.9zM0 15l12.98-7.5V0h-2v6.35L0 12.69v2.3zm0 18.5L12.98 41v8h-2v-6.85L0 35.81v-2.3zM15 0v7.5L27.99 15H28v-2.31h-.01L17 6.35V0h-2zm0 49v-8l12.99-7.5H28v2.31h-.01L17 42.15V49h-2z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#00FF66]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#00FF66] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-[#00FF66]/10 border border-[#00FF66]/30 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase text-[#00FF66] tracking-widest flex items-center gap-2 shadow-[0_0_15px_rgba(0,255,102,0.1)]">
                <span class="material-symbols-outlined text-sm">barcode_scanner</span> NHTSA DB CONNECTED
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-6xl mx-auto space-y-10 relative z-10">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#00FF66] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">VEHICLE_IDENTIFICATION_NETWORK</span>
                <h2 class="text-6xl md:text-7xl font-black tracking-tighter italic uppercase leading-none drop-shadow-[0_0_15px_rgba(0,255,102,0.15)] text-white">Décodeur VIN Pro</h2>
                <p class="text-[10px] uppercase font-black tracking-widest text-[#00FF66]/50 mt-4">Accès direct aux spécifications constructeur et historiques rappel.</p>
            </div>
        </div>

        <!-- Section de Saisie Principale -->
        <div class="bg-surface-container rounded-[40px] border border-white/5 p-8 relative overflow-hidden shadow-2xl">
            <!-- Animation Scan Layer -->
            <div class="absolute left-0 top-0 bottom-0 w-1 bg-[#00FF66] opacity-0 shadow-[0_0_20px_#00FF66,0_0_40px_#00FF66] @(isDecoding ? "animate-[scanBar_2s_linear_infinite]" : "")"></div>
            
            <div class="flex flex-col md:flex-row gap-6 items-end">
                <div class="flex-grow">
                    <label class="text-[10px] font-black tracking-[0.2em] text-white/40 uppercase mb-3 block">Saisie du VIN (17 Caractères)</label>
                    <div class="bg-black/50 border border-[#00FF66]/30 focus-within:border-[#00FF66] rounded-2xl flex items-center px-6 py-6 transition-all shadow-inner">
                        <span class="material-symbols-outlined text-[#00FF66]/40 text-3xl mr-6">barcode</span>
                        <input type="text" @bind="inputVin" @onkeyup="HandleKey" maxlength="17" placeholder="WAUZZZ4GZHN052814" 
                               class="bg-transparent border-none outline-none font-technical text-3xl md:text-4xl uppercase text-white tracking-[0.2em] font-black w-full placeholder:text-white/10" />
                    </div>
                </div>
                <button @onclick="LancerDecodage" disabled="@(isDecoding || string.IsNullOrWhiteSpace(inputVin) || inputVin.Length < 17)" 
                        class="bg-[#00FF66] text-black shrink-0 px-10 py-7 md:py-8 rounded-2xl text-lg font-black uppercase tracking-widest hover:bg-green-400 transition-all flex items-center justify-center gap-3 shadow-[0_0_30px_rgba(0,255,102,0.3)] disabled:opacity-30 disabled:hover:bg-[#00FF66]">
                    @if(isDecoding)
                    {
                        <span class="material-symbols-outlined animate-spin text-2xl">refresh</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-2xl">radar</span> <span>SCAN</span>
                    }
                </button>
            </div>
            <div class="mt-4 flex justify-between px-2">
                <span class="text-[9px] font-black tracking-widest uppercase text-white/30">@(inputVin?.Length ?? 0)/17 CARACTÈRES</span>
                <span class="text-[9px] font-black tracking-widest uppercase text-[#00FF66]/50">LATENCE API: ~1.2s</span>
            </div>
        </div>

        @if(result != null)
        {
            <!-- Results Grid -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 animate-[fadeInUp_0.4s_ease-out_forwards]">
                
                <!-- Main Spec Card -->
                <div class="md:col-span-8 bg-surface-container rounded-[40px] border border-white/5 p-8 relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-8 opacity-5">
                        <span class="material-symbols-outlined text-[150px]">directions_car</span>
                    </div>

                    <h3 class="font-black text-2xl italic uppercase tracking-tight text-white mb-2">@result.Year @result.Make @result.Model</h3>
                    <p class="font-technical text-[10px] tracking-[0.2em] uppercase font-bold text-[#00FF66] mb-8 bg-[#00FF66]/10 px-3 py-1 rounded inline-block">WMI: @result.Wmi | VDS: @result.Vds | VIS: @result.Vis</p>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-8 gap-x-4 relative z-10">
                        <!-- Spec Block -->
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">CONSTRUCTEUR</p>
                            <p class="text-sm font-black uppercase text-white">@result.Make</p>
                            <p class="text-[9px] font-black uppercase text-white/40 mt-1">@result.Country</p>
                        </div>
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">MOTEUR</p>
                            <p class="text-sm font-black uppercase text-white">@result.EngineType</p>
                            <p class="text-[9px] font-black uppercase text-white/40 mt-1">@result.Cylinders CYL.</p>
                        </div>
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">CARBURANT</p>
                            <p class="text-sm font-black uppercase text-white">@result.FuelType</p>
                        </div>
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">TRANSMISSION</p>
                            <p class="text-sm font-black uppercase text-white">@result.Transmission</p>
                            <p class="text-[9px] font-black uppercase text-[#00FF66] mt-1 shadow-none">@result.DriveType</p>
                        </div>
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">CARROSSERIE</p>
                            <p class="text-sm font-black uppercase text-white">@result.BodyStyle</p>
                            <p class="text-[9px] font-black uppercase text-white/40 mt-1">@result.Doors PORTES</p>
                        </div>
                        <div>
                            <p class="text-[8px] tracking-[0.2em] font-black uppercase text-white/30 mb-1">PLANT PROD</p>
                            <p class="text-sm font-black uppercase text-white">@result.PlantCountry</p>
                            <p class="text-[9px] font-black uppercase text-white/40 mt-1">@result.PlantCity</p>
                        </div>
                    </div>
                </div>

                <!-- Recalls Alerts -->
                <div class="md:col-span-4 bg-[#111318] rounded-[40px] border border-red-500/20 p-8 shadow-[inset_0_0_50px_rgba(239,68,68,0.05)]">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-full bg-red-500/20 flex items-center justify-center animate-[pulse_2s_infinite]">
                            <span class="material-symbols-outlined text-red-500 text-lg">warning</span>
                        </div>
                        <h3 class="font-black text-xl italic uppercase tracking-tight text-white">Rappels Actifs</h3>
                    </div>

                    @if (result.Recalls.Any())
                    {
                        <div class="space-y-4">
                            <p class="text-[10px] font-black tracking-widest uppercase text-red-400">@result.Recalls.Length ALERTES NHTSA</p>
                            @foreach(var recall in result.Recalls)
                            {
                                <div class="bg-white/5 border border-red-500/30 rounded-xl p-4">
                                    <p class="text-[9px] font-black text-red-400 bg-red-500/10 px-2 py-0.5 rounded tracking-widest inline-block mb-2">CAMPAGNE: @recall.Campaign</p>
                                    <p class="font-bold text-xs uppercase leading-snug text-white">@recall.Subject</p>
                                </div>
                            }
                        </div>
                        <button class="w-full mt-6 bg-red-500/10 border border-red-500/50 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-red-500/20 text-red-400 transition-all">
                            IMPRIMER NOTIFICATION
                        </button>
                    }
                    else
                    {
                        <div class="h-40 flex flex-col items-center justify-center text-center opacity-50">
                            <span class="material-symbols-outlined text-4xl text-[#00FF66] mb-2">verified</span>
                            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#00FF66]">AUCUN RAPPEL DÉTECTÉ</p>
                        </div>
                    }
                </div>
            </div>
            
            <div class="flex justify-center mt-8">
                <button class="px-8 py-3 bg-white/5 text-white font-black text-[10px] uppercase tracking-[0.3em] rounded-full border border-white/10 hover:bg-white/10 transition-colors">
                    AFFECTER AU DOSSIER CLIENT
                </button>
            </div>
        }

    </main>
</div>

<style>
    @@keyframes scanBar {
        0% { opacity: 1; transform: translateX(0); left: 0;}
        50% { opacity: 1; transform: translateX(100%); left: 100%;}
        100% { opacity: 1; transform: translateX(0); left: 0;}
    }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private string inputVin = "";
    private bool isDecoding = false;
    private VinSpec? result = null;

    private async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && inputVin.Length == 17)
        {
            await LancerDecodage();
        }
    }

    private async Task LancerDecodage()
    {
        isDecoding = true;
        result = null;

        await Task.Delay(1500); // Simulate API latency NHTSA

        // Dummy data based on standard VINs
        if (inputVin.ToUpper().StartsWith("WAU"))
        {
            result = new VinSpec("2014", "AUDI", "A6 / S6 / RS6", "ALLEMAGNE", "4.0L V8 TFSI", "8", "ESSENCE", "AUTOMATIQUE", "QUATTRO (AWD)", "Break (Avant)", "5", "Neckarsulm", "Allemagne", "WAU", "ZZZ4G", "ZHN052814", new[] {
                new Recall("18V423000", "Pompe de liquide de refroidissement additionnelle électrique")
            });
        }
        else
        {
            // Default generic response
            result = new VinSpec("2021", "PEUGEOT", "3008", "FRANCE", "1.5 BlueHDi", "4", "DIESEL", "EAT8", "TRACTION", "SUV Compact", "5", "Sochaux", "France", inputVin.Substring(0,3), inputVin.Substring(3,5), inputVin.Substring(8), Array.Empty<Recall>());
        }

        isDecoding = false;
    }

    record VinSpec(string Year, string Make, string Model, string Country, string EngineType, string Cylinders, string FuelType, string Transmission, string DriveType, string BodyStyle, string Doors, string PlantCity, string PlantCountry, string Wmi, string Vds, string Vis, Recall[] Recalls);
    record Recall(string Campaign, string Subject);
}
