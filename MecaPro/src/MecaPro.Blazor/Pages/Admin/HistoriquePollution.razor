@page "/admin/historique-pollution"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Historique Pollution</PageTitle>

<div class="bg-[#111318] text-[#e2e2e8] font-body selection:bg-primary/30 min-h-screen pb-24">
    <!-- Top App Bar -->
    <header class="bg-[#111318] flex justify-between items-center px-6 py-4 w-full sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-[#f5a623] cursor-pointer">menu</span>
            <h1 class="text-3xl font-black text-[#f5a623] tracking-widest font-headline uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="text-on-surface font-headline tracking-wider hidden md:block uppercase">Diagnostic Unit #42</span>
            <div class="w-10 h-10 rounded-full bg-[#333539] border border-[#524534] flex items-center justify-center overflow-hidden">
                <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC6BdDX2wD43P3kYFYG9P0yLcPQzrIm8UzMy_biNiMYpdvHfyo-QjnyA956uEOm8Ky3sbuQC8SzWz-SHZ-ygBqykS0mGgFr1qtauvkyMnMFKAGlZnLCJxxTROJ-JJ4giE1V3CHzyVug6V_AZ0ZMZfa9somBQdg4XgGalyg-3jwbNxwCzyFV8FGIMNG3_P-SLNOu0TX6smVnwtoZ1BCHcQsYFU57R_e3EGuL5KYw7T6gL-jB9-ASa4FDa9NNp2de8z9nai4bcn-IEDEy" alt="Operator"/>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 pt-6 space-y-6">
        <!-- Header -->
        <section class="bg-[#1a1c20] p-6 rounded-xl flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="space-y-1">
                <div class="flex items-center gap-2 text-primary">
                    <span class="material-symbols-outlined">factory</span>
                    <span class="font-headline tracking-widest text-xl uppercase">Analytique Emissions</span>
                </div>
                <h2 class="text-4xl font-headline tracking-wide text-on-surface uppercase font-bold">Historique Pollution</h2>
                <div class="flex items-center gap-3 pt-2">
                    <span class="bg-[#333539] px-3 py-1 rounded font-technical text-sm text-primary border-l-2 border-[#f26411]">VIN: JH2SC59A7BK00124</span>
                    <span class="bg-[#333539] px-3 py-1 rounded font-technical text-sm text-on-surface-variant">PLATE: AB-123-CD</span>
                </div>
            </div>
            <div class="flex gap-4 uppercase font-headline">
                <button class="bg-[#282a2e] hover:bg-[#333539] px-4 py-2 rounded-lg flex items-center gap-2 transition-colors border border-white/5">
                    <span class="material-symbols-outlined text-sm">download</span>
                    <span>Exporter Rapport</span>
                </button>
                <div class="bg-primary-container text-on-primary-container px-6 py-2 rounded-lg tracking-widest flex items-center gap-2 shadow-[0_0_20px_rgba(245,166,35,0.2)]">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    CONFORME EURO 6
                </div>
            </div>
        </section>

        <!-- Analytics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-8 bg-[#1a1c20] p-6 rounded-xl relative overflow-hidden group">
                <div class="flex justify-between items-start mb-8 font-headline uppercase font-bold">
                    <div>
                        <h3 class="text-2xl tracking-wide text-on-surface-variant">Émissions CO2 (g/km)</h3>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl font-technical text-primary">124.5</div>
                        <div class="text-[10px] font-technical uppercase text-secondary font-normal">Moyenne Annuelle</div>
                    </div>
                </div>
                <!-- Bars (Simplified) -->
                <div class="h-64 flex items-end justify-between gap-2 border-b border-white/10">
                    @for (int i = 0; i < 12; i++)
                    {
                        <div class="flex-1 bg-gradient-to-t from-primary-container/20 to-primary-container rounded-t-sm" style="height: @(50 + i * 2)%"></div>
                    }
                </div>
                <div class="flex justify-between mt-4 font-technical text-[10px] text-outline uppercase tracking-tighter">
                    <span>JAN</span><span>FEV</span><span>MAR</span><span>AVR</span><span>MAI</span><span>JUN</span>
                    <span>JUL</span><span>AOU</span><span>SEP</span><span>OCT</span><span>NOV</span><span>DEC</span>
                </div>
            </div>

            <div class="md:col-span-4 space-y-6">
                <!-- NOx Dial Card -->
                <div class="bg-[#282a2e] p-6 rounded-xl border-l-2 border-[#f26411]">
                    <h3 class="font-headline text-2xl tracking-wide mb-4 uppercase">Émissions NO<sub>x</sub></h3>
                    <div class="flex items-center justify-between">
                        <div class="relative w-24 h-24">
                            <svg class="w-full h-full transform -rotate-90">
                                <circle class="text-[#0c0e12]" cx="48" cy="48" fill="transparent" r="40" stroke="currentColor" stroke-width="8"></circle>
                                <circle class="text-[#f26411]" cx="48" cy="48" fill="transparent" r="40" stroke="currentColor" stroke-dasharray="251.2" stroke-dashoffset="60" stroke-width="8"></circle>
                            </svg>
                            <div class="absolute inset-0 flex flex-col items-center justify-center font-technical">
                                <span class="text-xl font-bold">78</span>
                                <span class="text-[8px]">mg/km</span>
                            </div>
                        </div>
                        <div class="flex-1 pl-6 space-y-2">
                            <div class="bg-[#0c0e12] p-2 rounded">
                                <div class="text-[10px] text-outline uppercase font-technical">Norme Max</div>
                                <div class="text-sm font-technical text-on-surface">80.0 mg/km</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
