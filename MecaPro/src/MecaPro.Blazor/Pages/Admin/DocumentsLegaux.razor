@page "/admin/documents-legaux"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Documents Légaux</PageTitle>

<div class="bg-[#111318] text-[#e2e2e8] font-body selection:bg-primary/30 min-h-screen">
    <!-- TopAppBar -->
    <header class="bg-[#111318] h-20 w-full fixed top-0 z-50 border-b border-[#524534]/15 flex justify-between items-center px-6">
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-[#f5a623]">settings_input_component</span>
            <h1 class="font-headline text-2xl tracking-[0.05em] uppercase text-[#f5a623]">SYSTEM_DIAGNOSTICS</h1>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#333539] flex items-center justify-center border-2 border-primary/20">
            <span class="material-symbols-outlined text-primary">account_circle</span>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pt-28 pb-32">
        <div class="mb-12">
            <div class="flex items-baseline gap-4 mb-2">
                <h2 class="font-headline text-7xl tracking-wider text-primary uppercase">LEGAL_VAULT</h2>
                <div class="h-1 flex-grow bg-[#333539] relative overflow-hidden">
                    <div class="absolute left-0 h-full w-1/3 bg-gradient-to-r from-[#f5a623] to-[#f26411]"></div>
                </div>
            </div>
            <p class="font-technical text-xs text-on-surface-variant tracking-widest uppercase opacity-70">Secured Archive // Professional Certifications // Safety Audits</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <!-- Compliance Card -->
            <div class="lg:col-span-4 bg-[#1a1c20] p-8 border-l-4 border-[#f26411] flex flex-col justify-between">
                <div>
                    <span class="font-technical text-[10px] text-secondary uppercase tracking-tighter block mb-4">Compliance Score</span>
                    <div class="font-headline text-8xl text-on-surface leading-none mb-2">98<span class="text-3xl text-primary">%</span></div>
                    <p class="text-sm text-on-surface-variant font-medium">All professional certifications are current.</p>
                </div>
                <div class="mt-8 flex gap-2 font-technical text-[10px] uppercase font-bold">
                    <span class="bg-primary/10 text-primary px-2 py-1 rounded">AUTO_SYNC_ON</span>
                    <span class="bg-secondary/10 text-secondary px-2 py-1 rounded">ENCRYPTED_AES256</span>
                </div>
            </div>

            <!-- Categories -->
            <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-[#282a2e] p-6 rounded-xl border border-outline-variant/10 group cursor-pointer hover:bg-[#37393e] transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div class="p-4 bg-[#0c0e12] rounded-lg">
                            <span class="material-symbols-outlined text-primary text-3xl">policy</span>
                        </div>
                    </div>
                    <h3 class="font-headline text-2xl font-bold uppercase tracking-tight">Assurances Garage</h3>
                    <p class="text-xs text-on-surface-variant font-medium mt-1 mb-4">RC Pro, Multirisque & Protection Juridique.</p>
                    <div class="flex justify-between font-technical text-[10px] text-primary font-bold">
                        <span>3 DOCUMENTS</span>
                        <span class="text-on-surface-variant/40">EXP: 31.12.2024</span>
                    </div>
                </div>
                 <div class="bg-[#282a2e] p-6 rounded-xl border border-outline-variant/10 group cursor-pointer hover:bg-[#37393e] transition-all">
                    <div class="flex justify-between items-start mb-6">
                        <div class="p-4 bg-[#0c0e12] rounded-lg">
                            <span class="material-symbols-outlined text-primary text-3xl">verified_user</span>
                        </div>
                    </div>
                    <h3 class="font-headline text-2xl font-bold uppercase tracking-tight">Certifications Pro</h3>
                    <p class="text-xs text-on-surface-variant font-medium mt-1 mb-4">Habilitations électriques & Certificats clim.</p>
                    <div class="flex justify-between font-technical text-[10px] text-primary font-bold">
                        <span>12 DOCUMENTS</span>
                        <span class="text-on-surface-variant/40">UPDATED: 04.05.2024</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Upload Zone -->
        <div class="mt-8 bg-gradient-to-br from-[#282a2e] to-[#0c0e12] p-12 rounded-xl text-center border-2 border-dashed border-outline-variant/30 group">
             <div class="w-20 h-20 bg-[#333539] rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-primary text-4xl">cloud_upload</span>
            </div>
            <h4 class="font-headline text-3xl font-bold uppercase tracking-widest mb-2">Déposer un document</h4>
            <p class="text-on-surface-variant font-medium mb-8">Glissez-déposez vos fichiers PDF ou images.</p>
            <button class="bg-gradient-to-r from-primary-container to-secondary-container text-on-primary font-headline text-2xl px-10 py-4 rounded-xl shadow-2xl active:scale-95 transition-all uppercase tracking-widest">
                Explorer les fichiers
            </button>
        </div>
    </main>
</div>
