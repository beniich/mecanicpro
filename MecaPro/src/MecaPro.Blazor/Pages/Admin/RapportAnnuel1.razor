@page "/admin/rapport-annuel-1"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Rapport d'Activité 2023</PageTitle>

<div class="bg-surface text-on-surface font-body selection:bg-primary-container min-h-screen pb-24">
    <!-- TopAppBar -->
    <header class="w-full sticky top-0 z-50 bg-[#111318] flex justify-between items-center px-6 h-20 shadow-2xl border-b border-[#524534]/15">
        <div class="flex items-center gap-3 uppercase font-headline">
            <span class="material-symbols-outlined text-[#f5a623] text-3xl">settings_input_component</span>
            <h1 class="text-[#f5a623] tracking-[0.05em] text-3xl italic font-black leading-none uppercase">MecaPro</h1>
        </div>
        <div class="flex items-center gap-4">
            <button class="p-2 rounded-full hover:bg-[#282a2e] transition-all text-[#e2e2e8]">
                <span class="material-symbols-outlined">notifications</span>
            </button>
            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container font-black text-xs shadow-lg">
                JD
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 pt-12 space-y-12">
        <!-- Executive Header -->
        <section class="flex flex-col md:flex-row md:items-end justify-between gap-6 uppercase font-headline">
            <div class="space-y-2">
                <p class="text-primary font-mono text-[10px] tracking-[0.4em] font-black not-italic mb-2">ANNUAL PERFORMANCE</p>
                <h2 class="text-7xl md:text-8xl tracking-wider leading-none font-black italic">Rapport d'Activité 2023</h2>
            </div>
            <div class="flex items-center gap-6 bg-surface-container-high p-6 rounded-xl border border-outline-variant/10 shadow-2xl">
                <div class="text-right">
                    <p class="text-[10px] text-on-surface-variant tracking-widest font-black">STATUS GLOBAL</p>
                    <p class="text-primary font-black text-2xl italic">EXCELLENT +12%</p>
                </div>
                <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center border border-primary/20">
                    <span class="material-symbols-outlined text-primary text-3xl">trending_up</span>
                </div>
            </div>
        </section>

        <!-- Bento Grid -->
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 uppercase font-headline">
            <div class="md:col-span-8 bg-surface-container-low rounded-xl p-10 flex flex-col justify-between min-h-[450px] shadow-2xl border-l-4 border-primary">
                <div>
                    <h3 class="text-4xl tracking-wide mb-8 italic font-black">ÉVOLUTION DU CA (12 MOIS)</h3>
                    <div class="flex items-baseline gap-4 mb-12 italic">
                        <span class="text-7xl text-primary font-black tracking-tighter">842.500</span>
                        <span class="text-on-surface-variant font-mono text-xl not-italic">EUR</span>
                        <span class="ml-6 text-green-400 font-mono text-sm bg-green-400/10 px-3 py-1.5 rounded-lg border border-green-400/20 not-italic">+14.2% VS 2022</span>
                    </div>
                </div>
                <div class="flex items-end justify-between h-56 gap-3">
                    @* Faux Chart Rendering *@
                    @for (int i = 0; i < 11; i++) {
                        <div class="flex-1 bg-surface-container-highest rounded-t-lg h-[60%] hover:bg-primary/40 transition-all duration-300"></div>
                    }
                    <div class="flex-1 bg-primary rounded-t-lg h-full shadow-[0_0_32px_rgba(245,166,35,0.4)]"></div>
                </div>
            </div>
        </div>
    </main>
</div>
