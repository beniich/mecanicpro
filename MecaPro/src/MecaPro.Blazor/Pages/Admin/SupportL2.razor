@page "/marketing/support-2"
@using System.Collections.Generic

<div class="min-h-screen bg-[#060709] text-white p-8 font-['Outfit']">
    <!-- Header: Tech Ops Level 2 -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-8">
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <div class="w-16 h-16 rounded-[2rem] bg-indigo-600/10 flex items-center justify-center border border-indigo-500/30 shadow-[0_0_50px_rgba(79,70,229,0.15)] overflow-hidden relative group">
                    <div class="absolute inset-0 bg-indigo-500/20 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
                    <span class="material-symbols-outlined text-indigo-400 text-4xl relative z-10">engineering</span>
                </div>
                <div>
                    <h1 class="text-6xl font-black italic uppercase tracking-tighter leading-none">Support <span class="text-indigo-500">Tier-2</span></h1>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-[0.5em] mt-2 italic shadow-none border-none">ESCALADE TECHNIQUE COMPLEXE & DEBUGGING IA</p>
                </div>
            </div>
            
            <div class="flex gap-4 pt-4">
                <div class="bg-indigo-600/5 border border-indigo-500/20 px-8 py-4 rounded-3xl flex items-center gap-6">
                    <div class="flex flex-col">
                        <p class="text-[9px] text-gray-500 font-black tracking-widest leading-none mb-1">STABILITÉ SYSTÈME</p>
                        <p class="text-2xl font-black text-indigo-400 italic">99.98<span class="text-xs">%</span></p>
                    </div>
                </div>
                <div class="bg-red-600/5 border border-red-500/20 px-8 py-4 rounded-3xl flex items-center gap-6">
                    <div class="flex flex-col">
                        <p class="text-[9px] text-gray-500 font-black tracking-widest leading-none mb-1">ESCALADES L1</p>
                        <p class="text-2xl font-black text-red-500 italic">3</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-black/40 border border-white/5 p-2 rounded-[2.5rem] flex gap-2">
            <button class="px-8 py-3 rounded-2xl bg-indigo-600 font-black uppercase text-xs tracking-widest transition-all shadow-xl">Actifs</button>
            <button class="px-8 py-3 rounded-2xl text-gray-500 hover:text-white font-black uppercase text-xs tracking-widest transition-all">Historique</button>
            <button class="px-8 py-3 rounded-2xl text-gray-500 hover:text-white font-black uppercase text-xs tracking-widest transition-all">Analyse IA</button>
        </div>
    </div>

    <!-- Tier-2 Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-4 gap-12">
        <!-- Sidebar: Active Incidents -->
        <div class="xl:col-span-1 space-y-6">
            <h2 class="text-xs font-black uppercase tracking-widest text-indigo-500 italic mb-4">Tickets Escaladés</h2>
            @foreach (var ticket in escalatedTickets)
            {
                <div class="bg-white/[0.03] border border-white/10 rounded-[2rem] p-6 hover:bg-white/[0.08] transition-all cursor-pointer @(ticket.IsSelected ? "ring-2 ring-indigo-500/50 bg-indigo-500/10 border-indigo-500/30" : "")">
                    <div class="flex justify-between items-start mb-4">
                        <span class="text-[9px] text-gray-500 font-black tracking-widest">ID #@ticket.Id</span>
                        <div class="w-2 h-2 rounded-full @(ticket.SeverityColor) shadow-[0_0_8px_rgba(0,0,0,0.5)]"></div>
                    </div>
                    <h4 class="text-sm font-black italic uppercase leading-tight mb-2">@ticket.Title</h4>
                    <p class="text-[10px] text-gray-400 italic mb-4">Demandé par @ticket.OriginAgent (L1)</p>
                    
                    <div class="flex justify-between items-center bg-black/40 px-3 py-2 rounded-xl">
                        <span class="text-[10px] font-black tracking-widest">@ticket.Category</span>
                        <span class="text-[10px] text-indigo-500 font-black italic">@ticket.WaitTime</span>
                    </div>
                </div>
            }
        </div>

        <!-- Main Column: Incident Deep-Dive -->
        <div class="xl:col-span-3 space-y-8">
            <div class="bg-[#111318]/80 backdrop-blur-3xl border border-white/10 rounded-[3rem] p-10 relative overflow-hidden">
                <!-- Watermark -->
                <span class="absolute -right-20 -bottom-20 material-symbols-outlined text-[30rem] text-white/[0.01] pointer-events-none select-none">bug_report</span>
                
                <div class="flex flex-col md:flex-row justify-between items-start mb-12 gap-8 relative z-10">
                    <div class="space-y-4">
                        <div class="flex items-center gap-3">
                            <span class="px-4 py-1.5 bg-red-600/20 text-red-500 text-[10px] font-black uppercase tracking-widest rounded-full border border-red-500/30">BLOQUANT (S1)</span>
                            <span class="text-gray-500 text-[10px] font-bold">CRÉÉ LE 20 MARS 2026</span>
                        </div>
                        <h2 class="text-4xl font-black italic tracking-tighter uppercase leading-none">Anomalie synchronisation Passerelle OBD-II Cloud</h2>
                        <div class="flex gap-4">
                            <button class="bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">Fichier Log.json</button>
                            <button class="bg-white/5 border border-white/10 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">Capture Trame MQTT</button>
                            <button class="bg-indigo-600/20 border border-indigo-500/30 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-indigo-400 hover:bg-indigo-600/30 transition-all font-outfit uppercase tracking-widest">Collaborer avec @IA-Assistant</button>
                        </div>
                    </div>
                    
                    <div class="bg-black/60 p-6 rounded-[2rem] border border-white/5 min-w-[200px]">
                        <p class="text-[9px] text-gray-500 font-black uppercase mb-4 tracking-widest">Agent Assigné</p>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-indigo-600 flex items-center justify-center font-black">KM</div>
                            <div>
                                <p class="text-xs font-bold uppercase">Karlan M.</p>
                                <p class="text-[10px] text-gray-500 font-medium">Expert Backend</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Chat/Logs Interface -->
                <div class="space-y-6 mb-12">
                    <div class="flex gap-4 max-w-[80%]">
                        <div class="w-8 h-8 rounded-full bg-gray-700 flex-shrink-0 flex items-center justify-center font-black text-[10px]">L1</div>
                        <div class="bg-white/5 p-4 rounded-2xl rounded-tl-none border border-white/10">
                            <p class="text-sm italic leading-relaxed text-gray-300">"Impossible de lier le véhicule AB-123-CD au garage Ultra-Speed. L'API renvoie un 403 Forbidden sur le POST /vehicles alors que le token garage est valide."</p>
                            <p class="text-[9px] text-gray-500 font-bold mt-2 font-outfit uppercase tracking-widest">MARC (L1) — 09:42</p>
                        </div>
                    </div>

                    <div class="flex gap-4 max-w-[80%] ml-auto justify-end">
                        <div class="bg-indigo-600/20 p-4 rounded-2xl rounded-tr-none border border-indigo-500/30 text-right">
                            <p class="text-sm italic leading-relaxed text-indigo-100">"Analyse des logs Elastic effectuée. Le token appartient à l'org_22 mais la ressource est verrouillée sur org_21. Suspicion d'erreur de migration de tenant."</p>
                            <p class="text-[9px] text-indigo-400 font-bold mt-2 font-outfit uppercase tracking-widest">KARLAN (L2) — 10:15</p>
                        </div>
                        <div class="w-8 h-8 rounded-full bg-indigo-600 flex-shrink-0 flex items-center justify-center font-black text-[10px]">KM</div>
                    </div>
                </div>

                <div class="relative bg-black/40 rounded-3xl p-1 border border-white/10 flex">
                    <input type="text" placeholder="Ajouter un commentaire ou diagnostic..." class="bg-transparent border-none flex-grow p-6 text-sm font-medium focus:outline-none">
                    <button class="m-2 bg-indigo-600 px-8 rounded-2xl font-black uppercase text-xs tracking-widest shadow-xl">Valider Action</button>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-8">
                <div class="bg-white/[0.02] border border-white/5 rounded-[2rem] p-8">
                    <h3 class="text-[10px] font-black uppercase text-gray-500 tracking-widest mb-4">Métriques Hardcore</h3>
                    <div class="h-24 w-full bg-indigo-500/5 rounded-2xl flex items-end gap-1 p-4">
                        @foreach (var i in Enumerable.Range(0, 20))
                        {
                            <div class="flex-grow bg-indigo-500/30 rounded-full" style="height: @(Random.Shared.Next(20, 100))%"></div>
                        }
                    </div>
                </div>
                <div class="bg-red-600/10 border border-red-500/20 rounded-[2rem] p-8 flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-black italic uppercase leading-none text-red-500">Escalade Critique</h3>
                        <p class="text-[10px] text-gray-500 font-black uppercase tracking-widest mt-2 font-outfit uppercase tracking-widest">Niveau CTO requis</p>
                    </div>
                    <button class="bg-red-600 text-white px-6 py-3 rounded-2xl font-black uppercase text-xs tracking-widest shadow-lg shadow-red-500/20">ALERT CTO</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<EscalatedTicket> escalatedTickets = new()
    {
        new EscalatedTicket { Id = "T-1049", Title = "Sync Passerelle Cloud 403", Category = "Backend", OriginAgent = "Marc", WaitTime = "2h", SeverityColor = "bg-red-500", IsSelected = true },
        new EscalatedTicket { Id = "T-1052", Title = "Timeout Dashboard Stats", Category = "Database", OriginAgent = "Julie", WaitTime = "4h", SeverityColor = "bg-orange-500", IsSelected = false },
        new EscalatedTicket { Id = "T-1061", Title = "Drift Capteur CO2 Pont 4", Category = "Hardware/IoT", OriginAgent = "Marc", WaitTime = "15m", SeverityColor = "bg-green-500", IsSelected = false }
    };

    public class EscalatedTicket
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
        public string OriginAgent { get; set; } = "";
        public string WaitTime { get; set; } = "";
        public string SeverityColor { get; set; } = "";
        public bool IsSelected { get; set; }
    }
}
