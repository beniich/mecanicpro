@page "/admin/support-technique-2"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Support Technique (Mobile)</PageTitle>

<div class="bg-surface text-on-surface font-body selection:bg-primary/30 min-h-screen pb-24 flex flex-col uppercase font-headline italic">
    <!-- TopAppBar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318] flex justify-between items-center px-6 h-16 shadow-lg">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[#f5a623]">precision_manufacturing</span>
            <h1 class="text-2xl font-black tracking-tighter text-[#f5a623] font-brand uppercase italic">MECAPRO</h1>
        </div>
        <button class="active:scale-95 duration-200">
            <span class="material-symbols-outlined text-slate-500">notifications</span>
        </button>
    </header>

    <main class="flex-1 mt-16 px-4 py-6 space-y-8">
        <!-- Hero Section -->
        <section class="space-y-4">
            <div class="flex items-end justify-between">
                <div>
                    <h2 class="text-4xl tracking-wider text-on-surface">SUPPORT TECHNIQUE</h2>
                    <p class="font-technical text-xs text-on-surface-variant uppercase tracking-widest italic not-italic">System Status: Optimal</p>
                </div>
                <div class="h-12 w-12 bg-primary-container/10 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary-container">support_agent</span>
                </div>
            </div>
            <button class="w-full h-16 bg-gradient-to-r from-primary-container to-secondary-container rounded-xl flex items-center justify-center gap-3 shadow-[0_8px_24px_rgba(245,166,35,0.15)] active:scale-[0.98] transition-all text-on-primary-fixed">
                <span class="material-symbols-outlined font-bold">add_circle</span>
                <span class="font-bold uppercase tracking-tight">Ouvrir un ticket</span>
            </button>
        </section>

        <!-- Ticket Cards -->
        <section class="space-y-4">
            <h3 class="text-xl tracking-widest text-on-surface-variant">Tickets Actifs</h3>
            <div class="bg-surface-container-high rounded-xl overflow-hidden relative group">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-secondary shadow-[0_0_12px_rgba(242,100,17,0.4)]"></div>
                <div class="p-5 space-y-4">
                    <div class="flex justify-between items-start">
                        <div>
                            <p class="font-technical text-[10px] text-primary/70 mb-1">ID: #TK-8829-X</p>
                            <h4 class="font-bold text-on-surface text-lg not-italic normal-case">Dysfonctionnement Presse H-400</h4>
                        </div>
                        <span class="bg-error-container/30 text-error px-2 py-1 rounded text-[10px] font-bold uppercase tracking-tighter">Urgent</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Resource Center -->
        <section class="space-y-4">
            <h3 class="text-xl tracking-widest text-on-surface-variant">Centre de ressources</h3>
            <div class="grid grid-cols-2 gap-3 font-body not-italic">
                <div class="bg-surface-container p-4 rounded-xl border border-white/5 uppercase">
                    <span class="material-symbols-outlined text-primary mb-3">menu_book</span>
                    <h5 class="font-bold text-sm text-on-surface">Guides Techniques</h5>
                </div>
            </div>
        </section>
    </main>
</div>
