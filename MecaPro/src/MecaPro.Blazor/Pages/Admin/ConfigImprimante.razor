@page "/settings/config-imprimante"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Configuration Imprimantes</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-white">settings</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-white uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
             <button class="bg-white/5 border border-white/10 px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">print_connect</span> AJOUTER IP
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-6xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-white text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">HARDWARE_OUTPUT_GRID</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Config Impression</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Gestion des files d'impression réseau pour factures, étiquettes et rapports.</p>
            </div>
        </div>

        <!-- Printer Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var printer in printers)
            {
                <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex flex-col relative overflow-hidden group hover:border-white/20 transition-all">
                    <!-- Status Indicator -->
                    <div class="absolute top-8 right-8 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full @(printer.IsOnline ? "bg-[#00FF66] shadow-[0_0_10px_#00FF66]" : "bg-red-500 shadow-[0_0_10px_#EF4444]")"></span>
                        <span class="text-[8px] font-black uppercase text-white/30 tracking-widest">@(printer.IsOnline ? "ONLINE" : "OFFLINE")</span>
                    </div>

                    <div class="w-16 h-16 rounded-2xl bg-black/40 border border-white/10 flex items-center justify-center text-white/40 group-hover:text-white transition-all mb-8">
                        <span class="material-symbols-outlined text-3xl">@(printer.Type == "LABEL" ? "receipt_long" : "print")</span>
                    </div>

                    <h3 class="font-black italic text-2xl uppercase tracking-tighter text-white mb-2">@printer.Name</h3>
                    <p class="text-[10px] font-black uppercase text-white/30 tracking-widest mb-6">IP: @printer.IpAddress</p>

                    <div class="space-y-4 mb-4">
                        <div class="flex justify-between items-center text-[8px] font-black uppercase tracking-widest text-white/40 border-b border-white/5 pb-2">
                            <span>TYPE FLUX</span>
                            <span class="text-white">@printer.Type</span>
                        </div>
                        <div class="flex justify-between items-center text-[8px] font-black uppercase tracking-widest text-white/40 border-b border-white/5 pb-2">
                            <span>FORMAT DÉFAUT</span>
                            <span class="text-white">@printer.Format</span>
                        </div>
                    </div>

                    <div class="mt-8 pt-8 flex gap-2">
                        <button class="flex-grow bg-white/5 border border-white/10 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all">TEST PRINT</button>
                        <button class="w-12 h-12 flex items-center justify-center bg-white/5 border border-white/10 rounded-xl text-white/60 hover:text-white transition-all"><span class="material-symbols-outlined text-sm">settings_input_composite</span></button>
                    </div>
                </div>
            }

            <!-- Add Printer Placeholder -->
             <div class="bg-white/5 border-2 border-dashed border-white/10 rounded-[40px] flex flex-col items-center justify-center text-center p-12 group hover:border-white/30 transition-all cursor-pointer">
                <div class="w-16 h-16 rounded-full bg-surface-container flex items-center justify-center mb-6 group-hover:bg-white/10 transition-all text-white/20 group-hover:text-white">
                    <span class="material-symbols-outlined text-3xl">add_circle</span>
                </div>
                <p class="font-black italic text-lg uppercase tracking-tighter text-white/20 group-hover:text-white transition-all italic">Scanner le Réseau<br/>pour Imprimantes</p>
            </div>
        </div>

        <div class="bg-primary/5 border border-primary/20 rounded-[32px] p-8 mt-12 flex items-center justify-between">
            <div class="flex items-center gap-6">
                <div class="w-14 h-14 bg-primary/20 rounded-2xl flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-3xl">info</span>
                </div>
                <p class="text-xs uppercase font-technical text-white/60 max-w-2xl font-bold leading-relaxed tracking-widest">
                   MecaPro utilise des flux Cloud-Print chiffrés. Assurez-vous que vos imprimantes acceptent les requêtes JSON-IPP sur le port 631.
                </p>
            </div>
            <p class="text-[8px] font-black text-white/10 uppercase tracking-[0.5em] font-technical">ENCRYPTION: AES-256-IP</p>
        </div>

    </main>
</div>

@code {
    private List<PrinterInfo> printers = new()
    {
        new(1, "BUREAU ACCUEIL HP-500", "192.168.1.104", "A4_REVISION", "A4", true),
        new(2, "ATELIER THERMIQUE", "192.168.1.12", "REPAIR_ORDER", "A4", false),
        new(3, "ÉDITEUR ÉTIQUETTES", "192.168.1.42", "LABEL", "ROULEAU_62MM", true),
    };

    record PrinterInfo(int Id, string Name, string IpAddress, string Type, string Format, bool IsOnline);
}
