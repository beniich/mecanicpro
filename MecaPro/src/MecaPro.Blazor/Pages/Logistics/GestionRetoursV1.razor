@page "/logistics/gestion-retours-1"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Red Supply Return Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-rose-600/20 flex items-center justify-center border border-rose-500/30">
                    <span class="material-symbols-outlined text-rose-400">u_turn_left</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Returns <span class="text-rose-500 font-light italic uppercase">Supplier</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">GESTION DES RMA & LOGISTIQUE INVERSE FOURNISSEURS</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-[2rem] flex items-center gap-8">
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">En attente Expé</p>
                      <p class="text-2xl font-black italic text-rose-500 shadow-none border-none border-0">2</p>
                 </div>
                 <div class="w-[1px] h-10 bg-white/10"></div>
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Crédit Avoir</p>
                      <p class="text-2xl font-black italic shadow-none border-none border-0">4,200 €</p>
                 </div>
             </div>
             <button class="bg-rose-600 text-white px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">add_circle</span> NOUVEAU RMA
             </button>
        </div>
    </div>

    <!-- Active RMA Table -->
    <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[3rem] overflow-hidden shadow-2xl relative">
        <div class="p-8 border-b border-white/5 flex justify-between items-center">
            <h3 class="text-xl font-black italic uppercase tracking-tighter italic shadow-none border-none">Suivi des Demandes de Retour (RMA)</h3>
            <div class="flex gap-4">
                 <button class="bg-white/5 border border-white/10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">Voir Archives</button>
            </div>
        </div>

        <div class="p-0">
             <table class="w-full text-left border-collapse">
                  <thead>
                       <tr class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] bg-black/20">
                            <th class="px-10 py-5">RMA ID</th>
                            <th class="px-10 py-5">Pièce Concernée</th>
                            <th class="px-10 py-5">Raison du Retour</th>
                            <th class="px-10 py-5">Fournisseur</th>
                            <th class="px-10 py-5">Statut</th>
                            <th class="px-10 py-5 text-right">Valeur Estimée</th>
                       </tr>
                  </thead>
                  <tbody class="divide-y divide-white/[0.05]">
                       @foreach (var rma in activeRmas)
                       {
                           <tr class="hover:bg-white/[0.01] transition-all group">
                                <td class="px-10 py-8">
                                     <span class="text-sm font-black italic text-rose-500">#@rma.Id</span>
                                </td>
                                <td class="px-10 py-8">
                                     <div class="flex items-center gap-4">
                                          <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center font-black text-xs">@rma.Ref.Substring(0, 2)</div>
                                          <div>
                                               <p class="text-sm font-black italic uppercase italic tracking-tight italic uppercase tracking-widest">@rma.PartLabel</p>
                                               <p class="text-[9px] text-gray-500 font-extrabold uppercase mt-1 italic shadow-none border-none border-0">@rma.Ref</p>
                                          </div>
                                     </div>
                                </td>
                                <td class="px-10 py-8">
                                     <span class="text-[10px] font-black uppercase text-gray-400 italic shadow-none border-none">@rma.Reason</span>
                                </td>
                                <td class="px-10 py-8">
                                     <span class="text-xs font-black uppercase italic shadow-none border-none">@rma.Supplier</span>
                                </td>
                                <td class="px-10 py-8">
                                     <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-tighter border @(GetRmaStyle(rma.Status))">@rma.Status</span>
                                </td>
                                <td class="px-10 py-8 text-right">
                                     <p class="text-xl font-black italic">@rma.Value <span class="text-xs text-gray-500">€</span></p>
                                </td>
                           </tr>
                       }
                  </tbody>
             </table>
        </div>
    </div>
</div>

@code {
    private List<RmaEntry> activeRmas = new()
    {
        new RmaEntry { Id = "RMA-9921", PartLabel = "ALTERNATEUR V8 4.0L", Ref = "ALT-441-B", Reason = "DÉFAUT ÉLECTRIQUE", Supplier = "M-AUTO DISTRI", Status = "ATTENTE ÉTIQUETTE", Value = "480.00" },
        new RmaEntry { Id = "RMA-9922", PartLabel = "KIT FREINAGE BMW MINI", Ref = "KIT-MIN-99", Reason = "ERREUR RÉFÉRENCE", Supplier = "RENAULT PIÈCES", Status = "EXPÉDIÉ", Value = "1,120.40" },
        new RmaEntry { Id = "RMA-9923", PartLabel = "BATTERIE ZOE LI-ION", Ref = "BAT-ZOE-ZE", Reason = "GARANTIE CONSTRUCTEUR", Supplier = "VALEO PRO", Status = "VALIDÉ", Value = "2,600.00" }
    };

    private string GetRmaStyle(string status) => status switch
    {
        "ATTENTE ÉTIQUETTE" => "border-rose-500/30 text-rose-500 bg-rose-500/10",
        "EXPÉDIÉ" => "border-sky-500/30 text-sky-500 bg-sky-500/10",
        "VALIDÉ" => "border-emerald-500/30 text-emerald-500 bg-emerald-500/10",
        _ => "border-white/20 text-gray-400 bg-white/5"
    };

    public class RmaEntry {
        public string Id { get; set; } = "";
        public string PartLabel { get; set; } = "";
        public string Ref { get; set; } = "";
        public string Reason { get; set; } = "";
        public string Supplier { get; set; } = "";
        public string Status { get; set; } = "";
        public string Value { get; set; } = "";
    }
}
