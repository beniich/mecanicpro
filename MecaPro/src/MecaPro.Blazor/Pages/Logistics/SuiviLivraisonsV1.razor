@page "/logistics/suivi-livraisons-1"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Logistics Webhook Map Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-sky-500/20 flex items-center justify-center border border-sky-500/30">
                    <span class="material-symbols-outlined text-sky-400">local_shipping</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Supply <span class="text-sky-500 font-light">TRACKER</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">SUIVI EN TEMPS RÉEL DES COLIS ET LIVRAISONS EN TRANSIT</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-[2rem] flex items-center gap-8">
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Livraisons Ce Jour</p>
                      <p class="text-2xl font-black italic text-sky-500 shadow-none border-none border-0">5</p>
                 </div>
                 <div class="w-[1px] h-10 bg-white/10"></div>
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Hub de Transit</p>
                      <p class="text-2xl font-black italic shadow-none border-none border-0">VEMARS (95)</p>
                 </div>
             </div>
        </div>
    </div>

    <!-- Tracking Feed Hub -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        <!-- Vertical Timeline Feed -->
        <div class="lg:col-span-1 border-r border-white/5 pr-8 space-y-10 relative">
             <div class="absolute right-[-1px] top-0 bottom-0 w-[2px] bg-gradient-to-b from-sky-500/40 via-sky-500/10 to-transparent"></div>
             
             @foreach (var pkg in trackings)
             {
                 <div class="bg-[#111318]/40 border border-white/5 rounded-3xl p-6 group cursor-pointer hover:bg-white/5 transition-all @(pkg.IsActive ? "border-sky-500/30 ring-2 ring-sky-500/10" : "")">
                      <div class="flex justify-between items-center mb-4">
                           <span class="text-[9px] font-black italic uppercase tracking-widest text-sky-500 shadow-none border-none border-0">#@pkg.TrackingID</span>
                           <span class="material-symbols-outlined text-gray-700 text-xs">open_in_new</span>
                      </div>
                      <h3 class="text-sm font-black italic uppercase tracking-tight italic uppercase tracking-widest italic shadow-none border-none">@pkg.Supplier</h3>
                      <p class="text-[10px] text-gray-500 font-black uppercase mt-1 italic shadow-none border-none border-0">STATUS: @pkg.Status</p>
                      
                      <div class="mt-4 flex items-center justify-between">
                           <p class="text-xs font-black italic italic @(pkg.IsDelayed ? "text-red-500" : "text-emerald-500") shadow-none border-none border-0">ETA: @pkg.ETA</p>
                           <p class="text-[9px] text-gray-700 font-extrabold pb-0.5 border-b border-gray-800 italic shadow-none border-none shadow-none border-0">@pkg.Carrier</p>
                      </div>
                 </div>
             }
        </div>

        <!-- Interactive Map / Map Placeholder -->
        <div class="lg:col-span-3 space-y-10">
             <div class="bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[4rem] p-12 overflow-hidden shadow-2xl relative">
                  <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6">
                       <h3 class="text-2xl font-black italic uppercase tracking-tighter italic shadow-none border-none">Localisation Géographique des Livraisons Active</h3>
                       <div class="bg-black/40 border border-white/10 rounded-xl px-4 py-2 flex items-center gap-4">
                            <span class="material-symbols-outlined text-emerald-500 text-xs shadow-none border-none border-0">satellite_alt</span>
                            <span class="text-[10px] font-black uppercase text-gray-400 italic shadow-none border-none">SIGNAL WEBHOOK: ACTIF</span>
                       </div>
                  </div>

                  <!-- Dark World Map Placeholder SVG -->
                  <div class="w-full aspect-video bg-black/40 border border-white/5 rounded-[3rem] flex items-center justify-center relative group">
                        <span class="material-symbols-outlined text-[20rem] text-white/[0.01] pointer-events-none select-none">travel_explore</span>
                        
                        <!-- Pulse Point Example -->
                        <div class="absolute top-[40%] left-[60%] w-6 h-6 bg-sky-500 rounded-full animate-ping opacity-60"></div>
                        <div class="absolute top-[40%] left-[60%] w-3 h-3 bg-sky-500 rounded-full shadow-[0_0_20px_rgba(14,165,233,0.8)] flex items-center justify-center">
                             <span class="text-[8px] font-black absolute bottom-full mb-2 uppercase text-white bg-black/80 px-2 py-1 rounded-lg italic shadow-none border-none">CHRONOPOST — VEMARS</span>
                        </div>
                  </div>

                  <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-6">
                       @foreach (var hub in hubPoints)
                       {
                           <div class="p-6 bg-white/5 rounded-[2rem] border border-white/5 flex flex-col gap-2">
                                <p class="text-[9px] text-gray-500 font-extrabold uppercase mb-1 italic shadow-none border-none">Plateforme @hub.Name</p>
                                <p class="text-sm font-black italic uppercase italic tracking-tighter italic shadow-none border-none">@hub.City</p>
                                <p class="text-[10px] text-emerald-500 font-black italic uppercase mt-2 italic shadow-none border-none border-0">Colis @hub.Count</p>
                           </div>
                       }
                  </div>
             </div>
        </div>
    </div>
</div>

@code {
    private List<TrackingPkg> trackings = new()
    {
        new TrackingPkg { TrackingID = "CH-9921-X", Supplier = "M-AUTO DISTRI", Carrier = "CHRONOPOST", Status = "EN LIVRAISON", ETA = "14:30 TODAY", IsActive = true, IsDelayed = false },
        new TrackingPkg { TrackingID = "DH-4410-L", Supplier = "VALEO PRO", Carrier = "DHL EXPRESS", Status = "HUB DE TRI", ETA = "16:15 TODAY", IsActive = false, IsDelayed = false },
        new TrackingPkg { TrackingID = "LP-8842-P", Supplier = "BOSCH DE", Carrier = "LA POSTE", Status = "EXPÉDIÉ", ETA = "TOMORROW", IsActive = false, IsDelayed = true },
        new TrackingPkg { TrackingID = "CH-441-A", Supplier = "PIRELLI SPA", Carrier = "CHRONOPOST", Status = "EN TRANSIT", ETA = "TODAY 15:00", IsActive = false, IsDelayed = false }
    };

    private List<HubPoint> hubPoints = new()
    {
        new HubPoint { Name = "Logidex", City = "VÉMARS (95)", Count = 2 },
        new HubPoint { Name = "DistriPort", City = "ROISSY (95)", Count = 1 },
        new HubPoint { Name = "MecaHub", City = "AULNAY (93)", Count = 2 }
    };

    public class TrackingPkg {
        public string TrackingID { get; set; } = "";
        public string Supplier { get; set; } = "";
        public string Carrier { get; set; } = "";
        public string Status { get; set; } = "";
        public string ETA { get; set; } = "";
        public bool IsActive { get; set; }
        public bool IsDelayed { get; set; }
    }

    public class HubPoint {
        public string Name { get; set; } = "";
        public string City { get; set; } = "";
        public int Count { get; set; }
    }
}
