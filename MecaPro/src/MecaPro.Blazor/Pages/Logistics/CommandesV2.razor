@page "/stock/commandes-2"
@using System.Collections.Generic

<div class="min-h-screen bg-[#0d0e12] text-white p-8 font-['Outfit']">
    <!-- Red Alert Logistics Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-red-600/20 flex items-center justify-center border border-red-500/30 shadow-[0_0_40px_rgba(239,68,68,0.15)] overflow-hidden relative group">
                    <span class="material-symbols-outlined text-red-500 text-3xl animate-pulse">timer_off</span>
                    <div class="absolute inset-x-0 bottom-0 h-1 bg-red-600"></div>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter">Delay <span class="text-red-500">Monitor</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">SURVEILLANCE DES COMMANDES EN RETARD DE LIVRAISON</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-[2rem] flex items-center gap-8">
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Retards S1</p>
                      <p class="text-2xl font-black italic text-red-500">3</p>
                 </div>
                 <div class="w-[1px] h-10 bg-white/10"></div>
                 <div class="text-center">
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Moyenne Retard</p>
                      <p class="text-2xl font-black italic">4.2 <span class="text-xs text-white/50 lowercase">jours</span></p>
                 </div>
             </div>
        </div>
    </div>

    <!-- Delayed Orders Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var order in delayedOrders)
        {
            <div class="bg-[#111318]/80 backdrop-blur-3xl border border-red-500/20 rounded-[3rem] p-10 hover:bg-white/[0.04] transition-all group overflow-hidden relative cursor-pointer shadow-2xl">
                 <div class="absolute -right-8 -top-8 w-24 h-24 bg-red-600/10 blur-[50px] opacity-40"></div>
                 
                 <div class="flex justify-between items-start mb-8">
                      <div>
                           <span class="text-[10px] font-black italic uppercase tracking-widest text-red-500 bg-red-500/10 px-3 py-1 rounded-full border border-red-500/30 shadow-none border-none">RETARD +@order.DelayDays J.</span>
                           <h3 class="text-2xl font-black italic uppercase italic tracking-tighter mt-4 italic shadow-none border-none">@order.Supplier</h3>
                           <p class="text-[10px] text-gray-500 font-black uppercase mt-1 italic shadow-none border-none border-0">RÉF : #@order.Id</p>
                      </div>
                      <div class="w-12 h-12 rounded-xl bg-black border border-white/10 flex items-center justify-center font-black text-xs">@order.Supplier.Substring(0, 1)</div>
                 </div>

                 <div class="bg-black/40 p-6 rounded-[2rem] border border-white/5 mb-10">
                      <div class="flex justify-between items-center mb-1 text-[10px]">
                           <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0">ÉCHÉANCE INITIALE</span>
                           <span class="font-black text-gray-300">@order.ExpectedDate</span>
                      </div>
                      <div class="flex justify-between items-center mt-3 text-[10px]">
                           <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0">MONTANT COMMANDE</span>
                           <span class="font-black italic text-orange-500">@order.Amount €</span>
                      </div>
                 </div>

                 <div class="flex gap-2">
                      <button class="flex-grow bg-red-600 text-white py-4 rounded-2xl font-black uppercase text-[10px] tracking-widest shadow-xl shadow-red-900/40">RELANCER FOURNISSEUR</button>
                      <button class="w-14 h-14 bg-white/5 rounded-2xl border border-white/10 flex items-center justify-center hover:bg-white/10 transition-all">
                           <span class="material-symbols-outlined text-sm">mail</span>
                      </button>
                 </div>
            </div>
        }
    </div>
</div>

@code {
    private List<DelayedOrder> delayedOrders = new()
    {
        new DelayedOrder { Id = "BC-2025-992", Supplier = "M-AUTO DISTRI", DelayDays = 5, ExpectedDate = "15 Mar 2026", Amount = "2,840.00" },
        new DelayedOrder { Id = "BC-2025-998", Supplier = "RENAULT PIÈCES", DelayDays = 3, ExpectedDate = "17 Mar 2026", Amount = "1,120.00" },
        new DelayedOrder { Id = "BC-2026-003", Supplier = "CHRONO-PIECES", DelayDays = 2, ExpectedDate = "18 Mar 2026", Amount = "450.50" },
        new DelayedOrder { Id = "BC-2025-981", Supplier = "BOSCH PRO", DelayDays = 12, ExpectedDate = "08 Mar 2026", Amount = "8,400.00" }
    };

    public class DelayedOrder {
        public string Id { get; set; } = "";
        public string Supplier { get; set; } = "";
        public int DelayDays { get; set; }
        public string ExpectedDate { get; set; } = "";
        public string Amount { get; set; } = "";
    }
}
