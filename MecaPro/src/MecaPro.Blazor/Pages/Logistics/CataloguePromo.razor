@page "/stock/catalogue-promo"
@using System.Collections.Generic

<div class="min-h-screen bg-[#0d0e12] text-white p-8 font-['Outfit']">
    <!-- Flash Sale / Promo Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-orange-600/20 flex items-center justify-center border border-orange-500/30">
                    <span class="material-symbols-outlined text-orange-500 text-3xl animate-bounce">sell</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Flash <span class="text-orange-500 font-light italic uppercase shadow-none border-none">Promos</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">OFFRES TEMPORAIRES & VENTES FLASH LOGISTIQUE</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-3 px-6 rounded-2xl flex items-center gap-6">
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">Offres Actives</p>
                      <p class="text-xl font-black italic text-orange-500 italic tracking-tighter shadow-none border-none">X3</p>
                 </div>
                 <div class="w-[1px] h-8 bg-white/10"></div>
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">Prochain Flash</p>
                      <p class="text-xl font-black italic shadow-none border-none border-0 uppercase tracking-widest leading-relaxed">02:14:55</p>
                 </div>
             </div>
        </div>
    </div>

    <!-- Featured Promo Matrix -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        @foreach (var promo in activePromos)
        {
            <div class="bg-[#111318]/60 backdrop-blur-3xl border @(promo.IsFlash ? "border-orange-500/40" : "border-white/10") rounded-[4rem] p-12 hover:bg-white/[0.04] transition-all cursor-pointer group shadow-2xl relative overflow-hidden flex flex-col items-center text-center">
                 @if (promo.IsFlash)
                 {
                     <div class="absolute top-0 right-0 p-8">
                         <span class="bg-orange-600 text-[8px] font-black px-3 py-1 rounded-full uppercase tracking-widest animate-pulse italic shadow-none border-none">FLASH SALE</span>
                     </div>
                 }
                 
                 <div class="w-32 h-32 bg-black border border-white/5 rounded-[3rem] mb-10 flex items-center justify-center group-hover:scale-105 transition-transform relative overflow-hidden">
                      <span class="material-symbols-outlined text-7xl text-gray-800 opacity-20 shadow-none border-none border-0">@(promo.Icon)</span>
                      <div class="absolute inset-0 bg-gradient-to-tr from-orange-500/20 to-transparent"></div>
                 </div>

                 <h3 class="text-2xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none mb-4 italic uppercase tracking-widest leading-relaxed">@promo.Title</h3>
                 <p class="text-xs font-black italic text-gray-500 italic mb-10 uppercase italic tracking-widest leading-relaxed line-clamp-2 italic">@promo.Description</p>
                 
                 <div class="grid grid-cols-2 gap-4 w-full mb-12">
                      <div class="bg-white/5 border border-white/5 p-6 rounded-3xl">
                           <p class="text-[8px] text-gray-600 font-black uppercase mb-2 italic shadow-none border-none border-0 italic leading-relaxed">PRIX AVANT</p>
                           <p class="text-lg font-bold text-gray-600 line-through italic shadow-none border-none italic leading-relaxed uppercase tracking-widest">@promo.OldPrice €</p>
                      </div>
                      <div class="bg-orange-500/10 border border-orange-500/20 p-6 rounded-3xl">
                           <p class="text-[8px] text-orange-500 font-extrabold mb-2 italic shadow-none border-none border-0 italic leading-relaxed uppercase tracking-widest">OFFRE FLASH</p>
                           <p class="text-2xl font-black italic text-orange-500 shadow-none border-none italic leading-relaxed uppercase tracking-widest">@promo.NewPrice <span class="text-xs">€</span></p>
                      </div>
                 </div>

                 <div class="mt-auto w-full">
                      <div class="flex justify-between items-center mb-4 text-[9px] font-black uppercase tracking-widest text-gray-700 italic">
                           <span>Reste @promo.StockUnits unités</span>
                           <span class="text-orange-500 uppercase italic">@promo.TimeLeft Restants</span>
                      </div>
                      <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden mb-8">
                           <div class="h-full bg-orange-600" style="width: @(promo.StockUnits * 100 / promo.TotalUnits)%"></div>
                      </div>
                      
                      <button class="w-full @(promo.IsFlash ? "bg-orange-600 text-black border-orange-600 shadow-xl shadow-orange-900/40" : "bg-white/5 border border-white/10 text-white") py-5 px-4 rounded-3xl font-black uppercase text-[10px] tracking-widest italic transition-all shadow-none border-none italic leading-relaxed uppercase tracking-widest font-outfit uppercase tracking-widest">AJOUTER AU PANIER FLASH</button>
                 </div>
            </div>
        }
    </div>
</div>

@code {
    private List<PromoInfo> activePromos = new()
    {
        new PromoInfo { 
            Title = "Kit Vidange Premium V6", 
            Description = "Ensemble comprenant 10L d'huile CASTROL EDGE + 2 Filtres Bosch série Pro.", 
            Icon = "local_gas_station", 
            OldPrice = 145.00, 
            NewPrice = 85.20, 
            IsFlash = true, 
            StockUnits = 12, 
            TotalUnits = 50, 
            TimeLeft = "12H 45M" 
        },
        new PromoInfo { 
            Title = "Lot Alternateurs 2026", 
            Description = "Pack de 3 alternateurs PSA révisés. Vendu en lot uniquement pour pro.", 
            Icon = "bolt", 
            OldPrice = 420.00, 
            NewPrice = 295.00, 
            IsFlash = false, 
            StockUnits = 2, 
            TotalUnits = 5, 
            TimeLeft = "3 JOURS" 
        },
        new PromoInfo { 
            Title = "Gomme Été Michelin PS5", 
            Description = "Set de 4 pneus 245/45 R18 (Montage inclus en atelier local).", 
            Icon = "tire_repair", 
            OldPrice = 880.00, 
            NewPrice = 740.00, 
            IsFlash = true, 
            StockUnits = 4, 
            TotalUnits = 20, 
            TimeLeft = "04H 22M" 
        }
    };

    public class PromoInfo {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public double OldPrice { get; set; }
        public double NewPrice { get; set; }
        public bool IsFlash { get; set; }
        public int StockUnits { get; set; }
        public int TotalUnits { get; set; }
        public string TimeLeft { get; set; } = "";
    }
}
