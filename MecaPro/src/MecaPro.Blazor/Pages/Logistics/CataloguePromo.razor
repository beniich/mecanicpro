@page "/stock/catalogue-promo"
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MecaPro — Catalogue & Promos (Glass)</PageTitle>

<div class="min-h-screen font-sans pb-10">

    <!-- Flash Sale / Promo Header -->
    <div class="glass-card !border-x-0 !border-t-0 !rounded-none px-6 py-6 mb-8 border-b border-[#384358]">
        <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <div class="flex items-center gap-4 mb-2">
                    <div class="w-12 h-12 rounded-xl bg-[#242F49] border border-[#384358] flex items-center justify-center text-[#FFA586] shadow-inner">
                        <span class="material-symbols-outlined text-2xl animate-pulse drop-shadow-[0_0_8px_#FFA586]">sell</span>
                    </div>
                    <h1 class="text-2xl font-black headline-font text-white drop-shadow-sm">Flash Promos</h1>
                </div>
                <p class="text-[11px] font-bold text-[#A0ABC0] uppercase tracking-widest ml-1">Offres temporaires & Ventes flash logistique</p>
            </div>
            
            <div class="flex gap-4">
                 <div class="bg-[#161E2F]/60 border border-[#384358] py-2 px-6 rounded-2xl flex items-center gap-4 shadow-inner">
                     <div>
                          <p class="text-[10px] text-[#A0ABC0] font-bold tracking-widest uppercase mb-0.5">Offres Actives</p>
                          <p class="text-2xl font-black headline-font text-[#FFA586] drop-shadow-[0_0_5px_rgba(255,165,134,0.5)]">@(activePromos?.Count ?? 0)</p>
                     </div>
                 </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="flex justify-center p-20">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-[#FFA586] shadow-[0_0_15px_#FFA586]"></div>
        </div>
    }
    else
    {
        <!-- Featured Promo Matrix -->
        <div class="max-w-screen-2xl mx-auto grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 px-6">
            @foreach (var promo in activePromos ?? new())
            {
                <div class="glass-card p-8 hover:border-[#FFA586]/60 transition-all cursor-pointer group relative overflow-hidden flex flex-col hover:shadow-[0_0_30px_rgba(255,165,134,0.15)]">
                    @if (promo.IsFlash)
                    {
                        <div class="absolute top-5 right-5 z-10">
                            <span class="bg-[#FFA586]/20 text-[#FFA586] border border-[#FFA586]/40 shadow-[0_0_15px_rgba(255,165,134,0.3)] text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest animate-pulse flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-[12px]">bolt</span> Flash
                            </span>
                        </div>
                    }
                    
                    <div class="w-20 h-20 bg-[#161E2F] border border-[#384358] rounded-2xl mb-6 flex items-center justify-center group-hover:bg-[#FFA586]/10 group-hover:border-[#FFA586]/30 transition-all shadow-inner">
                        <span class="material-symbols-outlined text-4xl text-[#A0ABC0] group-hover:text-[#FFA586] transition-colors drop-shadow-sm">@(promo.Icon)</span>
                    </div>

                    <h3 class="text-xl font-bold headline-font text-white mb-2 leading-tight drop-shadow-sm group-hover:text-[#FFA586] transition-colors">@promo.Title</h3>
                    <p class="text-xs font-medium text-[#A0ABC0] mb-6 line-clamp-3 leading-relaxed">@promo.Description</p>
                    
                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div class="bg-[#161E2F]/40 border border-[#384358]/50 p-4 rounded-xl shadow-inner">
                                <p class="text-[9px] text-[#A0ABC0] font-black uppercase tracking-widest mb-1 opacity-80">Prix catalogue</p>
                                <p class="text-sm font-bold text-[#A0ABC0] line-through decoration-[#B51A2B]/70 decoration-2">@(promo.OldPrice.ToString("N2")) €</p>
                        </div>
                        <div class="bg-[#FFA586]/10 border border-[#FFA586]/30 shadow-[0_0_15px_rgba(255,165,134,0.1)] p-4 rounded-xl">
                                <p class="text-[9px] text-[#FFA586] font-black uppercase tracking-widest mb-1 flex items-center gap-1"><span class="w-1.5 h-1.5 bg-[#FFA586] rounded-full inline-block animate-pulse"></span> Net Flash</p>
                                <p class="text-xl font-black headline-font text-white leading-none drop-shadow-sm">@(promo.NewPrice.ToString("N2")) <span class="text-xs font-bold text-[#FFA586]">€</span></p>
                        </div>
                    </div>

                    <div class="mt-auto pt-5 border-t border-[#384358]/50">
                        <div class="flex justify-between items-center mb-2 text-[10px] font-black uppercase tracking-widest text-[#A0ABC0]">
                                <span>@promo.StockUnits en stock</span>
                                <span class="@(promo.IsFlash ? "text-[#FFA586]" : "text-white")">⏱ @promo.TimeLeft</span>
                        </div>
                        <div class="w-full h-1.5 bg-[#161E2F] border border-[#384358]/50 rounded-full overflow-hidden mb-6">
                                <div class="h-full @(promo.IsFlash ? "bg-[#FFA586] shadow-[0_0_10px_#FFA586]" : "bg-[#4ade80] shadow-[0_0_10px_#4ade80]")" style="width: @(Math.Min(100, promo.StockUnits * 10))%"></div>
                        </div>
                        
                        <button class="w-full @(promo.IsFlash ? "btn-electric" : "btn-ghost-glass text-xs hover:border-[#4ade80] hover:text-[#4ade80]") py-3 rounded-xl">
                            <span class="flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[16px]">add_shopping_cart</span> Ajouter au Panier
                            </span>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<PromoInfo>? activePromos;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        var pagedResult = await Api.GetAsync<PagedResult<PartDto>>("/api/v1/parts?page=1&pageSize=6");
        
        if (pagedResult?.Items != null)
        {
            activePromos = pagedResult.Items.Select(p => new PromoInfo {
                Title = p.Name,
                Description = $"Référence technique: {p.Reference}. Marque: {p.Brand ?? "OEM"}. Composant haute durabilité certifié MecaPro, avec garantie constructeur préservée.",
                Icon = GetIcon(p.Category),
                OldPrice = (double)p.UnitPrice * 1.3,
                NewPrice = (double)p.UnitPrice,
                IsFlash = p.IsLowStock,
                StockUnits = p.StockQuantity,
                TotalUnits = 100,
                TimeLeft = p.IsLowStock ? "02H 15M" : "3 JOURS"
            }).ToList();
        }
        loading = false;
    }

    private string GetIcon(string category) => category?.ToLower() switch {
        "moteur" => "settings",
        "freinage" => "stop_circle",
        "pneus" => "tire_repair",
        "electronique" => "cable",
        _ => "inventory_2"
    };

    public class PromoInfo {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public double OldPrice { get; set; }
        public double NewPrice { get; set; }
        public bool IsFlash { get; set; }
        public int StockUnits { get; set; }
        public int TotalUnits { get; set; }
        public string TimeLeft { get; set; } = "";
    }
}
