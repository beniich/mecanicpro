@page "/stock/detail-commande"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Clean Sheet Detail Header -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-orange-600/20 flex items-center justify-center border border-orange-500/30">
                    <span class="material-symbols-outlined text-orange-500">receipt_long</span>
                </div>
                <div>
                   <h1 class="text-4xl font-black italic uppercase tracking-tighter">Order <span class="text-orange-500">Details</span></h1>
                   <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em] mt-1 shadow-none border-none">BON DE COMMANDE FOURNISSEUR #BC-2026-0042</p>
                </div>
            </div>
        </div>
        
        <div class="flex gap-4">
             <button class="bg-white/5 border border-white/10 px-8 py-3 rounded-2xl font-black uppercase text-xs tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">IMPRIMER BC</button>
             <button class="bg-orange-600 text-black px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">verified</span> VALIDER RÉCEPTION
             </button>
        </div>
    </div>

    <!-- Main Detail Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        <!-- Supplier Brief & Meta -->
        <div class="lg:col-span-1 space-y-8">
             <div class="bg-[#111318]/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-10 relative overflow-hidden">
                  <div class="absolute -right-12 -top-12 w-32 h-32 bg-orange-600/10 blur-[50px] opacity-40"></div>
                  
                  <h3 class="text-xs font-black uppercase text-gray-500 tracking-widest mb-10 italic">Informations Fournisseur</h3>
                  
                  <div class="flex flex-col items-center text-center mb-10">
                       <div class="w-24 h-24 rounded-[2.5rem] bg-black border-2 border-orange-500/30 flex items-center justify-center font-black text-3xl italic mb-4">MA</div>
                       <h4 class="text-xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none">M-AUTO DISTRI FR</h4>
                       <p class="text-[9px] text-gray-500 font-black uppercase tracking-widest mt-1 italic shadow-none border-none border-0">SIRET : 4491 002 998 12</p>
                  </div>

                  <div class="space-y-6 pt-10 border-t border-white/5">
                       <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0 italic leading-relaxed">Date BC</span>
                            <span class="font-black italic text-gray-300">20 Mar 2026</span>
                       </div>
                       <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0 italic leading-relaxed">Mode Paiement</span>
                            <span class="font-black italic text-gray-300">VIREMENT 30J</span>
                       </div>
                  </div>
             </div>

             <div class="bg-orange-600/5 border border-orange-500/20 rounded-[2rem] p-8">
                  <p class="text-[9px] text-orange-400 font-black uppercase tracking-widest mb-4 italic shadow-none border-none border-0">Notes Logistiques</p>
                  <p class="text-xs font-medium leading-relaxed italic text-gray-300 italic">Attention : Livraison partielle possible sur les filtres à particules (Prio #1).</p>
             </div>
        </div>

        <!-- Order Lines Table -->
        <div class="lg:col-span-3">
             <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[3.5rem] overflow-hidden shadow-2xl">
                  <div class="p-8 border-b border-white/5">
                       <h3 class="text-xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none">Détail des Lignes de Commande</h3>
                  </div>

                  <div class="p-0">
                       <table class="w-full text-left border-collapse">
                            <thead>
                                 <tr class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] bg-black/20">
                                      <th class="px-10 py-5">Référence / Produit</th>
                                      <th class="px-10 py-5 text-center">Quantité</th>
                                      <th class="px-10 py-5">Prix Unitaire</th>
                                      <th class="px-10 py-5 text-right">Total HT</th>
                                 </tr>
                            </thead>
                            <tbody class="divide-y divide-white/[0.05]">
                                 @foreach (var line in orderLines)
                                 {
                                     <tr class="hover:bg-white/[0.01] transition-all group">
                                         <td class="px-10 py-8">
                                              <p class="text-sm font-black italic text-orange-500 uppercase italic tracking-widest">@line.Ref</p>
                                              <p class="text-[10px] text-gray-500 font-black uppercase mt-1 italic shadow-none border-none border-0">@line.Label</p>
                                         </td>
                                         <td class="px-10 py-8 text-center">
                                              <p class="text-xl font-black italic text-white uppercase italic tracking-tighter">@line.Qty</p>
                                              <p class="text-[9px] text-gray-700 font-extrabold uppercase mt-1 italic shadow-none border-none border-0">UNITÉS</p>
                                         </td>
                                         <td class="px-10 py-8">
                                              <p class="text-sm font-black italic text-gray-300 uppercase italic tracking-widest shadow-none border-none">@line.UnitPrice <span class="text-xs text-gray-500">€</span></p>
                                         </td>
                                         <td class="px-10 py-8 text-right">
                                              <p class="text-xl font-black italic italic @(line.Total > 500 ? "text-orange-500" : "text-white") shadow-none border-none border-0">@line.Total <span class="text-xs text-gray-500">€</span></p>
                                         </td>
                                     </tr>
                                 }
                            </tbody>
                       </table>
                  </div>

                  <div class="p-12 bg-black/40 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-10">
                        <div class="flex gap-10">
                             <div>
                                  <p class="text-[9px] text-gray-600 font-extrabold uppercase tracking-widest mb-1 italic shadow-none border-none">TVA (20%)</p>
                                  <p class="text-xl font-black italic text-gray-500 italic shadow-none border-none">248.42 <span class="text-xs">€</span></p>
                             </div>
                             <div class="w-[1px] h-10 bg-white/5"></div>
                             <div>
                                  <p class="text-[9px] text-gray-600 font-extrabold uppercase tracking-widest mb-1 italic shadow-none border-none">TOTAL TTC</p>
                                  <p class="text-3xl font-black italic text-orange-500 italic shadow-none border-none shadow-xl shadow-orange-900/40">1,490.52 <span class="text-xs text-white/50">€</span></p>
                             </div>
                        </div>
                  </div>
             </div>
        </div>
    </div>
</div>

@code {
    private List<OrderLine> orderLines = new()
    {
        new OrderLine { Ref = "FLT-9921", Label = "FILTRE À HUILE PURFLUX L358A", Qty = 24, UnitPrice = "8.50", Total = 204.00 },
        new OrderLine { Ref = "BRK-441-D", Label = "DISQUE DE FREIN VENTILÉ BMW SERIE 1 (PAIRE)", Qty = 6, UnitPrice = "142.00", Total = 852.00 },
        new OrderLine { Ref = "IGN-772-B", Label = "BOUGIE ALLUMAGE NGK IRIDIUM X4", Qty = 12, UnitPrice = "15.50", Total = 186.10 }
    };

    public class OrderLine {
        public string Ref { get; set; } = "";
        public string Label { get; set; } = "";
        public int Qty { get; set; }
        public string UnitPrice { get; set; } = "";
        public double Total { get; set; }
    }
}
