@page "/clients/{CustomerId:guid}/add-vehicle"
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Nouveau Véhicule</PageTitle>

<div class="max-w-4xl mx-auto p-8">
    <div class="mb-12">
        <span class="text-primary text-[10px] tracking-[0.4em] uppercase mb-2 block font-black italic">FLEET_EXPANSION_02</span>
        <h2 class="text-6xl font-black tracking-tighter italic uppercase text-white">AJOUT VÉHICULE</h2>
        <p class="text-on-surface-variant font-technical uppercase mt-4 opacity-50">Enregistrement d'une nouvelle unité dans le parc client</p>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="bg-error/10 border border-error/20 p-4 rounded-xl text-error text-xs font-black uppercase mb-8">
            ERREUR_SYSTÈME: @error
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-6">
            <div class="bg-[#352372] p-6 rounded-3xl border border-white/5 space-y-4 shadow-xl">
                 <div>
                    <label class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">Immatriculation</label>
                    <input @bind="command.LicensePlate" type="text" placeholder="AB-123-CD" class="w-full bg-[#111318] border border-white/5 rounded-xl px-4 py-3 font-technical text-white focus:border-primary outline-none transition-all uppercase"/>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">Marque</label>
                        <input @bind="command.Make" type="text" placeholder="BMW, Audi..." class="w-full bg-[#111318] border border-white/5 rounded-xl px-4 py-3 font-technical text-white focus:border-primary outline-none transition-all uppercase"/>
                    </div>
                    <div>
                        <label class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">Modèle</label>
                        <input @bind="command.Model" type="text" placeholder="M4, A3..." class="w-full bg-[#111318] border border-white/5 rounded-xl px-4 py-3 font-technical text-white focus:border-primary outline-none transition-all uppercase"/>
                    </div>
                </div>
            </div>

            <div class="bg-[#352372] p-6 rounded-3xl border border-white/5 space-y-4 shadow-xl">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">Année</label>
                        <input @bind="command.Year" type="number" class="w-full bg-[#111318] border border-white/5 rounded-xl px-4 py-3 font-technical text-white focus:border-primary outline-none transition-all"/>
                    </div>
                    <div>
                        <label class="text-[10px] font-black uppercase tracking-widest text-primary mb-2 block">Kilométrage</label>
                        <input @bind="command.Mileage" type="number" class="w-full bg-[#111318] border border-white/5 rounded-xl px-4 py-3 font-technical text-white focus:border-primary outline-none transition-all"/>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-[#111318] rounded-3xl p-8 border border-white/5 flex flex-col justify-between shadow-2xl">
            <div>
                <h3 class="text-primary font-black italic uppercase tracking-widest mb-4">SPEC_SUMMARY</h3>
                <div class="space-y-4 opacity-70 italic text-sm text-white">
                    <p>UNIT_TYPE: PASSENGER_CAR</p>
                    <p>STATUS_DEFAULT: IDLE</p>
                    <p>QR_GENERATION: AUTOMATIC</p>
                </div>
            </div>

            <button @onclick="HandleSubmit" disabled="@loading" class="w-full bg-primary hover:bg-primary/80 text-on-primary py-5 rounded-2xl font-black italic uppercase tracking-[0.2em] transition-all active:scale-95 shadow-2xl shadow-primary/20 mt-12 flex items-center justify-center gap-3">
                @if (loading)
                {
                    <div class="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-on-primary"></div>
                }
                else
                {
                    <span class="material-symbols-outlined">directions_car</span>
                    <span>ENREGISTRER_VÉHICULE</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid CustomerId { get; set; }
    private CreateVehicleRequest command = new();
    private bool loading = false;
    private string? error;

    protected override void OnInitialized()
    {
        command.CustomerId = CustomerId;
        command.Year = DateTime.Now.Year;
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(command.LicensePlate) || string.IsNullOrWhiteSpace(command.Make) || string.IsNullOrWhiteSpace(command.Model))
        {
            error = "Veuillez remplir tous les champs obligatoires.";
            return;
        }

        loading = true;
        error = null;

        var result = await Api.PostAsync<VehicleDto>("/api/v1/vehicles", command);
        
        if (result != null)
        {
            Nav.NavigateTo($"/clients/fiche-client/{CustomerId}");
        }
        else
        {
            error = "Échec de l'enregistrement. L'immatriculation est peut-être déjà utilisée.";
        }

        loading = false;
    }

    public class CreateVehicleRequest
    {
        public Guid CustomerId { get; set; }
        public string LicensePlate { get; set; } = "";
        public string Make { get; set; } = "";
        public string Model { get; set; } = "";
        public int Year { get; set; }
        public int Mileage { get; set; }
    }
}
