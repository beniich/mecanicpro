@page "/clients/ventes-occasion"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Catalogue Occasion</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Hexagon Background Decor -->
    <div class="absolute inset-0 pointer-events-none opacity-5 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary/30 via-transparent to-transparent"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-primary uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
             <button class="bg-primary text-black px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-orange-600 transition-all flex items-center gap-2 shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined text-sm">add_circle</span> AJOUTER VO
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-primary text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">USED_CAR_MARKETING_HUB</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Ventes Occasion</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Gestion du parc VO, fiches techniques certifiées et réservations.</p>
            </div>
            
            <div class="flex bg-white/5 border border-white/10 p-1 rounded-2xl">
                <button @onclick='() => filter = "ALL"' class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(filter == "ALL" ? "bg-primary text-black" : "text-white/40 hover:text-white hover:bg-white/5")">TOUT LE PARC</button>
                <button @onclick='() => filter = "RESERVED"' class="px-6 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all @(filter == "RESERVED" ? "bg-primary text-black" : "text-white/40 hover:text-white hover:bg-white/5")">RÉSERVÉS (2)</button>
            </div>
        </div>

        <!-- VO Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            @foreach (var vo in FilteredVO())
            {
                <div class="bg-surface-container rounded-[40px] border border-white/5 overflow-hidden group hover:border-primary/30 transition-all duration-500 shadow-2xl relative">
                    <!-- Status Badge -->
                    @if (vo.IsReserved)
                    {
                        <div class="absolute top-8 left-8 z-20 bg-yellow-500 text-black text-[8px] font-black px-3 py-1.5 rounded-lg uppercase tracking-widest shadow-lg animate-pulse">RÉSERVÉ</div>
                    }

                    <!-- Image Section -->
                    <div class="relative h-64 overflow-hidden">
                        <img src="@vo.ImageUrl" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Vehicle"/>
                        <div class="absolute inset-0 bg-gradient-to-t from-surface-container via-transparent to-transparent"></div>
                        <div class="absolute bottom-6 right-8 text-right">
                             <p class="text-4xl font-black italic text-white font-technical leading-none tracking-tighter">@vo.Price.ToString("N0")<span class="text-lg opacity-50 ml-1">€</span></p>
                             <p class="text-[8px] font-black uppercase tracking-[0.3em] text-primary mt-2">GARANTIE 12 MOIS</p>
                        </div>
                    </div>

                    <!-- Details Section -->
                    <div class="p-8 space-y-6">
                        <div class="flex justify-between items-start">
                            <div>
                                <h3 class="font-black italic text-2xl uppercase tracking-tighter text-white">@vo.Model</h3>
                                <p class="text-[10px] font-black uppercase text-white/30 tracking-widest mt-1">@vo.Motorisation</p>
                            </div>
                            <span class="text-primary material-symbols-outlined text-4xl opacity-10 font-black">directions_car</span>
                        </div>

                        <!-- Mini Specs Chart -->
                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5 flex flex-col items-center">
                                <p class="text-[7px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">KILOMÉTRAGE</p>
                                <p class="text-xl font-black italic text-white font-technical">@vo.Km.ToString("N0")<span class="text-[10px] ml-1 opacity-40">KM</span></p>
                            </div>
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5 flex flex-col items-center">
                                <p class="text-[7px] font-black text-white/30 uppercase tracking-[0.2em] mb-1">ANNÉE MODEIL</p>
                                <p class="text-xl font-black italic text-white font-technical">@vo.Year</p>
                            </div>
                        </div>

                        <ul class="space-y-4 pt-4">
                             <li class="flex items-center gap-3 text-[9px] font-black uppercase tracking-widest text-white/60"><span class="material-symbols-outlined text-primary text-sm">verified_user</span> HISTORIQUE CERTIFIÉ MECAPRO</li>
                             <li class="flex items-center gap-3 text-[9px] font-black uppercase tracking-widest text-white/60"><span class="material-symbols-outlined text-primary text-sm">speed</span> RÉVISION COMPLÈTE EFFECTUÉE</li>
                        </ul>

                        <!-- CTA Row -->
                        <div class="flex gap-2 pt-4">
                             <button class="flex-grow bg-white/5 border border-white/10 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all">VOIR FICHE PDF</button>
                             <button class="bg-primary/10 border border-primary/30 text-primary px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-primary hover:text-black transition-all">ÉDITER</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Add Vehicle Placeholder -->
             <div class="bg-white/5 border-2 border-dashed border-white/10 rounded-[40px] flex flex-col items-center justify-center text-center p-12 group hover:border-primary/40 transition-all cursor-pointer">
                <div class="w-20 h-20 rounded-full bg-surface-container flex items-center justify-center mb-6 group-hover:bg-primary/10 transition-all">
                    <span class="material-symbols-outlined text-4xl text-white/20 group-hover:text-primary transition-all">add_to_photos</span>
                </div>
                <p class="font-black italic text-xl uppercase tracking-tighter text-white/30 group-hover:text-white transition-all italic">Ajouter<br/>Véhicule au Parc VO</p>
            </div>
        </div>

    </main>
</div>

@code {
    private string filter = "ALL";

    private List<VOVehicle> vehicles = new()
    {
        new(1, "Porsche 911 (992) GT3", "4.0L Flat-Six 510ch", 2022, 12500, 184900, "https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&q=80&w=800", false),
        new(2, "Audi RS6 Avant C8", "4.0L V8 Bi-Turbo 600ch", 2023, 8400, 142500, "https://images.unsplash.com/photo-1614162692292-7ac56d7f7f1e?auto=format&fit=crop&q=80&w=800", true),
        new(3, "Tesla Model S Plaid", "Tr-Moteur 1020ch", 2022, 14200, 94000, "https://images.unsplash.com/photo-1560958089-b8a1929cea89?auto=format&fit=crop&q=80&w=800", false),
        new(4, "BMW M4 Competition", "3.0L L6 510ch", 2021, 22000, 89500, "https://images.unsplash.com/photo-1555215695-3004980ad54e?auto=format&fit=crop&q=80&w=800", false),
        new(5, "Mercedes AMG A45S", "2.0L Turbo 421ch", 2021, 31000, 68000, "https://images.unsplash.com/photo-1617469767053-d3b523a0b982?auto=format&fit=crop&q=80&w=800", true),
    };

    private List<VOVehicle> FilteredVO() => filter == "ALL" ? vehicles : vehicles.Where(v => v.IsReserved).ToList();

    record VOVehicle(int Id, string Model, string Motorisation, int Year, int Km, int Price, string ImageUrl, bool IsReserved);
}
