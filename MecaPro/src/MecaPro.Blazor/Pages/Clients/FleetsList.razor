@page "/clients/flottes"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Gestion des Parcs B2B</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 relative overflow-hidden">
    
    <!-- Background Decor -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-primary uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <button class="bg-white/5 border border-white/10 px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">add_business</span> NOUVELLE FLOTTE
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-primary text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">B2B_ENTERPRISE_NETWORK</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none">Parcs & Flottes</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Supervision centralisée des comptes professionnels et grands comptes.</p>
            </div>
            
            <div class="bg-surface-container-low p-6 border-l-2 border-primary/40 rounded-r-3xl flex items-center gap-8">
                <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-1">TOTAL VÉHICULES B2B</p>
                    <p class="text-4xl font-black italic text-primary">142</p>
                </div>
                <div class="w-px h-10 bg-white/10"></div>
                <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-1">CHIFFRE D'AFFAIRES YTD</p>
                    <p class="text-4xl font-black italic text-white font-technical">84K<span class="text-lg">€</span></p>
                </div>
            </div>
        </div>

        <!-- Fleet Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var fleet in flottes)
            {
                <div class="bg-surface-container rounded-[40px] border border-white/5 p-8 relative overflow-hidden group hover:border-primary/30 transition-all duration-500 shadow-2xl">
                    <!-- Icon Decor -->
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-10 transition-all">
                        <span class="material-symbols-outlined text-[120px]">local_shipping</span>
                    </div>

                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <h3 class="font-black italic text-3xl uppercase tracking-tighter text-white">@fleet.CompanyName</h3>
                                <p class="text-[10px] font-black uppercase text-primary/60 tracking-widest mt-1">SIRET: @fleet.Siret</p>
                            </div>
                            <span class="material-symbols-outlined text-primary text-3xl">corporate_fare</span>
                        </div>

                        <!-- Mini Stats -->
                        <div class="grid grid-cols-2 gap-4 mb-8">
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5">
                                <p class="text-[8px] font-black text-white/30 uppercase tracking-widest mb-1">VÉHICULES</p>
                                <p class="text-2xl font-black italic text-white">@fleet.VehicleCount</p>
                            </div>
                            <div class="bg-black/20 rounded-2xl p-4 border border-white/5">
                                <p class="text-[8px] font-black text-white/30 uppercase tracking-widest mb-1">ALERTES</p>
                                <p class="text-2xl font-black italic @(fleet.AlertCount > 0 ? "text-red-400" : "text-[#00FF66]")">@fleet.AlertCount</p>
                            </div>
                        </div>

                        <!-- Progress Section -->
                        <div class="space-y-4 mb-8">
                            <div>
                                <div class="flex justify-between text-[10px] font-black uppercase tracking-widest mb-2">
                                    <span class="text-white/40">Entretien au Carré</span>
                                    <span class="text-primary font-technical">@fleet.Compliance%</span>
                                </div>
                                <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
                                    <div class="h-full bg-primary" style="width: @fleet.Compliance%"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-2 pt-2">
                            <button @onclick='() => Nav.NavigateTo($"/clients/gestion-flotte/{fleet.Id}")' class="flex-grow bg-white/5 border border-white/10 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all">GÉRER PARC</button>
                            <button @onclick='() => Nav.NavigateTo($"/clients/portail-flotte-b2b")' class="w-12 h-12 flex items-center justify-center bg-primary/10 border border-primary/30 rounded-xl text-primary hover:bg-primary hover:text-on-primary transition-all">
                                <span class="material-symbols-outlined text-sm">login</span>
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Add Fleet Placeholder -->
            <div class="bg-black/20 border-2 border-dashed border-white/10 rounded-[40px] flex flex-col items-center justify-center text-center p-12 group hover:border-primary/40 transition-all cursor-pointer">
                <div class="w-20 h-20 rounded-full bg-white/5 flex items-center justify-center mb-6 group-hover:bg-primary/10 transition-all">
                    <span class="material-symbols-outlined text-4xl text-white/20 group-hover:text-primary transition-all">add_business</span>
                </div>
                <p class="font-black italic text-xl uppercase tracking-tighter text-white/30 group-hover:text-white transition-all">Enregistrer Nouveau<br/>Grand Compte</p>
            </div>
        </div>

        <!-- Section Alertes Critiques Flottes -->
        <section class="mt-12">
            <div class="bg-red-500/5 border border-red-500/20 rounded-[40px] p-8 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex items-center gap-6">
                    <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-red-500 text-3xl">notification_important</span>
                    </div>
                    <div>
                        <h3 class="font-black italic text-2xl uppercase tracking-tight text-white">Alertes de Parc Prioritaires</h3>
                        <p class="text-xs text-white/40 font-technical uppercase mt-1">@criticalAlerts.Count VECHICULES B2B AVEC RÉVISION EXPIRÉE</p>
                    </div>
                </div>
                <div class="flex -space-x-3 overflow-hidden">
                    @foreach (var alert in criticalAlerts)
                    {
                        <div class="inline-block h-10 w-10 rounded-full ring-2 ring-[#111318] bg-surface-container flex items-center justify-center" title="@alert.Plate">
                            <span class="material-symbols-outlined text-red-400 text-lg">minor_crash</span>
                        </div>
                    }
                    <div class="flex items-center justify-center h-10 w-10 rounded-full ring-2 ring-[#111318] bg-white/10 text-[10px] font-black text-white">
                        +@criticalAlerts.Count
                    </div>
                </div>
                <button class="bg-red-500 text-white px-8 py-4 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-red-600 transition-all shadow-lg shadow-red-500/20">AFFICHER LES RÉVISIONS DUES</button>
            </div>
        </section>

    </main>
</div>

@code {
    record FleetEntry(int Id, string CompanyName, string Siret, int VehicleCount, int AlertCount, int Compliance);
    record FleetAlert(string Plate, string DaysOverdue);

    private List<FleetEntry> flottes = new()
    {
        new(1, "ALPHA LOGISTICS", "123-456-789-00012", 24, 2, 88),
        new(2, "BTP SERVICES SUD", "987-654-321-00045", 12, 0, 100),
        new(3, "Mairie de Paris", "217-500-016-00019", 42, 5, 76),
        new(4, "UBER GLOBAL FR", "842-123-456-00011", 56, 1, 94),
        new(5, "PHARMA DISTRI", "333-555-777-00010", 8, 0, 100),
    };

    private List<FleetAlert> criticalAlerts = new()
    {
        new("AB-123-CD", "12"),
        new("EF-456-GH", "5"),
        new("IJ-789-KL", "8"),
        new("MN-012-OP", "3"),
    };
}
