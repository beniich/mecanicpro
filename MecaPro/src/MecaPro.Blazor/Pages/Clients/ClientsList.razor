@page "/clients"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>MECAPRO — Gestion Clients</PageTitle>

<div class="p-8 space-y-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <span class="text-primary text-[10px] tracking-[0.4em] uppercase mb-2 block font-black italic">BASE_DE_DONNÉES_CRM</span>
            <h2 class="text-6xl font-black tracking-tighter leading-none italic uppercase">GESTION CLIENTS</h2>
        </div>
        <div class="flex gap-4">
             <div class="bg-surface-container-high px-6 py-4 rounded-xl border border-outline-variant/10 shadow-2xl flex items-center gap-4">
                  <span class="material-symbols-outlined text-primary text-3xl">search</span>
                  <input type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" placeholder="RECHERCHER_CLIENT..." class="bg-transparent border-none focus:ring-0 font-technical text-sm font-black w-64 placeholder:text-on-surface-variant/30 uppercase italic"/>
             </div>
             <button class="bg-primary hover:bg-primary/80 text-on-primary px-8 py-4 rounded-xl font-black italic uppercase tracking-widest transition-all active:scale-95 shadow-lg shadow-primary/20 flex items-center gap-2">
                 <span class="material-symbols-outlined">person_add</span>
                 NOUVEAU_CLIENT
             </button>
        </div>
    </div>

    @if (loading)
    {
        <div class="flex justify-center py-24">
            <div class="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-primary"></div>
        </div>
    }
    else if (pagedResult?.Items.Any() != true)
    {
        <div class="bg-surface-container rounded-3xl p-24 text-center border border-outline-variant/5">
            <span class="material-symbols-outlined text-8xl text-on-surface-variant/20 mb-4">person_off</span>
            <p class="text-on-surface-variant/50 font-black italic uppercase tracking-widest">AUCUN_CLIENT_TROUVÉ</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var c in pagedResult.Items)
            {
                <a href="/clients/fiche-client/@c.Id" class="bg-[#352372] rounded-[32px] p-6 border border-white/5 hover:border-primary/50 transition-all group relative overflow-hidden flex flex-col justify-between h-64">
                    <div class="absolute top-0 left-0 w-2 h-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-14 h-14 rounded-2xl bg-[#1f346e] flex items-center justify-center text-primary border border-primary/20">
                            <span class="material-symbols-outlined text-3xl">person</span>
                        </div>
                        <div class="overflow-hidden">
                            <h3 class="font-black italic uppercase text-lg text-white truncate">@c.FirstName @c.LastName</h3>
                            <span class="text-[10px] font-black text-primary/70 tracking-widest uppercase">@c.Segment</span>
                        </div>
                    </div>

                    <div class="space-y-2 mb-6">
                        <div class="flex items-center gap-2 text-white/50 text-[10px] font-black uppercase">
                            <span class="material-symbols-outlined text-sm">mail</span>
                            <span class="truncate">@c.Email</span>
                        </div>
                        <div class="flex items-center gap-2 text-white/50 text-[10px] font-black uppercase">
                            <span class="material-symbols-outlined text-sm">phone</span>
                            <span>@(c.Phone ?? "N/A")</span>
                        </div>
                    </div>

                    <div class="flex items-center justify-between pt-4 border-t border-white/5">
                        <div class="flex flex-col">
                            <span class="text-[8px] text-white/30 font-black uppercase tracking-widest">Fidélité</span>
                            <span class="text-primary font-black italic">@c.LoyaltyPoints PTS</span>
                        </div>
                        <span class="material-symbols-outlined text-primary opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0">arrow_forward</span>
                    </div>
                </a>
            }
        </div>

        <div class="flex justify-center gap-4 mt-12 pb-12">
            <button @onclick="PrevPage" disabled="@(page <= 1)" class="w-12 h-12 rounded-xl bg-surface-container-high flex items-center justify-center disabled:opacity-30">
                <span class="material-symbols-outlined">chevron_left</span>
            </button>
            <div class="bg-surface-container-high px-6 flex items-center rounded-xl font-technical font-black italic">
                PAGE @(page) / @(pagedResult.TotalPages)
            </div>
             <button @onclick="NextPage" disabled="@(!pagedResult.HasNext)" class="w-12 h-12 rounded-xl bg-surface-container-high flex items-center justify-center disabled:opacity-30">
                <span class="material-symbols-outlined">chevron_right</span>
            </button>
        </div>
    }
</div>

@code {
    private PagedResult<CustomerDto>? pagedResult;
    private bool loading = true;
    private int page = 1;
    private string? searchQuery;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        loading = true;
        pagedResult = await Api.GetAsync<PagedResult<CustomerDto>>($"/api/v1/customers?page={page}&pageSize=12&search={searchQuery}");
        loading = false;
    }

    private async Task HandleSearch()
    {
        page = 1;
        await LoadData();
    }

    private async Task NextPage() { page++; await LoadData(); }
    private async Task PrevPage() { page--; await LoadData(); }
}
