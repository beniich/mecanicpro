@page "/clients/pret-vehicule"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Flotte de Prêt</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-sky-400">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-sky-400 uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
             <button class="bg-sky-400 text-black px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-sky-500 transition-all flex items-center gap-2 shadow-lg shadow-sky-400/20">
                <span class="material-symbols-outlined text-sm">vpn_key</span> NOUVEAU PRÊT
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-sky-400 text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">REPLACEMENT_VEHICLE_FLEET</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Véhicules de Prêt</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Supervision des véhicules de courtoisie et contrats de prêt actifs.</p>
            </div>
            
            <div class="bg-surface-container-low p-6 rounded-3xl border border-white/5 flex items-center gap-8">
                 <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-[#00FF66] mb-1">DISPONIBLES</p>
                    <p class="text-4xl font-black italic text-white font-technical">08</p>
                 </div>
                 <div class="w-px h-10 bg-white/10"></div>
                 <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-red-500 mb-1">EN CIRCULATION</p>
                    <p class="text-4xl font-black italic text-white font-technical">04</p>
                 </div>
            </div>
        </div>

        <!-- Loaner Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var car in loaners)
            {
                <div class="bg-surface-container rounded-[32px] border @(car.IsAvailable ? "border-white/5 opacity-100" : "border-red-500/20 opacity-80") p-8 flex flex-col relative overflow-hidden group hover:border-sky-400/20 transition-all">
                    <!-- Progress Bar (Cleanliness/Fuel) -->
                    @if (!car.IsAvailable)
                    {
                        <div class="absolute top-0 right-0 bg-red-500 text-white text-[7px] font-black px-4 py-1.5 rounded-bl-xl uppercase tracking-widest">SORTE: @car.ReturnDate</div>
                    }

                    <div class="flex justify-between items-start mb-6">
                         <div class="w-12 h-12 rounded-2xl bg-black/40 border border-white/10 flex items-center justify-center">
                             <span class="material-symbols-outlined @(car.IsAvailable ? "text-sky-400" : "text-red-500")">@(car.IsAvailable ? "lock_open" : "lock")</span>
                         </div>
                         <p class="text-[10px] items-center gap-1 font-black uppercase text-white tracking-widest italic pt-2">@car.Plate</p>
                    </div>

                    <h3 class="font-black italic text-xl uppercase tracking-tighter text-white mb-2">@car.Name</h3>
                    <p class="text-[8px] font-black uppercase text-white/20 tracking-widest mb-8">@car.Group • KM: @car.Km.ToString("N0")</p>

                    <div class="space-y-4">
                         <div class="flex justify-between text-[8px] font-black uppercase tracking-widest">
                            <span class="text-white/30">FUEL_LEVEL</span>
                            <span class="text-sky-400">@car.Fuel%</span>
                         </div>
                         <div class="h-1 bg-white/5 rounded-full overflow-hidden"><div class="h-full bg-sky-400 shadow-[0_0_10px_#38BDF8]" style="width: @car.Fuel%;"></div></div>
                    </div>

                    <div class="mt-8 pt-8 border-t border-white/5 space-y-3">
                        @if (car.IsAvailable)
                        {
                            <button class="w-full bg-sky-400 text-black py-4 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all hover:bg-sky-500">ATTRIBUER</button>
                        }
                        else
                        {
                            <div class="bg-black/20 p-4 rounded-xl border border-white/5">
                                 <p class="text-[7px] font-black text-white/30 uppercase tracking-widest mb-1 italic">CLIENT ACTUEL</p>
                                 <p class="text-xs font-black uppercase text-white truncate">@car.CurrentClient</p>
                            </div>
                            <button class="w-full bg-white/5 border border-white/10 py-4 rounded-xl text-[10px] font-black text-white/50 uppercase tracking-widest hover:text-white transition-all">TERMINER PRÊT</button>
                        }
                    </div>
                </div>
            }
        </div>

    </main>
</div>

@code {
    private List<LoanerCar> loaners = new()
    {
        new(1, "Volkswagen Golf VIII", "COMPACT", "AB-123-CD", 12500, 85, true, null, null),
        new(2, "Renault Clio V", "CITADINE", "EF-456-GH", 24200, 42, false, "JEAN LUC P.", "DEMAIN 14H"),
        new(3, "Peugeot 308", "COMPACT", "IJ-789-KL", 18900, 98, true, null, null),
        new(4, "BMW 1 Series", "PREMIUM", "MN-012-OP", 4200, 60, false, "SARAH M.", "HIER 18H"),
        new(5, "Audi A3 Sportback", "PREMIUM", "YZ-842-MP", 9200, 10, true, null, null),
        new(6, "Dacia Sandero", "ECONO", "QR-111-XS", 45000, 75, true, null, null),
        new(7, "Tesla Model 3", "EV_LUXE", "VO-777-BK", 15400, 100, true, null, null),
        new(8, "Skoda Octavia", "BERLINE", "ST-333-RM", 31000, 45, false, "ALEX V.", "MARDI 09H"),
    };

    record LoanerCar(int Id, string Name, string Group, string Plate, int Km, int Fuel, bool IsAvailable, string CurrentClient, string ReturnDate);
}
