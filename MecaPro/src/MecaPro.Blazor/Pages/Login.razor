@page "/login"
@layout EmptyLayout
@using MecaPro.Blazor.Services
@inject NavigationManager Navigation
@inject AuthService AutoAuth
@inject ApiClient Api

<div class="min-h-screen flex items-center justify-center p-4 bg-[#11051F]" style="background: radial-gradient(circle at top right, #241348, #11051F 40%, #090212 90%);">
    <div class="relative w-full max-w-md p-[2px] rounded-[2rem] overflow-hidden group">
        <!-- Glow effect behind card -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#00ffff]/20 via-[#402685]/50 to-[#f5a623]/20 blur-xl z-0 transition-opacity duration-500 opacity-60 group-hover:opacity-100"></div>
        
        <!-- Main Card -->
        <div class="relative z-10 w-full p-8 rounded-[2rem] flex flex-col gap-8" style="background-color: #2D205E; box-shadow: 0 0 50px rgba(0,0,0,0.6), inset 0 2px 10px rgba(255,255,255,0.05); border: 1px solid rgba(255, 255, 255, 0.05);">
            
            <!-- Header (Logo + Title) -->
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 rounded-[1rem] flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, #184b7a, #203164); box-shadow: inset 0 2px 6px rgba(0,255,255,0.2), 0 4px 12px rgba(0,0,0,0.5);">
                    <span class="material-symbols-outlined text-3xl font-bold" style="color: #00ffff; text-shadow: 0 0 10px rgba(0, 255, 255, 0.6);">precision_manufacturing</span>
                </div>
                <div class="flex flex-col">
                    <h1 class="text-white text-xl font-black tracking-widest font-headline uppercase" style="text-shadow: 0 2px 4px rgba(0,0,0,0.5);">MECAPRO</h1>
                    <h2 class="text-[10px] font-bold tracking-[0.15em] uppercase text-white/50">Centre de Commandement</h2>
                </div>
                <!-- Status dots matching screenshot -->
                <div class="ml-auto flex gap-1.5 focus">
                    <div class="w-1.5 h-1.5 rounded-full" style="background-color: #00ffff; box-shadow: 0 0 6px #00ffff;"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
                </div>
            </div>

            <div class="w-full h-px bg-white/5 my-1"></div>

            <!-- Forms -->
            <form @onsubmit="HandleLogin" class="flex flex-col gap-5">
                <div class="flex flex-col gap-2 relative">
                    <label class="text-[10px] uppercase font-bold tracking-widest text-[#00ffff] ml-1">Identifiant</label>
                    <input type="email" @bind="email" required class="w-full bg-[#352570] text-white font-technical py-3.5 px-4 rounded-xl border border-white/5 focus:outline-none focus:border-[#00ffff]/40 focus:bg-[#3C2A7B] focus:shadow-[0_0_20px_rgba(0,255,255,0.15)] transition-all placeholder-white/20" placeholder="admin@mecapro.com" />
                </div>
                
                <div class="flex flex-col gap-2 relative">
                    <label class="text-[10px] uppercase font-bold tracking-widest text-[#f5a623] ml-1">Code Secret</label>
                    <input type="password" @bind="password" required class="w-full bg-[#352570] text-white font-technical py-3.5 px-4 rounded-xl border border-white/5 focus:outline-none focus:border-[#f5a623]/40 focus:bg-[#3C2A7B] focus:shadow-[0_0_20px_rgba(245,166,35,0.15)] transition-all placeholder-white/20" placeholder="••••••••" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mt-2 p-3 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center gap-3">
                        <span class="material-symbols-outlined text-red-500 text-sm" style="text-shadow: 0 0 8px rgba(239, 68, 68, 0.4);">warning</span>
                        <span class="text-[11px] text-red-200 font-bold uppercase tracking-wider">@errorMessage</span>
                    </div>
                }

                <button type="submit" disabled="@loading" class="mt-4 w-full py-4 rounded-xl font-bold tracking-widest uppercase transition-all duration-300 relative overflow-hidden group border border-[#00ffff]/20 hover:border-[#00ffff]/60" style="background: linear-gradient(90deg, #1A386D, #2B1D61); box-shadow: 0 0 25px rgba(0,255,255,0.05), inset 0 1px 2px rgba(255,255,255,0.1);">
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-[#00ffff]/10 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></div>
                    <span class="relative z-10 text-white flex items-center justify-center gap-2 text-sm">
                        @if (loading) {
                            <div class="w-4 h-4 rounded-full border-2 border-white/20 border-t-[#00ffff] animate-spin"></div>
                            <span class="text-[11px] tracking-[0.2em] text-[#00ffff]">Authentification...</span>
                        } else {
                            <span class="material-symbols-outlined text-lg" style="color: #00ffff; text-shadow: 0 0 10px rgba(0,255,255,0.5);">login</span>
                            <span class="text-[11px] tracking-[0.2em]">Connexion Sécurisée</span>
                        }
                    </span>
                </button>
            </form>
            
            <div class="text-center pt-2">
                 <span class="text-[9px] text-[#f5a623]/50 font-bold uppercase tracking-[0.2em]">Liaison réseau chiffrée (AES-256)</span>
            </div>
        </div>
    </div>
</div>

<style>
    .font-headline { font-family: 'Bebas Neue', sans-serif; }
    .font-technical { font-family: 'JetBrains Mono', monospace; }
</style>

@code {
    private string email = "admin@mecapro.com";
    private string password = "Password123!";
    private bool loading = false;
    private string? errorMessage;

    async Task HandleLogin()
    {
        loading = true;
        errorMessage = null;
        StateHasChanged();
        
        var result = await AutoAuth.LoginAsync(email, password);
        if (result.Success)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = result.Error ?? "Identifiants rejetés par l'API.";
        }
        loading = false;
        StateHasChanged();
    }
}
