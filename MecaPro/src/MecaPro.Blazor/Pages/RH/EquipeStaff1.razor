@page "/rh/equipe-staff-1"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Équipe & Staff</PageTitle>

<div class="bg-background text-on-surface font-body selection:bg-primary-container min-h-screen pb-24">
    <!-- TopAppBar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318] flex justify-between items-center px-6 h-16 shadow-none">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-[#f5a623]">precision_manufacturing</span>
            <h1 class="text-2xl font-black tracking-tighter text-[#f5a623] font-headline uppercase leading-none">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-slate-500">notifications</span>
            <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/20">
                <span class="material-symbols-outlined text-sm text-primary">person</span>
            </div>
        </div>
    </header>

    <main class="pt-20 px-4 space-y-6 max-w-lg mx-auto">
        <!-- Page Header -->
        <section class="space-y-4">
            <div class="flex flex-col italic">
                <span class="text-primary font-technical text-[10px] tracking-widest uppercase mb-1 font-black">SYSTÈME DE GESTION</span>
                <h2 class="text-5xl font-industrial tracking-wider text-on-surface leading-none">ÉQUIPE & STAFF</h2>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-surface-container-high p-4 rounded-xl relative overflow-hidden italic">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-secondary"></div>
                    <p class="text-[10px] font-technical text-on-surface-variant uppercase tracking-tight font-black">CAPACITÉ TOTALE</p>
                    <div class="text-3xl font-industrial text-primary mt-1">12/14</div>
                    <p class="text-[9px] text-on-surface-variant/60 font-technical mt-1 font-black uppercase">MÉCANICIENS ACTIFS</p>
                </div>
                <div class="bg-surface-container-high p-4 rounded-xl relative overflow-hidden italic">
                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                    <p class="text-[10px] font-technical text-on-surface-variant uppercase tracking-tight font-black">EFFICACITÉ LABO</p>
                    <div class="text-3xl font-industrial text-primary mt-1">94.2%</div>
                    <p class="text-[9px] text-on-surface-variant/60 font-technical mt-1 font-black uppercase">+2.4% DEPUIS HIER</p>
                </div>
            </div>
        </section>

        <!-- Filters -->
        <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide italic font-industrial">
            <button class="bg-primary-container text-on-primary-container px-4 py-2 rounded-lg text-xs font-black tracking-widest uppercase">TOUS</button>
            <button class="bg-surface-container-highest text-on-surface-variant px-4 py-2 rounded-lg text-xs font-black tracking-widest uppercase">LIBRE (4)</button>
        </div>

        <!-- Team Grid -->
        <section class="grid grid-cols-1 gap-4">
            <!-- Mechanic Card -->
            <div class="bg-surface-container p-4 rounded-xl border-l-4 border-secondary-container italic">
                <div class="flex justify-between items-start mb-4">
                    <div class="flex gap-3">
                        <div class="w-14 h-14 rounded-lg bg-surface-container-high overflow-hidden">
                            <img class="w-full h-full object-cover grayscale" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3GNrJdy5RO17EI05nOlpP6HXUb3eDKdupnUfRk9gxIWZDqBXlees61Jcr31MC9gaLrxH35RqUHNYmF4j6vfTI9V9aLgeTn7FNB8rNGCQzJ4sDhsE_Q4Jer6iZI7xA0A2TYq9WOK7gyU8YyTT45UnMHahdpmTkcnvfhR8vvaQmPaKwIEU3ihXl23yPm3hW786d-CLeFKm5qvzlDRXJxbMkx0sBeIMKxkMDndlQus4kW6wTo1AKexdiacnS6ixPNDwuKXVmr1PXdWWl" alt="Jean-Marc L."/>
                        </div>
                        <div>
                            <h3 class="font-black text-on-surface text-lg leading-none uppercase">JEAN-MARC L.</h3>
                            <p class="text-[10px] font-technical text-on-surface-variant uppercase mt-1">ID: MEC-0042</p>
                        </div>
                    </div>
                </div>
                <!-- Productivity -->
                <div class="space-y-2">
                    <div class="flex justify-between items-end italic">
                        <span class="text-[10px] font-technical text-on-surface-variant uppercase font-black">EFFICACITÉ DU JOUR</span>
                        <span class="text-sm font-technical text-primary font-black">88%</span>
                    </div>
                    <div class="h-1.5 w-full bg-surface-container-lowest rounded-full overflow-hidden">
                        <div class="h-full bg-gradient-to-r from-primary-container to-secondary-container w-[88%]"></div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>
