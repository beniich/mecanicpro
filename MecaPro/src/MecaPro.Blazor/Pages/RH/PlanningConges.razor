@page "/atelier/planning-conges"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Header: Leave Management -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-teal-500/20 flex items-center justify-center border border-teal-500/30">
                    <span class="material-symbols-outlined text-teal-400">calendar_today</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter">Leave <span class="text-teal-500">Scheduler</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">GESTION DES ABSENCES & DISPONIBILITÉS ÉQUIPES</p>
        </div>
        
        <div class="flex gap-4">
            <div class="bg-black/40 border border-white/5 px-6 py-3 rounded-2xl flex items-center gap-6">
                <div>
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic">Effectif Présent</p>
                    <p class="text-xl font-black text-teal-500 italic">92<span class="text-xs text-white/50">%</span></p>
                </div>
                <div class="w-[1px] h-8 bg-white/10"></div>
                <div>
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic">Demandes en attente</p>
                    <p class="text-xl font-black italic text-orange-500">3</p>
                </div>
            </div>
            <button class="bg-teal-600 hover:bg-teal-500 px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-[0_0_30px_rgba(20,184,166,0.3)] flex items-center gap-2">
                <span class="material-symbols-outlined">add</span> NOUVELLE DEMANDE
            </button>
        </div>
    </div>

    <!-- Calendar View Placeholder / Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-12">
        <!-- Monthly Availability -->
        <div class="lg:col-span-3 bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[3rem] p-8 overflow-hidden relative">
            <div class="flex justify-between items-center mb-8">
                <div class="flex items-center gap-4">
                    <button class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-teal-500/20 transition-all">
                        <span class="material-symbols-outlined text-sm">chevron_left</span>
                    </button>
                    <h3 class="text-xl font-black italic uppercase tracking-tighter italic">MARS 2026</h3>
                    <button class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-teal-500/20 transition-all">
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                    </button>
                </div>
                <div class="flex gap-2">
                    <span class="flex items-center gap-1.5 text-[9px] font-black uppercase text-gray-500"><div class="w-2 h-2 rounded-full bg-teal-500 shadow-[0_0_8px_rgba(20,184,166,0.6)]"></div> CONGÉS</span>
                    <span class="flex items-center gap-1.5 text-[9px] font-black uppercase text-gray-500"><div class="w-2 h-2 rounded-full bg-orange-500"></div> FORMATION</span>
                    <span class="flex items-center gap-1.5 text-[9px] font-black uppercase text-gray-500"><div class="w-2 h-2 rounded-full bg-red-500"></div> MALADIE</span>
                </div>
            </div>

            <div class="grid grid-cols-7 gap-px bg-white/5 border border-white/5 rounded-3xl overflow-hidden shadow-2xl">
                @foreach (var day in calendarDays)
                {
                    <div class="min-h-[120px] bg-[#111318] p-4 group hover:bg-white/[0.02] transition-all relative">
                         <span class="text-xs font-black @(day.IsCurrentMonth ? "text-gray-400" : "text-gray-700")">@day.DayNumber</span>
                         
                         @if (day.Requests.Any())
                         {
                             <div class="mt-2 space-y-1">
                                 @foreach (var req in day.Requests)
                                 {
                                     <div class="px-2 py-1 rounded-md @(GetRequestColor(req.Type)) text-[8px] font-black uppercase tracking-tighter truncate border @(GetRequestBorder(req.Type))">
                                         @req.EmployeeName
                                     </div>
                                 }
                             </div>
                         }
                    </div>
                }
            </div>
        </div>

        <!-- Pending Workflow -->
        <div class="space-y-6">
             <div class="bg-orange-600/5 border border-orange-500/20 rounded-[2.5rem] p-8">
                  <h3 class="text-xs font-black uppercase text-orange-500 tracking-[0.2em] mb-6 italic">Validations en attente</h3>
                  <div class="space-y-4">
                       @foreach (var p in pendingRequests)
                       {
                           <div class="p-4 bg-black/40 border border-white/5 rounded-2xl hover:bg-black/60 transition-all cursor-pointer">
                                <div class="flex justify-between items-start mb-2">
                                     <p class="text-xs font-black uppercase">@p.EmployeeName</p>
                                     <span class="text-[8px] font-black uppercase px-2 py-0.5 bg-white/10 rounded-full">@p.Type</span>
                                </div>
                                <p class="text-[9px] text-gray-500 font-medium italic mb-4">Du @p.StartDate au @p.EndDate</p>
                                <div class="flex gap-2">
                                     <button class="flex-grow bg-teal-600 text-black py-2 rounded-xl text-[9px] font-black uppercase tracking-widest shadow-lg shadow-teal-900/20">APPROUVER</button>
                                     <button class="w-10 h-10 bg-white/5 rounded-xl border border-white/10 flex items-center justify-center hover:bg-red-500/20 group/btn transition-all">
                                          <span class="material-symbols-outlined text-xs text-gray-500 group-hover/btn:text-red-500">close</span>
                                     </button>
                                </div>
                           </div>
                       }
                  </div>
             </div>

             <div class="bg-teal-600/5 border border-teal-500/20 rounded-[2.5rem] p-8">
                  <h3 class="text-xs font-black uppercase text-teal-500 tracking-[0.2em] mb-4 italic">Quota Annuel</h3>
                  <div class="space-y-4">
                       <div>
                            <div class="flex justify-between items-center text-[10px] mb-1">
                                 <span class="text-gray-500 font-bold">RTT RESTANTS</span>
                                 <span class="font-black">8 J.</span>
                            </div>
                            <div class="w-full h-1 bg-white/5 rounded-full"><div class="w-[60%] h-full bg-teal-500"></div></div>
                       </div>
                       <div>
                            <div class="flex justify-between items-center text-[10px] mb-1">
                                 <span class="text-gray-500 font-bold">CONGÉS PAYÉS</span>
                                 <span class="font-black">15 J.</span>
                            </div>
                            <div class="w-full h-1 bg-white/5 rounded-full"><div class="w-[45%] h-full bg-teal-500"></div></div>
                       </div>
                  </div>
             </div>
        </div>
    </div>
</div>

@code {
    private List<CalendarDay> calendarDays = GenerateMockCalendar();

    private List<LeaveRequest> pendingRequests = new()
    {
        new LeaveRequest { EmployeeName = "MARC L.", Type = "CP", StartDate = "22/03", EndDate = "28/03" },
        new LeaveRequest { EmployeeName = "SOPHIE V.", Type = "RTT", StartDate = "25/03", EndDate = "25/03" },
        new LeaveRequest { EmployeeName = "JULIA B.", Type = "MAL", StartDate = "20/03", EndDate = "22/03" }
    };

    private string GetRequestColor(string type) => type switch
    {
        "CP" => "bg-teal-500/10 text-teal-300",
        "FOR" => "bg-orange-500/10 text-orange-300",
        "MAL" => "bg-red-500/10 text-red-300",
        _ => "bg-white/5 text-white"
    };

    private string GetRequestBorder(string type) => type switch
    {
        "CP" => "border-teal-500/20",
        "FOR" => "border-orange-500/20",
        "MAL" => "border-red-500/20",
        _ => "border-white/10"
    };

    private static List<CalendarDay> GenerateMockCalendar()
    {
        var list = new List<CalendarDay>();
        for (int i = 23; i <= 28; i++) list.Add(new CalendarDay { DayNumber = i, IsCurrentMonth = false });
        for (int i = 1; i <= 31; i++) 
        {
            var day = new CalendarDay { DayNumber = i, IsCurrentMonth = true };
            if (i == 12) day.Requests.Add(new LeaveRequest { EmployeeName = "DANIEL M.", Type = "CP" });
            if (i == 12) day.Requests.Add(new LeaveRequest { EmployeeName = "SYLVAIN T.", Type = "FOR" });
            if (i == 20) day.Requests.Add(new LeaveRequest { EmployeeName = "JULIA B.", Type = "MAL" });
            list.Add(day);
        }
        return list;
    }

    public class CalendarDay {
        public int DayNumber { get; set; }
        public bool IsCurrentMonth { get; set; }
        public List<LeaveRequest> Requests { get; set; } = new();
    }

    public class LeaveRequest {
        public string EmployeeName { get; set; } = "";
        public string Type { get; set; } = "";
        public string StartDate { get; set; } = "";
        public string EndDate { get; set; } = "";
    }
}
