@page "/atelier/planning-conges"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Header: Leave Management -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-teal-500/20 flex items-center justify-center border border-teal-500/30">
                    <span class="material-symbols-outlined text-teal-400">calendar_today</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Leave <span class="text-teal-500 font-light italic uppercase shadow-none border-none">Scheduler</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">GESTION DES ABSENCES & DISPONIBILITÉS ÉQUIPES</p>
        </div>
        
        <div class="flex gap-4">
            <div class="bg-black/40 border border-white/5 px-6 py-3 rounded-2xl flex items-center gap-6">
                <div>
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">Effectif Présent</p>
                    <p class="text-xl font-black italic text-teal-500 italic shadow-none border-none">@(100 - (absences?.Count(a => a.Status == "Approved") ?? 0) * 10)%</p>
                </div>
                <div class="w-[1px] h-8 bg-white/10"></div>
                <div>
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">Demandes en attente</p>
                    <p class="text-xl font-black italic text-orange-500 shadow-none border-none">@(absences?.Count(a => a.Status == "Pending") ?? 0)</p>
                </div>
            </div>
        </div>
    </div>

    @if (loading)
    {
        <div class="flex justify-center p-20">
            <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-teal-500"></div>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-12">
            <!-- Monthly Availability -->
            <div class="lg:col-span-3 bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[3rem] p-8 overflow-hidden relative">
                <div class="flex justify-between items-center mb-8">
                    <h3 class="text-xl font-black italic uppercase tracking-tighter italic shadow-none border-none">Planning de l'Équipe</h3>
                </div>

                <div class="space-y-4">
                    @foreach (var a in absences ?? new())
                    {
                        <div class="p-6 bg-black/40 border-l-4 @(GetBorderColor(a.Type)) rounded-xl flex justify-between items-center">
                            <div>
                                <p class="text-sm font-black uppercase text-white tracking-widest">Collaborateur #@a.EmployeeId.ToString().Substring(0,8)</p>
                                <p class="text-[10px] text-gray-500 font-bold mt-1 uppercase">Du @a.StartDate.ToString("dd/MM") au @a.EndDate.ToString("dd/MM") — @a.Type</p>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="px-3 py-1 bg-white/5 rounded-lg text-[8px] font-black tracking-widest uppercase">@a.Status</span>
                                @if (a.Status == "Pending")
                                {
                                    <button @onclick="() => Approve(a.Id)" class="bg-teal-600 text-black px-6 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest shadow-none border-none">APPROUVER</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<AbsenceDto>? absences;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        // Mock Guid for demo
        absences = await Api.GetAsync<List<AbsenceDto>>("/api/v1/hr/absences/employee/00000000-0000-0000-0000-000000000000");
        loading = false;
    }

    private async Task Approve(Guid id)
    {
        await Api.PostAsync<bool>($"/api/v1/hr/absences/{id}/approve", new { ApprovedByUserId = "Admin" });
        await LoadData();
    }

    private string GetBorderColor(string type) => type switch
    {
        "Vacation" => "border-teal-500",
        "Sick" => "border-red-500",
        "Training" => "border-orange-500",
        _ => "border-white/20"
    };
}
