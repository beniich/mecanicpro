@page "/rh/detail-formation-staff"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Clean Academy Header -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-sky-600/20 flex items-center justify-center border border-sky-500/30">
                    <span class="material-symbols-outlined text-sky-400">school</span>
                </div>
                <div>
                   <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Formation <span class="text-sky-500 font-light italic uppercase shadow-none border-none">Timeline</span></h1>
                   <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em] mt-1 shadow-none border-none">SUIVI INDIVIDUEL DES CERTIFICATIONS & PARCOURS COMPÉTENCES</p>
                </div>
            </div>
        </div>
        
        <div class="flex gap-4">
             <button class="bg-white/5 border border-white/10 px-8 py-3 rounded-2xl font-black uppercase text-xs tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">IMPRIMER CURRICULUM</button>
             <button class="bg-sky-600 text-black px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">add_circle</span> PLANIFIER SESSION
             </button>
        </div>
    </div>

    <!-- Employee Selection & Summary -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        <!-- Sidebar Summary -->
        <div class="lg:col-span-1 space-y-8">
             <div class="bg-[#111318]/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-10 relative overflow-hidden">
                  <div class="absolute -right-8 -top-8 w-32 h-32 bg-sky-600/10 blur-[50px] opacity-40"></div>
                  
                  <div class="flex flex-col items-center text-center">
                       <div class="w-24 h-24 rounded-full border-4 border-sky-500/30 bg-black flex items-center justify-center font-black text-3xl italic mb-6 shadow-xl shadow-sky-900/20">KM</div>
                       <h4 class="text-xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none uppercase tracking-widest leading-relaxed">KARLAN MECH</h4>
                       <p class="text-[9px] text-sky-500 font-black uppercase tracking-widest mt-1 italic shadow-none border-none border-0 uppercase tracking-widest leading-relaxed">DIAGNOSTIQUEUR IA</p>
                  </div>

                  <div class="space-y-6 pt-10 mt-10 border-t border-white/5">
                       <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0 italic leading-relaxed">Certs Obtenues</span>
                            <span class="font-black italic text-sky-500">8</span>
                       </div>
                       <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0 italic leading-relaxed">En cours</span>
                            <span class="font-black italic text-orange-500">1</span>
                       </div>
                       <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none border-0 italic leading-relaxed">Budget CPF</span>
                            <span class="font-black italic text-green-500">2,480 €</span>
                       </div>
                  </div>
             </div>
             
             <div class="bg-sky-600/5 border border-sky-500/20 rounded-[2rem] p-8">
                  <p class="text-[9px] text-sky-400 font-black uppercase tracking-widest mb-4 italic shadow-none border-none border-0">Prochaine Certification</p>
                  <p class="text-sm font-black italic italic uppercase tracking-widest italic shadow-none border-none uppercase tracking-widest leading-relaxed">HABILITATION ÉLECTRIQUE B2VL</p>
                  <p class="text-[10px] text-gray-500 mt-2 font-medium italic shadow-none border-none shadow-none border-0">Date : 12 AVRIL 2026</p>
             </div>
        </div>

        <!-- Timeline of Training Events -->
        <div class="lg:col-span-3">
             <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[3.5rem] p-12 overflow-hidden shadow-2xl relative">
                  <h3 class="text-xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none mb-12">Historique Chronologique des Formations</h3>

                  <div class="space-y-12 relative pb-10">
                       <!-- Vertical Timeline Line -->
                       <div class="absolute left-[39px] top-4 bottom-10 w-[2px] bg-gradient-to-b from-sky-500 via-sky-500/30 to-transparent"></div>
                       
                       @foreach (var eventItem in trainingHistory)
                       {
                           <div class="flex items-start gap-10 relative">
                                <div class="w-20 h-20 rounded-2xl bg-black border-2 @(eventItem.IsDone ? "border-emerald-500/30" : "border-gray-800") flex items-center justify-center z-10 relative group-hover:scale-110 transition-transform">
                                     <span class="material-symbols-outlined @(eventItem.IsDone ? "text-emerald-500" : "text-gray-700") text-3xl">@(eventItem.Icon)</span>
                                     @if (!eventItem.IsDone)
                                     {
                                         <div class="absolute inset-x-0 bottom-[-5px] h-1 bg-orange-500 animate-pulse"></div>
                                     }
                                </div>
                                <div class="flex-grow pt-2">
                                     <div class="flex items-center gap-4 mb-2">
                                          <p class="text-[11px] text-gray-500 font-extrabold uppercase tracking-widest italic shadow-none border-none border-0">@eventItem.Date</p>
                                          @if (!eventItem.IsDone) { <span class="bg-orange-600/10 text-orange-500 text-[8px] font-black px-2 py-0.5 rounded-full border border-orange-500/30 italic">PLANIFIÉ / EN COURS</span> }
                                     </div>
                                     <h4 class="text-2xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none uppercase tracking-widest leading-relaxed">@eventItem.Title</h4>
                                     <p class="text-sm font-medium italic text-gray-400 italic mt-2 italic shadow-none border-none uppercase tracking-widest leading-relaxed italic uppercase tracking-widest leading-relaxed">@eventItem.Organization — Id: @eventItem.CertificateId</p>
                                     
                                     <div class="mt-6 flex gap-3">
                                          @foreach (var skill in eventItem.SkillsAcquired)
                                          {
                                              <span class="px-3 py-1 bg-white/5 border border-white/5 text-[9px] font-black uppercase rounded-lg text-gray-500 italic shadow-none border-none italic leading-relaxed uppercase tracking-widest font-outfit uppercase tracking-widest">#@skill</span>
                                          }
                                     </div>
                                </div>
                                <div class="text-right pt-2 min-w-[120px]">
                                     <p class="text-[8px] text-gray-600 font-extrabold uppercase mb-2 italic shadow-none border-none">Statut Certification</p>
                                     <span class="text-sm font-black italic @(eventItem.IsDone ? "text-emerald-500" : "text-gray-700")">@(eventItem.IsDone ? "VALIDE" : "EN COURS")</span>
                                </div>
                           </div>
                       }
                  </div>
             </div>
        </div>
    </div>
</div>

@code {
    private List<TrainingEvent> trainingHistory = new()
    {
        new TrainingEvent { Date = "12 AVRIL 2026", Title = "Expertise Haute Tension EV", Organization = "BOSCH ACADEMY", CertificateId = "HT-EV-441-2026", Icon = "bolt", IsDone = false, SkillsAcquired = new() { "EV", "SAFETY", "BMS" } },
        new TrainingEvent { Date = "15 JANV 2026", Title = "Master Diagnostic OpenAI v4o", Organization = "MECAPRO INNOVATION", CertificateId = "AI-OBD-0012", Icon = "psychology", IsDone = true, SkillsAcquired = new() { "IA", "OBD-III", "PYTHON" } },
        new TrainingEvent { Date = "20 OCT 2025", Title = "Pneumatiques Haute Performance", Organization = "MICHELIN CAMPUS", CertificateId = "MIC-2025-X", Icon = "tire_repair", IsDone = true, SkillsAcquired = new() { "TYRES", "ALIGMENT" } },
        new TrainingEvent { Date = "04 MAI 2025", Title = "Relation Client & Support B2B", Organization = "FORMA-PRO", CertificateId = "SLA-B2B-1", Icon = "contact_support", IsDone = true, SkillsAcquired = new() { "SOFT-SKILLS", "CRM" } }
    };

    public class TrainingEvent {
        public string Date { get; set; } = "";
        public string Title { get; set; } = "";
        public string Organization { get; set; } = "";
        public string CertificateId { get; set; } = "";
        public string Icon { get; set; } = "";
        public bool IsDone { get; set; }
        public List<string> SkillsAcquired { get; set; } = new();
    }
}
