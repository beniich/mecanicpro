@page "/rh/equipe-staff-1"
@using System.Collections.Generic

<div class="min-h-screen bg-[#0d0e12] text-white p-8 font-['Outfit']">
    <!-- Indigo/Corporate Org Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-indigo-600/20 flex items-center justify-center border border-indigo-500/30">
                    <span class="material-symbols-outlined text-indigo-400">account_tree</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Team <span class="text-indigo-500 font-light italic uppercase shadow-none border-none">Hierarchy</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">ORGANIGRAMME INTERACTIF & STRUCTURE MANAGÉRIALE MECAPRO</p>
        </div>
        
        <div class="flex gap-4">
             <button class="bg-white/5 border border-white/10 px-6 py-3 rounded-2xl font-black uppercase text-xs tracking-widest hover:bg-white/10 transition-all font-outfit uppercase tracking-widest">IMPRIMER STRUCTURE</button>
             <button class="bg-indigo-600 text-black px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">edit</span> ÉDITER NOEUDS
             </button>
        </div>
    </div>

    <!-- Interactive Org Chart Simulation -->
    <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[4rem] p-16 min-h-[700px] flex flex-col items-center relative overflow-hidden shadow-2xl">
         <!-- Geometric Background Lines -->
         <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 to-transparent pointer-events-none"></div>
         
         <!-- CEO Node -->
         <div class="relative z-10 flex flex-col items-center mb-20 animate-fade-in">
              <div class="w-32 h-32 rounded-[2.5rem] bg-indigo-600 text-black border-4 border-black flex items-center justify-center font-black text-4xl italic shadow-2xl shadow-indigo-900/40 relative group">
                   PJ
                   <div class="absolute inset-0 border-2 border-white/20 rounded-[2.5rem]"></div>
              </div>
              <p class="text-sm font-black italic uppercase italic tracking-tight italic uppercase tracking-widest mt-4 italic shadow-none border-none">PHILIPPE JOULIA</p>
              <p class="text-[9px] text-indigo-500 font-extrabold uppercase tracking-widest">CEO / DIRECTEUR GÉNÉRAL</p>
              
              <!-- Vertical Connection Line -->
              <div class="w-[2px] h-16 bg-gradient-to-b from-indigo-600 to-indigo-500/30 mt-6 animate-pulse"></div>
         </div>

         <!-- Level 1 Managers -->
         <div class="relative z-10 flex flex-col lg:flex-row gap-20 items-center justify-center">
              @foreach (var manager in managers)
              {
                  <div class="flex flex-col items-center relative group">
                       <!-- Horizontal Branch Line (Simulated) -->
                       <div class="absolute top-[-40px] w-full h-[2px] bg-indigo-500/20"></div>
                       
                       <div class="w-24 h-24 rounded-3xl bg-black border-2 border-indigo-500/30 flex items-center justify-center font-black text-xl italic group-hover:border-indigo-500 group-hover:bg-indigo-500/10 transition-all shadow-xl relative overflow-hidden">
                             @manager.Initial
                             <div class="absolute bottom-0 left-0 right-0 h-1 bg-indigo-500"></div>
                       </div>
                       <p class="text-xs font-black italic uppercase italic tracking-tight italic uppercase tracking-widest mt-3 italic shadow-none border-none">@manager.Name</p>
                       <p class="text-[8px] text-gray-500 font-bold uppercase tracking-[0.2em] italic shadow-none border-none border-0">@manager.Position</p>
                       
                       <!-- Sub-Team Dots -->
                       <div class="flex gap-1 mt-6">
                            @for(int i=0; i<manager.TeamCount; i++) {
                                <div class="w-2 h-2 rounded-full bg-white/5 border border-white/10 hover:bg-indigo-500 transition-colors"></div>
                            }
                       </div>
                  </div>
              }
         </div>

         <!-- Staff Search Mini Toolbar -->
         <div class="mt-auto pt-20 flex gap-6 z-10">
              <div class="bg-black/60 border border-white/5 py-4 px-10 rounded-[2rem] flex items-center gap-10">
                   <div class="text-center">
                        <p class="text-[8px] text-gray-600 font-black uppercase mb-1 italic shadow-none border-none">COLLABORATEURS</p>
                        <p class="text-xl font-black italic italic shadow-none border-none border-0">34</p>
                   </div>
                   <div class="w-[1px] h-8 bg-white/10"></div>
                   <div class="text-center">
                        <p class="text-[8px] text-gray-600 font-black uppercase mb-1 italic shadow-none border-none">DÉPARTEMENTS</p>
                        <p class="text-xl font-black italic italic shadow-none border-none border-0">4</p>
                   </div>
              </div>
         </div>
    </div>
</div>

@code {
    private List<ManagerNode> managers = new()
    {
        new ManagerNode { Initial = "MA", Name = "MARC ATELIER", Position = "DIRECTEUR TECHNIQUE", TeamCount = 12 },
        new ManagerNode { Initial = "SL", Name = "SOPHIE LARUE", Position = "CHEF AGNECE B2B", TeamCount = 5 },
        new ManagerNode { Initial = "MC", Name = "MARIE COMPTA", Position = "COORD. FINANCE & RH", TeamCount = 3 },
        new ManagerNode { Initial = "LM", Name = "LUCAS MKT", Position = "REP. MARKETING & CRM", TeamCount = 4 }
    };

    public class ManagerNode {
        public string Initial { get; set; } = "";
        public string Name { get; set; } = "";
        public string Position { get; set; } = "";
        public int TeamCount { get; set; }
    }
}
