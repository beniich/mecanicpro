@page "/rh/gestion-employes"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Blue RH Corporate Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-indigo-600/20 flex items-center justify-center border border-indigo-500/30">
                    <span class="material-symbols-outlined text-indigo-400">badge</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">HR <span class="text-indigo-500 font-light italic uppercase shadow-none border-none">Manager</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">ADMINISTRATION DU PERSONNEL & DOSSIERS COLLABORATEURS</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-3 px-6 rounded-2xl flex items-center gap-6">
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">Effectif Total</p>
                      <p class="text-xl font-black italic text-indigo-500 shadow-none border-none border-0">34</p>
                 </div>
                 <div class="w-[1px] h-8 bg-white/10"></div>
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic shadow-none border-none">CDI Actifs</p>
                      <p class="text-xl font-black italic shadow-none border-none border-0">28</p>
                 </div>
             </div>
             <button class="bg-indigo-600 text-black px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">person_add</span> RECRUTEMENT
             </button>
        </div>
    </div>

    <!-- Employee Directory Grid -->
    <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[3rem] overflow-hidden shadow-2xl relative">
        <div class="p-8 border-b border-white/5 flex justify-between items-center">
            <h3 class="text-xl font-black italic uppercase tracking-tighter italic shadow-none border-none">Annuaire Dynamique du Staff</h3>
            <div class="flex gap-4">
                 <div class="bg-black/40 border border-white/10 rounded-xl px-4 py-2 flex items-center gap-2 shadow-inner">
                      <span class="material-symbols-outlined text-xs text-gray-500 shadow-none border-none border-0">search</span>
                      <input type="text" placeholder="Rechercher par Nom / Poste..." class="bg-transparent border-none text-[10px] font-bold text-gray-300 focus:outline-none w-64 italic">
                 </div>
            </div>
        </div>

        <div class="p-0">
             <table class="w-full text-left border-collapse">
                  <thead>
                       <tr class="text-[10px] text-gray-500 font-black uppercase tracking-[0.2em] bg-black/20">
                            <th class="px-10 py-5">Collaborateur</th>
                            <th class="px-10 py-5">Poste / Département</th>
                            <th class="px-10 py-5">Contrat</th>
                            <th class="px-10 py-5">Ancienneté</th>
                            <th class="px-10 py-5">Statut RH</th>
                            <th class="px-10 py-5 text-right">Action</th>
                       </tr>
                  </thead>
                  <tbody class="divide-y divide-white/[0.05]">
                       @foreach (var emp in employees)
                       {
                           <tr class="hover:bg-white/[0.01] transition-all group cursor-pointer">
                                <td class="px-10 py-8">
                                     <div class="flex items-center gap-4">
                                          <div class="w-12 h-12 rounded-full border-2 border-indigo-500/20 bg-black flex items-center justify-center font-black text-indigo-500 italic">@emp.Initial</div>
                                          <div>
                                               <p class="text-sm font-black italic uppercase italic tracking-tight italic uppercase tracking-widest leading-relaxed">@emp.Name</p>
                                               <p class="text-[9px] text-gray-500 font-extrabold uppercase mt-1 italic shadow-none border-none border-0">@emp.Email</p>
                                          </div>
                                     </div>
                                </td>
                                <td class="px-10 py-8">
                                     <p class="text-xs font-black uppercase italic shadow-none border-none">@emp.Position</p>
                                     <p class="text-[9px] text-gray-600 font-bold uppercase mt-1 italic shadow-none border-none border-0 tracking-widest">@emp.Department</p>
                                </td>
                                <td class="px-10 py-8">
                                     <span class="text-[10px] font-black uppercase text-gray-300 italic shadow-none border-none">@emp.ContractType</span>
                                </td>
                                <td class="px-10 py-8">
                                     <p class="text-sm font-bold italic shadow-none border-none italic leading-relaxed uppercase tracking-widest">@emp.Seniority <span class="text-[10px] text-gray-500 lowercase">ans</span></p>
                                </td>
                                <td class="px-10 py-8">
                                     <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-tighter border @(GetHrStatusColor(emp.Status))">@emp.Status</span>
                                </td>
                                <td class="px-10 py-8 text-right">
                                     <button class="bg-white/5 hover:bg-white/10 px-4 py-2 rounded-xl text-[9px] font-black uppercase tracking-widest border border-white/10 transition-all font-outfit uppercase tracking-widest">DOSSIER</button>
                                </td>
                           </tr>
                       }
                  </tbody>
             </table>
        </div>
    </div>
</div>

@code {
    private List<EmployeeRecord> employees = new()
    {
        new EmployeeRecord { Name = "JEAN-MICHEL ATELIER", Initial = "JA", Email = "jm.atelier@mecanicpro.fr", Position = "CHEF D'ATELIER", Department = "OPÉRATIONS", ContractType = "CDI", Seniority = 8, Status = "ACTIF" },
        new EmployeeRecord { Name = "SYLVAIN BRICOLO", Initial = "SB", Email = "s.bricolo@mecanicpro.fr", Position = "TECHNICIEN MASTER V8", Department = "ATELIER LOURD", ContractType = "CDI", Seniority = 12, Status = "ACTIF" },
        new EmployeeRecord { Name = "MARIE COMPTA", Initial = "MC", Email = "m.compta@mecanicpro.fr", Position = "RESPONSABLE FINANCE", Department = "ADMINISTRATION", ContractType = "CDI", Seniority = 4, Status = "EN CONGÉ" },
        new EmployeeRecord { Name = "KARLAN MECH", Initial = "KM", Email = "k.mech@mecanicpro.fr", Position = "DIAGNOSTIQUEUR IA", Department = "OPÉRATIONS", ContractType = "CDD", Seniority = 1, Status = "PÉRIODE ESSAI" }
    };

    private string GetHrStatusColor(string status) => status switch
    {
        "ACTIF" => "border-emerald-500/30 text-emerald-500 bg-emerald-500/10",
        "EN CONGÉ" => "border-sky-500/30 text-sky-500 bg-sky-500/10",
        "PÉRIODE ESSAI" => "border-orange-500/30 text-orange-500 bg-orange-500/10",
        _ => "border-white/20 text-gray-400 bg-white/5"
    };

    public class EmployeeRecord {
        public string Name { get; set; } = "";
        public string Initial { get; set; } = "";
        public string Email { get; set; } = "";
        public string Position { get; set; } = "";
        public string Department { get; set; } = "";
        public string ContractType { get; set; } = "";
        public int Seniority { get; set; }
        public string Status { get; set; } = "";
    }
}
