@page "/rh/equipe-staff-2"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Crimson Performance Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-rose-600/20 flex items-center justify-center border border-rose-500/30">
                    <span class="material-symbols-outlined text-rose-400">monitoring</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter shadow-none border-none">Staff <span class="text-rose-500 font-light italic uppercase shadow-none border-none">Performance</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">DASHBOARD ANALYTIQUE DE PRODUCTIVITÉ TECHNICIEN & KPI QUALITÉ</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-[2rem] flex items-center gap-8">
                 <div class="text-center">
                      <p class="text-[8px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Satisfaction Équipe</p>
                      <p class="text-2xl font-black italic text-rose-500 shadow-none border-none border-0">4.8 / 5</p>
                 </div>
                 <div class="w-[1px] h-10 bg-white/10"></div>
                 <div class="text-center">
                      <p class="text-[8px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic shadow-none border-none">Taux Échec</p>
                      <p class="text-2xl font-black italic shadow-none border-none border-0 text-emerald-500">0.2%</p>
                 </div>
             </div>
        </div>
    </div>

    <!-- Tech Performance Matrix -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        @foreach (var tech in techPerformances)
        {
            <div class="bg-[#111318]/80 backdrop-blur-3xl border border-white/10 rounded-[3.5rem] p-10 hover:bg-white/[0.04] transition-all group overflow-hidden relative shadow-2xl">
                 <div class="absolute -right-8 -top-8 w-48 h-48 bg-rose-600/5 blur-3xl opacity-20 pointer-events-none group-hover:opacity-40 transition-opacity"></div>
                 
                 <div class="flex justify-between items-start mb-10">
                      <div class="flex items-center gap-6">
                           <div class="w-16 h-16 rounded-[1.5rem] bg-black border-2 border-rose-500/30 flex items-center justify-center font-black text-2xl italic group-hover:border-rose-500 transition-all uppercase tracking-widest leading-relaxed">@tech.Initial</div>
                           <div>
                                <h3 class="text-2xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none">@tech.Name</h3>
                                <p class="text-[9px] text-rose-500 font-black uppercase tracking-widest mt-1 italic shadow-none border-none border-0">SPECIALISTE : @tech.Speciality</p>
                           </div>
                      </div>
                      <div class="text-right">
                           <p class="text-[8px] text-gray-500 font-black uppercase mb-1 italic shadow-none border-none">INTERVENTIONS / MOIS</p>
                           <p class="text-3xl font-black italic italic shadow-none border-none border-0">@tech.TotalInterventions</p>
                      </div>
                 </div>

                 <!-- Performance Bars -->
                 <div class="space-y-6 pt-10 border-t border-white/5">
                      <div>
                           <div class="flex justify-between items-center mb-2">
                                <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest italic shadow-none border-none italic leading-relaxed">Rentabilité Temps Passé / Estimé</span>
                                <span class="text-xs font-black italic @(tech.Efficiency > 95 ? "text-emerald-500" : "text-rose-500") italic shadow-none border-none border-0">@tech.Efficiency%</span>
                           </div>
                           <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full bg-rose-600" style="width: @(tech.Efficiency)%"></div>
                           </div>
                      </div>
                      
                      <div>
                           <div class="flex justify-between items-center mb-2">
                                <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest italic shadow-none border-none italic leading-relaxed">Score Qualité (Satisfaction Client)</span>
                                <span class="text-xs font-black italic text-emerald-500 italic shadow-none border-none border-0">@tech.QualityScore / 5</span>
                           </div>
                           <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full bg-emerald-500" style="width: @(tech.QualityScore * 20)%"></div>
                           </div>
                      </div>
                 </div>

                 <div class="mt-10 flex gap-4">
                      <button class="bg-white/5 px-6 py-4 rounded-xl border border-white/10 group-hover:bg-rose-600/10 transition-all flex items-center justify-center gap-2 flex-grow">
                           <span class="material-symbols-outlined text-sm">history</span>
                           <span class="text-[9px] font-black uppercase tracking-widest font-outfit uppercase tracking-widest">LOGS ACTIVITÉ</span>
                      </button>
                      <button class="bg-rose-600 text-black px-6 py-4 rounded-xl font-black uppercase text-[9px] tracking-widest shadow-xl shadow-rose-900/40 italic flex-grow">VOIR DOSSIER RH</button>
                 </div>
            </div>
        }
    </div>
</div>

@code {
    private List<TechStat> techPerformances = new()
    {
        new TechStat { Initial = "SB", Name = "SYLVAIN BRICOLO", Speciality = "MOTEUR V8 / THERMIQUE", TotalInterventions = 42, Efficiency = 108, QualityScore = 4.9 },
        new TechStat { Initial = "KM", Name = "KARLAN MECH", Speciality = "DIAGNOSTIC / EV", TotalInterventions = 28, Efficiency = 94, QualityScore = 4.7 },
        new TechStat { Initial = "MT", Name = "MAXIME TECH", Speciality = "PNEUMATIQUE / LUBRIFICATION", TotalInterventions = 56, Efficiency = 115, QualityScore = 4.5 },
        new TechStat { Initial = "JL", Name = "JEAN-LUC MART", Speciality = "ÉLECTRONIQUE MULTIMÉDIA", TotalInterventions = 18, Efficiency = 88, QualityScore = 4.2 }
    };

    public class TechStat {
        public string Initial { get; set; } = "";
        public string Name { get; set; } = "";
        public string Speciality { get; set; } = "";
        public int TotalInterventions { get; set; }
        public int Efficiency { get; set; }
        public double QualityScore { get; set; }
    }
}
