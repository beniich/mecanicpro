@page "/rh/matrice-competences"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Matrice de Compétences</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Hexagon Overlay Decor -->
    <div class="absolute inset-x-0 bottom-0 z-0 h-1/2 opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-500/30 via-transparent to-transparent"></div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-blue-400">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-blue-400 uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <button class="bg-blue-500 text-white px-5 py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 transition-all flex items-center gap-2 shadow-lg shadow-blue-500/20">
                <span class="material-symbols-outlined text-sm">edit_note</span> ÉDITION_AVANCÉE
            </button>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-blue-400 text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">SKILL_ENGINEER_VALUATION</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Matrice Compétences</h2>
                <div class="flex gap-4 mt-6">
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] uppercase font-black tracking-widest text-[#00FF66] flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[#00FF66]"></span> EXPERT</span>
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] uppercase font-black tracking-widest text-blue-400 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span> MAÎTRISE</span>
                    <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-lg text-[10px] uppercase font-black tracking-widest text-white/40 flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-white/40"></span> BASE</span>
                </div>
            </div>
            
            <div class="bg-surface-container-low p-6 rounded-3xl border border-white/5 text-right">
                <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-1">SCORE MOYEN ATELIER</p>
                <div class="flex items-baseline justify-end gap-2">
                    <p class="text-5xl font-black italic text-white font-technical">4.2<span class="text-xl text-white/30">/5</span></p>
                </div>
                <p class="text-[8px] font-bold text-blue-400 uppercase mt-1 tracking-widest">PROGRESSION +5.4% VS Q1</p>
            </div>
        </div>

        <!-- Matrix Table -->
        <div class="bg-surface-container rounded-[40px] border border-white/5 shadow-2xl overflow-hidden">
            <div class="overflow-x-auto custom-scroll">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-black/40 border-b border-white/5">
                            <th class="p-8 min-w-[300px] border-r border-white/5 bg-white/[0.01]">
                                <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 italic">TECHNICIENS / DOMAINES</p>
                            </th>
                            @foreach (var domain in domains)
                            {
                                <th class="p-8 text-center min-w-[120px] border-r border-white/5 last:border-0 group cursor-help">
                                    <div class="flex flex-col items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-blue-500/10 border border-blue-500/30 flex items-center justify-center text-blue-400 group-hover:bg-blue-500 group-hover:text-black transition-all">
                                            <span class="material-symbols-outlined text-lg">@domain.Icon</span>
                                        </div>
                                        <span class="text-[10px] font-black uppercase tracking-widest text-white/40 group-hover:text-white transition-all">@domain.Name</span>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var emp in staffSkills)
                        {
                            <tr class="group hover:bg-white/[0.03] transition-colors">
                                <td class="p-8 border-r border-white/5 bg-white/[0.01]">
                                    <div class="flex items-center gap-4">
                                        <img src="@emp.Avatar" class="w-14 h-14 rounded-2xl object-cover border border-white/10 grayscale group-hover:grayscale-0 transition-all"/>
                                        <div>
                                            <p class="font-black italic text-lg uppercase tracking-tighter text-white">@emp.Name</p>
                                            <p class="text-[9px] font-black uppercase text-blue-400/60 tracking-widest mt-1">SÉNIORITÉ: @emp.Seniority ANS</p>
                                        </div>
                                    </div>
                                </td>
                                @foreach (var domain in domains)
                                {
                                    var score = emp.LevelPerDomain[domain.Id];
                                    <td class="p-8 border-r border-white/5 last:border-0 text-center">
                                        <div class="flex flex-col items-center gap-2">
                                            <div class="flex gap-1 mb-1">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <div class="w-2 h-4 rounded-sm @(i <= score ? (score >= 4 ? "bg-[#00FF66]" : "bg-blue-400") : "bg-white/5 border border-white/5")"></div>
                                                }
                                            </div>
                                            <p class="font-technical font-black text-xs @(score >= 4 ? "text-[#00FF66]" : score >= 3 ? "text-blue-400" : "text-white/20")">@score.ToString("F1")</p>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- GAP Analysis Section -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
            <div class="bg-blue-500/5 border border-blue-500/20 rounded-[40px] p-8 relative overflow-hidden">
                <div class="flex items-center gap-6 mb-8 relative z-10">
                    <div class="w-14 h-14 bg-blue-500/20 rounded-2xl flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined text-blue-500 text-3xl">psychology_alt</span>
                    </div>
                    <div>
                        <h3 class="font-black italic text-2xl uppercase tracking-tight text-white">Analyse des Lacunes</h3>
                        <p class="text-[10px] text-white/40 font-black uppercase tracking-[0.2em] mt-1">DÉFICITS TECHNIQUES DÉTECTÉS</p>
                    </div>
                </div>
                
                <div class="space-y-4 relative z-10">
                    <div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5">
                        <span class="text-xs font-black uppercase tracking-widest text-[#FF00FF]">ÉLECTRIQUE / EV</span>
                        <div class="flex items-center gap-3">
                            <span class="text-[10px] font-black uppercase p-1 px-2 border border-[#FF00FF]/30 text-[#FF00FF] rounded-lg">CIBLE: 4.5</span>
                            <span class="text-[10px] font-black uppercase text-white/50">ACTUEL: 2.8</span>
                        </div>
                    </div>
                    <button class="w-full mt-4 bg-blue-500 text-white py-4 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 transition-all">PLANIFIER SESSION FORMATION</button>
                </div>
            </div>

            <div class="bg-[#111318] border border-white/5 rounded-[40px] p-8 flex flex-col items-center justify-center text-center">
                <div class="w-20 h-20 rounded-full border-4 border-dashed border-white/10 flex items-center justify-center mb-6 group cursor-pointer hover:border-blue-400 transition-all">
                    <span class="material-symbols-outlined text-white/20 text-4xl group-hover:text-blue-400">upload</span>
                </div>
                <p class="font-black italic text-xl uppercase tracking-tighter text-white mb-2">Importation de Certifications</p>
                <p class="text-[10px] uppercase font-technical text-white/30 max-w-xs leading-loose tracking-widest">GÉNÉRATEUR DE MATRICE BASÉ SUR LES RÉSULATS DE FORMATION ET CERTIFICATIONS CONSTRUCTEURS.</p>
            </div>
        </section>

    </main>
</div>

@code {
    private List<DomainInfo> domains = new()
    {
        new("mech", "MOTEUR THERM.", "handyman"),
        new("diag", "DIAG OBD-IA", "memory"),
        new("elec", "ÉLECTRIQUE/EV", "bolt"),
        new("brak", "FREINAGE/ABS", "speed"),
        new("tran", "TRANSMISSION", "settings_slow_motion"),
        new("body", "CARROSSERIE", "format_paint"),
    };

    private List<StaffSkillData> staffSkills = new()
    {
        new("Marc Dubois", "https://randomuser.me/api/portraits/men/32.jpg", 15, new Dictionary<string, double> {
            {"mech", 5.0}, {"diag", 4.5}, {"elec", 3.2}, {"brak", 4.8}, {"tran", 4.9}, {"body", 2.0}
        }),
        new("Sarah Meyer", "https://randomuser.me/api/portraits/women/44.jpg", 8, new Dictionary<string, double> {
            {"mech", 3.5}, {"diag", 5.0}, {"elec", 4.8}, {"brak", 3.0}, {"tran", 2.5}, {"body", 1.5}
        }),
        new("Karim Benali", "https://randomuser.me/api/portraits/men/22.jpg", 4, new Dictionary<string, double> {
            {"mech", 4.0}, {"diag", 2.0}, {"elec", 1.5}, {"brak", 4.5}, {"tran", 4.0}, {"body", 2.0}
        }),
        new("Thomas Lenoir", "https://randomuser.me/api/portraits/men/86.jpg", 12, new Dictionary<string, double> {
            {"mech", 2.0}, {"diag", 1.5}, {"elec", 1.0}, {"brak", 2.5}, {"tran", 2.0}, {"body", 5.0}
        }),
    };

    record DomainInfo(string Id, string Name, string Icon);
    record StaffSkillData(string Name, string Avatar, int Seniority, Dictionary<string, double> LevelPerDomain);
}
