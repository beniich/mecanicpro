@page "/garage/onboarding"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Bienvenue / Onboarding</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative flex flex-col items-center justify-center p-6">

    <!-- Background Decor -->
    <div class="absolute inset-0 pointer-events-none opacity-20">
        <div class="absolute top-0 left-0 w-[800px] h-[800px] bg-primary/10 rounded-full blur-[150px] -translate-y-1/2 -translate-x-1/2 animate-pulse"></div>
        <div class="absolute bottom-0 right-0 w-[800px] h-[800px] bg-primary/10 rounded-full blur-[150px] translate-y-1/2 translate-x-1/2 animate-pulse"></div>
    </div>

    <main class="max-w-4xl w-full space-y-12 relative z-10 transition-all duration-700 @(step == 0 ? "scale-100" : "scale-95 opacity-90")">

        @if (step == 0)
        {
            <!-- Step 0: Welcome -->
            <div class="text-center space-y-8 animate-[fadeInUp_0.8s_ease-out_forwards]">
                <div class="w-24 h-24 rounded-full bg-primary/20 border-2 border-primary/40 flex items-center justify-center mx-auto mb-10 shadow-[0_0_50px_rgba(249,107,12,0.2)]">
                    <span class="material-symbols-outlined text-5xl text-primary">precision_manufacturing</span>
                </div>
                <h1 class="text-8xl font-black tracking-tighter italic uppercase leading-tight text-white mb-6">MECAPRO Engine Start.</h1>
                <p class="text-xl uppercase font-technical text-white/40 max-w-2xl mx-auto leading-loose font-bold tracking-[0.2em] mb-12">
                   Initialisation de votre centre d'entretien intelligent. Configurez votre profil garage en 3 étapes clés.
                </p>
                <button @onclick="() => step = 1" class="bg-primary text-black px-12 py-6 rounded-2xl text-xs font-black uppercase tracking-[0.3em] hover:bg-orange-600 transition-all shadow-[0_10px_30px_rgba(249,107,12,0.3)]">COMMENCER ONBOARDING</button>
            </div>
        }
        else if (step == 1)
        {
            <!-- Step 1: Info Garage -->
            <div class="bg-surface-container rounded-[40px] border border-white/10 p-12 shadow-2xl space-y-8 animate-[fadeInRight_0.4s_ease-out_forwards]">
                <div class="flex justify-between items-center mb-10">
                    <span class="text-[10px] items-center gap-1 font-black uppercase text-primary tracking-widest italic">STEP_01 / IDENTITÉ</span>
                    <div class="flex gap-2"><div class="w-8 h-1 bg-primary rounded-full"></div><div class="w-8 h-1 bg-white/10 rounded-full"></div><div class="w-8 h-1 bg-white/10 rounded-full"></div></div>
                </div>
                <h2 class="text-5xl font-black italic uppercase tracking-tighter text-white">Profil du Garage</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                     <div class="space-y-2">
                        <label class="text-[9px] font-black tracking-widest uppercase text-white/30 ml-2">ENSEIGNE COMMERCIALE</label>
                        <input type="text" placeholder="EX: GARAGE DU CENTRE" class="w-full bg-black/40 border border-white/5 rounded-2xl p-5 text-sm font-black uppercase text-white tracking-widest outline-none focus:border-primary transition-all"/>
                     </div>
                     <div class="space-y-2">
                        <label class="text-[9px] font-black tracking-widest uppercase text-white/30 ml-2">NUMÉRO SIRET</label>
                        <input type="text" placeholder="14 CHIFFRES" class="w-full bg-black/40 border border-white/5 rounded-2xl p-5 text-sm font-black uppercase text-white tracking-widest outline-none focus:border-primary transition-all font-technical"/>
                     </div>
                     <div class="md:col-span-2 space-y-2">
                        <label class="text-[9px] font-black tracking-widest uppercase text-white/30 ml-2">ADRESSE COMPLÈTE</label>
                        <input type="text" placeholder="RUE, CP, VILLE" class="w-full bg-black/40 border border-white/5 rounded-2xl p-5 text-sm font-black uppercase text-white tracking-widest outline-none focus:border-primary transition-all"/>
                     </div>
                </div>

                <div class="pt-10 flex justify-between">
                     <button @onclick="() => step = 0" class="text-white/30 text-[10px] font-black uppercase tracking-widest hover:text-white transition-all">RETOUR</button>
                     <button @onclick="() => step = 2" class="bg-primary text-black px-10 py-5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-orange-600 transition-all">SUIVANT</button>
                </div>
            </div>
        }
        else if (step == 2)
        {
            <!-- Step 2: Plan Selection -->
            <div class="bg-surface-container rounded-[40px] border border-white/10 p-12 shadow-2xl space-y-12 animate-[fadeInRight_0.4s_ease-out_forwards]">
                <div class="flex justify-between items-center mb-10">
                    <span class="text-[10px] items-center gap-1 font-black uppercase text-primary tracking-widest italic">STEP_02 / ACTIVATION PLAN</span>
                    <div class="flex gap-2"><div class="w-8 h-1 bg-primary rounded-full"></div><div class="w-8 h-1 bg-primary rounded-full"></div><div class="w-8 h-1 bg-white/10 rounded-full"></div></div>
                </div>
                <h2 class="text-5xl font-black italic uppercase tracking-tighter text-white">Choisir votre Puissance</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                     <div class="bg-black/40 border border-white/5 rounded-[32px] p-8 space-y-6 hover:border-primary/40 transition-all cursor-pointer group shadow-xl">
                        <p class="text-[8px] font-black text-white/30 uppercase tracking-[0.4em]">ESSENTIEL</p>
                        <p class="text-4xl font-black italic text-white font-technical">49<span class="text-xl">€<span class="text-[10px] opacity-30">/MOIS</span></span></p>
                        <ul class="space-y-4 pt-6 border-t border-white/5 opacity-50 group-hover:opacity-100 transition-all">
                             <li class="flex items-center gap-2 text-[10px] font-black uppercase text-white"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> CRM & VÉHICULES</li>
                             <li class="flex items-center gap-2 text-[10px] font-black uppercase text-white"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> FACTURATION L1</li>
                        </ul>
                     </div>
                     <div class="bg-primary/5 border border-primary/40 rounded-[32px] p-8 space-y-6 relative overflow-hidden shadow-[0_0_30px_rgba(249,107,12,0.1)]">
                        <div class="absolute top-0 right-0 bg-primary text-black text-[7px] font-black px-4 py-2 rounded-bl-xl uppercase tracking-widest shadow-lg">RECOMMANDÉ</div>
                        <p class="text-[8px] font-black text-primary uppercase tracking-[0.4em]">ULTRA-DRIVE (IA)</p>
                        <p class="text-4xl font-black italic text-white font-technical">99<span class="text-xl">€<span class="text-[10px] opacity-30">/MOIS</span></span></p>
                        <ul class="space-y-4 pt-6 border-t border-white/5">
                             <li class="flex items-center gap-2 text-[10px] font-black uppercase text-white"><span class="material-symbols-outlined text-primary text-sm">bolt</span> TOUT ESSENTIEL + IA</li>
                             <li class="flex items-center gap-2 text-[10px] font-black uppercase text-white"><span class="material-symbols-outlined text-primary text-sm">bolt</span> MONITORING IOT</li>
                             <li class="flex items-center gap-2 text-[10px] font-black uppercase text-white"><span class="material-symbols-outlined text-primary text-sm">bolt</span> DEVIS COMPARATIF</li>
                        </ul>
                     </div>
                </div>

                <div class="pt-10 flex justify-between">
                     <button @onclick="() => step = 1" class="text-white/30 text-[10px] font-black uppercase tracking-widest hover:text-white transition-all">RETOUR</button>
                     <button @onclick="() => step = 3" class="bg-primary text-black px-10 py-5 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-orange-600 transition-all shadow-lg shadow-primary/20">CONFIGURER & LANCER</button>
                </div>
            </div>
        }
        else {
             <!-- Final: Success -->
             <div class="text-center space-y-8 animate-[fadeInUp_0.8s_ease-out_forwards]">
                <div class="w-32 h-32 rounded-full border-4 border-[#00FF66] flex items-center justify-center mx-auto mb-10 shadow-[0_0_50px_rgba(0,255,102,0.2)]">
                    <span class="material-symbols-outlined text-7xl text-[#00FF66] animate-bounce">check_circle</span>
                </div>
                <h1 class="text-7xl font-black tracking-tighter italic uppercase leading-tight text-white mb-6 italic">Configuration Terminée.</h1>
                <p class="text-xl uppercase font-technical text-white/40 max-w-2xl mx-auto leading-loose font-bold tracking-[0.2em] mb-12">
                   VOTRE GARAGE EST PRÊT À TOURNER À PLEINE PUISSANCE. TOUS LES MODULES IA SONT INITIALISÉS.
                </p>
                <button @onclick='() => Nav.NavigateTo("/")' class="bg-[#00FF66] text-black px-12 py-6 rounded-2xl text-xs font-black uppercase tracking-[0.3em] hover:bg-green-400 transition-all">ACCÉDER AU DASHBOARD</button>
            </div>
        }

    </main>

    <div class="mt-20">
         <p class="text-[8px] font-black text-white/10 uppercase tracking-[0.5em] font-technical">MECAPRO_OS v2026.3.0 // STABLE BUILD</p>
    </div>
</div>

@code {
    private int step = 0;
}
