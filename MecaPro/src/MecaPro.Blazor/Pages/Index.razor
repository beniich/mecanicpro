@page "/"
@attribute [Authorize]
@inject MecaPro.Blazor.Services.ApiClient Api

<PageTitle>Tableau de bord — MecaPro</PageTitle>

<div class="fade-in space-y-8 animate-in fade-in duration-700">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="bg-surface-container-high p-6 rounded-xl border-l-4 border-primary shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center text-primary">
          <span class="material-symbols-outlined text-2xl">directions_car</span>
        </div>
        <div class="font-technical text-3xl font-bold text-on-surface">@(stats?.VehiclesInProgress ?? 47)</div>
      </div>
      <div class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Véhicules en cours</div>
      <div class="mt-2 text-[10px] text-primary font-bold uppercase">↑ +3 cette semaine</div>
    </div>

    <div class="bg-surface-container-high p-6 rounded-xl border-l-4 border-secondary shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 bg-secondary/10 rounded-lg flex items-center justify-center text-secondary">
          <span class="material-symbols-outlined text-2xl">report_problem</span>
        </div>
        <div class="font-technical text-3xl font-bold text-on-surface">@(stats?.ActiveDiagnostics ?? 12)</div>
      </div>
      <div class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Pannes diagnostiquées</div>
      <div class="mt-2 text-[10px] text-secondary font-bold uppercase">↓ -2 vs hier</div>
    </div>

    <div class="bg-surface-container-high p-6 rounded-xl border-l-4 border-tertiary shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 bg-tertiary/10 rounded-lg flex items-center justify-center text-tertiary">
          <span class="material-symbols-outlined text-2xl">check_circle</span>
        </div>
        <div class="font-technical text-3xl font-bold text-on-surface">183</div>
      </div>
      <div class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">Révisions complètes</div>
      <div class="mt-2 text-[10px] text-tertiary font-bold uppercase">↑ +8 ce mois</div>
    </div>

    <div class="bg-surface-container-high p-6 rounded-xl border-l-4 border-outline-variant shadow-sm hover:shadow-md transition-shadow">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-10 h-10 bg-outline-variant/10 rounded-lg flex items-center justify-center text-on-surface">
          <span class="material-symbols-outlined text-2xl">payments</span>
        </div>
        <div class="font-technical text-3xl font-bold text-on-surface">42k</div>
      </div>
      <div class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">CA mensuel (€)</div>
      <div class="mt-2 text-[10px] text-on-surface-variant font-bold uppercase">↑ +12% vs M-1</div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <!-- Véhicules actifs -->
    <div class="lg:col-span-8 bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 shadow-sm">
      <div class="flex items-center justify-between mb-6">
        <h3 class="font-headline text-2xl tracking-widest uppercase italic text-on-surface">Véhicules Actifs</h3>
        <button class="px-4 py-2 bg-surface-container-highest text-[10px] font-bold uppercase tracking-widest rounded transition-colors hover:bg-surface-bright">Voir tout</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-outline-variant/10">
                    <th class="py-3 text-[10px] font-bold uppercase text-on-surface-variant tracking-widest">Immatriculation</th>
                    <th class="py-3 text-[10px] font-bold uppercase text-on-surface-variant tracking-widest">Modèle</th>
                    <th class="py-3 text-[10px] font-bold uppercase text-on-surface-variant tracking-widest">Client</th>
                    <th class="py-3 text-[10px] font-bold uppercase text-on-surface-variant tracking-widest uppercase">Statut</th>
                    <th class="py-3 text-[10px] font-bold uppercase text-on-surface-variant tracking-widest">Révision</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/5">
                <tr>
                    <td class="py-4 font-technical text-primary font-bold">AB-123-CD</td>
                    <td class="py-4 text-sm">Peugeot 308</td>
                    <td class="py-4 text-sm">M. Dupont</td>
                    <td class="py-4"><span class="bg-secondary/10 text-secondary px-2 py-0.5 rounded text-[10px] font-bold uppercase">En cours</span></td>
                    <td class="py-4 text-[10px] font-technical">15/03/25</td>
                </tr>
                <tr>
                    <td class="py-4 font-technical text-primary font-bold">EF-456-GH</td>
                    <td class="py-4 text-sm">Renault Clio</td>
                    <td class="py-4 text-sm">Mme. Martin</td>
                    <td class="py-4"><span class="bg-primary/10 text-primary px-2 py-0.5 rounded text-[10px] font-bold uppercase">Diagnostic</span></td>
                    <td class="py-4 text-[10px] font-technical">18/03/25</td>
                </tr>
            </tbody>
        </table>
      </div>
    </div>

    <!-- Stats rapides -->
    <div class="lg:col-span-4 bg-surface-container-low p-6 rounded-xl border border-outline-variant/10 shadow-sm">
      <h3 class="font-headline text-2xl tracking-widest uppercase italic text-on-surface mb-6">Statistiques Semaine</h3>
      <div class="space-y-4">
        <div class="flex justify-between items-center p-3 bg-surface-container-high rounded-lg border border-outline-variant/5">
          <span class="text-[10px] font-bold uppercase text-on-surface-variant">Taux retour client</span>
          <span class="font-technical text-primary font-bold">94%</span>
        </div>
        <div class="flex justify-between items-center p-3 bg-surface-container-high rounded-lg border border-outline-variant/5">
          <span class="text-[10px] font-bold uppercase text-on-surface-variant">Durée moy. révision</span>
          <span class="font-technical text-on-surface font-bold">2h 40m</span>
        </div>
        <div class="flex justify-between items-center p-3 bg-surface-container-high rounded-lg border border-outline-variant/5">
          <span class="text-[10px] font-bold uppercase text-on-surface-variant">Pièces commandées</span>
          <span class="font-technical text-secondary font-bold">34</span>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
    private MecaPro.Blazor.Services.DashboardStatsDto? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await Api.GetAsync<MecaPro.Blazor.Services.DashboardStatsDto>("/api/v1/dashboard/stats");
    }
}
