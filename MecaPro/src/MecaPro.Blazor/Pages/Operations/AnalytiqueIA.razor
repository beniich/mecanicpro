@page "/diagnostic/analytique-ia"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Matrix Green Predicitive Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-emerald-600/20 flex items-center justify-center border border-emerald-500/30 shadow-[0_0_40px_rgba(16,185,129,0.15)] overflow-hidden relative group">
                    <span class="material-symbols-outlined text-emerald-400 text-3xl animate-pulse">query_stats</span>
                    <div class="absolute inset-x-0 bottom-0 h-1 bg-emerald-600"></div>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter italic">Predictive <span class="text-emerald-500 italic uppercase">Analytic IA</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">MODÈLES ML.NET D'ANTICIPATION DES PANNES & TENDANCES PARC</p>
        </div>
        
        <div class="flex gap-4">
             <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-2xl flex items-center gap-6">
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic">Modèles Entraînés</p>
                      <p class="text-xl font-black italic text-emerald-500 italic">ML.NET v3.0</p>
                 </div>
                 <div class="w-[1px] h-10 bg-white/10"></div>
                 <div>
                      <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-1 uppercase italic">Précision Prédictive</p>
                      <p class="text-xl font-black italic shadow-none border-none border-0">87.4<span class="text-xs text-white/50 lowercase italic">%</span></p>
                 </div>
             </div>
        </div>
    </div>

    <!-- Prediction Summary Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 mb-12">
        @foreach (var alert in predictiveAlerts)
        {
            <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[2.5rem] p-8 hover:bg-white/[0.04] transition-all cursor-pointer group shadow-2xl relative overflow-hidden">
                 <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-600/10 blur-3xl opacity-20 group-hover:opacity-40 transition-opacity"></div>
                 
                 <div class="flex justify-between items-start mb-8">
                      <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center border border-emerald-500/30">
                           <span class="material-symbols-outlined text-emerald-400 text-xl">@(alert.Icon)</span>
                      </div>
                      <span class="text-[9px] font-black italic text-emerald-500 bg-emerald-500/10 px-2 py-0.5 rounded-full border border-emerald-500/20">SCORE CONF: @alert.Confidence%</span>
                 </div>
                 
                 <h3 class="text-base font-black italic uppercase italic tracking-tighter italic shadow-none border-none mb-2 italic">@alert.Title</h3>
                 <p class="text-[11px] text-gray-500 font-medium italic mb-8 font-outfit uppercase tracking-widest italic leading-relaxed">@alert.Description</p>
                 
                 <div class="mt-auto px-4 py-2 bg-black/40 rounded-xl border border-white/5 inline-block">
                      <p class="text-[9px] text-gray-500 font-black tracking-widest leading-none mb-1 uppercase">ÉCHÉANCE ESTIMÉE</p>
                      <p class="text-sm font-black italic text-emerald-500 uppercase font-outfit uppercase tracking-widest italic leading-relaxed">~ @alert.Estimate</p>
                 </div>
            </div>
        }
    </div>

    <!-- Global Trend Analytics -->
    <div class="bg-[#111318]/60 backdrop-blur-xl border border-white/10 rounded-[3.5rem] p-12 relative overflow-hidden">
         <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-6 relative z-10">
              <h3 class="text-2xl font-black italic uppercase italic tracking-tighter italic shadow-none border-none">Analyse de Fiabilité par Constructeur (Tendances Parc)</h3>
              <div class="flex gap-4">
                   <div class="bg-black/40 border border-white/10 rounded-xl px-4 py-2 flex items-center gap-4">
                        <span class="text-[9px] text-gray-500 font-black uppercase tracking-widest">Période : 12 MOIS</span>
                        <div class="w-[1px] h-4 bg-white/10"></div>
                        <span class="text-[9px] font-black uppercase text-emerald-500 italic shadow-none border-none border-0">DATA REFRESH: ON</span>
                   </div>
              </div>
         </div>

         <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 relative z-10">
              @foreach (var brand in brandTrends)
              {
                  <div class="bg-black/40 border border-white/5 p-8 rounded-[3rem] relative overflow-hidden group hover:bg-white/[0.02] transition-all">
                       <div class="flex justify-between items-end mb-8">
                            <h4 class="text-3xl font-black italic italic tracking-tighter uppercase tracking-widest leading-relaxed">@brand.Name</h4>
                            <div class="text-right">
                                 <p class="text-[10px] text-gray-500 font-bold italic mb-1 uppercase tracking-widest leading-relaxed">INCIDENCE PANNES</p>
                                 <p class="text-xl font-black italic @(brand.Incidence < 10 ? "text-emerald-500" : (brand.Incidence < 20 ? "text-orange-500" : "text-red-500"))">@brand.Incidence%</p>
                            </div>
                       </div>
                       
                       <div class="h-16 w-full bg-white/5 rounded-2xl flex items-end gap-1 p-4 mb-8 overflow-hidden">
                           @foreach (var v in brand.History)
                           {
                               <div class="flex-grow @(brand.Incidence < 15 ? "bg-emerald-500/30" : "bg-red-500/30") rounded-full" style="height: @(v)%"></div>
                           }
                       </div>
                       
                       <div class="space-y-4">
                            <p class="text-[9px] text-gray-500 font-black uppercase tracking-widest italic shadow-none border-none">Top Composant Défaillant</p>
                            <div class="flex items-center justify-between text-xs">
                                 <span class="font-bold text-gray-300">@brand.TopFailPart</span>
                                 <span class="font-black italic text-emerald-500 italic shadow-none border-none border-0 bg-emerald-500/10 px-2 py-0.5 rounded-full">@brand.TopFailRate% Cas</span>
                            </div>
                       </div>
                  </div>
              }
         </div>
    </div>
</div>

@code {
    private List<PredictiveAlert> predictiveAlerts = new()
    {
        new PredictiveAlert { Title = "Risque Alternateur", Description = "Détection de fluctuations de tension SignalR cycliques sur 3 mois.", Icon = "electric_car", Confidence = 82, Estimate = "2-3 SEMAINES" },
        new PredictiveAlert { Title = "Usure Freins AR Proche", Description = "Analyse de la courbe de pression hydraulique et kilomètres parcourus.", Icon = "settings_backup_restore", Confidence = 94, Estimate = "1,200 KM" },
        new PredictiveAlert { Title = "Surchauffe Injecteur 4", Description = "Température culasse divergente selon les cycles de combustions IA.", Icon = "propane", Confidence = 75, Estimate = "CRITIQUE (IMMÉDIAT)" },
        new PredictiveAlert { Title = "Habilitation BMS", Description = "Cycle de vie batterie détectant une baisse de SOH hors tolérance.", Icon = "battery_charging_full", Confidence = 88, Estimate = "4 MOIS" }
    };

    private List<BrandTrend> brandTrends = new()
    {
        new BrandTrend { Name = "RENAULT", Incidence = 12, TopFailPart = "Capteur PMH", TopFailRate = 22, History = new() { 40, 30, 80, 50, 60, 20, 45, 90, 30, 22 } },
        new BrandTrend { Name = "BMW", Incidence = 18, TopFailPart = "Turbocompresseur", TopFailRate = 14, History = new() { 60, 90, 40, 70, 30, 85, 20, 55, 78, 92 } },
        new BrandTrend { Name = "TESLA", Incidence = 8, TopFailPart = "Bras Suspension", TopFailRate = 35, History = new() { 20, 15, 30, 10, 25, 12, 18, 22, 10, 8 } }
    };

    public class PredictiveAlert {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public int Confidence { get; set; }
        public string Estimate { get; set; } = "";
    }

    public class BrandTrend {
        public string Name { get; set; } = "";
        public int Incidence { get; set; }
        public string TopFailPart { get; set; } = "";
        public int TopFailRate { get; set; }
        public List<int> History { get; set; } = new();
    }
}
