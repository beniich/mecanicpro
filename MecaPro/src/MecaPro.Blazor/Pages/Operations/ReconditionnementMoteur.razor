@page "/atelier/reconditionnement-moteur"
@using System.Collections.Generic

<div class="min-h-screen bg-[#0d0e12] text-white p-8 font-['Outfit']">
    <!-- Industrial Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-16 h-16 rounded-2xl bg-orange-600/20 flex items-center justify-center border border-orange-500/30 shadow-[0_0_40px_rgba(249,115,22,0.15)] overflow-hidden relative group">
                    <span class="material-symbols-outlined text-orange-500 text-4xl">settings_input_component</span>
                    <div class="absolute inset-x-0 bottom-0 h-1 bg-orange-500"></div>
                </div>
                <div>
                   <h1 class="text-5xl font-black italic uppercase tracking-tighter">Engine <span class="text-orange-500">Rebuild Hub</span></h1>
                   <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em] mt-2 italic shadow-none border-none">CHANTIERS LOURDS & RESTAURATION TECHNIQUE VÉHICULES</p>
                </div>
            </div>
        </div>
        
        <div class="flex gap-4">
            <div class="bg-black/60 border border-white/5 py-4 px-8 rounded-[2rem] flex items-center gap-6">
                <div>
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic">Chantiers Senior</p>
                    <p class="text-2xl font-black italic text-orange-500 italic">4 <span class="text-xs text-white/50 lowercase">en cours</span></p>
                </div>
                <div class="w-[1px] h-10 bg-white/10"></div>
                <div class="text-right">
                    <p class="text-[9px] text-gray-400 font-black tracking-widest leading-none mb-2 uppercase italic">Heures Senior</p>
                    <p class="text-2xl font-black italic">158<span class="text-xs text-white/50 lowercase">h accumulées</span></p>
                </div>
            </div>
            <button class="bg-orange-600 hover:bg-orange-500 px-10 py-4 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-[0_0_30px_rgba(249,115,22,0.3)]">
                CRÉER CHANTIER V8/V6
            </button>
        </div>
    </div>

    <!-- Engine Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        @foreach (var project in activeRebuilds)
        {
            <div class="bg-[#111318]/60 backdrop-blur-3xl border border-white/10 rounded-[3.5rem] p-10 hover:bg-white/[0.04] transition-all cursor-pointer group shadow-2xl relative overflow-hidden">
                <!-- Mechanical Blueprint Back -->
                <div class="absolute -right-20 -bottom-20 material-symbols-outlined text-[30rem] text-white/[0.01] pointer-events-none select-none">architecture</div>
                
                <div class="flex justify-between items-start mb-10 relative z-10">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                             <span class="px-3 py-1 bg-orange-500/10 text-orange-400 text-[8px] font-black uppercase tracking-widest rounded-full border border-orange-500/30 italic">PRÉCISION HAUT-MOTEUR</span>
                             <span class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">PROJET ID_@project.ProjectId</span>
                        </div>
                        <h3 class="text-3xl font-black italic uppercase tracking-tighter group-hover:text-orange-500 transition-colors uppercase italic leading-relaxed">@project.EngineModel — @project.Plate</h3>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-6 mb-10 relative z-10">
                    <div class="bg-black/60 p-6 rounded-3xl border border-white/5 shadow-inner">
                        <p class="text-[9px] text-gray-500 font-black tracking-widest mb-1 italic">PROGRESSION</p>
                        <p class="text-2xl font-black italic text-orange-500">@project.Progress%</p>
                    </div>
                    <div class="bg-black/60 p-6 rounded-3xl border border-white/5 shadow-inner col-span-2 flex justify-between items-center">
                        <div>
                             <p class="text-[9px] text-gray-500 font-black tracking-widest mb-1 italic">EXPERTISE REQUISE</p>
                             <p class="text-lg font-black italic uppercase italic tracking-tighter">@project.ExpertRole</p>
                        </div>
                        <span class="material-symbols-outlined text-orange-500/40 text-4xl">military_tech</span>
                    </div>
                </div>

                <!-- Checklist Overview -->
                <div class="space-y-4 mb-10 relative z-10">
                    @foreach (var step in project.Steps)
                    {
                        <div class="flex items-center gap-4 bg-white/5 border border-white/5 p-4 rounded-2xl group/step">
                             <div class="w-2 h-2 rounded-full @(step.IsDone ? "bg-orange-500" : "bg-gray-700")"></div>
                             <span class="text-xs font-black uppercase tracking-wider italic @(step.IsDone ? "text-white" : "text-gray-500")">@step.Name</span>
                             @if (step.IsDone)
                             {
                                 <span class="ml-auto material-symbols-outlined text-xs text-orange-500">verified</span>
                             }
                        </div>
                    }
                </div>

                <div class="flex gap-4 relative z-10">
                    <button class="flex-grow bg-[#1a1c24] hover:bg-white/5 border border-white/10 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all shadow-xl">LOGS ASSEMBLAGE</button>
                    <button class="flex-grow bg-orange-600 text-black py-4 rounded-2xl font-black uppercase text-[10px] tracking-widest shadow-xl shadow-orange-900/40">OUVRIR CHANTIER</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<RebuildProject> activeRebuilds = new()
    {
        new RebuildProject { 
            EngineModel = "V8 4.0L BITURBO (S63)", 
            Plate = "ER-003-XX", 
            ProjectId = "RE-9921",
            Progress = 62,
            ExpertRole = "MASTER TECH SENIOR",
            Steps = new() {
                new RebuildStep { Name = "DÉMONTAGE CULASSES", IsDone = true },
                new RebuildStep { Name = "ALÉSAGE CYLINDRES", IsDone = true },
                new RebuildStep { Name = "RÉGLAGE DISTRIBUTION", IsDone = false },
                new RebuildStep { Name = "TEST Étanchéité", IsDone = false }
            }
        },
        new RebuildProject { 
            EngineModel = "W16 8.0L (Restoration)", 
            Plate = "BUG-001-F", 
            ProjectId = "RE-4410",
            Progress = 15,
            ExpertRole = "INGÉNIEUR ATELIER",
            Steps = new() {
                new RebuildStep { Name = "SCAN 3D BLOC MOTEUR", IsDone = true },
                new RebuildStep { Name = "REMÉTALLISATION", IsDone = false },
                new RebuildStep { Name = "VÉRIFICATION TURBOS", IsDone = false }
            }
        }
    };

    public class RebuildProject {
        public string EngineModel { get; set; } = "";
        public string Plate { get; set; } = "";
        public string ProjectId { get; set; } = "";
        public int Progress { get; set; }
        public string ExpertRole { get; set; } = "";
        public List<RebuildStep> Steps { get; set; } = new();
    }

    public class RebuildStep {
        public string Name { get; set; } = "";
        public bool IsDone { get; set; }
    }
}
