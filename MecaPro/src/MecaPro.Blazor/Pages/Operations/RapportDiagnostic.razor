@page "/atelier/rapport-diagnostic"
@using System.Collections.Generic

<div class="min-h-screen bg-[#07080a] text-white p-8 font-['Outfit']">
    <!-- Clean PDF/Report Header -->
    <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-sky-500/20 flex items-center justify-center border border-sky-500/30">
                    <span class="material-symbols-outlined text-sky-400">picture_as_pdf</span>
                </div>
                <h1 class="text-4xl font-black italic uppercase tracking-tighter">Report <span class="text-sky-500">Generator</span></h1>
            </div>
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[0.4em]">COMPILATION & GÉNÉRATION DES RAPPORTS TECHNIQUES PDF</p>
        </div>
        
        <div class="flex gap-4">
             <button class="bg-white/5 hover:bg-white/10 px-8 py-3 rounded-2xl font-black uppercase text-xs tracking-widest border border-white/10 transition-all font-outfit uppercase tracking-widest">Voir Archives Rapports</button>
             <button class="bg-sky-600 text-black px-8 py-3 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl flex items-center gap-2">
                 <span class="material-symbols-outlined">send</span> ENVOYER CLIENT
             </button>
        </div>
    </div>

    <!-- Report Preview Hub -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Configuration & Sections Selection -->
        <div class="lg:col-span-1 space-y-8">
             <div class="bg-[#111318]/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-10">
                  <h3 class="text-xs font-black uppercase text-gray-500 tracking-widest mb-8 italic">Contenu du Rapport</h3>
                  <div class="space-y-6">
                       @foreach (var section in reportSections)
                       {
                           <div class="flex items-center justify-between p-4 bg-black/40 border border-white/5 rounded-2xl group cursor-pointer hover:bg-white/5 transition-all">
                                <div class="flex items-center gap-4">
                                     <div class="w-8 h-8 rounded-lg bg-sky-500/10 flex items-center justify-center border border-sky-500/20">
                                          <span class="material-symbols-outlined text-sky-500 text-sm">@(section.Icon)</span>
                                     </div>
                                     <span class="text-[10px] font-black uppercase tracking-tight">@(section.Title)</span>
                                </div>
                                <div class="w-5 h-5 rounded-md border-2 @(section.IsActive ? "bg-sky-500 border-sky-500" : "border-gray-700") flex items-center justify-center">
                                     @if (section.IsActive) { <span class="material-symbols-outlined text-black text-[12px] font-black">check</span> }
                                </div>
                           </div>
                       }
                  </div>
                  
                  <div class="mt-10 pt-10 border-t border-white/5 space-y-4">
                       <label class="text-[9px] text-gray-600 font-black uppercase block tracking-widest">Langue du Rapport</label>
                       <div class="flex gap-2">
                            <span class="px-3 py-1 bg-sky-500 text-black text-[9px] font-black rounded-lg">FR</span>
                            <span class="px-3 py-1 bg-white/5 text-gray-500 text-[9px] font-black rounded-lg hover:text-white transition-all cursor-pointer">EN</span>
                            <span class="px-3 py-1 bg-white/5 text-gray-500 text-[9px] font-black rounded-lg hover:text-white transition-all cursor-pointer">DE</span>
                       </div>
                  </div>
             </div>

             <div class="bg-sky-600/5 border border-sky-500/20 rounded-[2.5rem] p-8">
                  <div class="flex gap-4 items-center">
                       <span class="material-symbols-outlined text-sky-400">verified</span>
                       <p class="text-[11px] font-medium leading-relaxed italic text-gray-300 italic">Signature numérique du technicien @("@Technician_KM") activée pour validation légale.</p>
                  </div>
             </div>
        </div>

        <!-- Live Preview Page -->
        <div class="lg:col-span-2 relative bg-white/[0.02] border border-white/5 rounded-[4rem] p-12 overflow-hidden shadow-2xl">
             <!-- PDF Blueprint Sheet Mock -->
             <div class="bg-white text-black min-h-[800px] w-full max-w-[700px] mx-auto rounded-lg shadow-[0_40px_100px_rgba(0,0,0,0.4)] p-12 flex flex-col scale-[0.98]">
                  <!-- Header PDF -->
                  <div class="flex justify-between items-start mb-16 border-b-2 border-slate-100 pb-10">
                       <div class="flex gap-4">
                            <div class="w-12 h-12 bg-black flex items-center justify-center rounded-lg text-white font-black italic">MP</div>
                            <div>
                                 <p class="text-xl font-black tracking-tighter uppercase italic tracking-widest leading-relaxed">MecaPro <span class="text-sky-600">Solutions</span></p>
                                 <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Garage Expertise Automobiliste</p>
                            </div>
                       </div>
                       <div class="text-right">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500">RAPPORT N° 2026-DIAG-0042</p>
                            <p class="text-[9px] font-bold text-slate-400">DATE: 20 MARS 2026</p>
                       </div>
                  </div>

                  <!-- Vehicle Table PDF -->
                  <div class="bg-slate-50 px-8 py-6 rounded-2xl mb-12 flex justify-between">
                       <div>
                            <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest mb-1 italic shadow-none border-none">Propriétaire</p>
                            <p class="text-xs font-black uppercase">Marc LEGRAND</p>
                       </div>
                       <div>
                            <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest mb-1 italic shadow-none border-none">Véhicule</p>
                            <p class="text-xs font-black uppercase">RENAULT ZOE (AB-123-CD)</p>
                       </div>
                       <div>
                            <p class="text-[8px] text-slate-400 font-black uppercase tracking-widest mb-1 italic shadow-none border-none">Kilométrage</p>
                            <p class="text-xs font-black uppercase">142,091 KM</p>
                       </div>
                  </div>

                  <!-- Content Preview PDF -->
                  <div class="space-y-10 flex-grow">
                       <h2 class="text-lg font-black italic uppercase italic tracking-tighter border-l-4 border-sky-600 pl-4 py-1 italic shadow-none border-none">Analyse des Systèmes Critiques</h2>
                       <div class="space-y-6">
                            @foreach (var entry in mockEntries)
                            {
                                 <div class="flex gap-4 border-b border-slate-100 pb-4">
                                      <div class="w-2 h-2 rounded-full @(entry.Color) mt-1.5 shadow-none border-none border-0"></div>
                                      <div>
                                           <div class="flex gap-3 items-center mb-1">
                                                <p class="text-[10px] font-black uppercase">@entry.Code</p>
                                                @if (entry.IsOk) { <span class="text-[8px] font-bold text-emerald-600">PASSED</span> } 
                                                else { <span class="text-[8px] font-bold text-red-600">ACTION REQUIRED</span> }
                                           </div>
                                           <p class="text-[11px] text-slate-600 leading-relaxed italic">@entry.Description</p>
                                      </div>
                                 </div>
                            }
                       </div>
                  </div>

                  <!-- Signature/Footer PDF -->
                  <div class="mt-20 pt-10 border-t border-slate-100 flex justify-between items-end">
                       <div class="w-32 h-32 bg-slate-50 border-2 border-slate-100 rounded-lg flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-200 text-4xl">qr_code_2</span>
                       </div>
                       <div class="text-right">
                            <p class="text-[8px] text-slate-400 font-bold uppercase mb-4 italic shadow-none border-none">Visa Expert Technicien</p>
                            <p class="text-xs font-mono lowercase tracking-tighter uppercase tracking-widest leading-relaxed">0x4491...22FC810</p>
                            <div class="h-[2px] w-48 bg-sky-600 ml-auto mt-1"></div>
                       </div>
                  </div>
             </div>
        </div>
    </div>
</div>

@code {
    private List<ReportSection> reportSections = new()
    {
        new ReportSection { Title = "Synthèse Véhicule", Icon = "info", IsActive = true },
        new ReportSection { Title = "Codes OBDII (DTC)", Icon = "code", IsActive = true },
        new ReportSection { Title = "Analyse IA / Recommandations", Icon = "psychology", IsActive = true },
        new ReportSection { Title = "Mesures Batterie EV", Icon = "battery_charging_full", IsActive = false },
        new ReportSection { Title = "Historique Interventions", Icon = "history", IsActive = true },
        new ReportSection { Title = "Fiches Pièces Jointes", Icon = "attachment", IsActive = false }
    };

    private List<PdfEntry> mockEntries = new()
    {
        new PdfEntry { Code = "P0301", Description = "Raté d'allumage détecté sur cylindre 1. Sévérité Haute. Nécessite vérification bobine d'allumage.", Color = "bg-red-500", IsOk = false },
        new PdfEntry { Code = "FUEL_TRIM", Description = "Mesure du mélange air/carburant dans les tolérances constructeur (+3.2%).", Color = "bg-emerald-500", IsOk = true },
        new PdfEntry { Code = "U0121", Description = "Défaut communication avec le calculateur ABS. Perte ponctuelle détectée.", Color = "bg-orange-500", IsOk = false }
    };

    public class ReportSection {
        public string Title { get; set; } = "";
        public string Icon { get; set; } = "";
        public bool IsActive { get; set; }
    }

    public class PdfEntry {
        public string Code { get; set; } = "";
        public string Description { get; set; } = "";
        public string Color { get; set; } = "";
        public bool IsOk { get; set; }
    }
}
