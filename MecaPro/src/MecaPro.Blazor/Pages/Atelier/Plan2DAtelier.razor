@page "/atelier/plan-2d"
@inject NavigationManager Nav

<div class="flex items-center justify-center min-h-screen bg-[#0f172a] text-white">
    <div class="text-center">
        <div class="inline-block p-6 rounded-full bg-primary/10 mb-6">
            <span class="material-symbols-outlined text-primary text-6xl">account_tree</span>
        </div>
        <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-4">MISE À JOUR DU SYSTÈME</h2>
        <p class="text-on-surface/50 mb-8 max-w-md mx-auto">L'ancienne topographie 2D a été remplacée par l'interface interactive v2.1 pour une meilleure précision.</p>
        <button @onclick='() => Nav.NavigateTo("/atelier/visual-map")' class="bg-primary hover:bg-primary/80 px-8 py-4 rounded-xl font-bold transition-all shadow-lg shadow-primary/20">
            ACCÉDER À LA CARTE INTERACTIVE
        </button>
    </div>
</div>

@code {
    // Redirection automatique après 1 seconde pour laisser le temps de voir le message
    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(1000);
        Nav.NavigateTo("/atelier/visual-map");
    }
}
