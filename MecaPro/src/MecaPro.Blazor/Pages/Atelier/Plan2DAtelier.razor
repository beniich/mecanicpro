@page "/atelier/plan-2d"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Plan 2D Interactif Atelier</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-hidden">

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#02e1f2]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#02e1f2] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-[#02e1f2]/10 border border-[#02e1f2]/30 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase text-[#02e1f2] tracking-widest flex items-center gap-2 shadow-[0_0_15px_rgba(2,225,242,0.1)]">
                <span class="material-symbols-outlined text-sm">floor</span> MAPPING SENSORIEL ACTIF
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 mx-auto w-full h-[calc(100vh-100px)] flex flex-col">

        <!-- Header Controls -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 mb-8 shrink-0">
            <div>
                <span class="text-[#02e1f2] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">GEOSPATIAL_WORKSHOP_MAP</span>
                <h2 class="text-6xl md:text-5xl font-black tracking-tighter italic uppercase leading-none drop-shadow-[0_0_15px_rgba(2,225,242,0.1)] text-white">Topographie Atelier</h2>
            </div>
            
            <div class="flex gap-4">
                <!-- Légende -->
                <div class="bg-white/5 border border-white/5 rounded-2xl p-2 flex gap-4 mr-6">
                    <div class="flex items-center gap-2"><div class="w-3 h-3 bg-[#00FF66]/20 border border-[#00FF66] rounded-sm"></div><span class="text-[9px] font-black tracking-widest text-[#00FF66] uppercase">LIBRE</span></div>
                    <div class="flex items-center gap-2"><div class="w-3 h-3 bg-red-500/20 border border-red-500 rounded-sm animate-pulse-border"></div><span class="text-[9px] font-black tracking-widest text-red-500 uppercase">OCCUPÉ</span></div>
                    <div class="flex items-center gap-2"><div class="w-3 h-3 bg-yellow-400/20 border border-yellow-400 rounded-sm"></div><span class="text-[9px] font-black tracking-widest text-yellow-400 uppercase">RÉSERVÉ</span></div>
                </div>

                <button class="bg-white/5 border border-white/10 px-5 text-[10px] font-black uppercase tracking-widest hover:bg-white/10 transition-all rounded-xl shadow-lg flex items-center gap-2">
                    <span class="material-symbols-outlined text-sm">my_location</span> RECENTRER
                </button>
            </div>
        </div>

        <!-- Interactive SVG Map -->
        <div class="flex-grow bg-[#090B10] border-2 border-white/5 rounded-[40px] relative overflow-hidden flex items-center justify-center shadow-[inset_0_0_100px_rgba(0,0,0,0.8)] cursor-move" style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 40px 40px;">

            @if (selectedZone != null)
            {
                <!-- Context Menu Info -->
                <div class="absolute top-8 right-8 bg-[#111318]/90 backdrop-blur-md border border-[#02e1f2]/30 p-6 rounded-3xl w-80 shadow-[0_0_40px_rgba(2,225,242,0.15)] z-20 animate-fade-in pointer-events-auto">
                    <div class="flex justify-between items-start mb-6 border-b border-white/10 pb-4">
                        <div>
                            <p class="text-[10px] font-black uppercase text-[#02e1f2] tracking-widest mb-1">ZONE IDENTIFIÉE</p>
                            <h3 class="font-black italic text-3xl uppercase tracking-tighter shadow-none text-white">@selectedZone.Name</h3>
                        </div>
                        <button class="text-white/50 hover:text-white" @onclick="() => selectedZone = null"><span class="material-symbols-outlined">close</span></button>
                    </div>

                    @if (selectedZone.Status == "Occupé")
                    {
                        <div class="space-y-4">
                            <div class="bg-red-500/10 border border-red-500/20 p-4 rounded-2xl">
                                <p class="text-[8px] font-black uppercase text-red-400 tracking-[0.2em] mb-1">ÉTAT EN TEMPS RÉEL</p>
                                <p class="font-black text-red-400 font-technical text-sm uppercase tracking-widest">EN CHARGE : MÉCANIQUE LOURDE</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-[#02e1f2] mb-1">VÉHICULE</p>
                                <p class="font-black italic text-xl uppercase">Porsche 911 GT3</p>
                                <p class="font-technical text-xs text-white/50 uppercase">AB-123-CD</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-[#02e1f2] mb-1">AFFECTATION STAFF</p>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-surface-container flex items-center justify-center border border-white/20"><span class="material-symbols-outlined text-[#02e1f2] text-sm">engineering</span></div>
                                    <div>
                                        <p class="font-black uppercase text-sm">Marc D.</p>
                                        <p class="font-bold text-[8px] uppercase tracking-widest text-white/40 shadow-none">CHEF ATELIER</p>
                                    </div>
                                </div>
                            </div>
                            <button class="w-full mt-2 bg-[#02e1f2]/10 border border-[#02e1f2]/50 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-[#02e1f2]/20 text-[#02e1f2] transition-all flex items-center justify-center gap-2">
                                VOIR INTERVENTION <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </button>
                        </div>
                    }
                    else if(selectedZone.Status == "Réservé")
                    {
                        <div class="space-y-4">
                            <div class="bg-yellow-400/10 border border-yellow-400/20 p-4 rounded-2xl">
                                <p class="text-[8px] font-black uppercase text-yellow-500 tracking-[0.2em] mb-1">ÉTAT EN TEMPS RÉEL</p>
                                <p class="font-black text-yellow-500 font-technical text-sm uppercase tracking-widest">RÉSERVÉ (14:00 - 15:30)</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-[#02e1f2] mb-1">VÉHICULE ATTENDU</p>
                                <p class="font-black italic text-xl text-white/50 uppercase">Audi A3 S-Line</p>
                                <p class="font-technical text-xs text-white/30 uppercase">FF-999-ZZ</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="flex flex-col items-center justify-center text-center p-6 bg-white/5 rounded-2xl border border-white/5">
                            <span class="material-symbols-outlined text-5xl text-[#00FF66]/20 mb-3">check_circle</span>
                            <p class="font-black uppercase tracking-widest text-[#00FF66]">PONT DISPONIBLE</p>
                            <button class="mt-4 px-4 py-2 bg-white/10 rounded-lg text-[10px] font-black uppercase hover:bg-white/20 transition-all border border-white/20">AFFECTER VÉHICULE</button>
                        </div>
                    }
                </div>
            }

            <!-- SVG CANVAS -->
            <svg class="w-[800px] h-[600px] drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] transition-transform duration-500" viewBox="0 0 1000 700">
                <defs>
                    <!-- Zone Patterns -->
                    <pattern id="diagBackground" width="20" height="20" patternTransform="rotate(45 0 0)" patternUnits="userSpaceOnUse">
                        <line x1="0" y1="0" x2="0" y2="20" stroke="rgba(255,255,255,0.05)" stroke-width="2"/>
                    </pattern>
                    <!-- Car Icon path -->
                    <g id="car-top">
                        <path d="M 15 10 L 85 10 C 95 10 95 20 95 20 L 95 80 C 95 80 95 90 85 90 L 15 90 C 5 90 5 80 5 80 L 5 20 C 5 20 5 10 15 10 Z" fill="currentColor"/>
                        <rect x="20" y="25" width="60" height="15" rx="2" fill="rgba(0,0,0,0.8)"/>
                        <rect x="25" y="60" width="50" height="10" rx="2" fill="rgba(0,0,0,0.8)"/>
                    </g>
                </defs>

                <!-- Workshop Floor Outline -->
                <rect x="50" y="50" width="900" height="600" fill="url(#diagBackground)" stroke="rgba(255,255,255,0.1)" stroke-width="4" rx="20"/>
                
                <!-- Zone : Réception -->
                <rect x="50" y="50" width="250" height="200" fill="rgba(2,225,242,0.05)" stroke="rgba(2,225,242,0.2)" stroke-width="2" rx="20" stroke-dasharray="10 5"/>
                <text x="175" y="150" fill="rgba(2,225,242,0.5)" font-family="monospace" font-size="20" font-weight="900" text-anchor="middle" letter-spacing="5">RÉCEPTION</text>

                <!-- Zone : Stock Pièces -->
                <rect x="750" y="50" width="200" height="600" fill="rgba(255,255,255,0.02)" stroke="rgba(255,255,255,0.1)" stroke-width="2" rx="20"/>
                <text x="850" y="350" fill="rgba(255,255,255,0.2)" font-family="sans-serif" font-size="24" font-weight="900" font-style="italic" text-anchor="middle" transform="rotate(-90 850 350)" letter-spacing="10">MAGASIN STOCK</text>

                <!-- Drawing Interactive Ponts/Bays -->
                @foreach(var bay in bays)
                {
                    <g @onclick="() => selectedZone = bay" class="cursor-pointer group transition-all" transform="translate(@bay.X, @bay.Y)">
                        @{
                            var fg = bay.Status == "Occupé" ? "#EF4444" : bay.Status == "Réservé" ? "#EAB308" : "#00FF66";
                            var bg = bay.Status == "Occupé" ? "rgba(239, 68, 68, 0.1)" : bay.Status == "Réservé" ? "rgba(234, 179, 8, 0.1)" : "rgba(0, 255, 102, 0.05)";
                            var hasCar = bay.Status != "Libre";
                        }
                        
                        <!-- Box Base -->
                        <rect width="180" height="240" rx="15" fill="@bg" stroke="@fg" stroke-width="2" class="group-hover:stroke-[4px] transition-all"/>
                        
                        <!-- Pont elevateur -->
                        <rect x="30" y="60" width="10" height="120" rx="2" fill="rgba(255,255,255,0.2)"/>
                        <rect x="140" y="60" width="10" height="120" rx="2" fill="rgba(255,255,255,0.2)"/>
                        
                        <!-- Bay Name -->
                        <text x="90" y="30" fill="@fg" font-family="sans-serif" font-size="16" font-weight="900" font-style="italic" text-anchor="middle" letter-spacing="2">@bay.Name</text>

                        <!-- Vehicle representation if occupied -->
                        @if(hasCar)
                        {
                            <g transform="translate(40, 70)" class="text-white/80">
                                <use href="#car-top" width="100" height="100"/>
                            </g>
                        }
                    </g>
                }

                <!-- Diagnostic Area -->
                <rect x="50" y="350" width="250" height="300" fill="rgba(255,215,0,0.05)" stroke="rgba(255,215,0,0.2)" stroke-width="2" rx="20"/>
                <text x="175" y="500" fill="rgba(255,215,0,0.3)" font-family="sans-serif" font-size="20" font-weight="900" font-style="italic" text-anchor="middle" letter-spacing="3">DIAGNOSTIC IA</text>
            </svg>

        </div>

    </main>
</div>

<style>
    .animate-fade-in { animation: fadeInScale 0.2s ease-out forwards; }
    @@keyframes fadeInScale { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @@keyframes pulse-b { 0%,100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); } 50% { box-shadow: 0 0 0 6px rgba(239,68,68,0); } }
    .animate-pulse-border { animation: pulse-b 2s ease-in-out infinite; }
</style>

@code {
    private Bay? selectedZone = null;

    record Bay(int Id, string Name, int X, int Y, string Status);

    private List<Bay> bays = new()
    {
        new(1, "PONT LOURD 01", 340, 80, "Occupé"),
        new(2, "PONT RAPIDE 02", 540, 80, "Libre"),
        new(3, "PONT LOURD 03", 340, 360, "Réservé"),
        new(4, "PONT GÉOMÉTRIE", 540, 360, "Occupé"),
    };
}
