            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-6 md:p-10 space-y-10">
        <!-- Hero Section -->
        <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-end">
            <div class="lg:col-span-2 space-y-2">
                <div class="flex items-center gap-3">
                    <span class="px-3 py-1 bg-primary-container/20 text-primary-container text-xs font-technical rounded border-l-2 border-secondary-container">VIN_VERIFIED</span>
                    <span class="font-technical text-on-surface-variant/60 text-sm tracking-tighter uppercase">Diagnostic ID: #PX-992-88-L</span>
                </div>
                <h2 class="font-industrial text-6xl md:text-8xl tracking-tight text-on-surface leading-none uppercase">RAPPORT_POLLUTION</h2>
            </div>
            <div class="bg-surface-container-low p-6 rounded-xl border-l-2 border-primary-container flex flex-col justify-between h-full">
                <span class="font-technical text-[10px] text-on-surface-variant uppercase">Vehicle_Identity</span>
                <div class="mt-4">
                    <p class="font-technical text-2xl text-primary leading-none tracking-tighter uppercase">WBA-7A11-040-CL-5509</p>
                    <p class="text-sm text-on-surface/60 mt-1 uppercase">Industrial Heavy-Duty Transport • Euro VI-D</p>
                </div>
            </div>
        </section>

        <!-- KPI Grid -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 uppercase">
            <div class="bg-surface-container-high p-6 rounded relative overflow-hidden shadow-[0_0_24px_-4px_rgba(245,166,35,0.08)]">
