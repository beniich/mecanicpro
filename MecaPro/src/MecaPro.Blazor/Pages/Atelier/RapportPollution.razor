@page "/atelier/rapport-pollution"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MECAPRO — Rapport Pollution</PageTitle>

<div class="bg-surface text-on-surface font-body min-h-screen pb-24 md:pb-0 selection:bg-primary/30">
    <!-- TopAppBar -->
    <header class="bg-[#111318] border-b border-[#524534]/15 flex justify-between items-center px-6 h-20 w-full z-50 sticky top-0">
        <div class="flex items-center gap-4">
            <span class="material-symbols-outlined text-[#f5a623]">settings_input_component</span>
            <h1 class="font-industrial uppercase tracking-[0.05em] text-2xl text-[#f5a623]">SYSTEM_DIAGNOSTICS</h1>
        </div>
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex gap-6 font-technical text-xs tracking-widest uppercase font-bold">
                <a class="text-[#f5a623]" href="#">Dashboard</a>
                <a class="text-[#e2e2e8]/60 hover:text-[#f5a623] transition-colors" href="#">Scanner</a>
                <a class="text-[#e2e2e8]/60 hover:text-[#f5a623] transition-colors" href="#">Reports</a>
            </nav>
            <div class="w-10 h-10 rounded-full bg-surface-container-highest border border-outline-variant/30 flex items-center justify-center overflow-hidden">
