                <div class="h-64 w-full bg-surface-container-lowest border-l border-b border-outline-variant/20 relative">
                    <svg class="w-full h-full" viewbox="0 0 1000 200">
                        <path d="M0,120 L50,115 L100,105 L150,110 L200,98 L250,102 L300,95 L350,105 L400,100 L450,90 L500,100 L550,110 L600,100 L650,95 L700,98 L750,102 L800,100 L850,92 L900,100 L950,105 L1000,100" fill="none" stroke="#f5a623" stroke-width="2"></path>
