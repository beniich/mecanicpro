                    <span class="font-technical text-sm text-on-surface-variant">g/km</span>
                </div>
            </div>
        </section>

        <!-- Charts Section -->
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-6 uppercase">
            <div class="lg:col-span-8 bg-surface-container-low rounded-xl p-8 space-y-8">
                <div class="flex justify-between items-center">
                    <div>
                        <h3 class="font-industrial text-2xl text-on-surface">MESURES_LAMBDA_REAL-TIME</h3>
                        <p class="text-xs font-technical text-on-surface-variant/60">Dernières 60 secondes de test dynamique</p>
                    </div>
                </div>
