@page "/atelier/support-diagnostic"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Support Diagnostic Aide</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-white">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-white uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-white/5 border border-white/10 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase text-white/40 tracking-widest flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">menu_book</span> KNOWLEDGE_V4_INDEXED
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-white text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">TECHNICAL_SUPPORT_ENCYCLOPEDIA</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Support Diag</h2>
                <div class="flex gap-4 mt-6">
                    <div class="bg-white/5 border border-white/10 rounded-2xl flex items-center gap-3 px-4 py-2 focus-within:border-white/20 transition-all">
                        <span class="material-symbols-outlined text-white/30 text-xs">search</span>
                        <input type="text" placeholder="RECHERCHE OBD, CODE, MODÈLE..." class="bg-transparent border-none outline-none font-technical text-[10px] text-white uppercase italic placeholder:text-white/20 w-80 font-black"/>
                    </div>
                </div>
            </div>
            
            <div class="bg-white/5 border border-white/5 rounded-3xl p-6 flex flex-col items-center justify-center">
                 <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-3">IA_DIAG_ASSIST_READY</p>
                 <button class="bg-white text-black px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-white/90 transition-all shadow-[0_4px_15px_rgba(255,255,255,0.2)]">POSER UNE QUESTION IA</button>
            </div>
        </div>

        <!-- Knowledge Categories -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var c in categories)
            {
                <div class="bg-surface-container rounded-3xl p-8 border border-white/5 shadow-xl relative overflow-hidden group hover:bg-white/[0.05] transition-all cursor-pointer">
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-10 transition-all">
                        <span class="material-symbols-outlined text-[80px]">@c.Icon</span>
                    </div>
                    <span class="material-symbols-outlined text-3xl mb-6 @(c.Color)">@c.Icon</span>
                    <h3 class="font-black italic text-xl uppercase tracking-tighter text-white mb-2">@c.Name</h3>
                    <p class="text-[9px] font-black uppercase text-white/30 tracking-widest italic">@c.Count ARTICLES</p>
                </div>
            }
        </section>

        <!-- Featured Technical Guides -->
        <section class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-8">
                 <h3 class="font-black text-2xl italic uppercase tracking-tight text-white italic">Fiches de Procédure Récents</h3>
                 <div class="space-y-4">
                    @foreach (var guide in guides)
                    {
                        <div class="bg-surface-container rounded-[32px] border border-white/5 p-8 flex flex-col md:flex-row items-center justify-between gap-6 hover:border-white/20 transition-all group">
                             <div class="flex items-center gap-6">
                                <div class="w-16 h-16 rounded-2xl bg-black/40 border border-white/10 flex items-center justify-center grayscale group-hover:grayscale-0 transition-all opacity-40 group-hover:opacity-100">
                                   <span class="material-symbols-outlined text-3xl text-white">@(guide.Type == "FIX" ? "engineering" : "bolt")</span>
                                </div>
                                <div>
                                   <div class="flex gap-2 mb-2">
                                       <span class="px-2 py-0.5 rounded bg-white/5 text-white/40 text-[7px] font-black uppercase tracking-widest border border-white/5">TYPE: @guide.Type</span>
                                       <span class="px-2 py-0.5 rounded bg-white/5 text-white/40 text-[7px] font-black uppercase tracking-widest border border-white/5">COMPATIBILITÉ: @guide.Car</span>
                                   </div>
                                   <h4 class="font-black italic text-lg uppercase tracking-tighter text-white group-hover:text-primary transition-all">@guide.Title</h4>
                                </div>
                             </div>
                             <div class="flex flex-col items-end gap-2 shrink-0">
                                <span class="bg-[#00FF66]/10 border border-[#00FF66]/30 px-3 py-1 rounded text-[8px] font-black uppercase text-[#00FF66] tracking-widest">PUBLIÉ 14 MAR 2026</span>
                                <button class="text-white/40 hover:text-white transition-all"><span class="material-symbols-outlined">chevron_right</span></button>
                             </div>
                        </div>
                    }
                 </div>
            </div>

            <div class="bg-[#111318] rounded-[40px] border border-white/10 p-10 flex flex-col justify-between shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: repeating-linear-gradient(45deg, #ffffff, #ffffff 1px, transparent 1px, transparent 10px);"></div>
                
                <div>
                    <h3 class="font-black text-xl italic uppercase tracking-tight text-white mb-6">Trending OBD Codes</h3>
                    <div class="space-y-4">
                        @foreach (var code in obdCodes)
                        {
                            <div class="bg-black/40 border border-white/5 p-5 rounded-2xl flex justify-between items-center group cursor-pointer hover:border-red-500/20 transition-all">
                                <div>
                                    <p class="text-[10px] font-black text-red-500 uppercase tracking-widest mb-1 italic">DTC: @code.Code</p>
                                    <p class="text-xs font-bold text-white/60 leading-tight uppercase tracking-tight">@code.Symptom</p>
                                </div>
                                <span class="material-symbols-outlined text-white/20 group-hover:text-red-500 transition-all">lightbulb</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="mt-10 pt-10 border-t border-white/5 text-center">
                    <p class="text-[8px] font-black text-white/20 uppercase tracking-[0.3em] font-technical">DATASET UPDATED: EVERY 24H</p>
                </div>
            </div>
        </section>

    </main>
</div>

@code {
    private List<DiagCategory> categories = new()
    {
        new("MOTEURS", "engineering", 482, "text-sky-400"),
        new("DIAG OBD-II", "memory", 1240, "text-red-400"),
        new("BOITES VITESSE", "vibration", 125, "text-yellow-400"),
        new("HYBRIDE / EV", "bolt", 84, "text-[#00FF66]"),
    };

    private List<DiagGuide> guides = new()
    {
        new("DIAGNOSTIC CIRCUIT TURBO VW AG", "FIX", "VAG 2.0 TDI", "HIER"),
        new("PROCÉDURE ÉTALONNAGE RADAR ACC", "CALIBRATE", "AUDI/BMW", "14 MAR"),
        new("REMPLACEMENT MODULE BMS PACK 80V", "FIX", "TESLA/TOYOTA", "12 MAR"),
        new("MAPPING INJECTEURS PIÉZO-ÉLEC", "TUNE", "MERCEDES CDI", "10 MAR"),
    };

    private List<ObdCodeTrend> obdCodes = new()
    {
        new("P0171", "SYSTÈME TROP PAUVRE (BANQUE 1)"),
        new("P0300", "RATÉS D'ALLUMAGE ALÉATOIRES"),
        new("P0420", "RENDEMENT CATALYSEUR FAIBLE"),
    };

    record DiagCategory(string Name, string Icon, int Count, string Color);
    record DiagGuide(string Title, string Type, string Car, string LastDate);
    record ObdCodeTrend(string Code, string Symptom);
}
