@page "/atelier/maintenance-preventive"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>MECAPRO — Maintenance Préventive IA</PageTitle>

<div class="bg-[#111318] text-white min-h-screen pb-24 overflow-x-hidden relative">

    <!-- Glowing Lines Decor -->
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none overflow-hidden">
        <div class="absolute top-0 left-1/4 w-px h-full bg-gradient-to-b from-transparent via-[#00FF66] to-transparent"></div>
        <div class="absolute top-0 left-3/4 w-px h-full bg-gradient-to-b from-transparent via-[#00FF66] to-transparent"></div>
    </div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-[#111318]/90 backdrop-blur-xl px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-3 cursor-pointer" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#00FF66]">precision_manufacturing</span>
            <h1 class="text-xl font-black tracking-[0.2em] text-[#00FF66] uppercase">MECAPRO</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="bg-[#00FF66]/10 border border-[#00FF66]/30 px-3 py-1.5 rounded-xl text-[10px] font-black uppercase text-[#00FF66] tracking-widest flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">auto_graph</span> ENGINE_LIFETIME_PREDICTION_ACTIVE
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-12 relative z-10">

        <!-- Title Section -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-8 border-b border-white/10">
            <div>
                <span class="text-[#00FF66] text-[10px] tracking-[0.5em] font-black uppercase italic mb-2 block">PREDICTIVE_MAINTENANCE_LOGIC</span>
                <h2 class="text-7xl font-black tracking-tighter italic uppercase leading-none text-white">Maintenance Predict</h2>
                <p class="text-white/40 font-technical text-sm mt-4 uppercase tracking-[0.2em] font-black">Algorithme d'anticipation des pannes sur la base des cycles d'utilisation.</p>
            </div>
            
            <div class="bg-surface-container-low p-6 rounded-3xl border border-white/5 text-right flex items-center gap-6">
                <div>
                    <p class="text-[8px] font-black uppercase tracking-widest text-[#00FF66] mb-1">PROBABILITÉ PANNE (FLOTTE)</p>
                    <p class="text-4xl font-black italic text-white font-technical">14<span class="text-xl text-white/30">%</span></p>
                </div>
                <div class="w-px h-10 bg-white/10"></div>
                <div>
                   <p class="text-[8px] font-black uppercase tracking-widest text-white/30 mb-1">ALERTES CRITIQUES</p>
                   <p class="text-4xl font-black italic text-red-500 font-technical">03</p>
                </div>
            </div>
        </div>

        <!-- Predictive Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var p in predictions)
            {
                <div class="bg-surface-container rounded-[40px] border @(p.Severity == "Critical" ? "border-red-500/30" : "border-white/5") p-8 relative overflow-hidden group hover:border-[#00FF66]/30 transition-all duration-500 shadow-2xl">
                    <!-- Icon Decor -->
                    <div class="absolute top-0 right-0 p-8 opacity-[0.03]">
                        <span class="material-symbols-outlined text-[100px]">vital_signs</span>
                    </div>

                    <div class="relative z-10">
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <h3 class="font-black italic text-2xl uppercase tracking-tighter text-white">@p.Plate</h3>
                                <p class="text-[10px] font-black uppercase text-white/30 tracking-widest mt-1">@p.VehicleModel</p>
                            </div>
                            <span class="bg-white/5 border border-white/10 px-3 py-1 rounded text-[10px] font-black font-technical text-white/60">@p.Mileage KM</span>
                        </div>

                        <!-- Prediction Bar -->
                        <div class="space-y-4 mb-4">
                            <div class="flex justify-between text-[10px] font-black uppercase tracking-widest mb-2">
                                <span class="text-white/40">RISQUE @p.Component.ToUpper()</span>
                                <span class="@(p.Severity == "Critical" ? "text-red-500" : "text-[#00FF66]") font-technical">@p.Probability%</span>
                            </div>
                            <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
                                <div class="h-full @(p.Severity == "Critical" ? "bg-red-500" : "bg-[#00FF66]")" style="width: @p.Probability%"></div>
                            </div>
                        </div>

                        <div class="bg-black/20 rounded-2xl p-4 border border-white/5 mb-8">
                            <p class="text-[8px] font-black text-white/30 uppercase tracking-widest mb-1 italic">ACTION RECOMMANDÉE IA</p>
                            <p class="font-bold text-xs leading-loose text-white/80">Planifier remplacement <span class="text-[#00FF66]">@p.Action</span> sous @p.Deadline.</p>
                        </div>

                        <!-- Actions -->
                        <div class="flex gap-2">
                            <button class="flex-grow bg-[#00FF66]/10 border border-[#00FF66]/30 px-4 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-[#00FF66] hover:text-black transition-all">PROGRAMMER</button>
                            <button class="w-12 h-12 flex items-center justify-center bg-white/5 border border-white/10 rounded-xl text-white/60 hover:text-white transition-all">
                                <span class="material-symbols-outlined text-sm">notifications</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Predict Intelligence Explainer -->
        <section class="bg-surface-container p-10 rounded-[40px] border border-white/5 flex flex-col items-center justify-center text-center relative overflow-hidden">
             <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(circle at 50% 50%, #00FF66 0%, transparent 70%);"></div>
             <div class="w-20 h-20 rounded-full bg-[#00FF66]/10 flex items-center justify-center mb-6">
                 <span class="material-symbols-outlined text-4xl text-[#00FF66]">neuroscience</span>
             </div>
             <h3 class="font-black italic text-3xl uppercase tracking-tighter text-white mb-4">Algorithme de Maturation</h3>
             <p class="text-xs uppercase font-technical text-white/40 max-w-2xl leading-loose font-bold tracking-widest">
                MecaPro Predict analyse des millions de points de données croisant motorisation, kilométrage réel, cycles de démarrage et conditions climatiques locales pour anticiper les défaillances de composants critiques avant immobilisation.
             </p>
             <div class="mt-8 flex gap-3">
                 <span class="px-4 py-1.5 bg-white/5 border border-white/5 rounded-full text-[9px] font-black uppercase text-white/30">ML.NET CORE</span>
                 <span class="px-4 py-1.5 bg-white/5 border border-white/5 rounded-full text-[9px] font-black uppercase text-white/30">TIME SERIES ANALYSIS</span>
                 <span class="px-4 py-1.5 bg-white/5 border border-white/5 rounded-full text-[9px] font-black uppercase text-white/30">PREDICTIVE ANALYTICS v4.2</span>
             </div>
        </section>

    </main>
</div>

@code {
    private List<PredictionData> predictions = new()
    {
        new("AB-123-CD", "Porsche 911 GT3", 42500, "Alternateur", 92, "REMPLACEMENT", "48 HEURES", "Critical"),
        new("EF-456-GH", "Audi RS6 C8", 18200, "Pompe à Eau", 64, "CONTRÔLE", "2 SEMAINES", "Warning"),
        new("IJ-789-KL", "BMW M4 G82", 21500, "Injecteurs", 48, "NETTOYAGE", "1 MOIS", "Info"),
        new("MN-012-OP", "Tesla Model 3", 65000, "Liquide Refroidissement", 88, "PURGE", "5 JOURS", "Critical"),
        new("YZ-842-MP", "VW Golf GTI", 124000, "Turbo", 72, "DIAG PROFOND", "10 JOURS", "Warning"),
        new("QR-111-XS", "Peugeot 3008", 45000, "FAP", 55, "RÉGÉNÉRATION", "1 MOIS", "Info")
    };

    record PredictionData(string Plate, string VehicleModel, int Mileage, string Component, int Probability, string Action, string Deadline, string Severity);
}
