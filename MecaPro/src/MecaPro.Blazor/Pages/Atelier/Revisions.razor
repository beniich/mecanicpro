@page "/atelier/revisions"
@layout EmptyLayout
@attribute [Authorize]

<PageTitle>MecaPro — Révisions & Tâches (Glass)</PageTitle>

<div class="min-h-screen font-sans pb-10">

    <!-- Main Header -->
    <div class="glass-card !border-x-0 !border-t-0 !rounded-none px-6 py-6 mb-8 border-b border-[#384358]">
        <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
            <div>
                <div class="flex items-center gap-4 mb-2">
                    <div class="w-12 h-12 rounded-xl bg-[#242F49] border border-[#384358] flex items-center justify-center text-[#FFA586] shadow-inner">
                        <span class="material-symbols-outlined text-2xl">build_circle</span>
                    </div>
                    <h1 class="text-2xl font-black headline-font text-white drop-shadow-sm">Flux Révisions</h1>
                </div>
                <p class="text-[11px] font-bold text-[#A0ABC0] uppercase tracking-widest ml-1">État des interventions atelier</p>
            </div>
            
            <div class="flex gap-4">
                 <div class="bg-[#161E2F]/60 border border-[#384358] p-1.5 rounded-xl flex shadow-inner">
                     <button class="px-5 py-2 rounded-lg bg-[#FFA586] font-black text-[10px] uppercase tracking-wider text-[#161E2F] transition-all shadow-md">Tout</button>
                     <button class="px-5 py-2 rounded-lg text-[#A0ABC0] font-bold text-[10px] uppercase tracking-wider hover:text-white transition-all">En cours</button>
                     <button class="px-5 py-2 rounded-lg text-[#A0ABC0] font-bold text-[10px] uppercase tracking-wider hover:text-white transition-all">Planifié</button>
                 </div>
                 <button class="btn-electric text-xs px-6">
                     <span class="material-symbols-outlined text-[14px]">add</span> NOUVELLE RÉVISION
                 </button>
            </div>
        </div>
    </div>

    <!-- Active Service Counter & KPIs -->
    <div class="max-w-screen-2xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 px-6 mb-8">
        @foreach (var stat in stats)
        {
            var textGlowCss = stat.Label == "Interventions du jour" ? "text-white" : stat.Color;
            var borderHoverCss = stat.Label == "Retards Planning" ? "hover:border-[#B51A2B] hover:shadow-[0_0_20px_rgba(181,26,43,0.15)]" : stat.Label == "Urgences Critiques" ? "hover:border-[#4ade80] hover:shadow-[0_0_20px_rgba(74,222,128,0.15)]" : "hover:border-[#FFA586] hover:shadow-[0_0_20px_rgba(255,165,134,0.15)]";

            <div class="glass-card p-6 flex justify-between items-center transition-all group @borderHoverCss">
                <div>
                    <p class="text-[10px] text-[#A0ABC0] font-bold uppercase tracking-widest mb-1.5">@stat.Label</p>
                    <p class="text-4xl font-black headline-font @textGlowCss drop-shadow-sm mb-1">@stat.Value</p>
                </div>
                <div class="w-14 h-14 rounded-2xl bg-[#161E2F]/60 border border-[#384358] flex items-center justify-center text-[#A0ABC0] group-hover:bg-[#242F49] transition-colors shadow-inner @(stat.Color != "text-white" ? $"group-hover:{stat.Color}" : "group-hover:text-white")">
                    <span class="material-symbols-outlined text-2xl">@stat.Icon</span>
                </div>
            </div>
        }
    </div>

    <!-- Revisions Grid/Table -->
    <div class="max-w-screen-2xl mx-auto px-6 mb-10">
        <div class="glass-card overflow-hidden">
            <div class="px-6 py-5 border-b border-[#384358] bg-[#161E2F]/30 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
                <h3 class="text-sm font-bold text-white headline-font uppercase tracking-wider">Répertoires des Interventions</h3>
                
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[16px] text-[#A0ABC0] pointer-events-none">search</span>
                    <input type="text" placeholder="Rechercher Immatriculation..." class="pl-9 pr-4 py-2 text-[10px] font-bold uppercase tracking-widest border border-[#384358] rounded-xl bg-[#242F49] text-white focus:outline-none focus:border-[#FFA586] focus:ring-1 focus:ring-[#FFA586] w-64 md:w-80 transition-all placeholder:text-[#A0ABC0]/50">
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm text-[#A0ABC0]">
                    <thead>
                        <tr class="border-b border-[#384358]/50 bg-[#161E2F]/40">
                            <th class="py-3 px-6 font-bold uppercase tracking-wider text-[10px]">Véhicule & Client</th>
                            <th class="py-3 px-6 font-bold uppercase tracking-wider text-[10px]">Type / Description</th>
                            <th class="py-3 px-6 font-bold uppercase tracking-wider text-[10px]">Statut</th>
                            <th class="py-3 px-6 font-bold uppercase tracking-wider text-[10px]">Échéance</th>
                            <th class="py-3 px-6 font-bold uppercase tracking-wider text-[10px] text-right">Devis</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rev in revisions)
                        {
                            <tr class="border-b border-[#384358]/30 hover:bg-[#242F49]/40 transition-colors cursor-pointer group">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 rounded-xl bg-[#161E2F]/60 border border-[#384358] flex items-center justify-center font-black text-xl text-white shadow-inner group-hover:text-[#FFA586] transition-colors headline-font">
                                            @rev.Plate.Substring(0, 2)
                                        </div>
                                        <div>
                                            <div class="glass-badge mb-1.5 inline-block">@rev.Plate</div>
                                            <div class="text-[10px] text-[#A0ABC0] uppercase tracking-widest font-bold">@rev.Customer</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 px-6">
                                    <p class="text-sm font-black text-white headline-font mb-1 drop-shadow-sm">@rev.Type</p>
                                    <p class="text-[10px] font-bold text-[#A0ABC0] uppercase tracking-widest">@rev.VehicleModel</p>
                                </td>
                                <td class="py-4 px-6">
                                    @{
                                        var cssBadge = GetStatusStyle(rev.Status);
                                    }
                                    <span class="glass-badge scale-90 origin-left @cssBadge whitespace-nowrap">@rev.Status</span>
                                </td>
                                <td class="py-4 px-6">
                                    <p class="text-sm font-bold text-white mb-1">@rev.Date</p>
                                    <p class="text-[10px] font-technical font-bold text-[#A0ABC0] uppercase tracking-widest bg-[#161E2F]/60 px-2 py-0.5 rounded border border-[#384358]/50 inline-block">⏱ @rev.Time</p>
                                </td>
                                <td class="py-4 px-6 text-right">
                                    <p class="text-[15px] font-black text-white mb-2 tracking-wide headline-font">@rev.Cost <span class="text-xs text-[#A0ABC0] font-normal">€</span></p>
                                    @if (rev.IsPaid) {
                                        <span class="text-[9px] font-black text-[#4ade80] bg-[#4ade80]/10 border border-[#4ade80]/30 px-2 py-1 rounded inline-block uppercase tracking-widest shadow-inner">Payé</span>
                                    } else {
                                        <span class="text-[9px] font-black text-[#FFA586] bg-[#FFA586]/10 border border-[#FFA586]/30 px-2 py-1 rounded inline-block uppercase tracking-widest shadow-inner">En attente</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<StatCard> stats = new()
    {
        new StatCard { Label = "Interventions du jour", Value = "14", Icon = "today", Color = "text-white" },
        new StatCard { Label = "En attente de pièces", Value = "3", Icon = "inventory_2", Color = "text-[#FFA586]" },
        new StatCard { Label = "Urgences Critiques", Value = "0", Icon = "flash_on", Color = "text-[#4ade80]" },
        new StatCard { Label = "Retards Planning", Value = "1", Icon = "error", Color = "text-[#B51A2B]" }
    };

    private List<RevisionEntry> revisions = new()
    {
        new RevisionEntry { Plate = "AB-123-CD", Customer = "JEAN-LUC MARTINET", Type = "RÉVISION COMPLÈTE", VehicleModel = "RENAULT ZOE E-TECH", Status = "EN COURS", Date = "20 Mar 2026", Time = "14:30", Cost = "242.50", IsPaid = true },
        new RevisionEntry { Plate = "XY-987-ZZ", Customer = "SOPHIE LARUE", Type = "CHANGEMENT PNEUMATIQUES", VehicleModel = "BMW SERIE 1", Status = "PLANIFIÉ", Date = "21 Mar 2026", Time = "09:00", Cost = "380.00", IsPaid = false },
        new RevisionEntry { Plate = "KM-442-PT", Customer = "TRANS-LOGISTIX", Type = "DIAGNOSTIC IA AVANCÉ", VehicleModel = "MASTER ZE", Status = "TERMINÉ", Date = "19 Mar 2026", Time = "11:15", Cost = "150.00", IsPaid = true },
        new RevisionEntry { Plate = "ER-003-XX", Customer = "PHILIPPE MOREL", Type = "RECONDITIONNEMENT MOTEUR", VehicleModel = "BMW M4 CSL", Status = "EN COURS", Date = "20 Mar 2026", Time = "08:30", Cost = "4,200.00", IsPaid = false }
    };

    private string GetStatusStyle(string status) => status switch
    {
        "EN COURS" => "electric",
        "PLANIFIÉ" => "",
        "TERMINÉ"  => "success",
        _ => ""
    };

    public class StatCard {
        public string Label { get; set; } = "";
        public string Value { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Color { get; set; } = "";
    }

    public class RevisionEntry {
        public string Plate { get; set; } = "";
        public string Customer { get; set; } = "";
        public string Type { get; set; } = "";
        public string VehicleModel { get; set; } = "";
        public string Status { get; set; } = "";
        public string Date { get; set; } = "";
        public string Time { get; set; } = "";
        public string Cost { get; set; } = "";
        public bool IsPaid { get; set; }
    }
}
