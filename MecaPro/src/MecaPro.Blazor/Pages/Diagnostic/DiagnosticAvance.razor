@page "/diagnostic/avancer"
@layout EmptyLayout
@attribute [Authorize]
@inject ApiClient Api
@inject AiStreamService AiStream
@inject NavigationManager Nav

<PageTitle>MecaPro — Diagnostic OBD & IA Avancé (Glass)</PageTitle>

<div class="min-h-screen pb-24 font-sans">

    <!-- Top Bar -->
    <header class="fixed top-0 w-full z-50 glass-card !border-x-0 !border-t-0 !rounded-none px-6 py-4 flex justify-between items-center text-white bg-[#161E2F]/80">
        <div class="flex items-center gap-3 cursor-pointer group" @onclick='() => Nav.NavigateTo("/")'>
            <span class="material-symbols-outlined text-[#FFA586] group-hover:drop-shadow-[0_0_10px_#FFA586] transition-all">precision_manufacturing</span>
            <h1 class="text-xl font-bold headline-font text-[#FFA586] uppercase tracking-widest drop-shadow-[0_0_5px_rgba(255,165,134,0.3)]">MecaPro</h1>
        </div>
        <div class="flex items-center gap-4">
            <span class="glass-badge success flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-[#4ade80] shadow-[0_0_8px_#4ade80] animate-pulse"></span> SYSTEM ONLINE
            </span>
        </div>
    </header>

    <main class="pt-24 px-6 max-w-7xl mx-auto space-y-8">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-end gap-6 py-4 border-b border-[#384358]">
            <div>
                <span class="text-[#FFA586] drop-shadow-sm text-[10px] tracking-[0.3em] font-bold uppercase mb-2 block">OBD III / IA Assistant</span>
                <h2 class="text-4xl md:text-5xl font-black headline-font uppercase text-white drop-shadow-md">Diagnostic Avancé</h2>
            </div>
            <div class="flex gap-3">
                <button class="btn-ghost-glass text-xs">Historique Scans</button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <!-- Interface Analyse / Input -->
            <div class="lg:col-span-4 space-y-6">
                <!-- Vehicle Selection -->
                <div class="glass-card p-6 relative overflow-hidden">
                    <h3 class="font-black text-sm headline-font text-white uppercase tracking-widest mb-5">Cible Scan</h3>
                    <div class="space-y-4 relative z-10">
                        <div>
                            <label class="text-[10px] font-bold text-[#A0ABC0] uppercase tracking-widest mb-2 block">VIN ou Immat.</label>
                            <input type="text" placeholder="AB-123-CD" class="w-full bg-[#161E2F]/60 border border-[#384358] rounded-xl px-4 py-2.5 text-sm font-technical font-bold uppercase text-white outline-none focus:border-[#FFA586] focus:ring-1 focus:ring-[#FFA586]/50 transition-all placeholder:text-[#A0ABC0]/40 shadow-inner" />
                        </div>
                        <button class="w-full bg-[#384358]/30 border border-[#384358] px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-[#384358] hover:text-white hover:border-[#A0ABC0]/50 text-[#A0ABC0] transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">wifi_tethering</span> Connexion OBD-III
                        </button>
                    </div>
                </div>

                <!-- Manual Input -->
                <div class="glass-card p-6">
                    <h3 class="font-black text-sm headline-font text-white uppercase tracking-widest mb-3">Codes Défauts</h3>
                    <p class="text-[9px] text-[#A0ABC0] uppercase tracking-widest font-bold mb-4 opacity-80">Séparez par des virgules (P0300, P0171)</p>
                    <textarea @bind="inputCodes" rows="3" class="w-full bg-[#161E2F]/60 border border-[#384358] rounded-xl px-4 py-3 text-lg font-technical font-bold uppercase text-[#FFA586] drop-shadow-[0_0_5px_rgba(255,165,134,0.3)] shadow-inner outline-none focus:border-[#FFA586] focus:ring-1 focus:ring-[#FFA586]/50 transition-all placeholder:text-[#384358] custom-scroll" placeholder="P0171, P0301..."></textarea>
                    
                    <button @onclick="LancerAnalyse" disabled="@isAnalyzing" class="w-full mt-6 btn-electric py-3.5 flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                        @if (isAnalyzing)
                        {
                            <div class="w-5 h-5 border-[3px] border-[#161E2F]/20 border-t-[#161E2F] rounded-full animate-spin shadow-sm"></div>
                            <span class="tracking-widest">TRAITEMENT EN COURS...</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-[18px]">memory</span> <span class="tracking-widest">ANALYSE EXPERTE</span>
                        }
                    </button>
                </div>
            </div>

            <!-- Résultats & IA Chat -->
            <div class="lg:col-span-8 flex flex-col gap-6">
                <!-- Result Area -->
                <div class="glass-card flex-grow p-6 sm:p-8 flex flex-col relative min-h-[500px]">
                    @if (isAnalyzing || aiEvents.Any())
                    {
                        <div class="flex justify-between items-center mb-6 pb-4 border-b border-[#384358]/60">
                            <div>
                                <h3 class="font-black text-xl headline-font text-white mb-1 tracking-wider uppercase drop-shadow-sm">Orchestrateur IA</h3>
                                <p class="text-[9px] font-technical uppercase font-bold tracking-widest flex items-center gap-2 @(isAnalyzing ? "text-[#FFA586]" : "text-[#4ade80]")">
                                    <span class="@(isAnalyzing ? "animate-pulse bg-[#FFA586] shadow-[0_0_8px_#FFA586]" : "bg-[#4ade80] shadow-[0_0_8px_#4ade80]") w-1.5 h-1.5 rounded-full block"></span>
                                    @(isAnalyzing ? "Analyse Télémétrique en cours..." : "Analyse terminée")
                                </p>
                            </div>
                        </div>

                        <div class="flex-grow overflow-y-auto custom-scroll space-y-4 pr-2">
                            @foreach (var ev in aiEvents)
                            {
                                <div class="bg-[#161E2F]/60 border border-[#384358]/50 rounded-xl p-4 text-sm shadow-inner transition-colors hover:bg-[#161E2F]/80">
                                    <div class="flex items-center gap-3 mb-2">
                                        <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded bg-[#384358] text-[#dde4f0] shadow-sm">
                                            @ev.Event
                                        </span>
                                        <span class="text-[10px] text-[#A0ABC0] font-technical opacity-70">@DateTime.Now.ToString("HH:mm:ss.fff")</span>
                                    </div>
                                    <p class="font-medium text-[#c4d0e5] leading-relaxed font-technical break-words text-xs">
                                        @GetEventDetails(ev)
                                    </p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(finalResult))
                            {
                                <div class="bg-[#FFA586]/10 border border-[#FFA586]/30 shadow-[0_0_20px_rgba(255,165,134,0.1)] rounded-2xl p-6 mt-8">
                                    <div class="flex items-center gap-3 mb-4 border-b border-[#FFA586]/20 pb-4">
                                        <span class="material-symbols-outlined text-[#FFA586] text-2xl drop-shadow-[0_0_8px_rgba(255,165,134,0.5)]">verified</span>
                                        <h4 class="font-black uppercase text-white tracking-widest text-sm drop-shadow-sm">Conclusion & Recommandations</h4>
                                    </div>
                                    <div class="text-sm font-medium text-[#dde4f0] leading-relaxed max-w-none">
                                        <!-- Note: Normally we'd use a markdown render component here, but for now we just show text -->
                                        <p class="whitespace-pre-wrap leading-loose">@finalResult</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Empty State -->
                        <div class="h-full flex flex-col items-center justify-center text-center opacity-40">
                            <span class="material-symbols-outlined text-7xl text-[#384358] mb-6 drop-shadow-md">memory</span>
                            <p class="font-black headline-font text-xl text-[#A0ABC0] uppercase tracking-widest mb-2">En attente de télémétrie</p>
                            <p class="text-xs font-medium text-[#384358] max-w-sm tracking-wide leading-relaxed">Connectez une interface OBD ou saisissez des codes manuellement pour démarrer le diagnostic.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </main>
</div>

<style>
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-track { background: rgba(22, 30, 47, 0.4); border-radius: 8px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: rgba(56, 67, 88, 0.8); border-radius: 8px; }
    .custom-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255, 165, 134, 0.5); }
</style>

@code {
    private string inputCodes = "P0301, P0171";
    private bool isAnalyzing = false;
    private List<AiEventDto> aiEvents = new();
    private string finalResult = "";

    private async Task LancerAnalyse()
    {
        if (string.IsNullOrWhiteSpace(inputCodes)) return;
        
        isAnalyzing = true;
        aiEvents.Clear();
        finalResult = "";
        StateHasChanged();

        await AiStream.StreamAiAnalyseAsync($"Analyse des codes défauts suivants : {inputCodes}", (ev) => {
            if (ev.Event == "final_answer") 
            {
                var data = JsonSerializer.Deserialize<JsonElement>(ev.Data.ToString()!);
                finalResult = data.GetProperty("text").GetString() ?? "";
            }
            else 
            {
                aiEvents.Add(ev);
            }
            StateHasChanged();
        });

        isAnalyzing = false;
        StateHasChanged();
    }

    private string GetEventDetails(AiEventDto ev)
    {
        try {
            var data = JsonSerializer.Deserialize<JsonElement>(ev.Data.ToString()!);
            if (ev.Event == "thinking") return data.GetProperty("text").GetString() ?? "...";
            if (ev.Event == "agent_start") return $"Délégation à l'agent : {data.GetProperty("agentId").GetString()}";
            if (ev.Event == "agent_done") return $"Réponse reçue de {data.GetProperty("agentId").GetString()}";
            if (ev.Event == "tool_call") return $"Appel outil : {data.GetProperty("toolName").GetString()}";
            return ev.Data.ToString() ?? "";
        } catch {
            return ev.Data.ToString() ?? "";
        }
    }
}
