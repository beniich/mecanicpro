@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="sidebar">
  <div class="logo">
    <div class="logo-text">MecaPro</div>
    <div class="logo-sub">Garage Intelligence System</div>
  </div>

  <nav class="nav">
    <div class="nav-section">
      <div class="nav-label">Principal</div>
      <div class="nav-item @(IsActive("") ? "active" : "")" @onclick='() => NavigateTo("")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Tableau de bord
      </div>
      <div class="nav-item @(IsActive("vehicles") ? "active" : "")" @onclick='() => NavigateTo("vehicles")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v9a2 2 0 01-2 2h-2"/><circle cx="9" cy="17" r="2"/><circle cx="19" cy="17" r="2"/></svg>
        Véhicules & QR
      </div>
      <div class="nav-item @(IsActive("pannes") ? "active" : "")" @onclick='() => NavigateTo("pannes")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Pannes
        <span class="nav-badge">3</span>
      </div>
      <div class="nav-item @(IsActive("revisions") ? "active" : "")" @onclick='() => NavigateTo("revisions")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Révisions
      </div>
      <div class="nav-item @(IsActive("tasks") ? "active" : "")" @onclick='() => NavigateTo("tasks")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Tâches effectuées
      </div>
    </div>

    <div class="nav-section">
      <div class="nav-label">Médias & Pièces</div>
      <div class="nav-item @(IsActive("images") ? "active" : "")" @onclick='() => NavigateTo("images")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        Galerie Images
      </div>
      <div class="nav-item @(IsActive("parts") ? "active" : "")" @onclick='() => NavigateTo("parts")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M4.93 4.93a10 10 0 000 14.14"/></svg>
        Pièces Détachées
      </div>
    </div>

    <div class="nav-section">
      <div class="nav-label">Communication</div>
      <div class="nav-item @(IsActive("chat") ? "active" : "")" @onclick='() => NavigateTo("chat")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
        Chat Client
        <div class="notif-dot" style="margin-left:auto"></div>
      </div>
    </div>

    <div class="nav-section">
      <div class="nav-label">Commerce</div>
      <div class="nav-item @(IsActive("ecommerce") ? "active" : "")" @onclick='() => NavigateTo("ecommerce")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        E-Commerce
      </div>
      <div class="nav-item @(IsActive("architecture") ? "active" : "")" @onclick='() => NavigateTo("architecture")'>
        <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        Architecture .NET
      </div>
    </div>
  </nav>

  <div class="sidebar-footer">
    <div class="user-card">
      <div class="avatar">JL</div>
      <div class="user-info">
        <strong>Jean-Luc M.</strong>
        <small>Chef Mécanicien</small>
      </div>
    </div>
  </div>
</div>

<div class="main">
  <div class="topbar">
    <span class="topbar-title">@GetPageTitle()</span>
    <div class="topbar-actions">
      <button class="btn btn-ghost" @onclick='() => NavigateTo("vehicles")'>⊕ Nouveau Véhicule</button>
      <button class="btn btn-primary">⬡ Générer QR Code</button>
    </div>
  </div>

  <div class="content">
    @Body
  </div>
</div>

@code {
    private string currentUrl = "";

    protected override void OnInitialized()
    {
        currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += (s, e) =>
        {
            currentUrl = Nav.ToBaseRelativePath(e.Location);
            StateHasChanged();
        };
    }

    private bool IsActive(string path)
    {
        if (string.IsNullOrEmpty(path)) return string.IsNullOrEmpty(currentUrl);
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string path)
    {
        Nav.NavigateTo($"/{path}");
    }

    private string GetPageTitle()
    {
        if (string.IsNullOrEmpty(currentUrl)) return "Tableau de Bord";
        if (currentUrl.StartsWith("vehicles")) return "Véhicules & QR Codes";
        if (currentUrl.StartsWith("pannes")) return "Désignation des Pannes";
        if (currentUrl.StartsWith("revisions")) return "Révisions & Coûts";
        if (currentUrl.StartsWith("tasks")) return "Tâches Effectuées";
        if (currentUrl.StartsWith("images")) return "Galerie Images";
        if (currentUrl.StartsWith("parts")) return "Pièces Détachées";
        if (currentUrl.StartsWith("chat")) return "Chat Client";
        if (currentUrl.StartsWith("ecommerce")) return "E-Commerce";
        if (currentUrl.StartsWith("architecture")) return "Architecture .NET";
        return "MecaPro";
    }
}
