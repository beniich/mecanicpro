@inherits LayoutComponentBase
@inject NavigationManager Nav

<header class="bg-[#111318] flex justify-between items-center px-6 py-4 w-full border-b border-[#524534]/15 sticky top-0 z-50">
    <div class="flex items-center gap-3 cursor-pointer" @onclick='() => NavigateTo("")'>
        <span class="material-symbols-outlined text-[#f5a623] text-2xl">precision_manufacturing</span>
        <h1 class="text-2xl font-black tracking-[0.2em] text-[#f5a623] font-headline uppercase">MECAPRO</h1>
    </div>
    
    <div class="hidden md:flex gap-8 items-center">
        <nav class="flex gap-6">
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("") ? "text-[#f5a623] font-bold" : "text-[#e2e2e8]/60 hover:text-[#f5a623]/80")" href="" @onclick:preventDefault @onclick='() => NavigateTo("")'>Planning</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("tasks") ? "text-[#f5a623] font-bold" : "text-[#e2e2e8]/60 hover:text-[#f5a623]/80")" href="tasks" @onclick:preventDefault @onclick='() => NavigateTo("tasks")'>Tâches</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("explorateur-modules") ? "text-[#f5a623] font-bold" : "text-[#e2e2e8]/60 hover:text-[#f5a623]/80")" href="explorateur-modules" @onclick:preventDefault @onclick='() => NavigateTo("explorateur-modules")'>Modules</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("billing") ? "text-[#f5a623] font-bold" : "text-[#e2e2e8]/60 hover:text-[#f5a623]/80")" href="billing" @onclick:preventDefault @onclick='() => NavigateTo("billing")'>Factures</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("profile") ? "text-[#f5a623] font-bold" : "text-[#e2e2e8]/60 hover:text-[#f5a623]/80")" href="profile" @onclick:preventDefault @onclick='() => NavigateTo("profile")'>Profil</a>
        </nav>
        <div class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/20 cursor-pointer" @onclick='() => NavigateTo("profile")'>
            <span class="material-symbols-outlined text-primary">person</span>
        </div>
    </div>
</header>

<main class="min-h-screen bg-background text-on-surface">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-8">
        @Body
    </div>
</main>

<nav class="md:hidden fixed bottom-0 w-full z-50 bg-[#0c0e12] flex justify-around items-center px-2 py-3 border-t border-[#524534]/15 shadow-[0_-4px_24px_rgba(245,166,35,0.05)] rounded-t-xl">
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("") ? "bg-[#f5a623]/10 text-[#f5a623] rounded-xl shadow-[0_0_12px_rgba(245,166,35,0.1)] translate-y-[-2px]" : "text-[#e2e2e8]/40 hover:text-[#f5a623]/80")" href="" @onclick:preventDefault @onclick='() => NavigateTo("")'>
        <span class="material-symbols-outlined text-xl">calendar_today</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Planning</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("explorateur-modules") ? "bg-[#f5a623]/10 text-[#f5a623] rounded-xl shadow-[0_0_12px_rgba(245,166,35,0.1)] translate-y-[-2px]" : "text-[#e2e2e8]/40 hover:text-[#f5a623]/80")" href="explorateur-modules" @onclick:preventDefault @onclick='() => NavigateTo("explorateur-modules")'>
        <span class="material-symbols-outlined text-xl">apps</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Modules</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("profile") ? "bg-[#f5a623]/10 text-[#f5a623] rounded-xl shadow-[0_0_12px_rgba(245,166,35,0.1)] translate-y-[-2px]" : "text-[#e2e2e8]/40 hover:text-[#f5a623]/80")" href="profile" @onclick:preventDefault @onclick='() => NavigateTo("profile")'>
        <span class="material-symbols-outlined text-xl">settings</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Profil</span>
    </a>
</nav>

<style>
    .font-headline { font-family: 'Bebas Neue', sans-serif; }
    .font-body { font-family: 'DM Sans', sans-serif; }
    .font-technical { font-family: 'JetBrains Mono', monospace; }
</style>

@code {
    private string currentUrl = "";

    protected override void OnInitialized()
    {
        currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += (s, e) =>
        {
            currentUrl = Nav.ToBaseRelativePath(e.Location);
            StateHasChanged();
        };
    }

    private bool IsActive(string path)
    {
        if (string.IsNullOrEmpty(path)) return string.IsNullOrEmpty(currentUrl);
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string path)
    {
        Nav.NavigateTo($"/{path}");
    }
}
