@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<header class="bg-surface/80 backdrop-blur-xl flex justify-between items-center px-6 py-4 w-full border-b border-outline-variant/15 sticky top-0 z-50">
    <div class="flex items-center gap-3 cursor-pointer" @onclick='() => NavigateTo("")'>
        <span class="material-symbols-outlined text-primary text-2xl">precision_manufacturing</span>
        <h1 class="text-2xl font-black tracking-[0.2em] text-primary font-headline uppercase">MECAPRO</h1>
    </div>
    
    <div class="hidden md:flex gap-8 items-center">
        <nav class="flex gap-6">
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="" @onclick:preventDefault @onclick='() => NavigateTo("")'>Planning</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("tasks") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="tasks" @onclick:preventDefault @onclick='() => NavigateTo("tasks")'>Tâches</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("atelier") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="atelier/hub" @onclick:preventDefault @onclick='() => NavigateTo("atelier/hub")'>Atelier</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("explorateur-modules") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="explorateur-modules" @onclick:preventDefault @onclick='() => NavigateTo("explorateur-modules")'>Modules</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("billing") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="billing" @onclick:preventDefault @onclick='() => NavigateTo("billing")'>Factures</a>
            <a class="text-sm uppercase tracking-tighter font-medium transition-colors duration-200 @(IsActive("profile") ? "text-primary font-bold" : "text-on-surface/60 hover:text-primary/80")" href="profile" @onclick:preventDefault @onclick='() => NavigateTo("profile")'>Profil</a>
        </nav>
        <button class="w-10 h-10 rounded-xl bg-surface-container-high flex items-center justify-center border border-outline-variant/30 shadow-lg cursor-pointer hover:border-primary/50 transition-all" @onclick="ToggleTheme">
            <span class="material-symbols-outlined text-primary">@(_isDarkMode ? "light_mode" : "dark_mode")</span>
        </button>
        <div class="w-10 h-10 rounded-xl bg-surface-container-high flex items-center justify-center border border-outline-variant/30 shadow-lg cursor-pointer hover:border-primary/50 transition-all" @onclick='() => NavigateTo("profile")'>
            <span class="material-symbols-outlined text-primary">person</span>
        </div>
    </div>
</header>

<main class="min-h-screen bg-background text-on-surface">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-8">
        @Body
    </div>
</main>

<footer class="bg-surface border-t border-outline-variant/10 pt-16 pb-24 md:pb-12 px-6 mt-20">
    <div class="max-w-7xl mx-auto">
        <!-- Section Accès Visuel Rapide -->
        <div class="mb-16">
            <h4 class="text-on-surface/30 font-headline tracking-[0.3em] text-[10px] uppercase mb-8 text-center Italics">MecaPro Services / Visual Mapping</h4>
            <div class="grid grid-cols-4 md:grid-cols-8 gap-4">
                <a @onclick='() => NavigateTo("atelier/hub")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">lift_chair</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Levage</span>
                </a>
                <a @onclick='() => NavigateTo("tasks")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-emerald-400 group-hover:scale-110 transition-transform">format_paint</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Peinture</span>
                </a>
                <a @onclick='() => NavigateTo("atelier/revisions")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-amber-400 group-hover:scale-110 transition-transform">settings_input_component</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Moteur</span>
                </a>
                <a @onclick='() => NavigateTo("diagnostic/avancer")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-blue-400 group-hover:scale-110 transition-transform">memory</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Diag</span>
                </a>
                <a @onclick='() => NavigateTo("parts")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-pink-400 group-hover:scale-110 transition-transform">inventory_2</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Stock</span>
                </a>
                <a @onclick='() => NavigateTo("tasks")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-cyan-400 group-hover:scale-110 transition-transform">tire_repair</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Roues</span>
                </a>
                <a @onclick='() => NavigateTo("chat")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-primary/50 transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-indigo-400 group-hover:scale-110 transition-transform">support_agent</span>
                    <span class="text-[9px] font-bold text-on-surface/60 uppercase tracking-tighter">Support</span>
                </a>
                <a @onclick='() => NavigateTo("atelier/visual-map")' class="flex flex-col items-center gap-3 p-4 rounded-2xl bg-primary/10 border border-primary/20 hover:border-primary transition-all group cursor-pointer">
                    <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">view_in_ar</span>
                    <span class="text-[9px] font-bold text-primary uppercase tracking-tighter">Map 3D</span>
                </a>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10">
            <!-- Pôle Atelier -->
            <div>
                <h4 class="text-primary font-headline tracking-[0.2em] text-sm uppercase mb-6">Atelier & Technique</h4>
                <ul class="space-y-3">
                    <li><a @onclick='() => NavigateTo("atelier/hub")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Hub Opérationnel</a></li>
                    <li><a @onclick='() => NavigateTo("planning/planning-atelier")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Planning Atelier</a></li>
                    <li><a @onclick='() => NavigateTo("tasks")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Journal des Tâches</a></li>
                    <li>
                        <a @onclick='() => NavigateTo("atelier/visual-map")' class="text-xs text-primary hover:text-primary/80 transition-colors cursor-pointer uppercase font-bold flex items-center gap-2">
                            MAPPAGE VISUEL 3D
                            <span class="bg-primary/20 text-primary text-[8px] px-1.5 py-0.5 rounded-full">NEW</span>
                        </a>
                    </li>
                    <li><a @onclick='() => NavigateTo("diagnostic/avancer")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Diagnostic OBD</a></li>
                    <li><a @onclick='() => NavigateTo("diagnostic/avancer")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Diagnostic OBD</a></li>
                </ul>
            </div>

            <!-- Pôle Clients -->
            <div>
                <h4 class="text-on-surface/80 font-headline tracking-[0.2em] text-sm uppercase mb-6">Relation Client</h4>
                <ul class="space-y-3">
                    <li><a @onclick='() => NavigateTo("clients")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Gestion Clients (CRM)</a></li>
                    <li><a @onclick='() => NavigateTo("vehicles")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Parc Véhicules</a></li>
                    <li><a @onclick='() => NavigateTo("sales")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Ventes & Devis</a></li>
                    <li><a @onclick='() => NavigateTo("ecommerce")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">E-Commerce</a></li>
                    <li><a @onclick='() => NavigateTo("chat")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Support Chat</a></li>
                </ul>
            </div>

            <!-- Pôle Logistique -->
            <div>
                <h4 class="text-on-surface/80 font-headline tracking-[0.2em] text-sm uppercase mb-6">Logistique & Stock</h4>
                <ul class="space-y-3">
                    <li><a @onclick='() => NavigateTo("stock/inventaire")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Inventaire Stock</a></li>
                    <li><a @onclick='() => NavigateTo("parts")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Catalogue Pièces</a></li>
                    <li><a @onclick='() => NavigateTo("stock/commandes-1")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Commandes Fournisseurs</a></li>
                    <li><a @onclick='() => NavigateTo("logistics")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Suivi Expéditions</a></li>
                </ul>
            </div>

            <!-- Pôle Finance -->
            <div>
                <h4 class="text-on-surface/80 font-headline tracking-[0.2em] text-sm uppercase mb-6">Finance & RH</h4>
                <ul class="space-y-3">
                    <li><a @onclick='() => NavigateTo("billing")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Facturation</a></li>
                    <li><a @onclick='() => NavigateTo("finance")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Trésorerie</a></li>
                    <li><a @onclick='() => NavigateTo("rh/gestion-employes")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Gestion RH</a></li>
                    <li><a @onclick='() => NavigateTo("planning/planning-equipes")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Planning Staff</a></li>
                </ul>
            </div>

            <!-- Pôle Système -->
            <div>
                <h4 class="text-on-surface/80 font-headline tracking-[0.2em] text-sm uppercase mb-6">Système</h4>
                <ul class="space-y-3">
                    <li><a @onclick='() => NavigateTo("explorateur-modules")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Explorateur de Modules</a></li>
                    <li><a @onclick='() => NavigateTo("profile")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Mon Profil</a></li>
                    <li><a @onclick='() => NavigateTo("settings")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Paramètres Généraux</a></li>
                    <li><a @onclick='() => NavigateTo("security")' class="text-xs text-on-surface/50 hover:text-primary transition-colors cursor-pointer uppercase font-medium">Sécurité & Accès</a></li>
                </ul>
            </div>
        </div>

        <div class="mt-16 pt-8 border-t border-outline-variant/5 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-xl">precision_manufacturing</span>
                <span class="text-[10px] font-black tracking-[0.3em] text-primary uppercase">MECAPRO OS v5.0</span>
            </div>
            <p class="text-[9px] font-bold text-on-surface/30 uppercase tracking-[0.1em]">© 2026 MECAPRO TECHNOLOGIES — TOUS DROITS RÉSERVÉS</p>
        </div>
    </div>
</footer>

<nav class="md:hidden fixed bottom-0 w-full z-50 bg-surface/90 backdrop-blur-xl flex justify-around items-center px-2 py-3 border-t border-outline-variant/15 shadow-[0_-4px_24px_rgba(237,138,103,0.05)] rounded-t-2xl">
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("") ? "bg-primary/10 text-primary rounded-xl shadow-[0_0_12px_rgba(237,138,103,0.1)] translate-y-[-2px]" : "text-on-surface/40 hover:text-primary/80")" href="" @onclick:preventDefault @onclick='() => NavigateTo("")'>
        <span class="material-symbols-outlined text-xl">calendar_today</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Planning</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("atelier") ? "bg-primary/10 text-primary rounded-xl shadow-[0_0_12px_rgba(237,138,103,0.1)] translate-y-[-2px]" : "text-on-surface/40 hover:text-primary/80")" href="atelier/hub" @onclick:preventDefault @onclick='() => NavigateTo("atelier/hub")'>
        <span class="material-symbols-outlined text-xl">factory</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Atelier</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("explorateur-modules") ? "bg-primary/10 text-primary rounded-xl shadow-[0_0_12px_rgba(237,138,103,0.1)] translate-y-[-2px]" : "text-on-surface/40 hover:text-primary/80")" href="explorateur-modules" @onclick:preventDefault @onclick='() => NavigateTo("explorateur-modules")'>
        <span class="material-symbols-outlined text-xl">apps</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Modules</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("atelier/visual-map") ? "bg-primary/10 text-primary rounded-xl shadow-[0_0_12px_rgba(237,138,103,0.1)] translate-y-[-2px]" : "text-on-surface/40 hover:text-primary/80")" href="atelier/visual-map" @onclick:preventDefault @onclick='() => NavigateTo("atelier/visual-map")'>
        <span class="material-symbols-outlined text-xl">view_in_ar</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">MAP 3D</span>
    </a>
    <a class="flex flex-col items-center justify-center px-3 py-1.5 transition-transform @(IsActive("profile") ? "bg-primary/10 text-primary rounded-xl shadow-[0_0_12px_rgba(237,138,103,0.1)] translate-y-[-2px]" : "text-on-surface/40 hover:text-primary/80")" href="profile" @onclick:preventDefault @onclick='() => NavigateTo("profile")'>
        <span class="material-symbols-outlined text-xl">settings</span>
        <span class="text-[10px] font-medium uppercase tracking-tight mt-1">Profil</span>
    </a>
</nav>

<style>
    .font-headline { font-family: 'Bebas Neue', sans-serif; }
    .font-body { font-family: 'DM Sans', sans-serif; }
    .font-technical { font-family: 'JetBrains Mono', monospace; }
</style>

@code {
    private string currentUrl = "";

    protected override void OnInitialized()
    {
        currentUrl = Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += (s, e) =>
        {
            currentUrl = Nav.ToBaseRelativePath(e.Location);
            StateHasChanged();
        };
    }

    private bool IsActive(string path)
    {
        if (string.IsNullOrEmpty(path)) return string.IsNullOrEmpty(currentUrl);
        return currentUrl.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private void NavigateTo(string path)
    {
        Nav.NavigateTo($"/{path}");
    }

    private bool _isDarkMode = true;
    
    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#ED8A67",
            Secondary = "#2A3342",
            Background = "#0F172A",
            Surface = "#111827",
            AppbarBackground = "#111827",
            DrawerBackground = "#111827",
            DrawerText = "#F9FAFB",
            ActionDefault = "#ED8A67",
            TextPrimary = "#F9FAFB",
            TextSecondary = "#9CA3AF",
            LinesDefault = "#374151",
            TableLines = "#1F2937",
            Divider = "#1F2937",
            OverlayDark = "rgba(15, 23, 42, 0.7)"
        },
        Palette = new PaletteLight()
        {
            Primary = "#ED8A67",
            Secondary = "#2A3342",
            Background = "#F9FAFB",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#111827",
            ActionDefault = "#ED8A67",
            TextPrimary = "#111827",
            TextSecondary = "#6B7280",
            LinesDefault = "#E5E7EB",
            TableLines = "#F3F4F6",
            Divider = "#E5E7EB"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px"
        }
    };
}
